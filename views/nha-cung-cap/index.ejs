<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <style>
    .detail-pane{display:none}
    .detail-pane.is-active{display:block}
    .store-table tr[data-href]{cursor:pointer}
    .status-pill {
      display: inline-flex;
      align-items: center;
      height: 24px;
      padding: 0 10px;
      border-radius: 5px;
      font-size: 11px;
      font-weight: 700;
      white-space: nowrap;
    }
    .status-pill.is-active { background: #dcfce7; color: #166534; }
    .status-pill.is-draft { background: #fef9c3; color: #854d0e; }
    .status-pill.is-cancelled { background: #fee2e2; color: #991b1b; }
    .table-code-link {
      color: #0070f4;
      text-decoration: none;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 5px;
    }
    .table-code-link:hover { text-decoration: underline; }
    .history-type-icon { font-size: 14px; width: 16px; text-align: center; }
    .history-amount { font-weight: 700; font-size: 14px; }
    .history-amount.is-return { color: #ef4444; }
    .supplier-detail-footer {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 8px;
      padding-top: 14px;
      margin-top: 12px;
      border-top: 1px solid #e2e8f0;
    }
    .supplier-metric-readonly { font-size: 14px; font-weight: 700; color: #111827; }
    .supplier-metric-hint { font-size: 11px; color: #64748b; margin-top: 2px; font-weight: 400; }
    .supplier-create-modal { max-width: 760px; }
    .supplier-create-form.modal-body { max-height: 70vh; overflow: auto; padding: 20px 24px; }
    .supplier-address-toolbar{display:flex;justify-content:flex-end;gap:8px;margin:0 0 10px}
    .address-type-list{display:grid;gap:8px;max-height:280px;overflow:auto}
    .address-type-row{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:8px;align-items:center;border:1px solid #e2e8f0;border-radius:6px;padding:8px}
    .address-type-name{font-weight:700;color:#111827}
    .address-type-code{font-size:11px;color:#64748b;margin-top:2px}
    .address-type-actions{display:flex;gap:6px}
  </style>
</head>
<body class="admin-body">
  <%- include('../partials/header', { activeMenu: activeMenu, user: user }) %>

  <main class="admin-shell store-page">
    <%- include('../partials/flash-message', { flash: flash }) %>
    <% filterQueryString = filterQueryString || ''; %>

    <div class="store-toolbar">
      <h1>Nhà cung cấp</h1>
      <div class="store-search">
        <span>⌕</span>
        <input type="search" placeholder="Theo mã, tên nhà cung cấp">
      </div>
      <div class="page-actions">
        <button class="btn btn-primary" type="button" id="openAddSupplierModal">+ Tạo mới</button>
        <a class="btn btn-light" href="/nha-cung-cap/export.xlsx?<%= filterQueryString || '' %>">Xuất file</a>
        <button class="btn btn-danger" type="submit" form="bulkDeleteSuppliersForm" onclick="return confirm('Xóa các nhà cung cấp đã chọn?')">Xóa đã chọn</button>
      </div>
    </div>

    <div id="addSupplierModalOverlay" class="modal-overlay" data-auto-open="<%= formMode === 'create' ? '1' : '0' %>">
      <div class="modal-content customer-create-modal supplier-create-modal">
        <div class="modal-header">
          <h3>Tạo nhà cung cấp</h3>
          <button type="button" class="modal-close" id="addSupplierModalClose" aria-label="Đóng">×</button>
        </div>
        <form class="modal-body store-form-grid supplier-create-form" method="post" action="/nha-cung-cap/add" id="supplierCreateForm">
          <label><span>Mã NCC</span><input name="ma_ncc" placeholder="Tự động nếu bỏ trống"></label>
          <label><span>Tên nhà cung cấp *</span><input name="ten_ncc" placeholder="Nhập tên nhà cung cấp" required></label>
          <label><span>Điện thoại</span><input name="sdt" placeholder="Nhập số điện thoại"></label>
          <label><span>Email</span><input name="email" type="email" placeholder="email@example.com"></label>
          <label><span>Tên công ty</span><input name="ten_cong_ty" placeholder="Nhập tên công ty"></label>
          <label><span>Mã số thuế</span><input name="ma_so_thue" placeholder="Nhập mã số thuế"></label>
          <label><span>Tổng nợ</span><strong class="supplier-metric-readonly">0</strong>
            <span class="supplier-metric-hint"> — Tự động tính từ công nợ phiếu nhập</span>
          </label>
          <label><span>Tổng mua</span><strong class="supplier-metric-readonly">0</strong>
            <span class="supplier-metric-hint"> — Tự động tính từ phiếu đã nhập hàng</span>
          </label>
          <label class="span-2"><span>Ghi chú</span><input name="ghi_chu" placeholder="Nhập ghi chú"></label>
          <label><span>Trạng thái</span>
            <select name="trang_thai">
              <option value="active" selected>Đang hoạt động</option>
              <option value="inactive">Ngừng hoạt động</option>
            </select>
          </label>
        </form>
        <div class="page-actions modal-footer">
          <button class="btn btn-light" type="button" id="addSupplierModalCancel">Bỏ qua</button>
          <button class="btn btn-primary" type="submit" form="supplierCreateForm">Lưu</button>
        </div>
      </div>
    </div>

    <% var filterQueryPrefix = filterQueryString ? filterQueryString + '&' : ''; %>
    <div class="store-layout">
      <aside class="store-filter-panel">
        <form method="get" action="/nha-cung-cap" class="store-filter-form">
          <section class="customer-filter-section">
            <div class="customer-filter-title-row">
              <h4>Nhóm nhà cung cấp</h4>
              <button class="filter-link-btn" type="button" id="supplierGroupAddBtn">Tạo mới</button>
            </div>
            <% var selectedSupplierGroup = (supplierGroups || []).find(function(group) { return filter.groupId === String(group._id); }); %>
            <div class="group-manage-wrapper" id="supplierGroupManageSidebar">
              <div class="group-manage-header">
                <button class="group-manage-trigger" type="button" id="supplierGroupFilterTrigger">
                  <span id="supplierGroupFilterLabel"><%= selectedSupplierGroup ? selectedSupplierGroup.ten_nhom_ncc : 'Tất cả các nhóm' %></span>
                  <span>▾</span>
                </button>
              </div>
              <input type="hidden" name="groupId" id="supplierGroupFilterValue" value="<%= filter.groupId || 'all' %>">
              <div class="group-manage-dropdown" id="supplierGroupFilterDropdown">
                <div class="group-manage-item <%= (!filter.groupId || filter.groupId === 'all') ? 'is-active' : '' %>" data-id="" data-value="all" data-name="Tất cả các nhóm" data-desc="">
                  <button class="group-manage-option" type="button">Tất cả các nhóm</button>
                </div>
                <% (supplierGroups || []).forEach(function(group) { %>
                  <div class="group-manage-item <%= filter.groupId === String(group._id) ? 'is-active' : '' %>" data-id="<%= group._id %>" data-value="<%= group._id %>" data-name="<%= group.ten_nhom_ncc || '---' %>" data-desc="<%= group.mo_ta || '' %>">
                    <button class="group-manage-option" type="button"><%= group.ten_nhom_ncc || '---' %></button>
                    <div class="group-manage-actions">
                      <button class="group-manage-action-edit" type="button">Sửa</button>
                      <button class="group-manage-action-delete" type="button">Xóa</button>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>
            <h4>Tổng mua</h4>
            <div class="range-stack">
              <div class="range-row"><span>Từ</span><input type="number" min="0" name="totalBuyFrom" value="<%= filter.totalBuyFrom || '' %>" placeholder="Nhập giá trị"></div>
              <div class="range-row"><span>Tới</span><input type="number" min="0" name="totalBuyTo" value="<%= filter.totalBuyTo || '' %>" placeholder="Nhập giá trị"></div>
            </div>
            <h4>Thời gian</h4>
            <label class="filter-radio-row">
              <input type="radio" name="created" value="all" <%= filter.created !== 'custom' ? 'checked' : '' %>>
              <span>Toàn thời gian</span>
            </label>
            <label class="filter-radio-row">
              <input type="radio" name="created" value="custom" <%= filter.created === 'custom' ? 'checked' : '' %>>
              <span>Tùy chỉnh</span>
            </label>
            <div class="custom-date-range <%= filter.created === 'custom' ? 'is-visible' : '' %>" id="customDateRange">
              <label><span>Từ ngày</span><input type="date" name="createdFrom" value="<%= filter.createdFrom || '' %>"></label>
              <label><span>Đến ngày</span><input type="date" name="createdTo" value="<%= filter.createdTo || '' %>"></label>
            </div>
            <h4>Nợ hiện tại</h4>
            <div class="range-stack">
              <div class="range-row"><span>Từ</span><input type="number" min="0" name="currentDebtFrom" value="<%= filter.currentDebtFrom || '' %>" placeholder="Nhập giá trị"></div>
              <div class="range-row"><span>Tới</span><input type="number" min="0" name="currentDebtTo" value="<%= filter.currentDebtTo || '' %>" placeholder="Nhập giá trị"></div>
            </div>
            <h4>Trạng thái</h4>
            <div class="pill-row">
              <button class="pill-btn <%= filter.status === 'all' ? 'is-active' : '' %>" type="button" data-target-input="supplierStatusInput" data-value="all">Tất cả</button>
              <button class="pill-btn <%= filter.status === 'active' ? 'is-active' : '' %>" type="button" data-target-input="supplierStatusInput" data-value="active">Đang hoạt động</button>
              <button class="pill-btn <%= filter.status === 'inactive' ? 'is-active' : '' %>" type="button" data-target-input="supplierStatusInput" data-value="inactive">Ngừng hoạt động</button>
            </div>
            <input type="hidden" id="supplierStatusInput" name="status" value="<%= filter.status || 'all' %>">
            <div class="customer-filter-actions">
              <button class="btn btn-primary" type="submit">Áp dụng lọc</button>
              <a class="btn btn-light" href="/nha-cung-cap">Xóa lọc</a>
            </div>
          </section>
        </form>
      </aside>

      <section class="store-table-panel">
        <div class="table-wrap">
          <form id="bulkDeleteSuppliersForm" method="post" action="/nha-cung-cap/delete-selected">
          <table class="admin-table store-table">
            <thead>
              <tr>
                <th class="check-cell"><input id="selectAllSuppliers" type="checkbox" aria-label="Chọn tất cả"></th>
                <th>Mã NCC</th><th>Tên nhà cung cấp</th><th>Điện thoại</th><th>Email</th><th>Tổng nợ</th><th>Tổng mua</th><th>Trạng thái</th>
              </tr>
            </thead>
            <tbody>
              <% if (suppliers.length === 0) { %><tr><td colspan="8" class="empty-cell">Không có nhà cung cấp phù hợp với bộ lọc.</td></tr><% } %>
              <% suppliers.forEach(function(supplier) { %>
                <% var isSelected = selectedSupplier && String(selectedSupplier._id) === String(supplier._id); %>
                <% var rowHref = isSelected ? ('/nha-cung-cap' + (filterQueryString ? '?' + filterQueryString : '')) : ('/nha-cung-cap?' + filterQueryPrefix + 'supplier=' + supplier._id); %>
                <tr class="<%= isSelected ? 'is-selected' : '' %>" data-href="<%= rowHref %>">
                  <td class="check-cell" onclick="event.stopPropagation()"><input class="supplier-checkbox" type="checkbox" name="ids" value="<%= supplier._id %>" aria-label="Chọn nhà cung cấp"></td>
                  <td><a class="table-code-link" href="<%= rowHref %>"><%= supplier.ma_ncc || '---' %></a></td>
                  <td><strong><a class="table-code-link" href="<%= rowHref %>"><%= supplier.ten_ncc || '---' %></a></strong></td>
                  <td><%= supplier.sdt || '---' %></td>
                  <td><%= supplier.email || '---' %></td>
                  <td><%= Number(supplier.tong_no || 0).toLocaleString('vi-VN') %></td>
                  <td><%= Number(supplier.tong_mua || 0).toLocaleString('vi-VN') %></td>
                  <td><span class="status-pill <%= supplier.trang_thai === 'active' ? 'is-active' : '' %>"><%= supplier.trang_thai === 'active' ? 'Đang hoạt động' : 'Ngừng hoạt động' %></span></td>
                </tr>
                <% if (isSelected) { %>
                  <tr class="store-detail-row">
                    <td colspan="8">
                      <div class="store-detail">
                        <div class="detail-tabs">
                          <div class="detail-tab-list">
                            <button class="detail-tab is-active" type="button" data-detail-tab="info">Thông tin nhà cung cấp</button>
                            <button class="detail-tab" type="button" data-detail-tab="address">Danh sách địa chỉ</button>
                            <button class="detail-tab" type="button" data-detail-tab="history">Lịch sử nhập/trả hàng</button>
                            <button class="detail-tab" type="button" data-detail-tab="debt">Nợ cần trả nhà cung cấp</button>
                          </div>
                          <button class="detail-collapse-btn" type="button" aria-expanded="true">Thu gọn</button>
                        </div>
                        <div class="store-detail-body">
                          <div class="detail-pane is-active" data-detail-pane="info">
                          <div class="store-info-block">
                            <div class="store-image-placeholder">NCC</div>
                            <div>
                              <h2><%= selectedSupplier.ten_ncc || 'Nhà cung cấp' %></h2>
                              <p><%- refLink('supplier', selectedSupplier, selectedSupplier.ma_ncc || '---') %></p>
                              <div class="tag-row"><span class="tag">Nhà cung cấp</span><span class="tag tag-green"><%= selectedSupplier.trang_thai === 'active' ? 'Đang hoạt động' : 'Ngừng hoạt động' %></span></div>
                            </div>
                          </div>
                          <div class="store-fields">
                            <div><span>Mã NCC</span><input name="ma_ncc" value="<%= selectedSupplier.ma_ncc || '' %>"></div>
                            <div><span>Tên nhà cung cấp *</span><input name="ten_ncc" value="<%= selectedSupplier.ten_ncc || '' %>" required></div>
                            <div><span>Điện thoại</span><input name="sdt" value="<%= selectedSupplier.sdt || '' %>"></div>
                            <div><span>Email</span><input name="email" type="email" value="<%= selectedSupplier.email || '' %>"></div>
                            <div><span>Tên công ty</span><input name="ten_cong_ty" value="<%= selectedSupplier.ten_cong_ty || '' %>"></div>
                            <div><span>Mã số thuế</span><input name="ma_so_thue" value="<%= selectedSupplier.ma_so_thue || '' %>"></div>
                            <div><span>Tổng nợ</span>
                              <div>
                                <strong class="supplier-metric-readonly"><%= Number(selectedSupplier.tong_no || 0).toLocaleString('vi-VN') %></strong>
                                <div class="supplier-metric-hint">Tự động tính từ phiếu nhập</div>
                              </div>
                            </div>
                            <div><span>Tổng mua</span>
                              <div>
                                <strong class="supplier-metric-readonly"><%= Number(selectedSupplier.tong_mua || 0).toLocaleString('vi-VN') %></strong>
                                <div class="supplier-metric-hint">Tự động tính từ phiếu đã nhập hàng</div>
                              </div>
                            </div>
                            <div><span>Trạng thái</span>
                              <select name="trang_thai">
                                <option value="active" <%= selectedSupplier.trang_thai !== 'inactive' ? 'selected' : '' %>>Đang hoạt động</option>
                                <option value="inactive" <%= selectedSupplier.trang_thai === 'inactive' ? 'selected' : '' %>>Ngừng hoạt động</option>
                              </select>
                            </div>
                            <div><span>Thời gian tạo</span><strong><%= formatDate(selectedSupplier.created_at) %></strong></div>
                            <div class="span-2"><span>Ghi chú</span><input name="ghi_chu" value="<%= selectedSupplier.ghi_chu || '' %>"></div>
                          </div>
                          </div>
                          <div class="detail-pane" data-detail-pane="address">
                            <% var supplierAddressReturnQuery = filterQueryString ? (filterQueryString + '&supplier=' + selectedSupplier._id) : ('supplier=' + selectedSupplier._id); %>
                            <div class="supplier-address-toolbar">
                              <button class="btn btn-light btn-sm js-open-address-type-modal" type="button">Loại địa chỉ</button>
                            </div>
                            <div class="table-wrap">
                              <table class="admin-table warehouse-table">
                                <thead>
                                  <tr>
                                    <th>Mã địa chỉ</th>
                                    <th>Tên người nhận</th>
                                    <th>SĐT</th>
                                    <th>Địa chỉ</th>
                                    <th>Loại địa chỉ</th>
                                    <th>Tạo lúc</th>
                                    <th>Thao tác</th>
                                  </tr>
                                </thead>
                                <tbody>
                                  <% var supplierAddressAddFormId = 'supplierAddressAdd_' + String(selectedSupplier._id); %>
                                  <tr class="warehouse-edit-row warehouse-add-row">
                                    <td>
                                      <input data-address-form="<%= supplierAddressAddFormId %>" name="returnQuery" type="hidden" value="<%= supplierAddressReturnQuery %>">
                                      <input data-address-form="<%= supplierAddressAddFormId %>" name="ma_dia_chi" placeholder="Tự động" readonly style="background: transparent; border: none;">
                                    </td>
                                    <td><input data-address-form="<%= supplierAddressAddFormId %>" name="ten_nguoi_nhan" placeholder="Tên người nhận"></td>
                                    <td><input data-address-form="<%= supplierAddressAddFormId %>" name="sdt_nguoi_nhan" placeholder="SĐT"></td>
                                    <td><input data-address-form="<%= supplierAddressAddFormId %>" name="dia_chi_day_du" placeholder="Địa chỉ đầy đủ"></td>
                                    <td>
                                      <select class="js-address-type-select" data-address-form="<%= supplierAddressAddFormId %>" name="loai_dia_chi">
                                        <option value="khac">Khác</option>
                                        <% if ((addressTypes || []).length === 0) { %>
                                          <option value="khac">Khác</option>
                                        <% } %>
                                        <% (addressTypes || []).forEach(function(type) { %>
                                          <option value="<%= type.ma_loai %>"><%= type.ten_loai %></option>
                                        <% }) %>
                                      </select>
                                    </td>
                                    <td>--</td>
                                    <td class="warehouse-action-cell">
                                      <div class="warehouse-action-buttons">
                                        <button type="button" class="btn btn-light btn-sm" onclick="this.closest('tr').nextElementSibling.style.display = this.closest('tr').nextElementSibling.style.display === 'none' ? 'table-row' : 'none'">▼</button>
                                        <button
                                          class="btn btn-primary btn-sm js-supplier-address-submit"
                                          type="button"
                                          data-form-id="<%= supplierAddressAddFormId %>"
                                          data-action="/nha-cung-cap/<%= selectedSupplier._id %>/dia-chi"
                                          data-confirm="Bạn có muốn thêm địa chỉ mới không?"
                                        >Thêm</button>
                                      </div>
                                    </td>
                                  </tr>
                                  <tr class="address-detail-row" style="display: none; background-color: #f8fafc;">
                                    <td colspan="7">
                                      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; padding: 15px;">
                                        <div><label style="display:block;margin-bottom:5px;font-weight:bold;font-size:12px;">Số nhà</label><input class="form-control" data-address-form="<%= supplierAddressAddFormId %>" name="so_nha" placeholder="Số nhà"></div>
                                        <div><label style="display:block;margin-bottom:5px;font-weight:bold;font-size:12px;">Phường/Xã</label><input class="form-control" data-address-form="<%= supplierAddressAddFormId %>" name="phuong_xa" placeholder="Phường/Xã"></div>
                                        <div><label style="display:block;margin-bottom:5px;font-weight:bold;font-size:12px;">Quận/Huyện</label><input class="form-control" data-address-form="<%= supplierAddressAddFormId %>" name="quan_huyen" placeholder="Quận/Huyện"></div>
                                        <div><label style="display:block;margin-bottom:5px;font-weight:bold;font-size:12px;">Tỉnh/Thành</label><input class="form-control" data-address-form="<%= supplierAddressAddFormId %>" name="tinh_thanh" placeholder="Tỉnh/Thành"></div>
                                        <div style="grid-column: span 2;"><label style="display:block;margin-bottom:5px;font-weight:bold;font-size:12px;">Ghi chú</label><input class="form-control" data-address-form="<%= supplierAddressAddFormId %>" name="ghi_chu" placeholder="Ghi chú"></div>
                                        <div style="grid-column: span 2; display: flex; align-items: center;"><label style="font-size:13px;cursor:pointer;"><input data-address-form="<%= supplierAddressAddFormId %>" type="checkbox" name="mac_dinh" value="true"> Đặt làm mặc định</label></div>
                                      </div>
                                    </td>
                                  </tr>
                                  <% if (!supplierAddresses || supplierAddresses.length === 0) { %>
                                    <tr><td colspan="7" class="empty-cell">Nhà cung cấp này chưa có địa chỉ.</td></tr>
                                  <% } %>
                                  <% (supplierAddresses || []).forEach(function(address) { %>
                                    <% var supplierAddressFormId = 'supplierAddressForm_' + String(address._id); %>
                                    <tr class="warehouse-edit-row">
                                      <td>
                                        <input data-address-form="<%= supplierAddressFormId %>" name="returnQuery" type="hidden" value="<%= supplierAddressReturnQuery %>">
                                        <input data-address-form="<%= supplierAddressFormId %>" name="ma_dia_chi" value="<%= address.ma_dia_chi || '' %>" readonly style="background: transparent; border: none; cursor: default;">
                                      </td>
                                      <td><input data-address-form="<%= supplierAddressFormId %>" name="ten_nguoi_nhan" value="<%= address.ten_nguoi_nhan || '' %>"></td>
                                      <td><input data-address-form="<%= supplierAddressFormId %>" name="sdt_nguoi_nhan" value="<%= address.sdt_nguoi_nhan || '' %>"></td>
                                      <td><input data-address-form="<%= supplierAddressFormId %>" name="dia_chi_day_du" value="<%= address.dia_chi_day_du || [address.so_nha, address.phuong_xa, address.quan_huyen, address.tinh_thanh].filter(Boolean).join(', ') || '' %>"></td>
                                      <td>
                                        <select class="js-address-type-select" data-address-form="<%= supplierAddressFormId %>" name="loai_dia_chi">
                                          <option value="khac" <%= address.loai_dia_chi === 'khac' ? 'selected' : '' %>>Khác</option>
                                          <% if ((addressTypes || []).length === 0) { %>
                                            <option value="khac" <%= address.loai_dia_chi === 'khac' ? 'selected' : '' %>>Khác</option>
                                          <% } %>
                                          <% (addressTypes || []).forEach(function(type) { %>
                                            <option value="<%= type.ma_loai %>" <%= address.loai_dia_chi === type.ma_loai ? 'selected' : '' %>><%= type.ten_loai %></option>
                                          <% }) %>
                                        </select>
                                      </td>
                                      <td><%= formatDate(address.created_at) %></td>
                                      <td class="warehouse-action-cell">
                                        <div class="warehouse-action-buttons">
                                          <button type="button" class="btn btn-light btn-sm" onclick="this.closest('tr').nextElementSibling.style.display = this.closest('tr').nextElementSibling.style.display === 'none' ? 'table-row' : 'none'">▼</button>
                                          <button
                                            class="btn btn-light btn-sm js-supplier-address-submit"
                                            type="button"
                                            data-form-id="<%= supplierAddressFormId %>"
                                            data-action="/nha-cung-cap/dia-chi/<%= address._id %>/update"
                                            data-confirm="Bạn có muốn lưu chỉnh sửa địa chỉ này không?"
                                          >Lưu</button>
                                          <button
                                            class="btn btn-danger btn-sm js-supplier-address-delete"
                                            type="button"
                                            data-return-query="<%= supplierAddressReturnQuery %>"
                                            data-action="/nha-cung-cap/dia-chi/<%= address._id %>/delete"
                                          >Xóa</button>
                                        </div>
                                      </td>
                                    </tr>
                                    <tr class="address-detail-row" style="display: none; background-color: #f8fafc;">
                                      <td colspan="7">
                                        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; padding: 15px;">
                                          <div><label style="display:block;margin-bottom:5px;font-weight:bold;font-size:12px;">Số nhà</label><input class="form-control" data-address-form="<%= supplierAddressFormId %>" name="so_nha" value="<%= address.so_nha || '' %>"></div>
                                          <div><label style="display:block;margin-bottom:5px;font-weight:bold;font-size:12px;">Phường/Xã</label><input class="form-control" data-address-form="<%= supplierAddressFormId %>" name="phuong_xa" value="<%= address.phuong_xa || '' %>"></div>
                                          <div><label style="display:block;margin-bottom:5px;font-weight:bold;font-size:12px;">Quận/Huyện</label><input class="form-control" data-address-form="<%= supplierAddressFormId %>" name="quan_huyen" value="<%= address.quan_huyen || '' %>"></div>
                                          <div><label style="display:block;margin-bottom:5px;font-weight:bold;font-size:12px;">Tỉnh/Thành</label><input class="form-control" data-address-form="<%= supplierAddressFormId %>" name="tinh_thanh" value="<%= address.tinh_thanh || '' %>"></div>
                                          <div style="grid-column: span 2;"><label style="display:block;margin-bottom:5px;font-weight:bold;font-size:12px;">Ghi chú</label><input class="form-control" data-address-form="<%= supplierAddressFormId %>" name="ghi_chu" value="<%= address.ghi_chu || '' %>"></div>
                                          <div style="grid-column: span 2; display: flex; align-items: center;"><label style="font-size:13px;cursor:pointer;"><input data-address-form="<%= supplierAddressFormId %>" type="checkbox" name="mac_dinh" value="true" <%= address.mac_dinh ? 'checked' : '' %>> Đặt làm mặc định</label></div>
                                        </div>
                                      </td>
                                    </tr>
                                  <% }) %>
                                </tbody>
                              </table>
                            </div>
                          </div>
                          <div class="detail-pane" data-detail-pane="history">
                            <div class="table-wrap" style="border: 1px solid #e2e8f0; border-radius: 8px; overflow: hidden;">
                              <table class="admin-table store-table" style="margin-bottom: 0;">
                                <thead style="background: #f8fafc;">
                                  <tr>
                                    <th style="width: 180px;">Mã phiếu</th>
                                    <th>Thời gian</th>
                                    <th>Người tạo</th>
                                    <th class="text-right">Tổng cộng</th>
                                    <th style="width: 140px;">Trạng thái</th>
                                  </tr>
                                </thead>
                                <tbody>
                                  <% if ((supplierPurchaseHistory || []).length === 0) { %>
                                    <tr><td colspan="5" class="empty-cell" style="padding: 40px;">Chưa có lịch sử nhập/trả hàng.</td></tr>
                                  <% } %>
                                  <% (supplierPurchaseHistory || []).forEach(function(row) { %>
                                    <tr>
                                      <td>
                                        <a href="<%= row.loai === 'nhap' && row.phieu_nhap_id ? refUrl('purchase', row.phieu_nhap_id) : '/nhap-hang' %>" class="table-code-link ref-link">
                                          <% if (row.loai === 'nhap') { %>
                                            <i class="fa-solid fa-file-import history-type-icon" title="Nhập hàng"></i>
                                          <% } else { %>
                                            <i class="fa-solid fa-arrow-rotate-left history-type-icon" title="Trả hàng" style="color:#ef4444"></i>
                                          <% } %>
                                          <%= row.ma_phieu || '--' %>
                                        </a>
                                      </td>
                                      <td style="color: #475569;"><%= formatDate(row.thoi_gian) %></td>
                                      <td>
                                        <div style="display: flex; align-items: center; gap: 6px;">
                                          <div style="width: 24px; height: 24px; border-radius: 50%; background: #f1f5f9; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; color: #64748b;">
                                            <%= (row.nguoi_tao || 'U').charAt(0).toUpperCase() %>
                                          </div>
                                          <%= row.nguoi_tao || '--' %>
                                        </div>
                                      </td>
                                      <td class="text-right">
                                        <span class="history-amount <%= row.loai === 'tra' ? 'is-return' : '' %>">
                                          <%= row.loai === 'tra' ? '-' : '' %><%= Number(row.tong_cong || 0).toLocaleString('vi-VN') %>
                                        </span>
                                      </td>
                                      <td>
                                        <% 
                                          let statusClass = 'status-pill';
                                          let statusLabelText = mapNhapHangStatus(row.trang_thai);
                                          if (row.trang_thai === 'completed') statusClass += ' is-active';
                                          else if (row.trang_thai === 'draft') statusClass += ' is-draft';
                                          else if (row.trang_thai === 'cancelled') statusClass += ' is-cancelled';
                                        %>
                                        <span class="<%= statusClass %>"><%= statusLabelText %></span>
                                      </td>
                                    </tr>
                                  <% }) %>
                                </tbody>
                              </table>
                            </div>
                          </div>
                          <div class="detail-pane" data-detail-pane="debt">
                            <div class="table-wrap">
                              <table class="admin-table store-table">
                                <thead>
                                  <tr>
                                    <th>Mã phiếu</th>
                                    <th>Loại chứng từ</th>
                                    <th>Thời gian</th>
                                    <th>Loại</th>
                                    <th>Giá trị</th>
                                    <th>Nợ cần trả nhà cung cấp</th>
                                    <th>Ghi chú</th>
                                  </tr>
                                </thead>
                                <tbody>
                                  <% if ((supplierDebtHistory || []).length === 0) { %>
                                    <tr><td colspan="7" class="empty-cell">Chưa có lịch sử công nợ.</td></tr>
                                  <% } %>
                                  <% (supplierDebtHistory || []).forEach(function(row) { %>
                                    <tr>
                                      <td><%- row.phieu_nhap_id ? refLink('purchase', row.phieu_nhap_id, row.ma_phieu || '--') : (row.phieu_thu_chi_id ? refLink('receipt', row.phieu_thu_chi_id, row.ma_phieu || '--') : (row.ma_phieu || '--')) %></td>
                                      <td><%= row.loai_chung_tu || '--' %></td>
                                      <td><%= formatDate(row.thoi_gian) %></td>
                                      <td><%= mapCongNoDirection ? mapCongNoDirection(row.loai) : mapCongNoLoai(row.loai) %></td>
                                      <td><%= Number(row.gia_tri || 0).toLocaleString('vi-VN') %></td>
                                      <td><%= Number(row.no_con_lai || 0).toLocaleString('vi-VN') %></td>
                                      <td><%= row.ghi_chu || '--' %></td>
                                    </tr>
                                  <% }) %>
                                </tbody>
                              </table>
                            </div>
                            <div class="detail-actions" style="margin-top:12px">
                              <button class="btn btn-light" type="button">Điều chỉnh</button>
                              <button class="btn btn-light" type="button">Thanh toán</button>
                              <button class="btn btn-light" type="button">Chiết khấu thanh toán</button>
                            </div>
                          </div>
                        </div>
                        <div class="page-actions detail-panel-footer supplier-detail-footer page-actions--sm">
                          <button class="btn btn-danger btn-sm" type="submit" formaction="/nha-cung-cap/<%= selectedSupplier._id %>/delete" formmethod="post" onclick="return confirm('Bạn có chắc muốn xóa nhà cung cấp này không?')">Xóa</button>
                          <button class="btn btn-success btn-sm" type="submit" formaction="/nha-cung-cap/<%= selectedSupplier._id %>/update" formmethod="post" onclick="return confirm('Bạn có muốn lưu thay đổi nhà cung cấp này không?')">Chỉnh sửa</button>
                          <a
                            class="btn btn-primary btn-sm supplier-detail-export-link"
                            href="/nha-cung-cap/<%= selectedSupplier._id %>/export/info"
                            data-supplier-id="<%= selectedSupplier._id %>"
                          >Xuất thông tin</a>
                        </div>
                      </div>
                    </td>
                  </tr>
                <% } %>
              <% }) %>
            </tbody>
          </table>
          </form>
        </div>
      </section>
    </div>
  </main>
  <div id="supplierGroupModalOverlay" class="group-modal-overlay">
    <div class="group-modal">
      <div class="group-modal-header">
        <h3 id="supplierGroupModalTitle">Sửa nhóm nhà cung cấp</h3>
        <button type="button" class="group-modal-close" id="supplierGroupModalClose">×</button>
      </div>
      <div class="group-modal-body">
        <label>
          <span>Tên nhóm</span>
          <input id="supplierGroupNameInput" type="text" placeholder="Nhập tên nhóm">
        </label>
        <label>
          <span>Ghi chú</span>
          <input id="supplierGroupDescInput" type="text" placeholder="Nhập ghi chú">
        </label>
      </div>
      <div class="page-actions group-modal-footer">
        <button class="btn btn-light btn-sm" type="button" id="supplierGroupModalCancel">Bỏ qua</button>
        <button class="btn btn-primary btn-sm" type="button" id="supplierGroupModalSubmit">Lưu</button>
      </div>
    </div>
  </div>
  <div id="addressTypeModalOverlay" class="group-modal-overlay">
    <div class="group-modal">
      <div class="group-modal-header">
        <h3 id="addressTypeModalTitle">Loại địa chỉ</h3>
        <button type="button" class="group-modal-close" id="addressTypeModalClose">×</button>
      </div>
      <div class="group-modal-body">
        <div class="address-type-list" id="addressTypeList"></div>
        <label>
          <span>Tên loại địa chỉ</span>
          <input id="addressTypeNameInput" type="text" placeholder="Ví dụ: Nhà riêng, Công ty">
        </label>
      </div>
      <div class="page-actions group-modal-footer">
        <button class="btn btn-light btn-sm" type="button" id="addressTypeModalCancel">Bỏ qua</button>
        <button class="btn btn-primary btn-sm" type="button" id="addressTypeModalSubmit">Thêm</button>
      </div>
    </div>
  </div>
  <script id="supplierGroupsSeed" type="application/json"><%- JSON.stringify(supplierGroups || []) %></script>
  <script id="addressTypesSeed" type="application/json"><%- JSON.stringify(addressTypes || []) %></script>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var openAddSupplierModalBtn = document.getElementById('openAddSupplierModal');
      var addSupplierModalOverlay = document.getElementById('addSupplierModalOverlay');
      var addSupplierModalClose = document.getElementById('addSupplierModalClose');
      var addSupplierModalCancel = document.getElementById('addSupplierModalCancel');
      var supplierCreateForm = document.getElementById('supplierCreateForm');

      function openAddSupplierModal() {
        if (!addSupplierModalOverlay) return;
        if (supplierCreateForm) supplierCreateForm.reset();
        addSupplierModalOverlay.classList.add('is-visible');
      }

      function closeAddSupplierModal() {
        if (!addSupplierModalOverlay) return;
        addSupplierModalOverlay.classList.remove('is-visible');
        if (window.location.search.indexOf('mode=create') >= 0) {
          var url = new URL(window.location.href);
          url.searchParams.delete('mode');
          window.history.replaceState({}, '', url.pathname + (url.searchParams.toString() ? '?' + url.searchParams.toString() : ''));
        }
      }

      if (openAddSupplierModalBtn) openAddSupplierModalBtn.addEventListener('click', openAddSupplierModal);
      if (addSupplierModalClose) addSupplierModalClose.addEventListener('click', closeAddSupplierModal);
      if (addSupplierModalCancel) addSupplierModalCancel.addEventListener('click', closeAddSupplierModal);
      if (addSupplierModalOverlay) {
        addSupplierModalOverlay.addEventListener('click', function(event) {
          if (event.target === addSupplierModalOverlay) closeAddSupplierModal();
        });
      }
      if (addSupplierModalOverlay && addSupplierModalOverlay.getAttribute('data-auto-open') === '1') {
        openAddSupplierModal();
      }

      var selectAll = document.getElementById('selectAllSuppliers');
      var checkboxes = Array.prototype.slice.call(document.querySelectorAll('.supplier-checkbox'));
      if (selectAll) {
        selectAll.addEventListener('change', function () { checkboxes.forEach(function (checkbox) { checkbox.checked = selectAll.checked; }); });
      }
      checkboxes.forEach(function (checkbox) {
        checkbox.addEventListener('change', function () {
          if (!selectAll) return;
          selectAll.checked = checkboxes.length > 0 && checkboxes.every(function (item) { return item.checked; });
        });
      });

      var createdFilterRadios = Array.prototype.slice.call(document.querySelectorAll('input[name="created"]'));
      var customDateRange = document.getElementById('customDateRange');
      function toggleCustomDateRange() {
        if (!customDateRange) return;
        var selectedCreated = createdFilterRadios.find(function(radio) { return radio.checked; });
        customDateRange.classList.toggle('is-visible', selectedCreated && selectedCreated.value === 'custom');
      }
      createdFilterRadios.forEach(function(radio) {
        radio.addEventListener('change', toggleCustomDateRange);
      });
      toggleCustomDateRange();

      var pillButtons = Array.prototype.slice.call(document.querySelectorAll('.pill-btn'));
      pillButtons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var targetInputId = btn.getAttribute('data-target-input');
          var value = btn.getAttribute('data-value');
          var input = document.getElementById(targetInputId);
          if (!input) return;
          input.value = value;
          var siblings = Array.prototype.slice.call(btn.parentElement.querySelectorAll('.pill-btn'));
          siblings.forEach(function(item) { item.classList.remove('is-active'); });
          btn.classList.add('is-active');
        });
      });

      var supplierGroupFilterTrigger = document.getElementById('supplierGroupFilterTrigger');
      var supplierGroupFilterLabel = document.getElementById('supplierGroupFilterLabel');
      var supplierGroupFilterValue = document.getElementById('supplierGroupFilterValue');
      var supplierGroupFilterDropdown = document.getElementById('supplierGroupFilterDropdown');
      var supplierGroupAddBtn = document.getElementById('supplierGroupAddBtn');
      var supplierGroupModalOverlay = document.getElementById('supplierGroupModalOverlay');
      var supplierGroupModalTitle = document.getElementById('supplierGroupModalTitle');
      var supplierGroupModalClose = document.getElementById('supplierGroupModalClose');
      var supplierGroupModalCancel = document.getElementById('supplierGroupModalCancel');
      var supplierGroupModalSubmit = document.getElementById('supplierGroupModalSubmit');
      var supplierGroupNameInput = document.getElementById('supplierGroupNameInput');
      var supplierGroupDescInput = document.getElementById('supplierGroupDescInput');
      var supplierGroupModalMode = 'add';
      var activeSupplierGroupItem = null;

      function bindSupplierGroupItems() {
        var groupItems = Array.prototype.slice.call(document.querySelectorAll('#supplierGroupFilterDropdown .group-manage-item'));
        groupItems.forEach(function(item) {
          var optionBtn = item.querySelector('.group-manage-option');
          var editBtn = item.querySelector('.group-manage-action-edit');
          var deleteBtn = item.querySelector('.group-manage-action-delete');

          if (optionBtn) {
            optionBtn.addEventListener('click', function() {
              groupItems.forEach(function(node) { node.classList.remove('is-active'); });
              item.classList.add('is-active');
              if (supplierGroupFilterValue) supplierGroupFilterValue.value = item.getAttribute('data-value') || 'all';
              if (supplierGroupFilterLabel) supplierGroupFilterLabel.textContent = item.getAttribute('data-name') || 'Tất cả các nhóm';
              if (supplierGroupFilterDropdown) supplierGroupFilterDropdown.classList.remove('is-open');
            });
          }

          if (editBtn) {
            editBtn.addEventListener('click', function(event) {
              event.stopPropagation();
              activeSupplierGroupItem = item;
              openSupplierGroupModal('edit');
            });
          }

          if (deleteBtn) {
            deleteBtn.addEventListener('click', function(event) {
              event.stopPropagation();
              var groupId = item.getAttribute('data-id') || '';
              if (!groupId) {
                alert('Vui lòng chọn nhóm cần xóa.');
                return;
              }
              if (!confirm('Bạn có chắc muốn xóa nhóm nhà cung cấp này không?')) return;
              requestSupplierGroups('/nha-cung-cap/groups/' + groupId + '/delete', {}, '');
            });
          }
        });
      }

      function renderSupplierGroupList(selectedValue) {
        if (!supplierGroupFilterDropdown) return;
        var groups = window.__supplierGroups || [];
        var rows = [];
        rows.push(
          '<div class="group-manage-item ' + ((selectedValue === 'all' || !selectedValue) ? 'is-active' : '') + '" data-id="" data-value="all" data-name="Tất cả các nhóm" data-desc="">' +
            '<button class="group-manage-option" type="button">Tất cả các nhóm</button>' +
          '</div>'
        );
        groups.forEach(function(group) {
          var id = String(group._id || '');
          var isActive = id === String(selectedValue || '');
          rows.push(
            '<div class="group-manage-item ' + (isActive ? 'is-active' : '') + '" data-id="' + id + '" data-value="' + id + '" data-name="' + (group.ten_nhom_ncc || '').replace(/"/g, '&quot;') + '" data-desc="' + (group.mo_ta || '').replace(/"/g, '&quot;') + '">' +
              '<button class="group-manage-option" type="button">' + (group.ten_nhom_ncc || '') + '</button>' +
              '<div class="group-manage-actions">' +
                '<button class="group-manage-action-edit" type="button">Sửa</button>' +
                '<button class="group-manage-action-delete" type="button">Xóa</button>' +
              '</div>' +
            '</div>'
          );
        });
        supplierGroupFilterDropdown.innerHTML = rows.join('');
        bindSupplierGroupItems();
      }

      function refreshSupplierGroupWidget(selectedId) {
        var selected = selectedId || (supplierGroupFilterValue ? supplierGroupFilterValue.value : 'all') || 'all';
        renderSupplierGroupList(selected);
        if (supplierGroupFilterDropdown && supplierGroupFilterLabel) {
          var activeItem = supplierGroupFilterDropdown.querySelector('.group-manage-item.is-active');
          supplierGroupFilterLabel.textContent = activeItem ? (activeItem.getAttribute('data-name') || 'Tất cả các nhóm') : 'Tất cả các nhóm';
          if (supplierGroupFilterValue) supplierGroupFilterValue.value = activeItem ? (activeItem.getAttribute('data-value') || 'all') : 'all';
        }
      }

      function requestSupplierGroups(url, payload, selectedId) {
        var formBody = Object.keys(payload).map(function(key) {
          return encodeURIComponent(key) + '=' + encodeURIComponent(payload[key]);
        }).join('&');

        fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
          },
          body: formBody
        })
          .then(function(response) {
            return response.json().catch(function() {
              return { success: false, message: 'Server không trả về JSON hợp lệ.' };
            });
          })
          .then(function(data) {
            if (!data || !data.success) {
              alert((data && data.message) || 'Không thể xử lý nhóm nhà cung cấp.');
              return;
            }
            if (Array.isArray(data.supplierGroups)) {
              window.__supplierGroups = data.supplierGroups;
            } else if (data.data && data.data._id) {
              window.__supplierGroups = (window.__supplierGroups || []).filter(function(group) {
                return String(group._id) !== String(data.data._id);
              });
              window.__supplierGroups.push(data.data);
            }
            refreshSupplierGroupWidget(data.selectedId || (data.data && data.data._id) || selectedId || '');
            closeSupplierGroupModal();
          })
          .catch(function(error) {
            alert((error && error.message) || 'Có lỗi khi xử lý nhóm nhà cung cấp.');
          });
      }

      function openSupplierGroupModal(mode) {
        supplierGroupModalMode = mode;
        if (!supplierGroupModalOverlay || !supplierGroupModalTitle) return;
        if (mode === 'add') {
          supplierGroupModalTitle.textContent = 'Thêm nhóm nhà cung cấp';
          if (supplierGroupNameInput) supplierGroupNameInput.value = '';
          if (supplierGroupDescInput) supplierGroupDescInput.value = '';
        } else {
          supplierGroupModalTitle.textContent = 'Sửa nhóm nhà cung cấp';
          if (supplierGroupNameInput) supplierGroupNameInput.value = activeSupplierGroupItem ? (activeSupplierGroupItem.getAttribute('data-name') || '') : '';
          if (supplierGroupDescInput) supplierGroupDescInput.value = activeSupplierGroupItem ? (activeSupplierGroupItem.getAttribute('data-desc') || '') : '';
        }
        supplierGroupModalOverlay.classList.add('is-open');
      }

      function closeSupplierGroupModal() {
        if (!supplierGroupModalOverlay) return;
        supplierGroupModalOverlay.classList.remove('is-open');
      }

      if (supplierGroupFilterTrigger && supplierGroupFilterDropdown) {
        supplierGroupFilterTrigger.addEventListener('click', function() {
          supplierGroupFilterDropdown.classList.toggle('is-open');
        });
      }
      if (supplierGroupAddBtn) {
        supplierGroupAddBtn.addEventListener('click', function() {
          openSupplierGroupModal('add');
        });
      }
      if (supplierGroupModalClose) supplierGroupModalClose.addEventListener('click', closeSupplierGroupModal);
      if (supplierGroupModalCancel) supplierGroupModalCancel.addEventListener('click', closeSupplierGroupModal);

      if (supplierGroupModalSubmit) {
        supplierGroupModalSubmit.addEventListener('click', function() {
          if (!supplierGroupNameInput || !supplierGroupNameInput.value.trim()) {
            alert('Vui lòng nhập tên nhóm nhà cung cấp.');
            return;
          }
          if (supplierGroupModalMode === 'add') {
            requestSupplierGroups('/nha-cung-cap/groups/add', {
              ten_nhom_ncc: supplierGroupNameInput.value.trim(),
              mo_ta: supplierGroupDescInput ? supplierGroupDescInput.value.trim() : ''
            }, '');
            return;
          }
          var groupId = activeSupplierGroupItem ? (activeSupplierGroupItem.getAttribute('data-id') || '') : '';
          if (!groupId) {
            alert('Vui lòng chọn nhóm cần sửa.');
            return;
          }
          requestSupplierGroups('/nha-cung-cap/groups/' + groupId + '/update', {
            ten_nhom_ncc: supplierGroupNameInput.value.trim(),
            mo_ta: supplierGroupDescInput ? supplierGroupDescInput.value.trim() : ''
          }, groupId);
        });
      }

      var supplierGroupsSeed = document.getElementById('supplierGroupsSeed');
      window.__supplierGroups = supplierGroupsSeed ? JSON.parse(supplierGroupsSeed.textContent || '[]') : [];
      refreshSupplierGroupWidget((supplierGroupFilterValue && supplierGroupFilterValue.value) || 'all');

      var addressTypesSeed = document.getElementById('addressTypesSeed');
      window.__addressTypes = addressTypesSeed ? JSON.parse(addressTypesSeed.textContent || '[]') : [];
      var addressTypeModalOverlay = document.getElementById('addressTypeModalOverlay');
      var addressTypeModalClose = document.getElementById('addressTypeModalClose');
      var addressTypeModalCancel = document.getElementById('addressTypeModalCancel');
      var addressTypeModalSubmit = document.getElementById('addressTypeModalSubmit');
      var addressTypeNameInput = document.getElementById('addressTypeNameInput');
      var addressTypeList = document.getElementById('addressTypeList');
      var activeAddressTypeItem = null;
      var addressTypeMode = 'add';

      function escapeHtml(value) {
        return String(value || '').replace(/[&<>"']/g, function(ch) {
          return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[ch];
        });
      }

      function renderAddressTypeSelects(selectedCode) {
        var types = window.__addressTypes || [];
        document.querySelectorAll('.js-address-type-select').forEach(function(select) {
          var current = selectedCode || select.value || 'khac';
          var html = '<option value="khac">Khác</option>';
          types.forEach(function(type) {
            html += '<option value="' + escapeHtml(type.ma_loai || '') + '">' + escapeHtml(type.ten_loai || '') + '</option>';
          });
          select.innerHTML = html;
          select.value = types.some(function(type) { return String(type.ma_loai) === String(current); }) || current === 'khac'
            ? current
            : 'khac';
        });
      }

      function bindAddressTypeRows() {
        if (!addressTypeList) return;
        Array.prototype.slice.call(addressTypeList.querySelectorAll('.address-type-row')).forEach(function(row) {
          var editBtn = row.querySelector('.js-address-type-edit');
          var deleteBtn = row.querySelector('.js-address-type-delete');
          if (editBtn) {
            editBtn.addEventListener('click', function() {
              activeAddressTypeItem = row;
              addressTypeMode = 'edit';
              if (addressTypeNameInput) addressTypeNameInput.value = row.getAttribute('data-name') || '';
              if (addressTypeModalSubmit) addressTypeModalSubmit.textContent = 'Lưu';
            });
          }
          if (deleteBtn) {
            deleteBtn.addEventListener('click', function() {
              var id = row.getAttribute('data-id') || '';
              if (!id) return;
              if (!confirm('Xóa loại địa chỉ này? Các địa chỉ đang dùng sẽ chuyển về Khác.')) return;
              requestAddressTypes('/nha-cung-cap/address-types/' + id + '/delete', {}, 'khac');
            });
          }
        });
      }

      function renderAddressTypeList() {
        if (!addressTypeList) return;
        var types = window.__addressTypes || [];
        if (!types.length) {
          addressTypeList.innerHTML = '<div class="empty-cell">Chưa có loại địa chỉ.</div>';
          return;
        }
        addressTypeList.innerHTML = types.map(function(type) {
          return '<div class="address-type-row" data-id="' + escapeHtml(type._id || '') + '" data-code="' + escapeHtml(type.ma_loai || '') + '" data-name="' + escapeHtml(type.ten_loai || '') + '">' +
            '<div><div class="address-type-name">' + escapeHtml(type.ten_loai || '') + '</div><div class="address-type-code">' + escapeHtml(type.ma_loai || '') + '</div></div>' +
            '<div class="address-type-actions">' +
              '<button class="btn btn-light btn-sm js-address-type-edit" type="button">Sửa</button>' +
              '<button class="btn btn-danger btn-sm js-address-type-delete" type="button">Xóa</button>' +
            '</div>' +
          '</div>';
        }).join('');
        bindAddressTypeRows();
      }

      function openAddressTypeModal() {
        activeAddressTypeItem = null;
        addressTypeMode = 'add';
        if (addressTypeNameInput) addressTypeNameInput.value = '';
        if (addressTypeModalSubmit) addressTypeModalSubmit.textContent = 'Thêm';
        renderAddressTypeList();
        if (addressTypeModalOverlay) addressTypeModalOverlay.classList.add('is-open');
      }

      function closeAddressTypeModal() {
        if (addressTypeModalOverlay) addressTypeModalOverlay.classList.remove('is-open');
      }

      function requestAddressTypes(url, payload, selectedCode) {
        var formBody = Object.keys(payload).map(function(key) {
          return encodeURIComponent(key) + '=' + encodeURIComponent(payload[key]);
        }).join('&');

        fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
          },
          body: formBody
        })
          .then(function(response) {
            return response.json().catch(function() {
              return { success: false, message: 'Server không trả về JSON hợp lệ.' };
            });
          })
          .then(function(data) {
            if (!data || !data.success) {
              alert((data && data.message) || 'Không thể xử lý loại địa chỉ.');
              return;
            }
            if (Array.isArray(data.addressTypes)) window.__addressTypes = data.addressTypes;
            renderAddressTypeList();
            renderAddressTypeSelects(data.selectedCode || selectedCode || '');
            if (addressTypeMode === 'add') {
              if (addressTypeNameInput) addressTypeNameInput.value = '';
            } else {
              activeAddressTypeItem = null;
              addressTypeMode = 'add';
              if (addressTypeNameInput) addressTypeNameInput.value = '';
              if (addressTypeModalSubmit) addressTypeModalSubmit.textContent = 'Thêm';
            }
          })
          .catch(function(error) {
            alert((error && error.message) || 'Có lỗi khi xử lý loại địa chỉ.');
          });
      }

      document.querySelectorAll('.js-open-address-type-modal').forEach(function(button) {
        button.addEventListener('click', openAddressTypeModal);
      });
      if (addressTypeModalClose) addressTypeModalClose.addEventListener('click', closeAddressTypeModal);
      if (addressTypeModalCancel) addressTypeModalCancel.addEventListener('click', closeAddressTypeModal);
      if (addressTypeModalSubmit) {
        addressTypeModalSubmit.addEventListener('click', function() {
          if (!addressTypeNameInput || !addressTypeNameInput.value.trim()) {
            alert('Vui lòng nhập tên loại địa chỉ.');
            return;
          }
          if (addressTypeMode === 'edit') {
            var typeId = activeAddressTypeItem ? activeAddressTypeItem.getAttribute('data-id') : '';
            if (!typeId) return alert('Vui lòng chọn loại địa chỉ cần sửa.');
            requestAddressTypes('/nha-cung-cap/address-types/' + typeId + '/update', {
              ten_loai: addressTypeNameInput.value.trim()
            }, activeAddressTypeItem.getAttribute('data-code') || '');
            return;
          }
          requestAddressTypes('/nha-cung-cap/address-types/add', {
            ten_loai: addressTypeNameInput.value.trim()
          }, '');
        });
      }
      renderAddressTypeSelects();

      var detailBlocks = Array.prototype.slice.call(document.querySelectorAll('.store-detail'));
      var exportLabels = { info: 'Xuất thông tin', address: 'Xuất địa chỉ', history: 'Xuất lịch sử', debt: 'Xuất công nợ' };
      function syncSupplierExportLink(detailBlock) {
        var link = detailBlock.querySelector('.supplier-detail-export-link');
        if (!link) return;
        var id = link.getAttribute('data-supplier-id');
        if (!id) return;
        var activeBtn = detailBlock.querySelector('.detail-tab.is-active[data-detail-tab]');
        var tab = activeBtn ? activeBtn.getAttribute('data-detail-tab') : 'info';
        link.href = '/nha-cung-cap/' + id + '/export/' + tab;
        link.textContent = exportLabels[tab] || 'Xuất';
      }
      detailBlocks.forEach(function (detailBlock) {
        var tabButtons = Array.prototype.slice.call(detailBlock.querySelectorAll('.detail-tab[data-detail-tab]'));
        var panes = Array.prototype.slice.call(detailBlock.querySelectorAll('.detail-pane[data-detail-pane]'));
        tabButtons.forEach(function(btn) {
          btn.addEventListener('click', function() {
            var target = btn.getAttribute('data-detail-tab');
            tabButtons.forEach(function(node) { node.classList.remove('is-active'); });
            panes.forEach(function(pane) { pane.classList.remove('is-active'); });
            btn.classList.add('is-active');
            var activePane = detailBlock.querySelector('.detail-pane[data-detail-pane="' + target + '"]');
            if (activePane) activePane.classList.add('is-active');
            syncSupplierExportLink(detailBlock);
          });
        });
        syncSupplierExportLink(detailBlock);

        var collapseBtn = detailBlock.querySelector('.detail-collapse-btn');
        var detailBody = detailBlock.querySelector('.store-detail-body');
        if (collapseBtn && detailBody) {
          collapseBtn.addEventListener('click', function () {
            var isCollapsed = detailBlock.classList.toggle('is-collapsed');
            collapseBtn.textContent = isCollapsed ? 'Mở rộng' : 'Thu gọn';
            collapseBtn.setAttribute('aria-expanded', isCollapsed ? 'false' : 'true');
          });
        }
      });

      function submitSupplierAddressForm(action, formId, confirmMessage) {
        if (!action || !formId) return;
        if (confirmMessage && !confirm(confirmMessage)) return;

        var tempForm = document.createElement('form');
        tempForm.method = 'post';
        tempForm.action = action;
        tempForm.style.display = 'none';

        var fields = document.querySelectorAll('[data-address-form="' + formId + '"]');
        fields.forEach(function(field) {
          if (!field.name) return;
          if ((field.type === 'checkbox' || field.type === 'radio') && !field.checked) return;
          var input = document.createElement('input');
          input.type = 'hidden';
          input.name = field.name;
          input.value = field.value || '';
          tempForm.appendChild(input);
        });

        document.body.appendChild(tempForm);
        tempForm.submit();
      }

      document.querySelectorAll('.js-supplier-address-submit').forEach(function(button) {
        button.addEventListener('click', function(event) {
          event.preventDefault();
          event.stopPropagation();
          submitSupplierAddressForm(
            button.getAttribute('data-action'),
            button.getAttribute('data-form-id'),
            button.getAttribute('data-confirm')
          );
        });
      });

      document.querySelectorAll('.js-supplier-address-delete').forEach(function(button) {
        button.addEventListener('click', function(event) {
          event.preventDefault();
          event.stopPropagation();
          if (!confirm('Bạn có chắc muốn xóa địa chỉ này không?')) return;

          var tempForm = document.createElement('form');
          tempForm.method = 'post';
          tempForm.action = button.getAttribute('data-action');
          tempForm.style.display = 'none';

          var returnQuery = document.createElement('input');
          returnQuery.type = 'hidden';
          returnQuery.name = 'returnQuery';
          returnQuery.value = button.getAttribute('data-return-query') || '';
          tempForm.appendChild(returnQuery);

          document.body.appendChild(tempForm);
          tempForm.submit();
        });
      });

      var clickableRows = Array.prototype.slice.call(document.querySelectorAll('.store-table tr[data-href]'));
      clickableRows.forEach(function(row) {
        row.addEventListener('click', function(event) {
          if (event.defaultPrevented) return;
          var t = event.target;
          if (t && t.closest && t.closest('a,button,input,select,textarea,label')) return;
          var href = row.getAttribute('data-href');
          if (href) window.location.href = href;
        });
      });

      document.addEventListener('click', function(event) {
        if (!supplierGroupFilterDropdown || !supplierGroupFilterTrigger) return;
        if (supplierGroupFilterDropdown.contains(event.target)) return;
        if (supplierGroupFilterTrigger.contains(event.target)) return;
        supplierGroupFilterDropdown.classList.remove('is-open');
      });
    });
  </script>
</body>
</html>
