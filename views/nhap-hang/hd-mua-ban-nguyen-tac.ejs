<%
  const fmt = value => Number(value || 0).toLocaleString('vi-VN');
  const d = value => value ? new Date(value).toLocaleDateString('vi-VN') : '';
  const safeTicket = locals.ticket || {};
  const safeItems = Array.isArray(locals.items) ? locals.items : [];
  const supplier = safeTicket.nha_cung_cap_id || {};
  const isProductList = locals.contractMode === 'product-list';
  const totalAmount = Number(safeTicket.tong_tien || safeItems.reduce((sum, row) => sum + Number(row.thanh_tien || 0), 0));
%>
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <style>
    body{font-family:Arial,sans-serif;margin:0;background:#f3f4f6;color:#111}
    .page{width:210mm;min-height:297mm;margin:0 auto;background:#fff;padding:16mm;box-sizing:border-box}
    h1{text-align:center;font-size:19px;text-transform:uppercase;margin:18px 0 8px}
    h2{font-size:14px;margin:14px 0 6px}
    p,.info{font-size:13px;line-height:1.55}
    table{width:100%;border-collapse:collapse;margin-top:10px}
    th,td{border:1px solid #333;padding:6px;font-size:12px}
    th{background:#f1f5f9}
    .num{text-align:right}
    .sign{display:grid;grid-template-columns:1fr 1fr;gap:40px;margin-top:30px;text-align:center;font-size:13px}
    .sign b{display:block;margin-bottom:60px;text-transform:uppercase}
    .print-actions{position:fixed;right:18px;top:18px;display:flex;gap:8px}
    .print-actions button{border:1px solid #1f2937;background:#fff;color:#111;padding:7px 12px;border-radius:3px;font-family:Arial,sans-serif;font-size:13px;cursor:pointer}
    @media print{body{background:#fff}.page{margin:0;width:auto;min-height:auto}.no-print{display:none!important}}
  </style>
</head>
<body>
  <div class="print-actions no-print">
    <button type="button" onclick="window.print()">In</button>
    <button type="button" onclick="window.location.href = window.location.pathname.replace(/\/$/, '') + '/pdf' + window.location.search">Tải PDF</button>
  </div>
  <main class="page">
    <h1>Hợp đồng mua bán nguyên tắc</h1>
    <% if (isProductList) { %>
      <p style="text-align:center">Căn cứ danh sách hàng hóa ngày <%= d(new Date()) %></p>
    <% } else { %>
      <p style="text-align:center">Căn cứ phiếu nhập hàng số <strong><%= safeTicket.ma_phieu_nhap || '' %></strong> ngày <%= d(safeTicket.ngay_nhap) %></p>
    <% } %>

    <h2>Bên mua</h2>
    <div class="info">
      Tên đơn vị: <strong><%= store ? (store.ten_cua_hang || '') : '' %></strong><br>
      Địa chỉ: <%= store ? (store.dia_chi_day_du || store.dia_chi || '') : '' %><br>
      Điện thoại: <%= store ? (store.sdt || '') : '' %>
    </div>

    <h2>Bên bán</h2>
    <div class="info">
      <% if (isProductList) { %>
        Nhà cung cấp: <strong>Theo từng hàng hóa trong danh sách</strong>
      <% } else { %>
        Nhà cung cấp: <strong><%= supplier.ten_ncc || '' %></strong><br>
        Công ty: <%= supplier.ten_cong_ty || '' %><br>
        Mã số thuế: <%= supplier.ma_so_thue || '' %><br>
        Điện thoại: <%= supplier.sdt || '' %> - Email: <%= supplier.email || '' %>
      <% } %>
    </div>

    <h2>Danh sách hàng hóa</h2>
    <table>
      <thead>
        <% if (isProductList) { %>
          <tr><th>STT</th><th>Mã hàng</th><th>Tên hàng</th><th>ĐVT</th><th>Nhà cung cấp</th><th>Tồn kho</th><th>Giá vốn</th><th>Thành tiền</th></tr>
        <% } else { %>
          <tr><th>STT</th><th>Tên hàng</th><th>Lô</th><th>Số lượng</th><th>Đơn giá</th><th>Thành tiền</th></tr>
        <% } %>
      </thead>
      <tbody>
        <% safeItems.forEach(function(row, index){ const product = row.hang_hoa_id || {}; %>
          <tr>
            <td class="num"><%= index + 1 %></td>
            <% if (isProductList) { %>
              <td><%= product.ma_hang || '' %></td>
              <td><%= product.ten_hang || '' %></td>
              <td><%= product.don_vi_tinh_id ? (product.don_vi_tinh_id.ten_don_vi || product.don_vi_tinh_id.ma_don_vi || '') : '' %></td>
              <td><%= product.nha_cung_cap_id ? (product.nha_cung_cap_id.ten_ncc || product.nha_cung_cap_id.ten_cong_ty || '') : '' %></td>
              <td class="num"><%= fmt(row.so_luong) %></td>
              <td class="num"><%= fmt(row.don_gia_nhap) %></td>
              <td class="num"><%= fmt(row.thanh_tien) %></td>
            <% } else { %>
              <td><%= product.ten_hang || '' %></td>
              <td><%= row.lo_hang_id ? (row.lo_hang_id.ma_lo || row.lo_hang_id.ten_lo || '') : '' %></td>
              <td class="num"><%= fmt(row.so_luong) %></td>
              <td class="num"><%= fmt(row.don_gia_nhap) %></td>
              <td class="num"><%= fmt(row.thanh_tien) %></td>
            <% } %>
          </tr>
        <% }) %>
        <% if (isProductList) { %>
          <tr><th colspan="7">Tổng giá trị tồn theo giá vốn</th><th class="num"><%= fmt(totalAmount) %></th></tr>
        <% } else { %>
          <tr><th colspan="5">Tổng tiền</th><th class="num"><%= fmt(totalAmount) %></th></tr>
        <% } %>
      </tbody>
    </table>

    <% if (isProductList) { %>
      <h2>Điều khoản nguyên tắc</h2>
      <p>Danh sách hàng hóa trên là cơ sở để hai bên thỏa thuận mua bán, giao nhận, đối soát số lượng và đơn giá theo từng lần phát sinh thực tế.</p>
      <h2>Giao nhận</h2>
      <p>Hàng hóa được giao nhận theo chứng từ phát sinh giữa hai bên. Hai bên xác nhận số lượng, chất lượng và giá trị theo từng lần giao nhận.</p>
    <% } else { %>
      <h2>Điều khoản thanh toán</h2>
      <p>Bên mua cần trả nhà cung cấp <strong><%= fmt(safeTicket.can_tra_ncc) %> VND</strong>, đã trả <strong><%= fmt(safeTicket.da_tra_ncc) %> VND</strong>, còn nợ <strong><%= fmt(safeTicket.con_no_ncc) %> VND</strong>. Phương thức thanh toán: <%= safeTicket.phuong_thuc_thanh_toan || 'cong_no' %>.</p>
      <h2>Giao nhận</h2>
      <p>Hàng hóa được giao và nhập tại kho <strong><%= safeTicket.kho_id ? (safeTicket.kho_id.ten_kho || safeTicket.kho_id.ma_kho || '') : '' %></strong>. Hai bên xác nhận số lượng, chất lượng hàng hóa theo danh sách trên tại thời điểm giao nhận.</p>
    <% } %>

    <section class="sign">
      <div><b>Đại diện bên mua</b>(Ký, ghi rõ họ tên)</div>
      <div><b>Đại diện bên bán</b>(Ký, ghi rõ họ tên)</div>
    </section>
  </main>
</body>
</html>
