<%
  const id = ticket && ticket._id ? String(ticket._id) : '';
  const code = ticket && ticket.ma_phieu_nhap ? ticket.ma_phieu_nhap : '';
%>
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title || 'In phiếu nhập và 02/TNDN' %></title>
  <style>
    *{box-sizing:border-box}
    body{margin:0;background:#eef2f6;color:#111827;font-family:Arial,sans-serif}
    .bundle-shell{height:100vh;display:flex;flex-direction:column;min-width:1024px}
    .bundle-header{height:54px;background:#fff;border-bottom:1px solid #d7dee8;display:flex;align-items:center;justify-content:space-between;padding:0 16px}
    .bundle-title{font-weight:800;font-size:16px}
    .bundle-title span{color:#0070f4}
    .bundle-actions{display:flex;gap:8px}
    .bundle-btn{height:34px;border:1px solid #c6d3e1;background:#fff;border-radius:6px;padding:0 12px;font-weight:700;color:#111827;text-decoration:none;display:inline-flex;align-items:center;cursor:pointer}
    .bundle-btn.primary{border-color:#0070f4;color:#0070f4}
    .bundle-grid{flex:1;min-height:0;display:grid;grid-template-columns:1fr 1fr;gap:12px;padding:12px}
    .print-pane{min-width:0;background:#fff;border:1px solid #d7dee8;border-radius:8px;display:flex;flex-direction:column;overflow:hidden}
    .pane-head{height:42px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid #e5ebf2;padding:0 10px;background:#f8fafc}
    .pane-head strong{font-size:14px}
    .pane-actions{display:flex;gap:6px}
    .pane-actions a,.pane-actions button{height:28px;border:1px solid #c6d3e1;background:#fff;border-radius:5px;padding:0 9px;font-size:12px;font-weight:700;text-decoration:none;color:#111827;display:inline-flex;align-items:center;cursor:pointer}
    iframe{width:100%;height:100%;border:0;background:#fff}
    .frame-wrap{flex:1;min-height:0}
    @media(max-width:1100px){
      .bundle-shell{min-width:0;height:auto;min-height:100vh}
      .bundle-grid{grid-template-columns:1fr}
      .print-pane{height:82vh}
    }
  </style>
</head>
<body>
  <div class="bundle-shell">
    <header class="bundle-header">
      <div class="bundle-title">In phiếu nhập và 02/TNDN <span><%= code %></span></div>
      <div class="bundle-actions">
        <a class="bundle-btn" href="/nhap-hang">Quay lại</a>
        <button class="bundle-btn primary" type="button" onclick="printBoth()">In cả 2</button>
      </div>
    </header>

    <main class="bundle-grid">
      <section class="print-pane">
        <div class="pane-head">
          <strong>Phiếu nhập</strong>
          <div class="pane-actions">
            <button type="button" onclick="printFrame('purchaseFrame')">In</button>
            <a href="/phieu-nhap/<%= id %>/in/pdf" target="_blank">Tải PDF</a>
            <a href="/phieu-nhap/<%= id %>/in" target="_blank">Mở riêng</a>
          </div>
        </div>
        <div class="frame-wrap">
          <iframe id="purchaseFrame" src="/phieu-nhap/<%= id %>/in?embed=1"></iframe>
        </div>
      </section>

      <section class="print-pane">
        <div class="pane-head">
          <strong>Bảng kê 02/TNDN</strong>
          <div class="pane-actions">
            <button type="button" onclick="printFrame('tndnFrame')">In</button>
            <a href="/phieu-nhap/<%= id %>/bang-ke-02-tndn/pdf" target="_blank">Tải PDF</a>
            <a href="/phieu-nhap/<%= id %>/bang-ke-02-tndn" target="_blank">Mở riêng</a>
          </div>
        </div>
        <div class="frame-wrap">
          <iframe id="tndnFrame" src="/phieu-nhap/<%= id %>/bang-ke-02-tndn?embed=1"></iframe>
        </div>
      </section>
    </main>
  </div>

  <script>
    function printFrame(id) {
      const frame = document.getElementById(id);
      if (!frame || !frame.contentWindow) return;
      frame.contentWindow.focus();
      frame.contentWindow.print();
    }
    function printBoth() {
      printFrame('purchaseFrame');
      setTimeout(function() { printFrame('tndnFrame'); }, 500);
    }
  </script>
</body>
</html>
