<%
  const safeList = Array.isArray(locals.list) ? locals.list : [];
  const safeCashBooks = Array.isArray(locals.cashBooks) ? locals.cashBooks : [];
  const safeCustomers = Array.isArray(locals.customers) ? locals.customers : [];
  const safeSuppliers = Array.isArray(locals.suppliers) ? locals.suppliers : [];
  const safeFilters = locals.filters || {};
  const safeSummary = locals.summary || {};
  const fmt = value => Number(value || 0).toLocaleString('vi-VN');
  const selectedBookId = String(locals.selectedCashBook?._id || '');
%>
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <style>
    body{background:#f3f6f9}.page{height:calc(100vh - 98px);display:grid;grid-template-columns:280px minmax(0,1fr);gap:14px;padding:16px 60px;overflow:hidden}.sidebar{background:#fff;border-radius:7px;padding:14px;overflow:auto}.title{font-size:24px;font-weight:800;margin:0 0 18px}.filter{margin-bottom:24px}.filter-title{font-weight:800;margin-bottom:12px}.radio,.check{display:flex;align-items:center;gap:9px;margin:13px 0;font-size:16px}.radio input,.check input{width:17px;height:17px;accent-color:#0070f4}.pill{height:36px;border:1px solid #cfd8e3;border-radius:8px;background:#fff;display:flex;align-items:center;justify-content:space-between;padding:0 12px;flex:1}.control{width:100%;height:36px;border:1px solid #cfd8e3;border-radius:8px;background:#fff;padding:0 12px;font-size:15px;color:#667085;margin-bottom:9px}.seg{display:flex;gap:8px}.seg button{height:36px;border:1px solid #cfd8e3;background:#fff;border-radius:20px;padding:0 16px;font-size:16px;cursor:pointer}.seg button.active{background:#0070f4;border-color:#0070f4;color:#fff;font-weight:800}.main{min-width:0;display:flex;flex-direction:column;gap:12px;overflow:hidden}.toolbar{display:flex;align-items:center;justify-content:space-between;gap:14px}.search{position:relative;width:562px;max-width:100%}.search i{position:absolute;left:14px;top:50%;transform:translateY(-50%);color:#667085}.search input{width:100%;height:37px;border:1px solid #cfd8e3;border-radius:8px;padding:0 42px 0 38px;font-size:16px}.search button{position:absolute;right:5px;top:5px;width:26px;height:26px;border:0;background:#fff}.actions{display:flex;gap:8px}.btn{height:37px;border:1px solid #cfd8e3;background:#fff;border-radius:8px;padding:0 13px;color:#111827;font-weight:800;font-size:15px;display:flex;align-items:center;gap:8px;text-decoration:none;cursor:pointer}.btn.primary{color:#0070f4;border-color:#0070f4}.icon{width:37px;height:37px;border:1px solid #cfd8e3;border-radius:8px;background:#fff;display:flex;align-items:center;justify-content:center}.summary{height:88px;background:#fff;border-radius:7px;display:grid;grid-template-columns:repeat(4,1fr);align-items:center;text-align:center}.summary label{display:block;color:#667085;font-size:16px;margin-bottom:10px}.summary strong{font-size:20px}.blue{color:#0070f4}.red{color:red}.green{color:#00a651}.table-wrap{flex:1;min-height:0;background:#fff;border-radius:7px;overflow:auto}.table{width:100%;min-width:980px;border-collapse:collapse}.table th{height:43px;background:#e8f3ff;border-bottom:1px solid #bcd9ff;text-align:left;padding:0 10px;font-size:13px}.table td{height:43px;border-bottom:1px solid #e5e9ee;padding:0 10px;font-size:14px}.check-col,.star-col{width:36px;text-align:center}.num{text-align:right}.receipt{color:#006dff;text-decoration:none;font-weight:800}.type{font-weight:800}.type.thu{color:#0070f4}.type.chi{color:red}.empty{height:520px;text-align:center}.empty-box{height:100%;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:12px}.empty-icon{width:112px;height:112px;border-radius:50%;background:#eef6ff;display:flex;align-items:center;justify-content:center;color:#0070f4;font-size:42px}.chat{position:fixed;right:14px;bottom:10px;background:#0070f4;color:#fff;border-radius:8px;height:36px;display:flex;align-items:center;gap:6px;padding:0 12px;font-weight:800}.modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.55);display:none;align-items:flex-start;justify-content:center;padding-top:24px;z-index:1000}.modal-backdrop.open{display:flex}.modal{width:1080px;max-width:calc(100vw - 80px);background:#fff;border-radius:10px;box-shadow:0 18px 42px rgba(0,0,0,.35);overflow:hidden}.modal-head{height:70px;display:flex;align-items:center;justify-content:space-between;padding:0 28px}.modal-head h2{font-size:24px;margin:0}.modal-close{border:0;background:#fff;font-size:26px;color:#5b646f;cursor:pointer}.modal-body{padding:16px 28px 26px}.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px 28px}.field label{display:block;font-size:14px;margin-bottom:7px}.field input,.field select{width:100%;height:36px;border:1px solid #cfd8e3;border-radius:8px;padding:0 12px;font-size:16px}.field.full{grid-column:1 / -1}.money-wrap{position:relative}.money-wrap input{text-align:right;padding-right:28px}.money-wrap span{position:absolute;right:12px;top:50%;transform:translateY(-50%);font-size:20px;color:#8b95a1;font-weight:800}.modal-foot{height:72px;border-top:1px solid #e5e9ee;display:flex;align-items:center;justify-content:flex-end;gap:8px;padding:0 28px}.modal-btn{height:45px;border:1px solid #cfd8e3;background:#fff;border-radius:8px;padding:0 20px;font-weight:800;font-size:15px;cursor:pointer}.modal-btn.save{border:0;background:#0070f4;color:#fff}.accounting{display:flex;align-items:center;gap:8px;margin-top:18px}.accounting input{width:18px;height:18px;accent-color:#0070f4}
  </style>
</head>
<body>
  <%- include('../partials/header') %>
  <form class="page" method="GET" action="/so-quy">
    <aside>
      <h1 class="title">Sổ quỹ tiền mặt</h1>
      <div class="sidebar">
        <div class="filter"><div class="filter-title">Quỹ tiền</div>
          <% safeCashBooks.forEach(book => { %>
            <label class="radio"><input type="radio" name="so_quy_id" value="<%= book._id %>" <%= String(safeFilters.so_quy_id || selectedBookId) === String(book._id) ? 'checked' : '' %> onchange="this.form.submit()"><span><%= book.ten_so_quy %></span></label>
          <% }) %>
          <label class="radio"><input type="radio" disabled><span>Ngân hàng</span></label>
          <label class="radio"><input type="radio" disabled><span>Ví điện tử</span></label>
          <label class="radio"><input type="radio" disabled><span>Tổng quỹ</span></label>
        </div>
        <div class="filter"><div class="filter-title">Thời gian</div><label class="radio"><input type="radio" name="time_type" value="this_month" <%= safeFilters.time_type === 'this_month' ? 'checked' : '' %> onchange="this.form.submit()"><span class="pill">Tháng này <i class="fa-solid fa-chevron-right"></i></span></label><input class="control" type="date" name="date_from" value="<%= safeFilters.date_from || '' %>" onchange="this.form.submit()"><input class="control" type="date" name="date_to" value="<%= safeFilters.date_to || '' %>" onchange="this.form.submit()"></div>
        <div class="filter"><div class="filter-title">Loại chứng từ</div><label class="check"><input type="radio" name="loai_phieu" value="thu" <%= safeFilters.loai_phieu === 'thu' ? 'checked' : '' %> onchange="this.form.submit()"> Phiếu thu</label><label class="check"><input type="radio" name="loai_phieu" value="chi" <%= safeFilters.loai_phieu === 'chi' ? 'checked' : '' %> onchange="this.form.submit()"> Phiếu chi</label></div>
        <div class="filter"><div class="filter-title">Loại thu chi</div><input class="control" name="loai_thu_chi" value="<%= safeFilters.loai_thu_chi || '' %>" placeholder="Chọn loại thu chi"></div>
        <div class="filter"><div class="filter-title">Trạng thái</div><select class="control" name="trang_thai" onchange="this.form.submit()"><option value="all">Tất cả</option><option value="paid" <%= safeFilters.trang_thai === 'paid' ? 'selected' : '' %>>Đã thanh toán</option><option value="cancelled" <%= safeFilters.trang_thai === 'cancelled' ? 'selected' : '' %>>Đã hủy</option></select></div>
        <div class="filter"><div class="filter-title">Hạch toán kết quả kinh doanh</div><div class="seg"><button type="button" class="<%= !safeFilters.hach_toan ? 'active' : '' %>" onclick="setCashFilter('hach_toan','')">Tất cả</button><button type="button" class="<%= safeFilters.hach_toan === 'yes' ? 'active' : '' %>" onclick="setCashFilter('hach_toan','yes')">Có</button><button type="button" class="<%= safeFilters.hach_toan === 'no' ? 'active' : '' %>" onclick="setCashFilter('hach_toan','no')">Không</button></div></div>
        <div class="filter"><div class="filter-title">Người tạo</div><input class="control" name="nguoi_tao" value="<%= safeFilters.nguoi_tao || '' %>" placeholder="Chọn người tạo"></div>
        <div class="filter"><div class="filter-title">Người nộp/nhận</div><select class="control" name="doi_tuong_loai" onchange="this.form.submit()"><option value="">Tất cả</option><option value="khach_hang" <%= safeFilters.doi_tuong_loai === 'khach_hang' ? 'selected' : '' %>>Khách hàng</option><option value="nha_cung_cap" <%= safeFilters.doi_tuong_loai === 'nha_cung_cap' ? 'selected' : '' %>>Nhà cung cấp</option><option value="khac" <%= safeFilters.doi_tuong_loai === 'khac' ? 'selected' : '' %>>Khác</option></select><input name="doi_tuong_search" value="<%= safeFilters.doi_tuong_search || '' %>" class="control" placeholder="Tên, mã người nộp/nhận"><input class="control" name="doi_tuong_phone" value="<%= safeFilters.doi_tuong_phone || '' %>" placeholder="Số điện thoại"></div>
        <div class="filter"><div class="filter-title">Công nợ đối tác</div><label class="check"><input type="checkbox" checked> Tính vào công nợ</label><label class="check"><input type="checkbox" checked> Không tính vào công nợ</label><label class="check"><input type="checkbox" checked> Không có công nợ</label></div>
      </div>
    </aside>
    <main class="main">
      <div class="toolbar">
        <div class="search"><i class="fa-solid fa-magnifying-glass"></i><input name="q" value="<%= safeFilters.q || '' %>" placeholder="Theo mã phiếu"><button><i class="fa-solid fa-sliders"></i></button></div>
        <div class="actions"><button type="button" class="btn primary" onclick="openReceiptModal('thu')"><i class="fa-solid fa-plus"></i> Phiếu thu</button><button type="button" class="btn primary" onclick="openReceiptModal('chi')"><i class="fa-solid fa-plus"></i> Phiếu chi</button><a class="btn" href="/so-quy/export.csv"><i class="fa-solid fa-file-export"></i> Xuất file</a><span class="icon"><i class="fa-solid fa-list"></i></span><span class="icon"><i class="fa-solid fa-gear"></i></span><span class="icon"><i class="fa-regular fa-circle-question"></i></span></div>
      </div>
      <div class="summary"><div><label>Quỹ đầu kỳ</label><strong><%= fmt(safeSummary.opening) %></strong></div><div><label>Tổng thu</label><strong class="blue"><%= fmt(safeSummary.totalThu) %></strong></div><div><label>Tổng chi</label><strong class="red"><%= fmt(safeSummary.totalChi) %></strong></div><div><label>Tồn quỹ <i class="fa-regular fa-circle-info"></i></label><strong class="green"><%= fmt(safeSummary.balance) %></strong></div></div>
      <div class="table-wrap"><table class="table"><thead><tr><th class="check-col"><input type="checkbox"></th><th class="star-col"><i class="fa-regular fa-star"></i></th><th>Mã phiếu</th><th>Thời gian</th><th>Loại thu chi</th><th>Người nộp/nhận</th><th class="num">Giá trị</th></tr></thead><tbody>
        <% if (safeList.length) { %>
          <% safeList.forEach(item => { %><tr><td class="check-col"><input type="checkbox"></td><td class="star-col"><i class="fa-regular fa-star"></i></td><td><a href="#" class="receipt" onclick="showReceipt('<%= item._id %>');return false"><%= item.ma_phieu %></a></td><td><%= item.ngay_lap ? new Date(item.ngay_lap).toLocaleString('vi-VN') : '' %></td><td><span class="type <%= item.loai_phieu %>"><%= item.loai_thu_chi || (item.loai_phieu === 'thu' ? 'Phiếu thu' : 'Phiếu chi') %></span></td><td><%= item.doi_tuong || item.khach_hang_id?.ten_khach_hang || item.nha_cung_cap_id?.ten_ncc || '' %></td><td class="num <%= item.loai_phieu === 'thu' ? 'blue' : 'red' %>"><%= item.loai_phieu === 'thu' ? '+' : '-' %><%= fmt(item.gia_tri) %></td></tr><% }) %>
        <% } else { %>
          <tr><td colspan="7" class="empty"><div class="empty-box"><div class="empty-icon"><i class="fa-regular fa-inbox"></i></div><strong>Không tìm thấy giao dịch nào phù hợp</strong></div></td></tr>
        <% } %>
      </tbody></table></div>
    </main>
  </form>

  <div id="receiptModal" class="modal-backdrop">
    <form class="modal" onsubmit="saveReceipt(event)">
      <div class="modal-head"><h2 id="receiptTitle">Tạo phiếu thu tiền mặt</h2><button type="button" class="modal-close" onclick="closeReceiptModal()">&times;</button></div>
      <div class="modal-body">
        <input type="hidden" name="loai_phieu" id="receiptType">
        <input type="hidden" name="so_quy_id" value="<%= selectedBookId %>">
        <div class="form-grid">
          <div class="field"><label>Mã phiếu</label><input name="ma_phieu" placeholder="Tự động"></div>
          <div class="field"><label>Thời gian</label><input type="datetime-local" name="ngay_lap" id="receiptDate"></div>
          <div class="field"><label id="categoryLabel">Loại thu</label><input name="loai_thu_chi" id="receiptCategory" placeholder="Nhập loại thu"></div>
          <div class="field"><label id="actorLabel">Người thu</label><select><option><%= user?.ho_ten || 'Admin' %></option></select></div>
          <div class="field"><label id="objectTypeLabel">Đối tượng nộp</label><select name="doi_tuong_loai" id="objectType" onchange="renderPartners()"><option value="khac">Khác</option><option value="khach_hang">Khách hàng</option><option value="nha_cung_cap">Nhà cung cấp</option></select></div>
          <div class="field"><label id="partnerLabel">Tên người nộp</label><select name="doi_tuong_id" id="partnerSelect"></select><input name="doi_tuong" id="partnerNameInput" placeholder="Nhập tên người nộp" style="display:none"></div>
          <div class="field full"><label>Số tiền</label><div class="money-wrap"><input name="gia_tri" id="amountInput" value="0" onfocus="this.value=this.value.replace(/\\./g,'')" onblur="formatAmount(this)"><span>0</span></div></div>
          <div class="field full"><label>Ghi chú</label><input name="ghi_chu" placeholder="Nhập ghi chú"></div>
        </div>
        <label class="accounting"><input type="checkbox" name="tinh_cong_no" checked> Hạch toán kết quả kinh doanh <i class="fa-regular fa-circle-info"></i></label>
      </div>
      <div class="modal-foot"><button type="button" class="modal-btn" onclick="closeReceiptModal()">Bỏ qua</button><button type="submit" class="modal-btn">Lưu & In</button><button type="submit" class="modal-btn save">Lưu</button></div>
    </form>
  </div>

  <div class="chat"><i class="fa-regular fa-comment-dots"></i> 1900 6522</div>
  <script>
    const receipts = <%- JSON.stringify(safeList.map(item => ({_id:String(item._id),ma_phieu:item.ma_phieu,loai_phieu:item.loai_phieu,loai_thu_chi:item.loai_thu_chi||'',gia_tri:item.gia_tri||0,doi_tuong:item.doi_tuong||'',ghi_chu:item.ghi_chu||'',ngay_lap:item.ngay_lap}))) %>;
    const customers = <%- JSON.stringify(safeCustomers.map(item => ({_id:String(item._id),name:item.ten_khach_hang,code:item.ma_khach_hang,phone:item.sdt||''}))) %>;
    const suppliers = <%- JSON.stringify(safeSuppliers.map(item => ({_id:String(item._id),name:item.ten_ncc,code:item.ma_ncc,phone:item.sdt||''}))) %>;
    const fmt = n => Number(n || 0).toLocaleString('vi-VN');
    function setCashFilter(key,value){const form=document.querySelector('form.page');let input=form.querySelector('[name="'+key+'"]');if(!input){input=document.createElement('input');input.type='hidden';input.name=key;form.appendChild(input)}input.value=value;form.submit()}
    function nowLocal(){const d=new Date();d.setMinutes(d.getMinutes()-d.getTimezoneOffset());return d.toISOString().slice(0,16)}
    function openReceiptModal(type){receiptType.value=type;receiptDate.value=nowLocal();receiptTitle.textContent=type==='thu'?'Tạo phiếu thu tiền mặt':'Tạo phiếu chi tiền mặt';categoryLabel.textContent=type==='thu'?'Loại thu':'Loại chi';objectTypeLabel.textContent=type==='thu'?'Đối tượng nộp':'Đối tượng nhận';partnerLabel.textContent=type==='thu'?'Tên người nộp':'Tên người nhận';actorLabel.textContent=type==='thu'?'Người thu':'Người chi';receiptCategory.value='';receiptCategory.placeholder=type==='thu'?'Nhập loại thu':'Nhập loại chi';partnerNameInput.value='';document.getElementById('receiptModal').classList.add('open');renderPartners()}
    function closeReceiptModal(){document.getElementById('receiptModal').classList.remove('open')}
    function renderPartners(){const type=objectType.value;const isOther=type==='khac';let rows=[];if(type==='khach_hang')rows=customers;if(type==='nha_cung_cap')rows=suppliers;partnerSelect.innerHTML='<option value="">Tìm người nộp/nhận</option>'+rows.map(x=>`<option value="${x._id}">${x.code} - ${x.name} ${x.phone?'- '+x.phone:''}</option>`).join('');partnerSelect.style.display=isOther?'none':'';partnerSelect.disabled=isOther;partnerNameInput.style.display=isOther?'':'none';partnerNameInput.disabled=!isOther;partnerNameInput.placeholder=receiptType.value==='thu'?'Nhập tên người nộp':'Nhập tên người nhận'}
    function formatAmount(input){input.value=fmt(String(input.value||'').replace(/\\./g,''))}
    function showReceipt(id){const item=receipts.find(x=>x._id===id);if(!item)return;alert(`${item.ma_phieu}\\n${item.loai_thu_chi || (item.loai_phieu==='thu'?'Phiếu thu':'Phiếu chi')}\\nĐối tượng: ${item.doi_tuong}\\nGiá trị: ${fmt(item.gia_tri)}\\nGhi chú: ${item.ghi_chu||''}`)}
    async function saveReceipt(e){e.preventDefault();const data=Object.fromEntries(new FormData(e.target).entries());data.gia_tri=String(data.gia_tri||'').replace(/\\./g,'').replace(/,/g,'');const selected=partnerSelect.options[partnerSelect.selectedIndex];if(!partnerSelect.disabled&&selected&&!data.doi_tuong)data.doi_tuong=selected.textContent;const res=await fetch('/so-quy/add',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});const result=await res.json();if(!result.success)return alert(result.message||'Không tạo được phiếu');location.reload()}
  </script>
</body>
</html>
