<%
  const safeList = Array.isArray(locals.list) ? locals.list : [];
  const safeCashBooks = Array.isArray(locals.cashBooks) ? locals.cashBooks : [];
  const safeCustomers = Array.isArray(locals.customers) ? locals.customers : [];
  const safeSuppliers = Array.isArray(locals.suppliers) ? locals.suppliers : [];
  const safeFilters = locals.filters || {};
  const safeSummary = locals.summary || {};
  const docs = locals.relatedDocuments || {};
  const fmt = value => Number(value || 0).toLocaleString('vi-VN');
  const selectedBookId = String(locals.selectedCashBook?._id || '');
  const codeOf = locals.relatedCode || function(item) {
    return item.don_hang_id?.ma_don_hang || item.hoa_don_id?.ma_hoa_don || item.phieu_nhap_id?.ma_phieu_nhap || item.phieu_tra_hang_nhap_id?.ma_phieu_tra_nhap || item.van_don_id?.ma_van_don || item.ma_chung_tu_goc || '';
  };
  const payLabel = value => ({ tien_mat: 'Tiền mặt', chuyen_khoan: 'Chuyển khoản', vi_dien_tu: 'Ví điện tử', khac: 'Khác' }[value] || 'Tiền mặt');
  const groupLabel = value => ({ khach_hang: 'Khách hàng', nha_cung_cap: 'Nhà cung cấp', doi_tac_giao_hang: 'Đối tác giao hàng', nhan_vien: 'Nhân viên', khac: 'Khác' }[value] || 'Khác');
%>
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <style>
    *{box-sizing:border-box}body{background:#f3f6f9}.page{height:calc(100vh - 98px);display:grid;grid-template-columns:280px minmax(0,1fr);gap:14px;padding:16px clamp(16px,5vw,60px);overflow:hidden}.sidebar{background:#fff;border-radius:7px;padding:14px;overflow:auto}.title{font-size:24px;font-weight:800;margin:0 0 18px}.filter{margin-bottom:22px}.filter-title{font-weight:800;margin-bottom:10px}.radio,.check{display:flex;align-items:center;gap:9px;margin:11px 0;font-size:15px}.radio input,.check input{width:17px;height:17px;accent-color:#0070f4}.control{width:100%;height:36px;border:1px solid #cfd8e3;border-radius:8px;background:#fff;padding:0 12px;font-size:14px;color:#475467;margin-bottom:9px}.seg{display:flex;gap:8px}.seg button{height:34px;border:1px solid #cfd8e3;background:#fff;border-radius:18px;padding:0 14px;cursor:pointer}.seg button.active{background:#0070f4;border-color:#0070f4;color:#fff;font-weight:800}.main{min-width:0;display:flex;flex-direction:column;gap:12px;overflow:hidden}.toolbar{display:flex;align-items:center;justify-content:space-between;gap:14px}.search{position:relative;width:500px;max-width:100%}.search i{position:absolute;left:14px;top:50%;transform:translateY(-50%);color:#667085}.search input{width:100%;height:37px;border:1px solid #cfd8e3;border-radius:8px;padding:0 42px 0 38px;font-size:15px}.search button{position:absolute;right:5px;top:5px;width:26px;height:26px;border:0;background:#fff}.actions{display:flex;gap:8px;flex-wrap:wrap}.btn{height:37px;border:1px solid #cfd8e3;background:#fff;border-radius:8px;padding:0 13px;color:#111827;font-weight:800;font-size:14px;display:flex;align-items:center;gap:8px;text-decoration:none;cursor:pointer}.btn.primary{color:#0070f4;border-color:#0070f4}.summary{height:88px;background:#fff;border-radius:7px;display:grid;grid-template-columns:repeat(4,1fr);align-items:center;text-align:center}.summary label{display:block;color:#667085;font-size:14px;margin-bottom:10px}.summary strong{font-size:20px}.blue{color:#0070f4}.red{color:#d92d20}.green{color:#00a651}.table-wrap{flex:1;min-height:0;background:#fff;border-radius:7px;overflow:auto}.table{width:100%;min-width:1180px;border-collapse:collapse}.table th{height:43px;background:#e8f3ff;border-bottom:1px solid #bcd9ff;text-align:left;padding:0 10px;font-size:13px}.table td{height:43px;border-bottom:1px solid #e5e9ee;padding:0 10px;font-size:14px}.check-col,.star-col{width:36px;text-align:center}.num{text-align:right}.receipt{color:#006dff;text-decoration:none;font-weight:800}.type{font-weight:800}.type.thu{color:#0070f4}.type.chi{color:#d92d20}.empty{height:420px;text-align:center}.empty-box{height:100%;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:12px}.empty-icon{width:96px;height:96px;border-radius:50%;background:#eef6ff;display:flex;align-items:center;justify-content:center;color:#0070f4;font-size:36px}.modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.55);display:none;align-items:flex-start;justify-content:center;padding-top:24px;z-index:1000}.modal-backdrop.open{display:flex}.modal{width:1080px;max-width:calc(100vw - 40px);background:#fff;border-radius:10px;box-shadow:0 18px 42px rgba(0,0,0,.35);overflow:hidden}.modal-head{height:70px;display:flex;align-items:center;justify-content:space-between;padding:0 28px}.modal-head h2{font-size:24px;margin:0}.modal-close{border:0;background:#fff;font-size:26px;color:#5b646f;cursor:pointer}.modal-body{padding:16px 28px 26px}.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px 28px}.field label{display:block;font-size:14px;margin-bottom:7px}.field input,.field select{width:100%;height:36px;border:1px solid #cfd8e3;border-radius:8px;padding:0 12px;font-size:15px}.field.full{grid-column:1 / -1}.money-wrap{position:relative}.money-wrap input{text-align:right;padding-right:28px}.money-wrap span{position:absolute;right:12px;top:50%;transform:translateY(-50%);font-size:18px;color:#8b95a1;font-weight:800}.modal-foot{height:72px;border-top:1px solid #e5e9ee;display:flex;align-items:center;justify-content:flex-end;gap:8px;padding:0 28px}.modal-btn{height:45px;border:1px solid #cfd8e3;background:#fff;border-radius:8px;padding:0 20px;font-weight:800;cursor:pointer}.modal-btn.save{border:0;background:#0070f4;color:#fff}.accounting{display:flex;align-items:center;gap:8px;margin-top:18px}.accounting input{width:18px;height:18px;accent-color:#0070f4}
  </style>
</head>
<body>
  <%- include('../partials/header') %>
  <form class="page" method="GET" action="/so-quy">
    <aside>
      <h1 class="title">Sổ quỹ</h1>
      <div class="sidebar">
        <div class="filter"><div class="filter-title">Sổ quỹ</div>
          <% safeCashBooks.forEach(book => { %>
            <label class="radio"><input type="radio" name="so_quy_id" value="<%= book._id %>" <%= String(safeFilters.so_quy_id || selectedBookId) === String(book._id) ? 'checked' : '' %> onchange="this.form.submit()"><span><%= book.ten_so_quy %></span></label>
          <% }) %>
        </div>
        <div class="filter"><div class="filter-title">Thời gian</div><label class="radio"><input type="radio" name="time_type" value="this_month" <%= safeFilters.time_type === 'this_month' ? 'checked' : '' %> onchange="this.form.submit()"> Tháng này</label><input class="control" type="date" name="date_from" value="<%= safeFilters.date_from || '' %>" onchange="this.form.submit()"><input class="control" type="date" name="date_to" value="<%= safeFilters.date_to || '' %>" onchange="this.form.submit()"></div>
        <div class="filter"><div class="filter-title">Loại chứng từ</div><label class="check"><input type="radio" name="loai_phieu" value="thu" <%= safeFilters.loai_phieu === 'thu' ? 'checked' : '' %> onchange="this.form.submit()"> Phiếu thu</label><label class="check"><input type="radio" name="loai_phieu" value="chi" <%= safeFilters.loai_phieu === 'chi' ? 'checked' : '' %> onchange="this.form.submit()"> Phiếu chi</label></div>
        <div class="filter"><div class="filter-title">Loại thu chi</div><input class="control" name="loai_thu_chi" value="<%= safeFilters.loai_thu_chi || '' %>" placeholder="Chọn loại thu chi"></div>
        <div class="filter"><div class="filter-title">Phương thức thanh toán</div><select class="control" name="phuong_thuc_thanh_toan" onchange="this.form.submit()"><option value="all">Tất cả</option><option value="tien_mat" <%= safeFilters.phuong_thuc_thanh_toan === 'tien_mat' ? 'selected' : '' %>>Tiền mặt</option><option value="chuyen_khoan" <%= safeFilters.phuong_thuc_thanh_toan === 'chuyen_khoan' ? 'selected' : '' %>>Chuyển khoản</option><option value="vi_dien_tu" <%= safeFilters.phuong_thuc_thanh_toan === 'vi_dien_tu' ? 'selected' : '' %>>Ví điện tử</option><option value="khac" <%= safeFilters.phuong_thuc_thanh_toan === 'khac' ? 'selected' : '' %>>Khác</option></select></div>
        <div class="filter"><div class="filter-title">Nhóm đối tượng</div><select class="control" name="nhom_doi_tuong" onchange="this.form.submit()"><option value="all">Tất cả</option><option value="khach_hang" <%= safeFilters.nhom_doi_tuong === 'khach_hang' ? 'selected' : '' %>>Khách hàng</option><option value="nha_cung_cap" <%= safeFilters.nhom_doi_tuong === 'nha_cung_cap' ? 'selected' : '' %>>Nhà cung cấp</option><option value="doi_tac_giao_hang" <%= safeFilters.nhom_doi_tuong === 'doi_tac_giao_hang' ? 'selected' : '' %>>Đối tác giao hàng</option><option value="nhan_vien" <%= safeFilters.nhom_doi_tuong === 'nhan_vien' ? 'selected' : '' %>>Nhân viên</option><option value="khac" <%= safeFilters.nhom_doi_tuong === 'khac' ? 'selected' : '' %>>Khác</option></select></div>
        <div class="filter"><div class="filter-title">Trạng thái</div><select class="control" name="trang_thai" onchange="this.form.submit()"><option value="all">Tất cả</option><option value="paid" <%= safeFilters.trang_thai === 'paid' ? 'selected' : '' %>>Đã thanh toán</option><option value="cancelled" <%= safeFilters.trang_thai === 'cancelled' ? 'selected' : '' %>>Đã hủy</option></select></div>
        <div class="filter"><div class="filter-title">Hạch toán công nợ</div><div class="seg"><button type="button" class="<%= !safeFilters.hach_toan ? 'active' : '' %>" onclick="setCashFilter('hach_toan','')">Tất cả</button><button type="button" class="<%= safeFilters.hach_toan === 'yes' ? 'active' : '' %>" onclick="setCashFilter('hach_toan','yes')">Có</button><button type="button" class="<%= safeFilters.hach_toan === 'no' ? 'active' : '' %>" onclick="setCashFilter('hach_toan','no')">Không</button></div></div>
        <div class="filter"><div class="filter-title">Người tạo</div><input class="control" name="nguoi_tao" value="<%= safeFilters.nguoi_tao || '' %>" placeholder="Chọn người tạo"></div>
        <div class="filter"><div class="filter-title">Người nộp/nhận</div><select class="control" name="doi_tuong_loai" onchange="this.form.submit()"><option value="">Tất cả</option><option value="khach_hang" <%= safeFilters.doi_tuong_loai === 'khach_hang' ? 'selected' : '' %>>Khách hàng</option><option value="nha_cung_cap" <%= safeFilters.doi_tuong_loai === 'nha_cung_cap' ? 'selected' : '' %>>Nhà cung cấp</option><option value="khac" <%= safeFilters.doi_tuong_loai === 'khac' ? 'selected' : '' %>>Khác</option></select><input name="doi_tuong_search" value="<%= safeFilters.doi_tuong_search || '' %>" class="control" placeholder="Tên, mã người nộp/nhận"><input class="control" name="doi_tuong_phone" value="<%= safeFilters.doi_tuong_phone || '' %>" placeholder="Số điện thoại"></div>
      </div>
    </aside>
    <main class="main">
      <div class="toolbar">
        <div class="search"><i class="fa-solid fa-magnifying-glass"></i><input name="q" value="<%= safeFilters.q || '' %>" placeholder="Theo mã phiếu"><button><i class="fa-solid fa-sliders"></i></button></div>
        <div class="actions"><button type="button" class="btn primary" onclick="openReceiptModal('thu')"><i class="fa-solid fa-plus"></i> Phiếu thu</button><button type="button" class="btn primary" onclick="openReceiptModal('chi')"><i class="fa-solid fa-plus"></i> Phiếu chi</button><a class="btn" href="/so-quy/export.csv"><i class="fa-solid fa-file-export"></i> Xuất file</a></div>
      </div>
      <div class="summary"><div><label>Đầu kỳ</label><strong><%= fmt(safeSummary.opening) %></strong></div><div><label>Tổng thu</label><strong class="blue"><%= fmt(safeSummary.totalThu) %></strong></div><div><label>Tổng chi</label><strong class="red"><%= fmt(safeSummary.totalChi) %></strong></div><div><label>Tồn quỹ</label><strong class="green"><%= fmt(safeSummary.balance) %></strong></div></div>
      <div class="table-wrap"><table class="table"><thead><tr><th class="check-col"><input type="checkbox"></th><th class="star-col"><i class="fa-regular fa-star"></i></th><th>Mã phiếu</th><th>Thời gian</th><th>Sổ quỹ</th><th>Loại thu chi</th><th>Người nộp/nhận</th><th>Nhóm</th><th>Chứng từ liên quan</th><th>Phương thức</th><th class="num">Giá trị</th></tr></thead><tbody>
        <% if (safeList.length) { %>
          <% safeList.forEach(item => { %><tr><td class="check-col"><input type="checkbox"></td><td class="star-col"><i class="fa-regular fa-star"></i></td><td><a href="/so-quy/phieu-thu-chi/<%= item._id %>" class="receipt ref-link" onclick="showReceipt('<%= item._id %>');return false"><%= item.ma_phieu %></a></td><td><%= item.ngay_lap ? new Date(item.ngay_lap).toLocaleString('vi-VN') : '' %></td><td><%- item.so_quy_id ? refLink('cashbook', item.so_quy_id, item.so_quy_id.ten_so_quy || item.so_quy_id.loai || '') : '' %></td><td><span class="type <%= item.loai_phieu %>"><%= item.loai_thu_chi || (item.loai_phieu === 'thu' ? 'Phiếu thu' : 'Phiếu chi') %></span></td><td><%= item.doi_tuong || item.khach_hang_id?.ten_khach_hang || item.nha_cung_cap_id?.ten_ncc || '' %></td><td><%= groupLabel(item.nhom_doi_tuong) %></td><td><%- item.phieu_nhap_id ? refLink('purchase', item.phieu_nhap_id, codeOf(item)) : item.don_hang_id ? refLink('order', item.don_hang_id, codeOf(item)) : item.hoa_don_id ? refLink('invoice', item.hoa_don_id, codeOf(item)) : item.van_don_id ? refLink('shipment', item.van_don_id, codeOf(item)) : codeOf(item) %></td><td><%= payLabel(item.phuong_thuc_thanh_toan) %></td><td class="num <%= item.loai_phieu === 'thu' ? 'blue' : 'red' %>"><%= item.loai_phieu === 'thu' ? '+' : '-' %><%= fmt(item.gia_tri) %></td></tr><% }) %>
        <% } else { %>
          <tr><td colspan="11" class="empty"><div class="empty-box"><div class="empty-icon"><i class="fa-regular fa-inbox"></i></div><strong>Không tìm thấy giao dịch nào phù hợp</strong></div></td></tr>
        <% } %>
      </tbody></table></div>
    </main>
  </form>

  <div id="receiptModal" class="modal-backdrop">
    <form class="modal" onsubmit="saveReceipt(event)">
      <div class="modal-head"><h2 id="receiptTitle">Tạo phiếu thu</h2><button type="button" class="modal-close" onclick="closeReceiptModal()">&times;</button></div>
      <div class="modal-body">
        <input type="hidden" name="loai_phieu" id="receiptType">
        <div class="form-grid">
          <div class="field"><label>Mã phiếu</label><input name="ma_phieu" placeholder="Tự động"></div>
          <div class="field"><label>Thời gian</label><input type="datetime-local" name="ngay_lap" id="receiptDate"></div>
          <div class="field"><label>Sổ quỹ</label><select name="so_quy_id" id="cashBookSelect"><% safeCashBooks.forEach(book => { %><option value="<%= book._id %>" <%= String(book._id) === selectedBookId ? 'selected' : '' %>><%= book.ten_so_quy %></option><% }) %></select></div>
          <div class="field"><label>Phương thức thanh toán</label><select name="phuong_thuc_thanh_toan"><option value="tien_mat">Tiền mặt</option><option value="chuyen_khoan">Chuyển khoản</option><option value="vi_dien_tu">Ví điện tử</option><option value="khac">Khác</option></select></div>
          <div class="field"><label id="categoryLabel">Loại thu</label><input name="loai_thu_chi" id="receiptCategory" placeholder="Nhập loại thu"></div>
          <div class="field"><label>Nhóm đối tượng</label><select name="nhom_doi_tuong" id="subjectGroup" onchange="syncObjectType()"><option value="khach_hang">Khách hàng</option><option value="nha_cung_cap">Nhà cung cấp</option><option value="doi_tac_giao_hang">Đối tác giao hàng</option><option value="nhan_vien">Nhân viên</option><option value="khac">Khác</option></select></div>
          <div class="field"><label id="objectTypeLabel">Đối tượng nộp</label><select name="doi_tuong_loai" id="objectType" onchange="renderPartners()"><option value="khac">Khác</option><option value="khach_hang">Khách hàng</option><option value="nha_cung_cap">Nhà cung cấp</option></select></div>
          <div class="field"><label id="partnerLabel">Tên người nộp</label><select name="doi_tuong_id" id="partnerSelect"></select><input name="doi_tuong" id="partnerNameInput" placeholder="Nhập tên người nộp" style="display:none"></div>
          <div class="field"><label>Loại chứng từ liên quan</label><select id="documentType" name="document_type" onchange="renderRelatedDocuments()"><option value="">Không chọn</option><option value="don_hang">Đơn hàng</option><option value="hoa_don">Hóa đơn bán hàng</option><option value="phieu_nhap">Phiếu nhập</option><option value="phieu_tra_hang_nhap">Phiếu trả hàng nhập</option><option value="van_don">Vận đơn/COD</option></select></div>
          <div class="field"><label>Chứng từ liên quan</label><select id="documentSelect" onchange="applyRelatedDocument()"><option value="">Chọn chứng từ</option></select><input type="hidden" name="don_hang_id" id="donHangId"><input type="hidden" name="hoa_don_id" id="hoaDonId"><input type="hidden" name="phieu_nhap_id" id="phieuNhapId"><input type="hidden" name="phieu_tra_hang_nhap_id" id="phieuTraHangNhapId"><input type="hidden" name="van_don_id" id="vanDonId"><input type="hidden" name="khach_hang_id" id="khachHangId"><input type="hidden" name="nha_cung_cap_id" id="nhaCungCapId"><input type="hidden" name="ma_chung_tu_goc" id="maChungTuGoc"></div>
          <div class="field full"><label>Số tiền</label><div class="money-wrap"><input name="gia_tri" id="amountInput" value="0" onfocus="this.value=this.value.replace(/\./g,'')" onblur="formatAmount(this)"><span>đ</span></div></div>
          <div class="field full"><label>Ghi chú</label><input name="ghi_chu" placeholder="Nhập ghi chú"></div>
        </div>
        <label class="accounting"><input type="checkbox" name="hach_toan" id="accountingCheck" checked> Hạch toán công nợ</label>
      </div>
      <div class="page-actions modal-foot"><button type="button" class="modal-btn" onclick="closeReceiptModal()">Bỏ qua</button><button type="submit" class="modal-btn save">Lưu</button></div>
    </form>
  </div>

  <script>
    const receipts = <%- JSON.stringify(safeList.map(item => ({_id:String(item._id),ma_phieu:item.ma_phieu,loai_phieu:item.loai_phieu,loai_thu_chi:item.loai_thu_chi||'',gia_tri:item.gia_tri||0,doi_tuong:item.doi_tuong||'',ghi_chu:item.ghi_chu||'',ngay_lap:item.ngay_lap,so_quy:item.so_quy_id?.ten_so_quy||'',chung_tu:codeOf(item)}))) %>;
    const customers = <%- JSON.stringify(safeCustomers.map(item => ({_id:String(item._id),name:item.ten_khach_hang,code:item.ma_khach_hang,phone:item.sdt||''}))) %>;
    const suppliers = <%- JSON.stringify(safeSuppliers.map(item => ({_id:String(item._id),name:item.ten_ncc,code:item.ma_ncc,phone:item.sdt||''}))) %>;
    const relatedDocs = {
      don_hang: <%- JSON.stringify((docs.orders || []).map(x => ({ _id:String(x._id), code:x.ma_don_hang, amount:x.tong_thanh_toan || x.tong_tien || 0, khach_hang_id:x.khach_hang_id?._id ? String(x.khach_hang_id._id) : String(x.khach_hang_id || ''), partner:x.khach_hang_id?.ten_khach_hang || '' }))) %>,
      hoa_don: <%- JSON.stringify((docs.invoices || []).map(x => ({ _id:String(x._id), code:x.ma_hoa_don, amount:x.thanh_toan || x.tong_tien || 0, don_hang_id:x.don_hang_id ? String(x.don_hang_id) : '', khach_hang_id:x.khach_hang_id?._id ? String(x.khach_hang_id._id) : String(x.khach_hang_id || ''), partner:x.khach_hang_id?.ten_khach_hang || '' }))) %>,
      phieu_nhap: <%- JSON.stringify((docs.purchases || []).map(x => ({ _id:String(x._id), code:x.ma_phieu_nhap, amount:x.con_no_ncc || x.da_tra_ncc || x.can_tra_ncc || x.tong_tien || 0, nha_cung_cap_id:x.nha_cung_cap_id?._id ? String(x.nha_cung_cap_id._id) : String(x.nha_cung_cap_id || ''), partner:x.nha_cung_cap_id?.ten_ncc || '' }))) %>,
      phieu_tra_hang_nhap: <%- JSON.stringify((docs.purchaseReturns || []).map(x => ({ _id:String(x._id), code:x.ma_phieu_tra_nhap, amount:x.ncc_da_tra || x.ncc_can_tra || 0, nha_cung_cap_id:x.nha_cung_cap_id?._id ? String(x.nha_cung_cap_id._id) : String(x.nha_cung_cap_id || ''), phieu_nhap_id:x.phieu_nhap_id ? String(x.phieu_nhap_id) : '', partner:x.nha_cung_cap_id?.ten_ncc || '' }))) %>,
      van_don: <%- JSON.stringify((docs.shipments || []).map(x => ({ _id:String(x._id), code:x.ma_van_don, amount:x.cod_amount || x.phi_giao_hang || 0, don_hang_id:x.don_hang_id ? String(x.don_hang_id) : '', hoa_don_id:x.hoa_don_id ? String(x.hoa_don_id) : '', khach_hang_id:x.khach_hang_id?._id ? String(x.khach_hang_id._id) : String(x.khach_hang_id || ''), partner:x.khach_hang_id?.ten_khach_hang || x.doi_tac_giao_hang_id?.ten_doi_tac || '' }))) %>
    };
    const fmt = n => Number(n || 0).toLocaleString('vi-VN');
    function setCashFilter(key,value){const form=document.querySelector('form.page');let input=form.querySelector('[name="'+key+'"]');if(!input){input=document.createElement('input');input.type='hidden';input.name=key;form.appendChild(input)}input.value=value;form.submit()}
    function nowLocal(){const d=new Date();d.setMinutes(d.getMinutes()-d.getTimezoneOffset());return d.toISOString().slice(0,16)}
    function openReceiptModal(type){receiptType.value=type;receiptDate.value=nowLocal();receiptTitle.textContent=type==='thu'?'Tạo phiếu thu':'Tạo phiếu chi';categoryLabel.textContent=type==='thu'?'Loại thu':'Loại chi';objectTypeLabel.textContent=type==='thu'?'Đối tượng nộp':'Đối tượng nhận';partnerLabel.textContent=type==='thu'?'Tên người nộp':'Tên người nhận';receiptCategory.value='';receiptCategory.placeholder=type==='thu'?'Nhập loại thu':'Nhập loại chi';subjectGroup.value=type==='thu'?'khach_hang':'nha_cung_cap';syncObjectType();clearRelatedDocument();document.getElementById('receiptModal').classList.add('open')}
    function closeReceiptModal(){document.getElementById('receiptModal').classList.remove('open')}
    function syncObjectType(){const group=subjectGroup.value;objectType.value=['khach_hang','nha_cung_cap'].includes(group)?group:'khac';renderPartners()}
    function renderPartners(){const type=objectType.value;const isOther=type==='khac';let rows=[];if(type==='khach_hang')rows=customers;if(type==='nha_cung_cap')rows=suppliers;partnerSelect.innerHTML='<option value="">Tìm người nộp/nhận</option>'+rows.map(x=>`<option value="${x._id}">${x.code || ''} - ${x.name || ''} ${x.phone?'- '+x.phone:''}</option>`).join('');partnerSelect.style.display=isOther?'none':'';partnerSelect.disabled=isOther;partnerNameInput.style.display=isOther?'':'none';partnerNameInput.disabled=!isOther;partnerNameInput.placeholder=receiptType.value==='thu'?'Nhập tên người nộp':'Nhập tên người nhận'}
    function clearRelatedDocument(){['donHangId','hoaDonId','phieuNhapId','phieuTraHangNhapId','vanDonId','khachHangId','nhaCungCapId','maChungTuGoc'].forEach(id=>document.getElementById(id).value='');documentType.value='';documentSelect.innerHTML='<option value="">Chọn chứng từ</option>'}
    function renderRelatedDocuments(){const type=documentType.value;const rows=relatedDocs[type]||[];documentSelect.innerHTML='<option value="">Chọn chứng từ</option>'+rows.map(x=>`<option value="${x._id}">${x.code || ''} - ${x.partner || ''} - ${fmt(x.amount)}</option>`).join('')}
    function applyRelatedDocument(){['donHangId','hoaDonId','phieuNhapId','phieuTraHangNhapId','vanDonId','khachHangId','nhaCungCapId','maChungTuGoc'].forEach(id=>document.getElementById(id).value='');const type=documentType.value;const row=(relatedDocs[type]||[]).find(x=>x._id===documentSelect.value);if(!row)return;maChungTuGoc.value=row.code||'';amountInput.value=fmt(row.amount||0);if(type==='don_hang')donHangId.value=row._id;if(type==='hoa_don'){hoaDonId.value=row._id;if(row.don_hang_id)donHangId.value=row.don_hang_id}if(type==='phieu_nhap')phieuNhapId.value=row._id;if(type==='phieu_tra_hang_nhap'){phieuTraHangNhapId.value=row._id;if(row.phieu_nhap_id)phieuNhapId.value=row.phieu_nhap_id}if(type==='van_don'){vanDonId.value=row._id;if(row.don_hang_id)donHangId.value=row.don_hang_id;if(row.hoa_don_id)hoaDonId.value=row.hoa_don_id}if(row.khach_hang_id){khachHangId.value=row.khach_hang_id;subjectGroup.value='khach_hang';objectType.value='khach_hang';renderPartners();partnerSelect.value=row.khach_hang_id}if(row.nha_cung_cap_id){nhaCungCapId.value=row.nha_cung_cap_id;subjectGroup.value='nha_cung_cap';objectType.value='nha_cung_cap';renderPartners();partnerSelect.value=row.nha_cung_cap_id}}
    function formatAmount(input){input.value=fmt(String(input.value||'').replace(/\./g,''))}
    async function showReceipt(id){const item=receipts.find(x=>x._id===id);if(!item)return;try{const res=await fetch('/so-quy/'+id+'/detail');const json=await res.json();if(!json.success)throw new Error(json.message||'Không tải được phiếu');const receipt=json.data.receipt||{};const rows=(json.data.items||[]).map(row=>`- ${(row.hang_hoa_id&&row.hang_hoa_id.ma_hang)||''} ${(row.hang_hoa_id&&row.hang_hoa_id.ten_hang)||''}: ${fmt(row.so_luong||0)} x ${fmt(row.don_gia_nhap||0)}`).join('\n');alert(`${item.ma_phieu}\n${item.loai_thu_chi || (item.loai_phieu==='thu'?'Phiếu thu':'Phiếu chi')}\nSổ quỹ: ${item.so_quy}\nNhà cung cấp: ${(receipt.nha_cung_cap_id&&receipt.nha_cung_cap_id.ten_ncc)||item.doi_tuong||''}\nPhiếu nhập: ${(receipt.phieu_nhap_id&&receipt.phieu_nhap_id.ma_phieu_nhap)||item.chung_tu||''}\nGiá trị: ${fmt(item.gia_tri)}\nGhi chú: ${item.ghi_chu||''}${rows?'\n\nHàng trong phiếu nhập:\n'+rows:''}`)}catch(error){alert(error.message||'Không tải được phiếu')}}
    async function saveReceipt(e){e.preventDefault();const data=Object.fromEntries(new FormData(e.target).entries());data.gia_tri=String(data.gia_tri||'').replace(/\./g,'').replace(/,/g,'');const selected=partnerSelect.options[partnerSelect.selectedIndex];if(!partnerSelect.disabled&&selected&&!data.doi_tuong)data.doi_tuong=selected.textContent;const res=await fetch('/so-quy/add',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});const result=await res.json();if(!result.success)return alert(result.message||'Không tạo được phiếu');location.reload()}
    document.addEventListener('DOMContentLoaded',()=>{const id=new URLSearchParams(location.search).get('receipt');if(id)showReceipt(id)})
  </script>
</body>
</html>
