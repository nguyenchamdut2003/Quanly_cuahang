<%
  const safeReturns = Array.isArray(locals.returns) ? locals.returns : [];
  const fmt = value => Number(value || 0).toLocaleString('vi-VN');
%>
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <style>
    .page{height:calc(100vh - 98px);background:#f3f6f9;padding:14px 12%;display:flex;flex-direction:column;gap:10px}
    .bar{display:flex;align-items:center;justify-content:space-between}h1{font-size:20px;margin:0}.btn{height:32px;border:1px solid #cfd8e3;background:#fff;border-radius:6px;padding:0 12px;font-weight:700;cursor:pointer;text-decoration:none;color:#111827;display:inline-flex;align-items:center;gap:7px}.btn.primary{border-color:#0070f4;color:#0070f4}
    .table-wrap{flex:1;background:#fff;border-radius:6px;overflow:auto}.table{width:100%;border-collapse:collapse}.table th{height:38px;background:#e8f3ff;border-bottom:1px solid #bcd9ff;text-align:left;padding:0 10px;font-size:13px}.table td{height:43px;border-bottom:1px solid #e5e9ee;padding:0 10px;font-size:13px}.num{text-align:right}.empty{text-align:center;color:#667085;height:240px}
    .modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:3000;align-items:center;justify-content:center}.modal.open{display:flex}.box{width:860px;max-width:94vw;background:#fff;border-radius:8px;box-shadow:0 18px 42px rgba(0,0,0,.25);overflow:hidden}.head,.foot{height:56px;display:flex;align-items:center;justify-content:space-between;padding:0 18px;border-bottom:1px solid #edf0f3}.foot{border-top:1px solid #edf0f3;border-bottom:0;justify-content:flex-end;gap:8px}.body{padding:16px 18px}.grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}.field label{display:block;font-size:12px;margin-bottom:6px}.input{width:100%;height:32px;border:1px solid #cfd8e3;border-radius:6px;padding:0 10px}.close{border:0;background:#fff;font-size:18px;cursor:pointer}.save{background:#0070f4;color:#fff;border-color:#0070f4}.mini-table{width:100%;border-collapse:collapse;margin-top:14px}.mini-table th{background:#f0f2f5;height:34px;text-align:left;padding:0 8px}.mini-table td{height:38px;border-bottom:1px solid #edf0f3;padding:0 8px}.small{width:86px;height:28px;border:1px solid #cfd8e3;border-radius:5px;text-align:right;padding:0 6px}
  </style>
</head>
<body>
  <%- include('../partials/header') %>
  <main class="page">
    <div class="bar"><h1>Trả hàng nhập</h1><button class="btn primary" onclick="openModal()"><i class="fa-solid fa-plus"></i> Trả hàng nhập</button></div>
    <div class="table-wrap"><table class="table"><thead><tr><th>Mã phiếu trả</th><th>Thời gian</th><th>Nhà cung cấp</th><th>Phiếu nhập</th><th class="num">Tổng tiền trả</th><th>Trạng thái</th></tr></thead><tbody>
      <% if (safeReturns.length) { %>
        <% safeReturns.forEach(r => { %><tr><td><%= r.ma_phieu_tra_nhap %></td><td><%= new Date(r.ngay_tra).toLocaleString('vi-VN') %></td><td><%= r.nha_cung_cap_id ? r.nha_cung_cap_id.ten_ncc : '' %></td><td><%- r.phieu_nhap_id ? refLink('purchase', r.phieu_nhap_id, r.phieu_nhap_id.ma_phieu_nhap || '') : '' %></td><td class="num"><%= fmt(r.tong_tien_tra) %></td><td>Hoàn thành</td></tr><% }) %>
      <% } else { %><tr><td colspan="6" class="empty">Chưa có phiếu trả hàng nhập</td></tr><% } %>
    </tbody></table></div>
  </main>
  <div class="modal" id="returnModal"><div class="box"><div class="head"><h2 style="font-size:18px;margin:0">Tạo phiếu trả hàng nhập</h2><button class="close" onclick="closeModal()"><i class="fa-solid fa-xmark"></i></button></div><div class="body">
    <div class="grid">
      <div class="field"><label>Nhà cung cấp</label><select id="nccId" class="input"><option value="">Chọn nhà cung cấp</option><% suppliers.forEach(s => { %><option value="<%= s._id %>"><%= s.ten_ncc %></option><% }) %></select></div>
      <div class="field"><label>Phiếu nhập</label><select id="pnId" class="input"><option value="">Không chọn</option><% receipts.forEach(r => { %><option value="<%= r._id %>"><%= r.ma_phieu_nhap %></option><% }) %></select></div>
      <div class="field"><label>Lý do</label><input id="lyDo" class="input" placeholder="Nhập lý do trả"></div>
      <div class="field"><label>Ghi chú</label><input id="ghiChu" class="input"></div>
    </div>
    <div style="margin-top:14px;display:flex;gap:8px"><select id="productId" class="input"><option value="">Chọn hàng trả</option><% products.forEach(p => { %><option value="<%= p._id %>" data-code="<%= p.ma_hang %>" data-name="<%= p.ten_hang %>" data-price="<%= p.gia_von || 0 %>"><%= p.ma_hang %> - <%= p.ten_hang %></option><% }) %></select><button class="btn" onclick="addItem()" type="button">Thêm</button></div>
    <table class="mini-table"><thead><tr><th>Mã hàng</th><th>Tên hàng</th><th class="num">Số lượng</th><th class="num">Đơn giá</th><th class="num">Thành tiền</th><th></th></tr></thead><tbody id="itemsBody"></tbody></table>
    <div style="text-align:right;margin-top:12px;font-weight:700">Tổng trả: <span id="totalReturn">0</span></div>
  </div><div class="foot"><button class="btn" onclick="closeModal()">Bỏ qua</button><button class="btn save" onclick="saveReturn()">Lưu</button></div></div></div>
  <script>
    let items = [];
    const fmt = n => Number(n || 0).toLocaleString('vi-VN');
    function openModal(){document.getElementById('returnModal').classList.add('open')}
    function closeModal(){document.getElementById('returnModal').classList.remove('open')}
    function addItem(){const sel=productId.options[productId.selectedIndex]; if(!productId.value)return; const ex=items.find(i=>i.hang_hoa_id===productId.value); if(ex)ex.so_luong++; else items.push({hang_hoa_id:productId.value,ma_hang:sel.dataset.code,ten_hang:sel.dataset.name,so_luong:1,don_gia:Number(sel.dataset.price)||0}); render();}
    function render(){let total=0; itemsBody.innerHTML=items.map(i=>{const line=i.so_luong*i.don_gia; total+=line; return `<tr><td>${i.ma_hang}</td><td>${i.ten_hang}</td><td class="num"><input class="small" value="${i.so_luong}" onchange="updQty('${i.hang_hoa_id}',this.value)"></td><td class="num"><input class="small" value="${i.don_gia}" onchange="updPrice('${i.hang_hoa_id}',this.value)"></td><td class="num">${fmt(line)}</td><td><i class="fa-solid fa-trash" style="color:#d92d20;cursor:pointer" onclick="removeItem('${i.hang_hoa_id}')"></i></td></tr>`}).join(''); totalReturn.textContent=fmt(total);}
    function updQty(id,v){const i=items.find(x=>x.hang_hoa_id===id); if(i)i.so_luong=Number(v)||0; render()} function updPrice(id,v){const i=items.find(x=>x.hang_hoa_id===id); if(i)i.don_gia=Number(v)||0; render()} function removeItem(id){items=items.filter(i=>i.hang_hoa_id!==id); render()}
    async function saveReturn(){const res=await fetch('/phieu-nhap/tra-hang-nhap/add',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({nha_cung_cap_id:nccId.value,phieu_nhap_id:pnId.value,ly_do:lyDo.value,ghi_chu:ghiChu.value,items})}); const data=await res.json(); if(!data.success)return alert(data.message||'Không lưu được'); location.reload();}
  </script>
</body>
</html>
