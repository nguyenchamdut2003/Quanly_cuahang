<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <style>
    .purchase-page{height:calc(100vh - 98px);background:#f3f6f9;display:grid;grid-template-columns:minmax(0,1fr) 398px;gap:10px;padding:10px 11% 0}
    .purchase-left{min-width:0;display:flex;flex-direction:column;background:#fff;border:1px solid #d7dde5}
    .purchase-top{height:43px;display:flex;align-items:center;gap:12px;padding:0 0 0 4px;background:#f3f6f9;border-bottom:1px solid #d7dde5}
    .back-link{width:26px;height:32px;display:flex;align-items:center;justify-content:center;color:#111827;text-decoration:none;font-size:18px}
    .purchase-title{font-size:20px;font-weight:700;color:#111827;margin-right:4px}
    .product-search{position:relative;flex:1;max-width:470px}
    .product-search i{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#667085}
    .product-search input{width:100%;height:32px;border:1px solid #0070f4;border-radius:7px;padding:0 76px 0 36px;font-size:13px;outline:none}
    .search-actions{position:absolute;right:6px;top:5px;display:flex;gap:12px;color:#111827}
    .search-results{display:none;position:absolute;top:36px;left:0;right:0;background:#fff;border:1px solid #cfd8e3;border-radius:6px;box-shadow:0 8px 22px rgba(0,0,0,.14);z-index:10;max-height:300px;overflow:auto}
    .search-item{height:42px;padding:0 12px;display:flex;align-items:center;justify-content:space-between;font-size:13px;cursor:pointer}
    .search-item:hover{background:#f0f7ff}
    .table-wrap{flex:1;min-height:0;overflow:auto;background:#fff}
    .items-table{width:100%;min-width:920px;border-collapse:collapse}
    .items-table th{height:36px;background:#e8f3ff;border-bottom:1px solid #bcd9ff;color:#111827;font-size:13px;font-weight:700;padding:0 10px;text-align:left}
    .items-table td{height:42px;border-bottom:1px solid #e5e9ee;padding:0 10px;font-size:13px;color:#111827}
    .items-table .num{text-align:right}
    .input-small{width:92px;height:28px;border:1px solid #cfd8e3;border-radius:5px;text-align:right;padding:0 7px}
    .empty-import{height:calc(100vh - 260px);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;color:#111827}
    .empty-import h3{font-size:18px;margin:0 0 22px}
    .empty-import p{font-size:13px;margin:0 0 32px}
    .empty-import a{color:#0070f4;text-decoration:none}
    .file-btn{height:52px;border:0;background:#0070f4;color:#fff;border-radius:3px;padding:0 24px;font-size:18px;font-weight:700;display:inline-flex;align-items:center;gap:10px;cursor:pointer}
    .purchase-right{background:#fff;border-radius:6px;display:flex;flex-direction:column;padding:18px 12px 10px}
    .right-tools{height:28px;display:flex;justify-content:space-between;align-items:center;margin-bottom:14px}
    .icon-group{display:flex;gap:6px}
    .icon-btn{width:30px;height:28px;border:1px solid #cfd8e3;background:#fff;border-radius:5px;display:flex;align-items:center;justify-content:center;color:#111827}
    .right-row{display:flex;gap:12px;margin-bottom:14px}
    .select-like,.date-input,.side-input{height:30px;border:1px solid #cfd8e3;border-radius:7px;background:#fff;padding:0 10px;font-size:13px;outline:none}
    .select-like{flex:1}
    .date-input{width:138px}
    .supplier-search{position:relative;margin-bottom:14px}
    .supplier-search input{width:100%;height:31px;border:1px solid #cfd8e3;border-radius:7px;padding:0 36px 0 10px;font-size:13px;outline:none}
    .supplier-search i{position:absolute;right:10px;top:50%;transform:translateY(-50%);font-size:18px}
    .supplier-results{display:none;position:absolute;top:35px;left:0;right:0;background:#fff;border:1px solid #cfd8e3;border-radius:6px;box-shadow:0 8px 22px rgba(0,0,0,.14);z-index:10;max-height:260px;overflow:auto}
    .summary-line{display:grid;grid-template-columns:1fr 172px;align-items:center;min-height:40px;font-size:13px;color:#111827}
    .summary-line strong{font-weight:700}
    .summary-line .num{text-align:right}
    .discount-input{height:30px;border:1px solid #cfd8e3;border-radius:7px;text-align:right;padding:0 10px;font-size:13px}
    .payable{color:#006dff!important;font-weight:700}
    .note{height:60px;border:1px solid #cfd8e3;border-radius:7px;padding:10px;resize:none;font-size:13px;margin-top:20px}
    .right-spacer{flex:1}
    .bottom-actions{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .btn-draft,.btn-complete{height:45px;border-radius:9px;font-size:15px;font-weight:700;cursor:pointer}
    .btn-draft{border:1px solid #0070f4;background:#fff;color:#0070f4}
    .btn-complete{border:0;background:#0070f4;color:#fff}
    @media(max-width:1150px){.purchase-page{padding:10px;grid-template-columns:minmax(0,1fr) 360px}}
  </style>
</head>
<body>
  <%- include('../partials/header') %>
  <main class="purchase-page">
    <section class="purchase-left">
      <div class="purchase-top">
        <a href="/phieu-nhap" class="back-link"><i class="fa-solid fa-arrow-left"></i></a>
        <div class="purchase-title">Nhập hàng</div>
        <div class="product-search">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input id="productSearch" placeholder="Tìm hàng hóa theo mã hoặc tên (F3)">
          <div class="search-actions"><i class="fa-solid fa-table-cells"></i><i class="fa-solid fa-plus"></i></div>
          <div id="searchResults" class="search-results"></div>
        </div>
      </div>
      <div class="table-wrap">
        <table class="items-table">
          <thead>
            <tr>
              <th style="width:60px;text-align:center">STT</th>
              <th style="width:110px">Mã hàng</th>
              <th>Tên hàng</th>
              <th style="width:80px">ĐVT</th>
              <th class="num" style="width:120px">Số lượng</th>
              <th class="num" style="width:130px">Đơn giá</th>
              <th class="num" style="width:120px">Giảm giá</th>
              <th class="num" style="width:140px">Thành tiền</th>
              <th style="width:42px"></th>
            </tr>
          </thead>
          <tbody id="itemsBody"></tbody>
        </table>
        <div id="emptyImport" class="empty-import">
          <h3>Thêm sản phẩm từ file excel</h3>
          <p>(Tải về file mẫu:<a href="#">Excel file</a>)</p>
          <button class="file-btn" type="button"><i class="fa-regular fa-copy"></i> Chọn file dữ liệu</button>
        </div>
      </div>
    </section>

    <aside class="purchase-right">
      <div class="right-tools">
        <div class="icon-group">
          <button class="icon-btn" type="button"><i class="fa-solid fa-scroll"></i></button>
          <button class="icon-btn" type="button"><i class="fa-solid fa-print"></i></button>
          <button class="icon-btn" type="button"><i class="fa-solid fa-eye"></i></button>
          <button class="icon-btn" type="button"><i class="fa-solid fa-exclamation"></i></button>
        </div>
      </div>
      <div class="right-row">
        <select id="storeId" class="select-like">
          <% stores.forEach(s => { %><option value="<%= s._id %>"><%= s.ten_cua_hang %></option><% }) %>
        </select>
        <input id="importDate" class="date-input" value="<%= new Date().toLocaleString('vi-VN', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>">
      </div>
      <div class="right-row">
        <select id="khoId" class="select-like" disabled>
          <option value="">Vui lòng chọn cửa hàng trước</option>
        </select>
      </div>
      <div class="supplier-search">
        <input id="supplierSearch" placeholder="Tìm nhà cung cấp">
        <i class="fa-solid fa-plus"></i>
        <div id="supplierResults" class="supplier-results"></div>
      </div>
      <input type="hidden" id="supplierId">
      <div class="summary-line"><span>Mã phiếu nhập</span><input id="receiptCode" class="side-input" placeholder="Mã phiếu tự động"></div>
      <div class="summary-line"><span>Mã đặt hàng nhập</span><span></span></div>
      <div class="summary-line"><span>Trạng thái</span><span>Phiếu tạm</span></div>
      <div class="summary-line"><span>Tổng tiền hàng <i class="fa-regular fa-circle-question"></i></span><span class="num" id="goodsTotal">0</span></div>
      <div class="summary-line"><span>Giảm giá</span><input id="discount" class="discount-input" value="0" oninput="renderItems()"></div>
      <div class="summary-line"><strong>Cần trả nhà cung cấp</strong><span class="num payable" id="payableTotal">0</span></div>
      <textarea id="note" class="note" placeholder="Ghi chú"></textarea>
      <div class="right-spacer"></div>
      <div class="bottom-actions">
        <button class="btn-draft" type="button" onclick="saveImport('draft')">Lưu tạm</button>
        <button class="btn-complete" type="button" onclick="saveImport('completed')">Hoàn thành</button>
      </div>
    </aside>
  </main>

  <script>
    let selectedItems = [];
    const products = <%- JSON.stringify(products.map(p => ({ _id:String(p._id), ma_hang:p.ma_hang, ten_hang:p.ten_hang, don_vi_tinh:p.don_vi_tinh || 'cái', ton_kho:p.ton_kho || 0, gia_von:p.gia_von || 0 }))) %>;
    const suppliers = <%- JSON.stringify(suppliers.map(s => ({ _id:String(s._id), ma_ncc:s.ma_ncc, ten_ncc:s.ten_ncc, sdt:s.sdt || '' }))) %>;
    const fmt = n => Number(n || 0).toLocaleString('vi-VN');
    const numeric = v => Number(String(v || '').replace(/\./g,'').replace(/,/g,'').trim()) || 0;
    const storeSelect = document.getElementById('storeId');
    const khoSelect = document.getElementById('khoId');

    async function loadKhoByStore() {
      const storeId = storeSelect.value;
      khoSelect.innerHTML = '<option value="">Chọn kho</option>';
      khoSelect.disabled = true;
      if (!storeId) return;

      try {
        const res = await fetch('/api/kho?cua_hang_id=' + encodeURIComponent(storeId));
        const result = await res.json();
        const warehouses = result.success ? (result.data || []) : [];
        khoSelect.innerHTML = '<option value="">Chọn kho</option>' + warehouses.map(k => `<option value="${k._id}">${k.ten_kho}</option>`).join('');
        khoSelect.disabled = false;
      } catch (error) {
        khoSelect.innerHTML = '<option value="">Không tải được kho</option>';
      }
    }

    storeSelect.addEventListener('change', loadKhoByStore);
    document.addEventListener('DOMContentLoaded', loadKhoByStore);

    const productSearch = document.getElementById('productSearch');
    const searchResults = document.getElementById('searchResults');
    productSearch.addEventListener('input', function() {
      const q = this.value.trim().toLowerCase();
      if (!q) { searchResults.style.display = 'none'; return; }
      const matched = products.filter(p => p.ma_hang.toLowerCase().includes(q) || p.ten_hang.toLowerCase().includes(q)).slice(0, 20);
      searchResults.innerHTML = matched.map(p => `<div class="search-item" onclick="addItem('${p._id}')"><span>${p.ten_hang} (${p.ma_hang})</span><span>Tồn: ${fmt(p.ton_kho)}</span></div>`).join('');
      searchResults.style.display = 'block';
    });

    const supplierSearch = document.getElementById('supplierSearch');
    const supplierResults = document.getElementById('supplierResults');
    supplierSearch.addEventListener('input', function() {
      const q = this.value.trim().toLowerCase();
      if (!q) { supplierResults.style.display = 'none'; return; }
      const matched = suppliers.filter(s => s.ma_ncc.toLowerCase().includes(q) || s.ten_ncc.toLowerCase().includes(q) || s.sdt.includes(q)).slice(0, 20);
      supplierResults.innerHTML = matched.map(s => `<div class="search-item" onclick="selectSupplier('${s._id}')"><span>${s.ten_ncc}</span><span>${s.ma_ncc}</span></div>`).join('');
      supplierResults.style.display = 'block';
    });

    function selectSupplier(id) {
      const supplier = suppliers.find(s => s._id === id);
      if (!supplier) return;
      document.getElementById('supplierId').value = id;
      supplierSearch.value = supplier.ten_ncc;
      supplierResults.style.display = 'none';
    }

    function addItem(id) {
      const product = products.find(p => p._id === id);
      if (!product) return;
      const existing = selectedItems.find(item => item.hang_hoa_id === id);
      if (existing) existing.so_luong += 1;
      else selectedItems.push({ hang_hoa_id:id, ma_hang:product.ma_hang, ten_hang:product.ten_hang, don_vi_tinh:product.don_vi_tinh, so_luong:1, don_gia_nhap:product.gia_von, giam_gia:0 });
      productSearch.value = '';
      searchResults.style.display = 'none';
      renderItems();
    }

    function renderItems() {
      const body = document.getElementById('itemsBody');
      let goodsTotal = 0;
      body.innerHTML = selectedItems.map((item, index) => {
        const lineTotal = Math.max(item.so_luong * item.don_gia_nhap - (item.giam_gia || 0), 0);
        goodsTotal += lineTotal;
        return `<tr>
          <td style="text-align:center">${index + 1}</td>
          <td>${item.ma_hang}</td>
          <td>${item.ten_hang}</td>
          <td>${item.don_vi_tinh}</td>
          <td class="num"><input class="input-small" value="${item.so_luong}" onchange="updateQty('${item.hang_hoa_id}', this.value)"></td>
          <td class="num"><input class="input-small" value="${item.don_gia_nhap}" onchange="updatePrice('${item.hang_hoa_id}', this.value)"></td>
          <td class="num"><input class="input-small" value="${item.giam_gia || 0}" onchange="updateLineDiscount('${item.hang_hoa_id}', this.value)"></td>
          <td class="num">${fmt(lineTotal)}</td>
          <td><i class="fa-solid fa-trash" style="color:#ef4444;cursor:pointer" onclick="removeItem('${item.hang_hoa_id}')"></i></td>
        </tr>`;
      }).join('');
      const discount = numeric(document.getElementById('discount').value);
      document.getElementById('goodsTotal').textContent = fmt(goodsTotal);
      document.getElementById('payableTotal').textContent = fmt(Math.max(goodsTotal - discount, 0));
      document.getElementById('emptyImport').style.display = selectedItems.length ? 'none' : 'flex';
    }

    function updateQty(id, val) { const item = selectedItems.find(i => i.hang_hoa_id === id); if (item) item.so_luong = numeric(val); renderItems(); }
    function updatePrice(id, val) { const item = selectedItems.find(i => i.hang_hoa_id === id); if (item) item.don_gia_nhap = numeric(val); renderItems(); }
    function updateLineDiscount(id, val) { const item = selectedItems.find(i => i.hang_hoa_id === id); if (item) item.giam_gia = numeric(val); renderItems(); }
    function removeItem(id) { selectedItems = selectedItems.filter(i => i.hang_hoa_id !== id); renderItems(); }

    async function saveImport(status) {
      const supplierId = document.getElementById('supplierId').value;
      if (!supplierId) return alert('Vui lòng chọn nhà cung cấp');
      if (!selectedItems.length) return alert('Vui lòng chọn ít nhất 1 hàng hóa');
      if (!document.getElementById('khoId').value) return alert('Vui lòng chọn kho.');
      const data = {
        nha_cung_cap_id: supplierId,
        cua_hang_id: document.getElementById('storeId').value,
        kho_id: document.getElementById('khoId').value,
        ma_phieu_nhap: document.getElementById('receiptCode').value,
        ngay_nhap: new Date().toISOString(),
        ghi_chu: document.getElementById('note').value,
        giam_gia: numeric(document.getElementById('discount').value),
        trang_thai: status,
        items: selectedItems
      };
      try {
        const res = await fetch('/phieu-nhap/add', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(data) });
        const result = await res.json();
        if (!result.success) return alert(result.message || 'Không lưu được phiếu nhập');
        window.location.href = '/phieu-nhap';
      } catch (error) {
        alert('Lỗi khi lưu phiếu nhập');
      }
    }

    document.addEventListener('click', e => {
      if (!productSearch.parentElement.contains(e.target)) searchResults.style.display = 'none';
      if (!supplierSearch.parentElement.contains(e.target)) supplierResults.style.display = 'none';
    });
  </script>
</body>
</html>
