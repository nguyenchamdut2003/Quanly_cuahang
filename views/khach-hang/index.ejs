      <div class="page-actions group-modal-footer">
        <button class="btn btn-light btn-sm" type="button" id="addressTypeModalCancel">Bỏ qua</button>
        <button class="btn btn-primary btn-sm" type="button" id="addressTypeModalSubmit">Lưu</button>
      </div>
    </div>
  </div>
  <script id="customerGroupsSeed" type="application/json"><%- JSON.stringify(customerGroups || []) %></script>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var selectAll = document.getElementById('selectAllCustomers');
      var checkboxes = Array.prototype.slice.call(document.querySelectorAll('.customer-checkbox'));

      if (selectAll) {
        selectAll.addEventListener('change', function () {
          checkboxes.forEach(function (checkbox) {
            checkbox.checked = selectAll.checked;
          });
        });
      }

      checkboxes.forEach(function (checkbox) {
        checkbox.addEventListener('change', function () {
          if (!selectAll) return;
          selectAll.checked = checkboxes.length > 0 && checkboxes.every(function (item) {
            return item.checked;
          });
        });
      });

      var createdFilterSelect = document.getElementById('createdFilterSelect');
      var customDateRange = document.getElementById('customDateRange');
      function toggleCustomDateRange() {
        if (!customDateRange) return;
        customDateRange.classList.toggle('is-visible', createdFilterSelect && createdFilterSelect.value === 'custom');
      }
      if (createdFilterSelect) createdFilterSelect.addEventListener('change', toggleCustomDateRange);
      toggleCustomDateRange();

      var groupFilterTrigger = document.getElementById('groupFilterTrigger');
      var groupFilterSelectedLabel = document.getElementById('groupFilterSelectedLabel');
      var groupFilterValue = document.getElementById('groupFilterValue');
      var groupFilterDropdown = document.getElementById('groupFilterDropdown');
      var groupModalTrigger = document.getElementById('groupModalTrigger');
      var groupModalSelectedLabel = document.getElementById('groupModalSelectedLabel');
      var groupModalValue = document.getElementById('groupModalValue');
      var groupModalDropdown = document.getElementById('groupModalDropdown');
      var groupNameInput = document.getElementById('groupNameInput');
      var groupDescInput = document.getElementById('groupDescInput');
      var groupAddBtn = document.getElementById('groupAddBtn');
      var groupModalAddBtn = document.getElementById('groupModalAddBtn');
      var groupModalOverlay = document.getElementById('groupModalOverlay');
      var groupModalTitle = document.getElementById('groupModalTitle');
      var groupModalSubmit = document.getElementById('groupModalSubmit');
      var groupModalClose = document.getElementById('groupModalClose');
      var groupModalCancel = document.getElementById('groupModalCancel');
      var modalMode = 'add';
      var activeGroupItem = null;
      var openAddCustomerModalBtn = document.getElementById('openAddCustomerModal');
      var addCustomerModalOverlay = document.getElementById('addCustomerModalOverlay');
      var addCustomerModalClose = document.getElementById('addCustomerModalClose');
      var addCustomerModalCancel = document.getElementById('addCustomerModalCancel');
      var addressTypeTrigger = document.getElementById('addressTypeTrigger');
      var addressTypeSelectedLabel = document.getElementById('addressTypeSelectedLabel');
      var addressTypeValue = document.getElementById('addressTypeValue');
      var addressTypeDropdown = document.getElementById('addressTypeDropdown');
      var addressTypeAddBtn = document.getElementById('addressTypeAddBtn');
      var addressTypeModalOverlay = document.getElementById('addressTypeModalOverlay');
      var addressTypeModalTitle = document.getElementById('addressTypeModalTitle');
      var addressTypeModalClose = document.getElementById('addressTypeModalClose');
      var addressTypeModalCancel = document.getElementById('addressTypeModalCancel');
      var addressTypeModalSubmit = document.getElementById('addressTypeModalSubmit');
      var addressTypeNameInput = document.getElementById('addressTypeNameInput');
      var addressTypeCodeInput = document.getElementById('addressTypeCodeInput');
      var addressTypeModalMode = 'add';
      var activeAddressTypeItem = null;

      function submitDynamicForm(action, payload) {
        var form = document.createElement('form');
        form.method = 'post';
        form.action = action;
        Object.keys(payload).forEach(function(key) {
          var input = document.createElement('input');
          input.type = 'hidden';
          input.name = key;
          input.value = payload[key];
          form.appendChild(input);
        });
        document.body.appendChild(form);
        form.submit();
      }

      function bindGroupItems() {
        var groupItems = Array.prototype.slice.call(document.querySelectorAll('.group-manage-item'));
        groupItems.forEach(function(item) {
          var optionBtn = item.querySelector('.group-manage-option');
          var editBtn = item.querySelector('.group-manage-action-edit');
          var deleteBtn = item.querySelector('.group-manage-action-delete');

          if (optionBtn) {
            optionBtn.addEventListener('click', function() {
              var container = item.closest('.group-manage-wrapper');
              if (!container) return;
              Array.prototype.slice.call(container.querySelectorAll('.group-manage-item')).forEach(function(node) {
                node.classList.remove('is-active');
              });
              item.classList.add('is-active');
              var valueInput = container.querySelector('input[type="hidden"]');
              if (valueInput) valueInput.value = item.getAttribute('data-value') || '';
              var labelNode = container.querySelector('.group-manage-trigger span');
              if (labelNode) labelNode.textContent = item.getAttribute('data-name') || '';
              var dropdownNode = container.querySelector('.group-manage-dropdown');
              if (dropdownNode) dropdownNode.classList.remove('is-open');
            });
          }

          if (editBtn) {
            editBtn.addEventListener('click', function(event) {
              event.stopPropagation();
              activeGroupItem = item;
              openGroupModal('edit');
            });
          }

          if (deleteBtn) {
            deleteBtn.addEventListener('click', function(event) {
              event.stopPropagation();
              var groupId = item.getAttribute('data-id') || '';
              if (!groupId) {
                alert('Vui lòng chọn nhóm cần xóa.');
                return;
              }
              if (!confirm('Bạn có chắc muốn xóa nhóm khách hàng này không?')) return;
              requestCustomerGroups('/khach-hang/groups/' + groupId + '/delete', {}, '');
            });
          }
        });
      }

      function renderGroupList(dropdownNode, selectedValue, includeRootOption) {
        if (!dropdownNode) return;
        var groups = window.__customerGroups || [];
        var rows = [];

        if (includeRootOption) {
          rows.push(
            '<div class="group-manage-item ' + ((selectedValue === 'all' || !selectedValue) ? 'is-active' : '') + '" data-id="" data-value="all" data-name="Tất cả các nhóm" data-desc="">' +
              '<button class="group-manage-option" type="button">Tất cả các nhóm</button>' +
            '</div>'
          );
        } else {
          rows.push(
            '<div class="group-manage-item ' + (!selectedValue ? 'is-active' : '') + '" data-id="" data-value="" data-name="Không chọn nhóm" data-desc="">' +
              '<button class="group-manage-option" type="button">Không chọn nhóm</button>' +
            '</div>'
          );
        }

        groups.forEach(function(group) {
          var value = String(group._id || '');
          var isActive = value === String(selectedValue || '');
          rows.push(
            '<div class="group-manage-item ' + (isActive ? 'is-active' : '') + '" data-id="' + value + '" data-value="' + value + '" data-name="' + (group.ten_nhom || '').replace(/"/g, '&quot;') + '" data-desc="' + (group.mo_ta || '').replace(/"/g, '&quot;') + '">' +
              '<button class="group-manage-option" type="button">' + (group.ten_nhom || '') + '</button>' +
              '<div class="group-manage-actions">' +
                '<button class="group-manage-action-edit" type="button">Sửa</button>' +
                '<button class="group-manage-action-delete" type="button">Xóa</button>' +
              '</div>' +
            '</div>'
          );
        });

        dropdownNode.innerHTML = rows.join('');
      }

      function refreshGroupWidgets(sidebarSelectedOverride, modalSelectedOverride) {
        if (Array.isArray(window.__customerGroups) === false) return;
        var sidebarSelected = typeof sidebarSelectedOverride === 'undefined'
          ? ((groupFilterValue ? groupFilterValue.value : 'all') || 'all')
          : sidebarSelectedOverride;
        var modalSelected = typeof modalSelectedOverride === 'undefined'
          ? ((groupModalValue ? groupModalValue.value : '') || '')
          : modalSelectedOverride;

        renderGroupList(groupFilterDropdown, sidebarSelected, true);
        renderGroupList(groupModalDropdown, modalSelected, false);

        if (groupFilterSelectedLabel && groupFilterDropdown) {
          var activeSidebar = groupFilterDropdown.querySelector('.group-manage-item.is-active');
          groupFilterSelectedLabel.textContent = activeSidebar ? (activeSidebar.getAttribute('data-name') || 'Tất cả các nhóm') : 'Tất cả các nhóm';
          if (groupFilterValue) groupFilterValue.value = activeSidebar ? (activeSidebar.getAttribute('data-value') || 'all') : 'all';
        }
        if (groupModalSelectedLabel && groupModalDropdown) {
          var activeModal = groupModalDropdown.querySelector('.group-manage-item.is-active');
          groupModalSelectedLabel.textContent = activeModal ? (activeModal.getAttribute('data-name') || 'Không chọn nhóm') : 'Không chọn nhóm';
          if (groupModalValue) groupModalValue.value = activeModal ? (activeModal.getAttribute('data-value') || '') : '';
        }

        bindGroupItems();
      }

      function requestCustomerGroups(url, payload, selectedId) {
        var formBody = Object.keys(payload).map(function(key) {
          return encodeURIComponent(key) + '=' + encodeURIComponent(payload[key]);
        }).join('&');

        fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
          },
          body: formBody
        })
          .then(function(response) { return response.json(); })
          .then(function(data) {
            if (!data || !data.success) {
              alert('Không thể xử lý nhóm khách hàng.');
              return;
            }
            var currentSidebarValue = groupFilterValue ? groupFilterValue.value : 'all';
            var currentModalValue = groupModalValue ? groupModalValue.value : '';
            window.__customerGroups = Array.isArray(data.customerGroups) ? data.customerGroups : [];
            refreshGroupWidgets(currentSidebarValue, data.selectedId || selectedId || currentModalValue || '');
            closeGroupModal();
          })
          .catch(function() {
            alert('Có lỗi khi xử lý nhóm khách hàng.');
          });
      }

      if (groupFilterTrigger && groupFilterDropdown) {
        groupFilterTrigger.addEventListener('click', function() {
          groupFilterDropdown.classList.toggle('is-open');
        });
      }
      if (groupModalTrigger && groupModalDropdown) {
        groupModalTrigger.addEventListener('click', function() {
          groupModalDropdown.classList.toggle('is-open');
        });
      }

      function openGroupModal(mode) {
        modalMode = mode;
        if (!groupModalOverlay || !groupModalTitle) return;
        if (mode === 'add') {
          groupModalTitle.textContent = 'Thêm nhóm khách hàng';
          if (groupNameInput) groupNameInput.value = '';
          if (groupDescInput) groupDescInput.value = '';
        } else {
          groupModalTitle.textContent = 'Sửa nhóm khách hàng';
          if (groupNameInput) groupNameInput.value = activeGroupItem ? (activeGroupItem.getAttribute('data-name') || '') : '';
          if (groupDescInput) groupDescInput.value = activeGroupItem ? (activeGroupItem.getAttribute('data-desc') || '') : '';
        }
        groupModalOverlay.classList.add('is-open');
      }

      function closeGroupModal() {
        if (!groupModalOverlay) return;
        groupModalOverlay.classList.remove('is-open');
      }

      if (groupAddBtn) {
        groupAddBtn.addEventListener('click', function() {
          openGroupModal('add');
        });
      }
      if (groupModalAddBtn) {
        groupModalAddBtn.addEventListener('click', function() {
          openGroupModal('add');
        });
      }

      if (groupModalSubmit) {
        groupModalSubmit.addEventListener('click', function() {
          if (!groupNameInput || !groupNameInput.value.trim()) {
            alert('Vui lòng nhập tên nhóm khách hàng.');
            return;
          }
          if (modalMode === 'add') {
            requestCustomerGroups('/khach-hang/groups/add', {
              ten_nhom: groupNameInput.value.trim(),
              mo_ta: groupDescInput ? groupDescInput.value.trim() : ''
            }, '');
            return;
          }
          var groupId = activeGroupItem ? (activeGroupItem.getAttribute('data-id') || '') : '';
          if (!groupId) {
            alert('Vui lòng chọn nhóm cần sửa.');
            return;
          }
          requestCustomerGroups('/khach-hang/groups/' + groupId + '/update', {
            ten_nhom: groupNameInput.value.trim(),
            mo_ta: groupDescInput ? groupDescInput.value.trim() : ''
          }, groupId);
        });
      }

      if (groupModalClose) groupModalClose.addEventListener('click', closeGroupModal);
      if (groupModalCancel) groupModalCancel.addEventListener('click', closeGroupModal);

      var customerGroupsSeed = document.getElementById('customerGroupsSeed');
      window.__customerGroups = customerGroupsSeed ? JSON.parse(customerGroupsSeed.textContent || '[]') : [];
      refreshGroupWidgets();

      function openAddressTypeModal(mode) {
        addressTypeModalMode = mode;
        if (!addressTypeModalOverlay || !addressTypeModalTitle) return;
        if (mode === 'add') {
          addressTypeModalTitle.textContent = 'Thêm loại địa chỉ';
          if (addressTypeNameInput) addressTypeNameInput.value = '';
          if (addressTypeCodeInput) addressTypeCodeInput.value = '';
          if (addressTypeCodeInput) addressTypeCodeInput.removeAttribute('disabled');
        } else {
          addressTypeModalTitle.textContent = 'Sửa loại địa chỉ';
          if (addressTypeNameInput) addressTypeNameInput.value = activeAddressTypeItem ? (activeAddressTypeItem.getAttribute('data-name') || '') : '';
          if (addressTypeCodeInput) addressTypeCodeInput.value = activeAddressTypeItem ? (activeAddressTypeItem.getAttribute('data-value') || '') : '';
          if (addressTypeCodeInput) addressTypeCodeInput.setAttribute('disabled', 'disabled');
        }
        addressTypeModalOverlay.classList.add('is-open');
      }

      function closeAddressTypeModal() {
        if (!addressTypeModalOverlay) return;
        addressTypeModalOverlay.classList.remove('is-open');
      }

      function escapeHtml(value) {
        return String(value || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function bindAddressTypeItems() {
        var addressTypeItems = Array.prototype.slice.call(document.querySelectorAll('.address-type-item'));
        addressTypeItems.forEach(function(item) {
          var optionBtn = item.querySelector('.address-type-option');
          var editBtn = item.querySelector('.address-type-action-edit');
          var deleteBtn = item.querySelector('.address-type-action-delete');

          if (optionBtn) {
            optionBtn.addEventListener('click', function() {
              addressTypeItems.forEach(function(node) { node.classList.remove('is-active'); });
              item.classList.add('is-active');
              if (addressTypeSelectedLabel) addressTypeSelectedLabel.textContent = item.getAttribute('data-name') || '';
              if (addressTypeValue) addressTypeValue.value = item.getAttribute('data-value') || '';
              if (addressTypeDropdown) addressTypeDropdown.classList.remove('is-open');
            });
          }

          if (editBtn) {
            editBtn.addEventListener('click', function(event) {
              event.stopPropagation();
              activeAddressTypeItem = item;
              openAddressTypeModal('edit');
            });
          }

          if (deleteBtn) {
            deleteBtn.addEventListener('click', function(event) {
              event.stopPropagation();
              var typeId = item.getAttribute('data-id') || '';
              if (!typeId) {
                alert('Vui lòng chọn loại địa chỉ cần xóa.');
                return;
              }
              if (!confirm('Bạn có chắc muốn xóa loại địa chỉ này không?')) return;
              requestAddressType('/khach-hang/address-types/' + typeId + '/delete', {});
            });
          }
        });
      }

      function renderAddressTypeList(addressTypes, selectedId) {
        if (!addressTypeDropdown || !addressTypeValue || !addressTypeSelectedLabel) return;
        var selectedType = null;
        if (selectedId) {
          selectedType = addressTypes.find(function(item) { return String(item._id) === String(selectedId); }) || null;
        }
        if (!selectedType && addressTypes.length > 0) {
          selectedType = addressTypes[0];
        }

        addressTypeDropdown.innerHTML = addressTypes.map(function(type) {
          var isActive = selectedType && String(selectedType._id) === String(type._id);
          return (
            '<div class="address-type-item ' + (isActive ? 'is-active' : '') + '" data-id="' + escapeHtml(type._id) + '" data-value="' + escapeHtml(type.ma_loai) + '" data-name="' + escapeHtml(type.ten_loai) + '">' +
              '<button class="address-type-option" type="button">' + escapeHtml(type.ten_loai) + '</button>' +
              '<div class="address-type-actions">' +
                '<button class="address-type-action-edit" type="button">Sửa</button>' +
                '<button class="address-type-action-delete" type="button">Xóa</button>' +
              '</div>' +
            '</div>'
          );
        }).join('');

        if (selectedType) {
          addressTypeValue.value = selectedType.ma_loai || '';
          addressTypeSelectedLabel.textContent = selectedType.ten_loai || 'Chọn loại địa chỉ';
        } else {
          addressTypeValue.value = '';
          addressTypeSelectedLabel.textContent = 'Chọn loại địa chỉ';
        }

        activeAddressTypeItem = null;
        bindAddressTypeItems();
      }

      function requestAddressType(url, payload, callback) {
        var formBody = Object.keys(payload).map(function(key) {
          return encodeURIComponent(key) + '=' + encodeURIComponent(payload[key]);
        }).join('&');

        fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
          },
          body: formBody
        })
          .then(function(response) { return response.json(); })
          .then(function(data) {
            if (!data || !data.success) {
              alert('Không thể xử lý loại địa chỉ.');
              return;
            }
            renderAddressTypeList(Array.isArray(data.addressTypes) ? data.addressTypes : [], data.selectedId || '');
            if (typeof callback === 'function') callback();
          })
          .catch(function() {
            alert('Có lỗi khi xử lý loại địa chỉ.');
          });
      }

      if (addressTypeAddBtn) {
        addressTypeAddBtn.addEventListener('click', function() {
          openAddressTypeModal('add');
        });
      }

      if (addressTypeTrigger && addressTypeDropdown) {
        addressTypeTrigger.addEventListener('click', function() {
          addressTypeDropdown.classList.toggle('is-open');
        });
      }

      bindAddressTypeItems();

      if (addressTypeModalSubmit) {
        addressTypeModalSubmit.addEventListener('click', function() {
          if (!addressTypeNameInput || !addressTypeNameInput.value.trim()) {
            alert('Vui lòng nhập tên loại địa chỉ.');
            return;
          }
          if (addressTypeModalMode === 'add') {
            requestAddressType('/khach-hang/address-types/add', {
              ten_loai: addressTypeNameInput.value.trim(),
              ma_loai: addressTypeCodeInput && addressTypeCodeInput.value ? addressTypeCodeInput.value.trim() : ''
            }, function() {
              closeAddressTypeModal();
            });
            return;
          }

          var typeId = activeAddressTypeItem ? (activeAddressTypeItem.getAttribute('data-id') || '') : '';
          if (!typeId) {
            alert('Vui lòng chọn loại địa chỉ cần sửa.');
            return;
          }

          requestAddressType('/khach-hang/address-types/' + typeId + '/update', {
            ten_loai: addressTypeNameInput.value.trim()
          }, function() {
            closeAddressTypeModal();
          });
        });
      }

      if (addressTypeModalClose) addressTypeModalClose.addEventListener('click', closeAddressTypeModal);
      if (addressTypeModalCancel) addressTypeModalCancel.addEventListener('click', closeAddressTypeModal);
      document.addEventListener('click', function(event) {
        if (addressTypeDropdown && addressTypeTrigger) {
          if (!addressTypeDropdown.contains(event.target) && !addressTypeTrigger.contains(event.target)) {
            addressTypeDropdown.classList.remove('is-open');
          }
        }
        if (groupFilterDropdown && groupFilterTrigger) {
          if (!groupFilterDropdown.contains(event.target) && !groupFilterTrigger.contains(event.target)) {
            groupFilterDropdown.classList.remove('is-open');
          }
        }
        if (groupModalDropdown && groupModalTrigger) {
          if (!groupModalDropdown.contains(event.target) && !groupModalTrigger.contains(event.target)) {
            groupModalDropdown.classList.remove('is-open');
          }
        }
      });

      function openAddCustomerModal() {
        if (!addCustomerModalOverlay) return;
        addCustomerModalOverlay.classList.add('is-visible');
      }

      function closeAddCustomerModal() {
        if (!addCustomerModalOverlay) return;
        addCustomerModalOverlay.classList.remove('is-visible');
      }

      if (openAddCustomerModalBtn) openAddCustomerModalBtn.addEventListener('click', openAddCustomerModal);
      if (addCustomerModalClose) addCustomerModalClose.addEventListener('click', closeAddCustomerModal);
      if (addCustomerModalCancel) addCustomerModalCancel.addEventListener('click', closeAddCustomerModal);
      if (addCustomerModalOverlay && addCustomerModalOverlay.getAttribute('data-auto-open') === '1') {
        openAddCustomerModal();
      }

      // Collapsible Sections Logic
      var collapsibleHeaders = Array.prototype.slice.call(document.querySelectorAll('.collapsible-header'));
      collapsibleHeaders.forEach(function(header) {
        header.addEventListener('click', function() {
          var section = header.parentElement;
          section.classList.toggle('is-active');
        });
      });

      var customerDetailBlocks = Array.prototype.slice.call(document.querySelectorAll('[data-customer-detail]'));
      customerDetailBlocks.forEach(function(detailBlock) {
        var collapseBtn = detailBlock.querySelector('.detail-collapse-btn');
        var tabs = Array.prototype.slice.call(detailBlock.querySelectorAll('.detail-tab'));
        var panes = Array.prototype.slice.call(detailBlock.querySelectorAll('.customer-detail-pane'));
        var exportAction = detailBlock.querySelector('[data-export-action]');

        function syncExportAction(target) {
          if (!exportAction || !target) return;
          var url = exportAction.getAttribute('data-' + target + '-url') || '#';
          var label = exportAction.getAttribute('data-' + target + '-label') || 'Xuất thông tin';
          var disabled = exportAction.getAttribute('data-' + target + '-disabled') === '1';

          exportAction.textContent = label;
          exportAction.href = disabled ? '#' : url;
          exportAction.classList.toggle('is-disabled', disabled);
          exportAction.setAttribute('aria-disabled', disabled ? 'true' : 'false');
        }

        syncExportAction('info');

        tabs.forEach(function(tab) {
          tab.addEventListener('click', function(event) {
            event.stopPropagation();
            var target = tab.getAttribute('data-tab-target');
            tabs.forEach(function(node) {
              node.classList.toggle('is-active', node === tab);
            });
            panes.forEach(function(pane) {
              pane.classList.toggle('is-active', pane.getAttribute('data-tab-pane') === target);
            });
            syncExportAction(target);
          });
        });

        if (exportAction) {
          exportAction.addEventListener('click', function(event) {
            if (exportAction.getAttribute('aria-disabled') === 'true') {
              event.preventDefault();
              alert('Không có dữ liệu để xuất');
            }
          });
        }

        if (collapseBtn) {
          collapseBtn.addEventListener('click', function(event) {
            event.stopPropagation();
            var isCollapsed = detailBlock.classList.toggle('is-collapsed');
            collapseBtn.textContent = isCollapsed ? 'Mở rộng' : 'Thu gọn';
            collapseBtn.setAttribute('aria-expanded', isCollapsed ? 'false' : 'true');
          });
        }
      });

      var customerCreateForm = document.getElementById('customerCreateForm');
      var editCustomerBtns = document.querySelectorAll('.btn-edit-customer');

      function keepDigitsOnly(input) {
        if (!input) return;
        input.value = String(input.value || '').replace(/\D/g, '');
      }

      Array.prototype.slice.call(document.querySelectorAll('[data-digits-only]')).forEach(function(input) {
        input.addEventListener('input', function() {
          keepDigitsOnly(input);
        });
      });

      if (customerCreateForm) {
        customerCreateForm.addEventListener('submit', function(event) {
          var phoneInput = customerCreateForm.querySelector('[name="sdt"]');
          var cccdInput = customerCreateForm.querySelector('[name="cccd"]');
          var selectedTypeInput = customerCreateForm.querySelector('input[name="loai_khach_hang"]:checked');
          var selectedType = selectedTypeInput ? selectedTypeInput.value : 'ca_nhan';
          var phone = phoneInput ? String(phoneInput.value || '').trim() : '';
          var cccd = cccdInput ? String(cccdInput.value || '').trim() : '';

          keepDigitsOnly(phoneInput);
          keepDigitsOnly(cccdInput);
          phone = phoneInput ? phoneInput.value : phone;
          cccd = cccdInput ? cccdInput.value : cccd;

          if (!phone) {
            event.preventDefault();
            alert('Vui lòng nhập số điện thoại.');
            if (phoneInput) phoneInput.focus();
            return;
          }

          if (!/^0\d{9}$/.test(phone)) {
            event.preventDefault();
            alert('Số điện thoại phải đủ 10 số và bắt đầu bằng 0.');
            if (phoneInput) phoneInput.focus();
            return;
          }

          if (selectedType === 'ca_nhan') {
            if (!cccd) {
              event.preventDefault();
              alert('Vui lòng nhập CCCD.');
              if (cccdInput) cccdInput.focus();
              return;
            }

            if (!/^\d{12}$/.test(cccd)) {
              event.preventDefault();
              alert('CCCD phải đủ 12 số.');
              if (cccdInput) cccdInput.focus();
            }
          }
        });
      }
      
      editCustomerBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var customerData = JSON.parse(decodeURIComponent(this.getAttribute('data-customer') || '%7B%7D'));
          if (!customerCreateForm) return;

          customerCreateForm.action = '/khach-hang/' + customerData._id + '/update';
          var title = document.getElementById('addCustomerModalTitle');
          if (title) title.textContent = 'Cập nhật khách hàng';

          var fields = ['ten_khach_hang', 'ma_khach_hang', 'sdt', 'sdt2', 'cccd', 'ngay_sinh', 'gioi_tinh', 'email', 'facebook', 'nhom_khach_hang_id', 'ghi_chu', 'loai_khach_hang', 'ma_so_thue', 'ten_cong_ty', 'stk_ngan_hang', 'chu_tai_khoan', 'ngan_hang', 'trang_thai', 'ten_nguoi_nhan', 'sdt_nguoi_nhan', 'so_nha', 'tinh_thanh', 'quan_huyen', 'phuong_xa', 'dia_chi_day_du', 'ghi_chu_dia_chi'];
          
          fields.forEach(function(field) {
            var input = customerCreateForm.querySelector('[name="' + field + '"]');
            if (input) {
              if (input.type === 'radio') {
                var radio = customerCreateForm.querySelector('input[name="' + field + '"][value="' + customerData[field] + '"]');
                if (radio) radio.checked = true;
              } else if (input.type === 'date' && customerData[field]) {
                input.value = new Date(customerData[field]).toISOString().split('T')[0];
              } else {
                input.value = customerData[field] || '';
              }
            }
          });

          var selectedType = customerData.loai_khach_hang || 'ca_nhan';
          var typeRadios = customerCreateForm.querySelectorAll('input[name="loai_khach_hang"]');
          typeRadios.forEach(function(r) { if (r.value === selectedType) r.checked = true; });
          
          if (typeof window.toggleCustomerType === 'function') window.toggleCustomerType();
          openAddCustomerModal();
        });
      });

      if (openAddCustomerModalBtn) {
        openAddCustomerModalBtn.addEventListener('click', function() {
          if (customerCreateForm) {
            customerCreateForm.reset();
            customerCreateForm.action = '/khach-hang/add';
            var title = document.getElementById('addCustomerModalTitle');
            if (title) title.textContent = 'Thêm khách hàng';
            if (typeof window.toggleCustomerType === 'function') window.toggleCustomerType();
          }
        });
      }

      var pillButtons = Array.prototype.slice.call(document.querySelectorAll('.pill-btn'));
      pillButtons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var targetInputId = btn.getAttribute('data-target-input');
          var value = btn.getAttribute('data-value');
          var input = document.getElementById(targetInputId);
          if (!input) return;
          input.value = value;
          var siblings = Array.prototype.slice.call(btn.parentElement.querySelectorAll('.pill-btn'));
          siblings.forEach(function(item) { item.classList.remove('is-active'); });
          btn.classList.add('is-active');
        });
      });

      document.querySelectorAll('.js-address-add').forEach(function(btn) {
        btn.addEventListener('click', function(event) {
          event.preventDefault();
          event.stopPropagation();
          if (!confirm('Bạn có muốn thêm địa chỉ mới không?')) return;

          var formId = btn.getAttribute('data-form-id');
          var action = btn.getAttribute('data-action');
          var tempForm = document.createElement('form');
          tempForm.method = 'post';
          tempForm.action = action;
          tempForm.style.display = 'none';

          document.querySelectorAll('[form="' + formId + '"]').forEach(function(field) {
            if (!field.name || field.disabled) return;
            if ((field.type === 'checkbox' || field.type === 'radio') && !field.checked) return;

            var hidden = document.createElement('input');
            hidden.type = 'hidden';
            hidden.name = field.name;
            hidden.value = field.value;
            tempForm.appendChild(hidden);
          });

          document.body.appendChild(tempForm);
          tempForm.submit();
        });
      });

      var customerTypeRadios = Array.prototype.slice.call(document.querySelectorAll('input[name="loai_khach_hang"]'));
      var customerTypePanes = Array.prototype.slice.call(document.querySelectorAll('.customer-type-pane'));
      function toggleCustomerTypePane() {
        var selected = customerTypeRadios.find(function(item) { return item.checked; });
        var selectedType = selected ? selected.value : 'ca_nhan';
        customerTypePanes.forEach(function(pane) {
          pane.classList.toggle('is-active', pane.getAttribute('data-customer-type-pane') === selectedType);
        });
      }
      customerTypeRadios.forEach(function(radio) {
        radio.addEventListener('change', toggleCustomerTypePane);
      });
      toggleCustomerTypePane();
    });
  </script>

</body>
</html>
