<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body class="admin-body">
  <%- include('../partials/header', { activeMenu: activeMenu, user: user }) %>
  <%
    var history = locals.customerHistory || {};
    var historyOrders = Array.isArray(history.orders) ? history.orders : [];
    var historyInvoices = Array.isArray(history.invoices) ? history.invoices : [];
    var historyReturns = Array.isArray(history.returns) ? history.returns : [];
    var historyDebts = Array.isArray(history.debts) ? history.debts : [];
    var money = function(value) { return Number(value || 0).toLocaleString('vi-VN'); };
  %>

  <main class="admin-shell customer-page">
    <%- include('../partials/flash-message', { flash: flash }) %>

    <div id="addCustomerModalOverlay" class="modal-overlay" data-auto-open="<%= formMode === 'create' ? '1' : '0' %>">
      <div class="modal-content customer-create-modal">
        <div class="modal-header">
          <h3 id="addCustomerModalTitle">Tạo khách hàng</h3>
          <button type="button" class="modal-close" id="addCustomerModalClose">×</button>
        </div>
      
        <form class="modal-body" method="post" action="/khach-hang/add" id="customerCreateForm">
          <div class="customer-form-grid">
      
            <!-- THONG TIN CHUNG -->
            <div class="form-row-full collapsible-section is-active">
              <div class="collapsible-header">
                <strong>Thông tin khách hàng</strong>
                <span class="chevron">▲</span>
              </div>
      
              <div class="collapsible-content customer-form-main">
                <div class="customer-form-field">
                  <label>Loại khách hàng</label>
                  <div class="radio-inline">
                    <label>
                      <input type="radio" name="loai_khach_hang" value="ca_nhan" checked>
                      Cá nhân
                    </label>
                    <label>
                      <input type="radio" name="loai_khach_hang" value="cong_ty">
                      Công ty
                    </label>
                  </div>
                </div>
      
                <div class="customer-form-field">
                  <label>Mã khách hàng</label>
                  <input name="ma_khach_hang" placeholder="Tự động">
                </div>
      
                <div class="customer-form-field form-row-full">
                  <label>Tên khách hàng *</label>
                  <input name="ten_khach_hang" placeholder="Nhập tên khách hàng" required>
                </div>
      
                <div class="customer-form-field company-field" style="display:none;">
                  <label>Tên công ty</label>
                  <input name="ten_cong_ty" placeholder="Nhập tên công ty">
                </div>
      
                <div class="customer-form-field company-field" style="display:none;">
                  <label>Mã số thuế</label>
                  <input name="ma_so_thue" placeholder="Nhập mã số thuế">
                </div>
      
                <div class="customer-form-field">
                  <label>Số điện thoại *</label>
                  <input name="sdt" type="tel" inputmode="numeric" pattern="0[0-9]{9}" maxlength="10" placeholder="Nhập số điện thoại" required data-digits-only data-phone-input>
                </div>
      
                <div class="customer-form-field">
                  <label>Email</label>
                  <input type="email" name="email" placeholder="email@gmail.com">
                </div>
      
                <div class="customer-form-field">
                  <label>Facebook</label>
                  <input name="facebook" placeholder="facebook.com/username">
                </div>
      
                <div class="customer-form-field individual-field">
                  <label>Ngày sinh</label>
                  <input type="date" name="ngay_sinh">
                </div>
      
                <div class="customer-form-field individual-field">
                  <label>Giới tính</label>
                  <select name="gioi_tinh">
                    <option value="">Chọn giới tính</option>
                    <option value="nam">Nam</option>
                    <option value="nu">Nữ</option>
                    <option value="khac">Khác</option>
                  </select>
                </div>
      
                <div class="customer-form-field individual-field">
                  <label>CCCD *</label>
                  <input name="cccd" type="text" inputmode="numeric" pattern="[0-9]{12}" maxlength="12" placeholder="Nhập CCCD" required data-digits-only data-cccd-input>
                </div>
      
              </div>
            </div>
      
      
            <!-- DIA CHI -->
            <div class="form-row-full collapsible-section is-active">
              <div class="collapsible-header">
                <strong>Địa chỉ khách hàng</strong>
                <span class="chevron">▲</span>
              </div>
      
              <div class="collapsible-content customer-form-main">
                <div class="customer-form-field">
                  <label>Mã địa chỉ</label>
                  <input name="ma_dia_chi" placeholder="Tự động">
                </div>
      
                <div class="customer-form-field">
                  <label>Loại địa chỉ</label>
                  <% var initialAddressType = (addressTypes && addressTypes[0]) ? addressTypes[0] : null; %>
                  <div class="address-type-wrapper">
                    <div class="address-type-header">
                      <button class="address-type-trigger" type="button" id="addressTypeTrigger">
                        <span id="addressTypeSelectedLabel"><%= initialAddressType ? initialAddressType.ten_loai : 'Chọn loại địa chỉ' %></span>
                        <span>▾</span>
                      </button>
                      <button class="btn btn-primary btn-sm" type="button" id="addressTypeAddBtn">Thêm</button>
                    </div>
                    <input type="hidden" name="loai_dia_chi" id="addressTypeValue" value="<%= initialAddressType ? initialAddressType.ma_loai : '' %>">
                    <div class="address-type-dropdown" id="addressTypeDropdown">
                      <% (addressTypes || []).forEach(function(type) { %>
                        <div
                          class="address-type-item <%= initialAddressType && String(initialAddressType._id) === String(type._id) ? 'is-active' : '' %>"
                          data-id="<%= type._id %>"
                          data-value="<%= type.ma_loai %>"
                          data-name="<%= type.ten_loai %>"
                        >
                          <button class="address-type-option" type="button"><%= type.ten_loai %></button>
                          <div class="address-type-actions">
                            <button class="address-type-action-edit" type="button">Sửa</button>
                            <button class="address-type-action-delete" type="button">Xóa</button>
                          </div>
                        </div>
                      <% }) %>
                    </div>
                  </div>
                </div>
      
                <div class="customer-form-field">
                  <label>Tên người nhận</label>
                  <input name="ten_nguoi_nhan" placeholder="Nhập tên người nhận">
                </div>
      
                <div class="customer-form-field">
                  <label>SĐT người nhận</label>
                  <input name="sdt_nguoi_nhan" placeholder="Nhập SĐT người nhận">
                </div>
      
                <div class="customer-form-field">
                  <label>Số nhà</label>
                  <input name="so_nha" placeholder="Nhập số nhà, đường">
                </div>
      
                <div class="customer-form-field">
                  <label>Tỉnh/Thành</label>
                  <input name="tinh_thanh" placeholder="Chọn Tỉnh/Thành phố">
                </div>
      
                <div class="customer-form-field">
                  <label>Quận/Huyện</label>
                  <input name="quan_huyen" placeholder="Chọn Quận/Huyện">
                </div>
      
                <div class="customer-form-field">
                  <label>Phường/Xã</label>
                  <input name="phuong_xa" placeholder="Chọn Phường/Xã">
                </div>
      
                <div class="customer-form-field form-row-full">
                  <label>Địa chỉ đầy đủ</label>
                  <input name="dia_chi_day_du" placeholder="Nhập địa chỉ đầy đủ">
                </div>
      
                <div class="customer-form-field form-row-full">
                  <label>
                    <input type="checkbox" name="mac_dinh" value="true" checked>
                    Đặt làm địa chỉ mặc định
                  </label>
                </div>
      
                <div class="customer-form-field form-row-full">
                  <label>Ghi chú địa chỉ</label>
                  <textarea name="ghi_chu_dia_chi" placeholder="Ví dụ: địa chỉ công ty, nơi nhận hàng, nhà riêng..."></textarea>
                </div>
              </div>
            </div>
      
            <div class="form-row-full collapsible-section is-active">
              <div class="collapsible-header">
                <strong>Nhóm khách hàng, ghi chú</strong>
                <span class="chevron">▲</span>
              </div>
      
              <div class="collapsible-content customer-form-main">
                <div class="customer-form-field form-row-full">
                  <label>Nhóm khách hàng</label>
                  <div class="group-manage-wrapper" id="groupManageModal">
                    <div class="group-manage-header">
                      <button class="group-manage-trigger" type="button" id="groupModalTrigger">
                        <span id="groupModalSelectedLabel">Không chọn nhóm</span>
                        <span>▾</span>
                      </button>
                      <button class="btn btn-primary btn-sm" type="button" id="groupModalAddBtn">Thêm</button>
                    </div>
                    <input type="hidden" name="nhom_khach_hang_id" id="groupModalValue" value="">
                    <div class="group-manage-dropdown" id="groupModalDropdown">
                      <div class="group-manage-item is-active" data-id="" data-value="" data-name="Không chọn nhóm" data-desc="">
                        <button class="group-manage-option" type="button">Không chọn nhóm</button>
                      </div>
                      <% customerGroups.forEach(function(group) { %>
                        <div class="group-manage-item" data-id="<%= group._id %>" data-value="<%= group._id %>" data-name="<%= group.ten_nhom %>" data-desc="<%= group.mo_ta || '' %>">
                          <button class="group-manage-option" type="button"><%= group.ten_nhom %></button>
                          <div class="group-manage-actions">
                            <button class="group-manage-action-edit" type="button">Sửa</button>
                            <button class="group-manage-action-delete" type="button">Xóa</button>
                          </div>
                        </div>
                      <% }) %>
                    </div>
                  </div>
                </div>
      
                <div class="customer-form-field">
                  <label>Ngân hàng</label>
                  <input name="ngan_hang" placeholder="Nhập tên ngân hàng">
                </div>
      
                <div class="customer-form-field">
                  <label>Số tài khoản ngân hàng</label>
                  <input name="stk_ngan_hang" placeholder="Nhập số tài khoản">
                </div>

                <div class="customer-form-field">
                  <label>Chủ tài khoản</label>
                  <input name="chu_tai_khoan" placeholder="Nhập tên chủ tài khoản">
                </div>
      
                <div class="customer-form-field form-row-full">
                  <label>Ghi chú</label>
                  <textarea name="ghi_chu" placeholder="Nhập ghi chú"></textarea>
                </div>
              </div>
            </div>
      
          </div>
        </form>
      
        <div class="page-actions modal-footer">
          <button class="btn btn-light" type="button" id="addCustomerModalCancel">Bỏ qua</button>
          <button class="btn btn-primary" type="submit" form="customerCreateForm">Lưu</button>
        </div>
      </div>
      
      <script>
        document.addEventListener('DOMContentLoaded', function () {

          const radios = document.querySelectorAll('input[name="loai_khach_hang"]');
          const companyFields = document.querySelectorAll('.company-field');
          const individualFields = document.querySelectorAll('.individual-field');
      
          function toggleCustomerType() {
            const selected = document.querySelector('input[name="loai_khach_hang"]:checked')?.value;
            const cccdInput = document.querySelector('[data-cccd-input]');
      
            companyFields.forEach(el => {
              el.style.display = selected === 'cong_ty' ? '' : 'none';
            });
      
            individualFields.forEach(el => {
              el.style.display = selected === 'ca_nhan' ? '' : 'none';
            });

            if (cccdInput) {
              cccdInput.required = selected === 'ca_nhan';
              if (selected !== 'ca_nhan') cccdInput.value = '';
            }
          }
          window.toggleCustomerType = toggleCustomerType;
      
          radios.forEach(radio => {
            radio.addEventListener('change', toggleCustomerType);
          });
      
          toggleCustomerType();
        });
      </script>
    </div>

    <div class="customer-shell">
      <aside class="customer-filter">
        <h2>Khách hàng</h2>
        <form method="get" action="/khach-hang" id="customerFilterForm">
          <section class="customer-filter-section">
            <div class="customer-filter-title-row">
              <h4>Nhóm khách hàng</h4>
              <button class="filter-link-btn" type="button" id="groupAddBtn">Tạo mới</button>
            </div>
            <% var selectedSidebarGroup = customerGroups.find(function(group) { return filter.groupId === String(group._id); }); %>
            <div class="group-manage-wrapper" id="groupManageSidebar">
              <div class="group-manage-header">
                <button class="group-manage-trigger" type="button" id="groupFilterTrigger">
                  <span id="groupFilterSelectedLabel"><%= selectedSidebarGroup ? selectedSidebarGroup.ten_nhom : 'Tất cả các nhóm' %></span>
                  <span>▾</span>
                </button>
              </div>
              <input type="hidden" name="groupId" id="groupFilterValue" value="<%= filter.groupId || 'all' %>">
              <div class="group-manage-dropdown" id="groupFilterDropdown">
                <div class="group-manage-item <%= (!filter.groupId || filter.groupId === 'all') ? 'is-active' : '' %>" data-id="" data-value="all" data-name="Tất cả các nhóm" data-desc="">
                  <button class="group-manage-option" type="button">Tất cả các nhóm</button>
                </div>
                <% customerGroups.forEach(function(group) { %>
                  <div class="group-manage-item <%= filter.groupId === String(group._id) ? 'is-active' : '' %>" data-id="<%= group._id %>" data-value="<%= group._id %>" data-name="<%= group.ten_nhom %>" data-desc="<%= group.mo_ta || '' %>">
                    <button class="group-manage-option" type="button"><%= group.ten_nhom %></button>
                    <div class="group-manage-actions">
                      <button class="group-manage-action-edit" type="button">Sửa</button>
                      <button class="group-manage-action-delete" type="button">Xóa</button>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>
            <h4>Ngày tạo</h4>
            <select name="created" id="createdFilterSelect">
              <option value="all" <%= filter.created === 'all' ? 'selected' : '' %>>Toàn thời gian</option>
              <option value="today" <%= filter.created === 'today' ? 'selected' : '' %>>Hôm nay</option>
              <option value="7days" <%= filter.created === '7days' ? 'selected' : '' %>>7 ngày qua</option>
              <option value="30days" <%= filter.created === '30days' ? 'selected' : '' %>>30 ngày qua</option>
              <option value="custom" <%= filter.created === 'custom' ? 'selected' : '' %>>Tùy chỉnh</option>
            </select>
            <div class="custom-date-range <%= filter.created === 'custom' ? 'is-visible' : '' %>" id="customDateRange">
              <input type="date" name="createdFrom" value="<%= filter.createdFrom || '' %>">
              <input type="date" name="createdTo" value="<%= filter.createdTo || '' %>">
            </div>
            <h4>Người tạo</h4>
            <input type="text" name="creatorKeyword" value="<%= filter.creatorKeyword || '' %>" placeholder="Chọn người tạo">
            <h4>Loại khách hàng</h4>
            <div class="pill-row">
              <button class="pill-btn <%= filter.customerType === 'all' ? 'is-active' : '' %>" type="button" data-target-input="customerTypeInput" data-value="all">Tất cả</button>
              <button class="pill-btn <%= filter.customerType === 'ca_nhan' ? 'is-active' : '' %>" type="button" data-target-input="customerTypeInput" data-value="ca_nhan">Cá nhân</button>
              <button class="pill-btn <%= filter.customerType === 'cong_ty' ? 'is-active' : '' %>" type="button" data-target-input="customerTypeInput" data-value="cong_ty">Công ty</button>
            </div>
            <input type="hidden" id="customerTypeInput" name="customerType" value="<%= filter.customerType || 'all' %>">
            <h4>Giới tính</h4>
            <div class="pill-row">
              <button class="pill-btn <%= filter.gender === 'all' ? 'is-active' : '' %>" type="button" data-target-input="genderInput" data-value="all">Tất cả</button>
              <button class="pill-btn <%= filter.gender === 'nam' ? 'is-active' : '' %>" type="button" data-target-input="genderInput" data-value="nam">Nam</button>
              <button class="pill-btn <%= filter.gender === 'nu' ? 'is-active' : '' %>" type="button" data-target-input="genderInput" data-value="nu">Nữ</button>
            </div>
            <input type="hidden" id="genderInput" name="gender" value="<%= filter.gender || 'all' %>">
            <h4>Tổng bán</h4>
            <div class="range-stack">
              <div class="range-row"><span>Từ</span><input type="number" min="0" name="totalSalesFrom" value="<%= filter.totalSalesFrom || '' %>" placeholder="Nhập giá trị"></div>
              <div class="range-row"><span>Tới</span><input type="number" min="0" name="totalSalesTo" value="<%= filter.totalSalesTo || '' %>" placeholder="Nhập giá trị"></div>
            </div>
            <h4>Nợ hiện tại</h4>
            <div class="range-stack">
              <div class="range-row"><span>Từ</span><input type="number" min="0" name="currentDebtFrom" value="<%= filter.currentDebtFrom || '' %>" placeholder="Nhập giá trị"></div>
              <div class="range-row"><span>Tới</span><input type="number" min="0" name="currentDebtTo" value="<%= filter.currentDebtTo || '' %>" placeholder="Nhập giá trị"></div>
            </div>
            <h4>Khu vực giao hàng</h4>
            <input type="text" name="shippingArea" value="<%= filter.shippingArea || '' %>" placeholder="Chọn Tỉnh/TP - Quận/Huyện">
            <button class="btn btn-primary" type="submit">Áp dụng lọc</button>
            <a class="btn btn-light" href="/khach-hang">Xóa lọc</a>
          </section>
        </form>
      </aside>

      <section class="customer-content">
        <% var filterQueryPrefix = filterQueryString ? filterQueryString + '&' : ''; %>
        <div class="customer-toolbar">
          <div class="customer-search">
            <span>⌕</span>
            <input type="search" name="keyword" form="customerFilterForm" value="<%= filter.keyword || '' %>" placeholder="Theo mã, tên, số điện thoại">
          </div>
          <div class="customer-toolbar-actions">
            <button class="btn btn-primary" type="button" id="openAddCustomerModal">+ Khách hàng</button>
            <a class="btn btn-light" href="/khach-hang/export.xlsx<%= filterQueryString ? '?' + filterQueryString : '' %>">Xuất file</a>
          </div>


        </div>

        <div class="customer-table-wrap">
          <form id="bulkDeleteCustomersForm" method="post" action="/khach-hang/delete-selected">
            <table class="admin-table customer-table">
              <thead>
                <tr>
                  <th class="check-cell"><input id="selectAllCustomers" type="checkbox" aria-label="Chọn tất cả"></th>
                  <th>Mã khách hàng</th>
                  <th>Tên khách hàng</th>
                  <th>Điện thoại</th>
                  <th>Nợ hiện tại</th>
                  <th>Tổng bán</th>
                  <th>Tổng bán trừ trả hàng</th>

                </tr>
              </thead>
              <tbody>
                <tr class="customer-summary-row" style="background-color: #f1f5f9;">
                  <td class="check-cell"></td>
                  <td colspan="3" style="text-align: right; font-weight: bold; color: #1e293b;">Tổng cộng:</td>
                  <td><strong><%= Number(summaryTotals.totalDebt || 0).toLocaleString('vi-VN') %></strong></td>
                  <td><strong><%= Number(summaryTotals.totalSales || 0).toLocaleString('vi-VN') %></strong></td>
                  <td><strong><%= Number(summaryTotals.totalSales || 0).toLocaleString('vi-VN') %></strong></td>
                </tr>
                <% if (customers.length === 0) { %>
                  <tr>
                    <td colspan="7" class="empty-cell">Không có khách hàng phù hợp với bộ lọc.</td>
                  </tr>

                <% } %>
                <% customers.forEach(function(customer) { %>
                  <% var isSelected = selectedCustomer && String(selectedCustomer._id) === String(customer._id); %>
                  <% var rowHref = isSelected ? ('/khach-hang' + (filterQueryString ? '?' + filterQueryString : '')) : ('/khach-hang?' + filterQueryPrefix + 'customer=' + customer._id); %>
                  <tr class="<%= isSelected ? 'is-selected' : '' %>" onclick="window.location.href='<%= rowHref %>'">
                    <td class="check-cell" onclick="event.stopPropagation()"><input class="customer-checkbox" type="checkbox" name="ids" value="<%= customer._id %>" aria-label="Chọn khách hàng"></td>
                    <td><a class="table-code-link" href="<%= rowHref %>"><%= customer.ma_khach_hang || '---' %></a></td>
                    <td><strong><%= customer.ten_khach_hang || '---' %></strong></td>
                    <td><%= customer.sdt || '---' %></td>
                    <td><%= Number(customer.tong_no || 0).toLocaleString('vi-VN') %></td>
                    <td><%= Number(customer.tong_ban || 0).toLocaleString('vi-VN') %></td>
                    <td><%= Number(customer.tong_ban || 0).toLocaleString('vi-VN') %></td>

                  </tr>
                  <% if (isSelected) { %>
                    <tr class="customer-detail-row">
                      <td colspan="7">
                        <div class="customer-detail" data-customer-detail>
                          <div class="detail-tabs">
                            <div class="detail-tab-list">
                              <button class="detail-tab is-active" type="button" data-tab-target="info">Thông tin</button>
                              <button class="detail-tab" type="button" data-tab-target="address">Danh sách địa chỉ</button>
                              <button class="detail-tab" type="button" data-tab-target="orders">Đơn hàng</button>
                              <button class="detail-tab" type="button" data-tab-target="invoices">Hóa đơn</button>
                              <button class="detail-tab" type="button" data-tab-target="returns">Trả hàng</button>
                              <button class="detail-tab" type="button" data-tab-target="debts">Công nợ</button>
                            </div>
                            <button class="detail-collapse-btn" type="button" aria-expanded="true">Thu gọn</button>
                          </div>
                          <div class="customer-detail-body">
                            <div class="customer-detail-pane is-active" data-tab-pane="info">
                                                            <% var c = selectedCustomer; %>
                              <% var isCompany = c.loai_khach_hang === 'cong_ty'; %>
                              <% var fbRaw = (c.facebook || '').trim(); %>
                              <% var fbHref = fbRaw ? (fbRaw.match(/^https?:\/\//i) ? fbRaw : 'https://' + fbRaw.replace(/^\/+/, '')) : ''; %>
                              <div class="store-fields customer-detail-fields">
                                <div>
                                  <span>Mã khách hàng</span>
                                  <strong><%- refLink('customer', c, c.ma_khach_hang || '---') %></strong>
                                </div>
                                <div>
                                  <span>Tên khách hàng</span>
                                  <strong><%= formatDetailText(c.ten_khach_hang) %></strong>
                                </div>
                                <div>
                                  <span>Nhóm khách hàng</span>
                                  <strong><%= formatDetailText(c.nhom_khach_hang_ten) %></strong>
                                </div>
                                <div>
                                  <span>Loại khách hàng</span>
                                  <strong><%= isCompany ? 'Công ty' : 'Cá nhân' %></strong>
                                </div>
                                <div>
                                  <span>Trạng thái</span>
                                  <strong><%= formatCustomerStatusLabel(c.trang_thai) %></strong>
                                </div>
                                <div>
                                  <span>Người tạo</span>
                                  <strong><%= typeof formatCreatorName === 'function' ? formatCreatorName(c) : formatDetailText(c.nguoi_tao_ten) %></strong>
                                </div>
                                <% if (isCompany) { %>
                                  <div>
                                    <span>Tên công ty</span>
                                    <strong><%= formatDetailText(c.ten_cong_ty || c.ten_khach_hang) %></strong>
                                  </div>
                                  <div>
                                    <span>Mã số thuế</span>
                                    <strong><%= formatDetailText(c.ma_so_thue) %></strong>
                                  </div>
                                  <div>
                                    <span>Người đại diện</span>
                                    <strong><%= formatDetailText(c.nguoi_dai_dien) %></strong>
                                  </div>
                                  <div>
                                    <span>Chức vụ người đại diện</span>
                                    <strong><%= formatDetailText(c.chuc_vu_nguoi_dai_dien) %></strong>
                                  </div>
                                <% } else { %>
                                  <div>
                                    <span>Tên cá nhân</span>
                                    <strong><%= formatDetailText(c.ten_ca_nhan || c.ten_khach_hang) %></strong>
                                  </div>
                                  <div>
                                    <span>CCCD</span>
                                    <strong><%= formatDetailText(c.cccd) %></strong>
                                  </div>
                                  <div>
                                    <span>Ngày sinh</span>
                                    <strong><%= formatDateOnly(c.ngay_sinh) %></strong>
                                  </div>
                                  <div>
                                    <span>Giới tính</span>
                                    <strong><%= formatGenderLabel(c.gioi_tinh) %></strong>
                                  </div>
                                <% } %>
                                <div>
                                  <span>Điện thoại</span>
                                  <strong><%= formatDetailText(c.sdt) %></strong>
                                </div>
                                <div>
                                  <span>Điện thoại 2</span>
                                  <strong><%= formatDetailText(c.sdt2) %></strong>
                                </div>
                                <div>
                                  <span>Email</span>
                                  <strong><%= formatDetailText(c.email) %></strong>
                                </div>
                                <div>
                                  <span>Facebook</span>
                                  <strong>
                                    <% if (fbRaw) { %>
                                      <a href="<%= fbHref %>" target="_blank" rel="noopener noreferrer"><%= fbRaw %></a>
                                    <% } else { %>---<% } %>
                                  </strong>
                                </div>
                                <div>
                                  <span>Ngân hàng</span>
                                  <strong><%= formatDetailText(c.ngan_hang) %></strong>
                                </div>
                                <div>
                                  <span>Số tài khoản</span>
                                  <strong><%= formatDetailText(c.stk_ngan_hang) %></strong>
                                </div>
                                <div>
                                  <span>Chủ tài khoản</span>
                                  <strong><%= formatDetailText(c.chu_tai_khoan) %></strong>
                                </div>
                                <div>
                                  <span>Tổng bán</span>
                                  <strong><%= Number(c.tong_ban || 0).toLocaleString('vi-VN') %></strong>
                                </div>
                                <div>
                                  <span>Nợ hiện tại</span>
                                  <strong><%= Number(c.tong_no || 0).toLocaleString('vi-VN') %></strong>
                                </div>
                                <div>
                                  <span>Ngày tạo</span>
                                  <strong><%= formatDate(c.created_at) %></strong>
                                </div>
                                <div>
                                  <span>Cập nhật lúc</span>
                                  <strong><%= formatDate(c.updated_at) %></strong>
                                </div>
                                <div class="customer-detail-field-full">
                                  <span>Ghi chú</span>
                                  <strong class="customer-detail-note"><%= formatDetailText(c.ghi_chu) %></strong>
                                </div>
                              </div>
                            </div>
                            <div class="customer-detail-pane" data-tab-pane="address">
                              <% var returnQuery = filterQueryString ? (filterQueryString + '&customer=' + selectedCustomer._id) : ('customer=' + selectedCustomer._id); %>
                              <table class="admin-table warehouse-table">
                                <thead>
                                  <tr>
                                    <th>Mã địa chỉ</th>
                                    <th>Tên người nhận</th>
                                    <th>SĐT</th>
                                    <th>Địa chỉ</th>
                                    <th>Loại địa chỉ</th>
                                    <th>Tạo lúc</th>
                                    <th>Thao tác</th>
                                  </tr>
                                </thead>
                                <tbody>
                                  <tr class="warehouse-edit-row warehouse-add-row">
                                    <td><input form="addressAddForm_<%= selectedCustomer._id %>" name="ma_dia_chi" placeholder="Tự động" readonly style="background: transparent; border: none;"></td>
                                    <td><input form="addressAddForm_<%= selectedCustomer._id %>" name="ten_nguoi_nhan" placeholder="Tên người nhận"></td>
                                    <td><input form="addressAddForm_<%= selectedCustomer._id %>" name="sdt_nguoi_nhan" placeholder="SĐT"></td>
                                    <td>
                                      <input form="addressAddForm_<%= selectedCustomer._id %>" name="dia_chi_day_du" placeholder="Địa chỉ đầy đủ">
                                    </td>
                                    <td>
                                      <select form="addressAddForm_<%= selectedCustomer._id %>" name="loai_dia_chi">
                                        <% (addressTypes || []).forEach(function(type) { %>
                                          <option value="<%= type.ma_loai %>"><%= type.ten_loai %></option>
                                        <% }) %>
                                      </select>
                                    </td>
                                    <td>--</td>
                                    <td class="warehouse-action-cell">
                                      <div class="warehouse-action-buttons">
                                        <button type="button" class="btn btn-light btn-sm" onclick="this.closest('tr').nextElementSibling.style.display = this.closest('tr').nextElementSibling.style.display === 'none' ? 'table-row' : 'none'">▼</button>
                                        <button
                                          form="addressAddForm_<%= selectedCustomer._id %>"
                                          class="btn btn-primary btn-sm js-address-add"
                                          data-form-id="addressAddForm_<%= selectedCustomer._id %>"
                                          data-action="/khach-hang/<%= selectedCustomer._id %>/addresses/add"
                                          type="submit"
                                        >Thêm</button>
                                      </div>
                                    </td>
                                  </tr>
                                  <tr class="address-detail-row" style="display: none; background-color: #f8fafc;">
                                    <td colspan="7">
                                      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; padding: 15px;">
                                        <div><label style="display:block;margin-bottom:5px;font-weight:bold;font-size:12px;">Số nhà</label><input class="form-control" form="addressAddForm_<%= selectedCustomer._id %>" name="so_nha" placeholder="Số nhà"></div>
                                        <div><label style="display:block;margin-bottom:5px;font-weight:bold;font-size:12px;">Phường/Xã</label><input class="form-control" form="addressAddForm_<%= selectedCustomer._id %>" name="phuong_xa" placeholder="Phường/Xã"></div>
                                        <div><label style="display:block;margin-bottom:5px;font-weight:bold;font-size:12px;">Quận/Huyện</label><input class="form-control" form="addressAddForm_<%= selectedCustomer._id %>" name="quan_huyen" placeholder="Quận/Huyện"></div>
                                        <div><label style="display:block;margin-bottom:5px;font-weight:bold;font-size:12px;">Tỉnh/Thành</label><input class="form-control" form="addressAddForm_<%= selectedCustomer._id %>" name="tinh_thanh" placeholder="Tỉnh/Thành"></div>
                                        <div style="grid-column: span 2;"><label style="display:block;margin-bottom:5px;font-weight:bold;font-size:12px;">Ghi chú</label><input class="form-control" form="addressAddForm_<%= selectedCustomer._id %>" name="ghi_chu" placeholder="Ghi chú"></div>
                                        <div style="grid-column: span 2; display: flex; align-items: center;"><label style="font-size:13px;cursor:pointer;"><input form="addressAddForm_<%= selectedCustomer._id %>" type="checkbox" name="mac_dinh" value="true"> Đặt làm mặc định</label></div>
                                      </div>
                                    </td>
                                  </tr>
                                  <% if (!customerAddresses || customerAddresses.length === 0) { %>
                                    <tr>
                                      <td colspan="7" class="empty-cell">Khách hàng này chưa có địa chỉ.</td>
                                    </tr>
                                  <% } %>
                                  <% (customerAddresses || []).forEach(function(address) { %>
                                    <% var addressFormId = 'addressForm_' + String(address._id); %>
                                    <tr class="warehouse-edit-row">
                                      <td><input form="<%= addressFormId %>" name="ma_dia_chi" value="<%= address.ma_dia_chi || '' %>" readonly style="background: transparent; border: none; cursor: default;"></td>
                                      <td><input form="<%= addressFormId %>" name="ten_nguoi_nhan" value="<%= address.ten_nguoi_nhan || '' %>" required></td>
                                      <td><input form="<%= addressFormId %>" name="sdt_nguoi_nhan" value="<%= address.sdt_nguoi_nhan || '' %>"></td>
                                      <td>
                                        <input form="<%= addressFormId %>" name="dia_chi_day_du" value="<%= address.dia_chi_day_du || [address.so_nha, address.phuong_xa, address.quan_huyen, address.tinh_thanh].filter(Boolean).join(', ') || '' %>">
                                      </td>
                                      <td>
                                        <select form="<%= addressFormId %>" name="loai_dia_chi">
                                          <% (addressTypes || []).forEach(function(type) { %>
                                            <option value="<%= type.ma_loai %>" <%= address.loai_dia_chi === type.ma_loai ? 'selected' : '' %>><%= type.ten_loai %></option>
                                          <% }) %>
                                        </select>
                                      </td>
                                      <td><%= formatDate(address.created_at) %></td>
                                      <td class="warehouse-action-cell">
                                        <div class="warehouse-action-buttons">
                                          <button type="button" class="btn btn-light btn-sm" onclick="this.closest('tr').nextElementSibling.style.display = this.closest('tr').nextElementSibling.style.display === 'none' ? 'table-row' : 'none'">▼</button>
                                          <button
                                            form="<%= addressFormId %>"
                                            class="btn btn-light btn-sm"
                                            type="submit"
                                            onclick="return confirm('Bạn có muốn lưu chỉnh sửa địa chỉ này không?')"
                                          >Lưu</button>
                                          <button
                                            form="addressDeleteForm_<%= address._id %>"
                                            class="btn btn-danger btn-sm"
                                            type="submit"
                                            onclick="return confirm('Bạn có chắc muốn xóa địa chỉ này không?')"
                                          >Xóa</button>
                                        </div>
                                      </td>
                                    </tr>
                                    <tr class="address-detail-row" style="display: none; background-color: #f8fafc;">
                                      <td colspan="7">
                                        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; padding: 15px;">
                                          <div><label style="display:block;margin-bottom:5px;font-weight:bold;font-size:12px;">Số nhà</label><input class="form-control" form="<%= addressFormId %>" name="so_nha" value="<%= address.so_nha || '' %>"></div>
                                          <div><label style="display:block;margin-bottom:5px;font-weight:bold;font-size:12px;">Phường/Xã</label><input class="form-control" form="<%= addressFormId %>" name="phuong_xa" value="<%= address.phuong_xa || '' %>"></div>
                                          <div><label style="display:block;margin-bottom:5px;font-weight:bold;font-size:12px;">Quận/Huyện</label><input class="form-control" form="<%= addressFormId %>" name="quan_huyen" value="<%= address.quan_huyen || '' %>"></div>
                                          <div><label style="display:block;margin-bottom:5px;font-weight:bold;font-size:12px;">Tỉnh/Thành</label><input class="form-control" form="<%= addressFormId %>" name="tinh_thanh" value="<%= address.tinh_thanh || '' %>"></div>
                                          <div style="grid-column: span 2;"><label style="display:block;margin-bottom:5px;font-weight:bold;font-size:12px;">Ghi chú</label><input class="form-control" form="<%= addressFormId %>" name="ghi_chu" value="<%= address.ghi_chu || '' %>"></div>
                                          <div style="grid-column: span 2; display: flex; align-items: center;"><label style="font-size:13px;cursor:pointer;"><input form="<%= addressFormId %>" type="checkbox" name="mac_dinh" value="true" <%= address.mac_dinh ? 'checked' : '' %>> Đặt làm mặc định</label></div>
                                        </div>
                                      </td>
                                    </tr>
                                  <% }) %>
                                </tbody>
                              </table>
                              <form id="addressAddForm_<%= selectedCustomer._id %>" method="post" action="/khach-hang/<%= selectedCustomer._id %>/addresses/add">
                                <input type="hidden" name="returnQuery" value="<%= returnQuery %>">
                              </form>
                              <% (customerAddresses || []).forEach(function(address) { %>
                                <form id="addressForm_<%= address._id %>" method="post" action="/khach-hang/<%= selectedCustomer._id %>/addresses/<%= address._id %>/update">
                                  <input type="hidden" name="returnQuery" value="<%= returnQuery %>">
                                </form>
                                <form id="addressDeleteForm_<%= address._id %>" method="post" action="/khach-hang/<%= selectedCustomer._id %>/addresses/<%= address._id %>/delete">
                                  <input type="hidden" name="returnQuery" value="<%= returnQuery %>">
                                </form>
                              <% }) %>
                            </div>
                            <div class="customer-detail-pane" data-tab-pane="orders">
                              <table class="admin-table warehouse-table">
                                <thead><tr><th>Mã đơn hàng</th><th>Ngày đặt</th><th>Tổng tiền hàng</th><th>Khách cần trả</th><th>Khách đã trả</th><th>Trạng thái đơn</th><th>Giao hàng</th><th>Thao tác</th></tr></thead>
                                <tbody>
                                  <% if (!historyOrders.length) { %>
                                    <tr><td colspan="8" class="empty-cell">Chưa có đơn hàng</td></tr>
                                  <% } %>
                                  <% historyOrders.forEach(function(order) { %>
                                    <tr>
                                      <td><%- refLink('order', order, order.ma_don_hang || '---') %></td>
                                      <td><%= formatDate(order.ngay_dat || order.created_at) %></td>
                                      <td><%= money(order.tong_tien_hang || order.tong_tien || 0) %></td>
                                      <td><%= money(order.tong_thanh_toan || order.tong_tien || 0) %></td>
                                      <td><%= money(order.khach_thanh_toan || order.khach_da_tra || 0) %></td>
                                      <td><%= order.trang_thai || '---' %></td>
                                      <td><%= order.trang_thai_giao_hang || '---' %></td>
                                      <td><a class="btn btn-light btn-sm" href="/don-hang?order=<%= order._id %>">Xem</a></td>
                                    </tr>
                                  <% }) %>
                                </tbody>
                              </table>
                            </div>
                            <div class="customer-detail-pane" data-tab-pane="invoices">
                              <table class="admin-table warehouse-table">
                                <thead><tr><th>Mã hóa đơn</th><th>Ngày bán</th><th>Tổng tiền</th><th>Thanh toán</th><th>Trạng thái</th><th>Đơn hàng</th><th>Thao tác</th></tr></thead>
                                <tbody>
                                  <% if (!historyInvoices.length) { %>
                                    <tr><td colspan="7" class="empty-cell">Chưa có hóa đơn</td></tr>
                                  <% } %>
                                  <% historyInvoices.forEach(function(invoice) { %>
                                    <tr>
                                      <td><%- refLink('invoice', invoice, invoice.ma_hoa_don || '---') %></td>
                                      <td><%= formatDate(invoice.ngay_ban || invoice.created_at) %></td>
                                      <td><%= money(invoice.tong_tien || 0) %></td>
                                      <td><%= money(invoice.thanh_toan || 0) %></td>
                                      <td><%= invoice.trang_thai || '---' %></td>
                                      <td><%- invoice.don_hang_id ? refLink('order', invoice.don_hang_id, invoice.don_hang_id.ma_don_hang || '---') : '---' %></td>
                                      <td>
                                        <a class="btn btn-light btn-sm" href="/don-hang/hoa-don">Xem</a>
                                        <a class="btn btn-light btn-sm" href="/don-hang/tra-hang/create?invoice_id=<%= invoice._id %>">Trả hàng</a>
                                      </td>
                                    </tr>
                                  <% }) %>
                                </tbody>
                              </table>
                            </div>
                            <div class="customer-detail-pane" data-tab-pane="returns">
                              <table class="admin-table warehouse-table">
                                <thead><tr><th>Mã phiếu trả</th><th>Ngày trả</th><th>Hóa đơn gốc</th><th>Tổng tiền trả</th><th>Trạng thái</th><th>Ghi chú</th><th>Thao tác</th></tr></thead>
                                <tbody>
                                  <% if (!historyReturns.length) { %>
                                    <tr><td colspan="7" class="empty-cell">Chưa có phiếu trả hàng</td></tr>
                                  <% } %>
                                  <% historyReturns.forEach(function(ret) { %>
                                    <tr>
                                      <td><%= ret.ma_phieu_tra || '---' %></td>
                                      <td><%= formatDate(ret.ngay_tra || ret.created_at) %></td>
                                      <td><%- ret.hoa_don_id ? refLink('invoice', ret.hoa_don_id, ret.hoa_don_id.ma_hoa_don || '---') : '---' %></td>
                                      <td><%= money(ret.can_tra_khach || ret.tong_tien_tra || 0) %></td>
                                      <td><%= ret.trang_thai || '---' %></td>
                                      <td><%= ret.ghi_chu || '---' %></td>
                                      <td><a class="btn btn-light btn-sm" href="/don-hang/tra-hang?customer=<%= selectedCustomer._id %>">Xem</a></td>
                                    </tr>
                                  <% }) %>
                                </tbody>
                              </table>
                            </div>
                            <div class="customer-detail-pane" data-tab-pane="debts">
                              <table class="admin-table warehouse-table">
                                <thead><tr><th>Ngày</th><th>Loại</th><th>Số tiền</th><th>Hóa đơn</th><th>Đơn hàng</th><th>Phiếu thu chi</th><th>Ghi chú</th></tr></thead>
                                <tbody>
                                  <% if (!historyDebts.length) { %>
                                    <tr><td colspan="7" class="empty-cell">Chưa có công nợ</td></tr>
                                  <% } %>
                                  <% historyDebts.forEach(function(debt) { %>
                                    <tr>
                                      <td><%= formatDate(debt.ngay || debt.created_at) %></td>
                                      <td><%= debt.loai || '---' %></td>
                                      <td><%= money(debt.so_tien || 0) %></td>
                                      <td><%- debt.hoa_don_id ? refLink('invoice', debt.hoa_don_id, debt.hoa_don_id.ma_hoa_don || '---') : '---' %></td>
                                      <td><%- debt.don_hang_id ? refLink('order', debt.don_hang_id, debt.don_hang_id.ma_don_hang || '---') : '---' %></td>
                                      <td><%- debt.phieu_thu_chi_id ? refLink('receipt', debt.phieu_thu_chi_id, debt.phieu_thu_chi_id.ma_phieu || debt.phieu_thu_chi_id.ma_phieu_thu_chi || '---') : '---' %></td>
                                      <td><%= debt.ghi_chu || '---' %></td>
                                    </tr>
                                  <% }) %>
                                </tbody>
                              </table>
                            </div>
                          </div>
                          <div class="customer-detail-footer">
                            <button
                              class="btn btn-success btn-sm btn-edit-customer"
                              type="button"
                              data-customer="<%= encodeURIComponent(JSON.stringify(selectedCustomer)) %>"
                            >Chỉnh sửa</button>
                            <button
                              class="btn btn-danger btn-sm"
                              type="submit"
                              form="deleteCustomerForm_<%= selectedCustomer._id %>"
                              onclick="return confirm('Bạn có chắc muốn xóa khách hàng này không?')"
                            >Xóa</button>
                            <a
                              class="btn btn-success btn-sm customer-detail-export-action"
                              href="/khach-hang/<%= selectedCustomer._id %>/export/info.xlsx"
                              data-export-action
                              data-info-url="/khach-hang/<%= selectedCustomer._id %>/export/info.xlsx"
                              data-info-label="Xuất thông tin"
                              data-info-disabled="0"
                              data-address-url="/khach-hang/<%= selectedCustomer._id %>/export/address.xlsx"
                              data-address-label="Xuất địa chỉ"
                              data-address-disabled="<%= customerAddresses && customerAddresses.length ? '0' : '1' %>"
                              data-orders-url="/khach-hang/<%= selectedCustomer._id %>/export/orders.xlsx"
                              data-orders-label="Xuất đơn hàng"
                              data-orders-disabled="<%= historyOrders.length ? '0' : '1' %>"
                              data-invoices-url="/khach-hang/<%= selectedCustomer._id %>/export/invoices.xlsx"
                              data-invoices-label="Xuất hóa đơn"
                              data-invoices-disabled="<%= historyInvoices.length ? '0' : '1' %>"
                              data-returns-url="/khach-hang/<%= selectedCustomer._id %>/export/returns.xlsx"
                              data-returns-label="Xuất trả hàng"
                              data-returns-disabled="<%= historyReturns.length ? '0' : '1' %>"
                              data-debts-url="/khach-hang/<%= selectedCustomer._id %>/export/debts.xlsx"
                              data-debts-label="Xuất công nợ"
                              data-debts-disabled="<%= historyDebts.length ? '0' : '1' %>"
                            >Xuất thông tin</a>
                          </div>
                        </div>
                      </td>
                    </tr>
                  <% } %>
                <% }) %>
              </tbody>
            </table>
          </form>
          <% customers.forEach(function(customer) { %>
            <form id="deleteCustomerForm_<%= customer._id %>" method="post" action="/khach-hang/<%= customer._id %>/delete"></form>
          <% }) %>
        </div>
      </section>
    </div>
  </main>
