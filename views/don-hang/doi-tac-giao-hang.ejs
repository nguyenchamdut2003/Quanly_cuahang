<%
  const safePartners = Array.isArray(locals.partners) ? locals.partners : [];
  const safeShipmentMap = locals.shipmentMap || {};
  const fmt = value => Number(value || 0).toLocaleString('vi-VN');
  const statusText = status => ({ draft: 'Phiếu tạm', shipping: 'Đang giao hàng', completed: 'Hoàn thành', cancelled: 'Đã hủy' })[status] || 'Phiếu tạm';
%>
<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <style>
    .page{height:calc(100vh - 98px);background:#f3f6f9;padding:14px 12%;display:flex;flex-direction:column;gap:10px}
    .bar{display:flex;align-items:center;justify-content:space-between}.bar-actions{display:flex;align-items:center;gap:8px}h1{font-size:20px;margin:0}.btn{height:32px;border:1px solid #cfd8e3;background:#fff;border-radius:6px;padding:0 12px;font-weight:700;cursor:pointer;color:#111827;text-decoration:none;display:inline-flex;align-items:center;gap:6px}.btn.primary{border-color:#0070f4;color:#0070f4}
    .table-wrap{flex:1;background:#fff;border-radius:6px;overflow:auto}.table{width:100%;border-collapse:collapse}.table th{height:38px;background:#e8f3ff;border-bottom:1px solid #bcd9ff;text-align:left;padding:0 10px;font-size:13px}.table td{height:43px;border-bottom:1px solid #e5e9ee;padding:0 10px;font-size:13px}.table tbody tr{cursor:pointer}.partner-row.active td{background:#f1f8ff;border-top:2px solid #0070f4}.empty{text-align:center;color:#667085;height:220px}
    .detail-row{display:none;cursor:default}.detail-row.open{display:table-row}.detail-cell{padding:0!important;border:2px solid #0070f4!important;border-top:0!important;background:#fff}.partner-detail{padding:0 18px 14px;min-height:280px}.detail-tabs{height:42px;display:flex;align-items:flex-end;gap:26px;border-bottom:1px solid #e5e9ee}.detail-tab{height:42px;border:0;background:#fff;color:#111827;padding:0 0 9px;font-size:14px;cursor:pointer}.detail-tab.active{color:#0070f4;border-bottom:2px solid #0070f4;font-weight:700}.detail-panel{display:none;padding-top:16px}.detail-panel.active{display:block}.detail-form{display:grid;grid-template-columns:1fr 1fr;gap:12px 22px}.detail-actions{height:44px;border-top:1px solid #e5e9ee;display:flex;justify-content:flex-end;align-items:center;gap:8px;margin-top:16px}.mini-table{width:100%;border-collapse:collapse}.mini-table th{height:34px;background:#f3f4f6;border-bottom:1px solid #cfd8e3;font-size:12px;text-align:left;padding:0 10px}.mini-table td{height:40px;border-bottom:1px solid #e5e9ee;font-size:13px;padding:0 10px}.num{text-align:right}.link{color:#006dff;text-decoration:none;font-weight:700}.status-chip{display:inline-flex;align-items:center;height:20px;border-radius:4px;background:#fff4d6;color:#9a6700;padding:0 6px;font-size:12px;font-weight:700}.status-chip.completed{background:#dff7e9;color:#008a3d}.status-chip.cancelled{background:#fee4e2;color:#b42318}.detail-empty{height:140px;text-align:center;color:#667085}
    .modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:3000;align-items:center;justify-content:center}.modal.open{display:flex}.box{width:560px;background:#fff;border-radius:8px;box-shadow:0 18px 42px rgba(0,0,0,.25);overflow:hidden}.head,.foot{height:56px;display:flex;align-items:center;justify-content:space-between;padding:0 18px;border-bottom:1px solid #edf0f3}.foot{border-top:1px solid #edf0f3;border-bottom:0;justify-content:flex-end;gap:8px}.body{padding:16px 18px}.grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}.field label{display:block;font-size:12px;margin-bottom:6px}.input{width:100%;height:32px;border:1px solid #cfd8e3;border-radius:6px;padding:0 10px}.textarea{height:60px;padding-top:8px;resize:vertical}.close{border:0;background:#fff;font-size:18px;cursor:pointer}.save{background:#0070f4;color:#fff;border-color:#0070f4}
  </style>
</head>
<body>
  <%- include('../partials/header') %>
  <main class="page">
    <div class="bar"><h1>Đối tác giao hàng</h1><div class="bar-actions"><button class="btn primary" onclick="openModal()"><i class="fa-solid fa-plus"></i> Đối tác</button><a class="btn" href="/don-hang/doi-tac-giao-hang/export.xlsx"><i class="fa-solid fa-file-export"></i> Xuất file</a></div></div>
    <div class="table-wrap"><table class="table"><thead><tr><th>Mã đối tác</th><th>Tên đối tác / nhà xe</th><th>Điện thoại</th><th>Email</th><th>Địa chỉ</th><th>Trạng thái</th></tr></thead><tbody>
      <% if (safePartners.length) { %>
        <% safePartners.forEach(p => { const shipments = safeShipmentMap[String(p._id)] || []; %>
          <tr class="partner-row" data-partner-row="<%= p._id %>" onclick="togglePartnerDetail('<%= p._id %>')">
            <td><%= p.ma_doi_tac %></td><td><%= p.ten_doi_tac %></td><td><%= p.sdt || '' %></td><td><%= p.email || '' %></td><td><%= p.dia_chi || '' %></td><td><%= p.trang_thai === 'inactive' ? 'Ngừng hoạt động' : 'Đang hoạt động' %></td>
          </tr>
          <tr class="detail-row" data-partner-detail="<%= p._id %>">
            <td class="detail-cell" colspan="6">
              <div class="partner-detail">
                <div class="detail-tabs">
                  <button type="button" class="detail-tab active" data-tab="info" onclick="showPartnerTab(event,'<%= p._id %>','info')">Thông tin</button>
                  <button type="button" class="detail-tab" data-tab="history" onclick="showPartnerTab(event,'<%= p._id %>','history')">Lịch sử vận chuyển</button>
                </div>
                <div class="detail-panel active" data-panel="info">
                  <div class="detail-form">
                    <input type="hidden" data-field="_id" value="<%= p._id %>">
                    <div class="field"><label>Tên đối tác / nhà xe</label><input class="input" data-field="ten_doi_tac" value="<%= p.ten_doi_tac || '' %>"></div>
                    <div class="field"><label>Mã đối tác</label><input class="input" data-field="ma_doi_tac" value="<%= p.ma_doi_tac || '' %>"></div>
                    <div class="field"><label>Điện thoại</label><input class="input" data-field="sdt" value="<%= p.sdt || '' %>"></div>
                    <div class="field"><label>Email</label><input class="input" data-field="email" value="<%= p.email || '' %>"></div>
                    <div class="field" style="grid-column:1/-1"><label>Địa chỉ</label><input class="input" data-field="dia_chi" value="<%= p.dia_chi || '' %>"></div>
                    <div class="field"><label>Trạng thái</label><select class="input" data-field="trang_thai"><option value="active" <%= p.trang_thai !== 'inactive' ? 'selected' : '' %>>Đang hoạt động</option><option value="inactive" <%= p.trang_thai === 'inactive' ? 'selected' : '' %>>Ngừng hoạt động</option></select></div>
                    <div class="field" style="grid-column:1/-1"><label>Ghi chú</label><textarea class="input textarea" data-field="ghi_chu"><%= p.ghi_chu || '' %></textarea></div>
                  </div>
                  <div class="detail-actions"><a class="btn" href="/don-hang/doi-tac-giao-hang/<%= p._id %>/export.xlsx"><i class="fa-solid fa-file-export"></i> Xuất file</a><button type="button" class="btn" onclick="event.stopPropagation();togglePartnerDetail('<%= p._id %>')">Bỏ qua</button><button type="button" class="btn save" onclick="savePartnerInline(event,'<%= p._id %>')">Lưu</button></div>
                </div>
                <div class="detail-panel" data-panel="history">
                  <table class="mini-table">
                    <thead><tr><th>Mã vận đơn</th><th>Thời gian tạo</th><th>Mã đơn/hóa đơn</th><th>Khách hàng</th><th class="num">Phí giao hàng</th><th>Trạng thái</th></tr></thead>
                    <tbody>
                      <% if (shipments.length) { %>
                        <% shipments.forEach(s => { %>
                          <tr><td><a class="link" href="/don-hang/van-don"><%= s.ma_van_don %></a></td><td><%= s.created_at ? new Date(s.created_at).toLocaleString('vi-VN') : '' %></td><td><%= s.hoa_don_id?.ma_hoa_don || s.don_hang_id?.ma_don_hang || '' %></td><td><%= s.khach_hang_id?.ten_khach_hang || s.ten_nguoi_nhan || '' %></td><td class="num"><%= fmt(s.phi_giao_hang) %></td><td><span class="status-chip <%= s.trang_thai === 'completed' ? 'completed' : s.trang_thai === 'cancelled' ? 'cancelled' : '' %>"><%= statusText(s.trang_thai) %></span></td></tr>
                        <% }) %>
                      <% } else { %>
                        <tr><td colspan="6" class="detail-empty">Chưa có đơn vận chuyển từ đối tác này</td></tr>
                      <% } %>
                    </tbody>
                  </table>
                </div>
              </div>
            </td>
          </tr>
        <% }) %>
      <% } else { %><tr><td colspan="6" class="empty">Chưa có đối tác giao hàng</td></tr><% } %>
    </tbody></table></div>
  </main>
  <div class="modal" id="partnerModal"><div class="box"><div class="head"><h2 style="font-size:18px;margin:0">Tạo đối tác giao hàng</h2><button class="close" onclick="closeModal()"><i class="fa-solid fa-xmark"></i></button></div><div class="body">
    <div class="grid">
      <div class="field"><label>Tên đối tác / nhà xe</label><input id="tenDoiTac" class="input" placeholder="Bắt buộc"></div>
      <div class="field"><label>Mã đối tác</label><input id="maDoiTac" class="input" placeholder="Tự động"></div>
      <div class="field"><label>Điện thoại</label><input id="sdt" class="input"></div>
      <div class="field"><label>Email</label><input id="email" class="input"></div>
      <div class="field" style="grid-column:1/-1"><label>Địa chỉ</label><input id="diaChi" class="input"></div>
      <div class="field" style="grid-column:1/-1"><label>Ghi chú</label><textarea id="ghiChu" class="input textarea"></textarea></div>
    </div>
  </div><div class="foot"><button class="btn" onclick="closeModal()">Bỏ qua</button><button class="btn save" onclick="savePartner()">Lưu</button></div></div></div>
  <script>
    function openModal(){document.getElementById('partnerModal').classList.add('open')}
    function closeModal(){document.getElementById('partnerModal').classList.remove('open')}
    function togglePartnerDetail(id){
      const row = document.querySelector('[data-partner-row="' + id + '"]');
      const detail = document.querySelector('[data-partner-detail="' + id + '"]');
      if (!detail) return;
      const shouldOpen = !detail.classList.contains('open');
      document.querySelectorAll('.detail-row').forEach(item => item.classList.remove('open'));
      document.querySelectorAll('.partner-row').forEach(item => item.classList.remove('active'));
      if (!shouldOpen) return;
      detail.classList.add('open');
      row?.classList.add('active');
    }
    function showPartnerTab(event,id,tab){
      event.stopPropagation();
      const detail = document.querySelector('[data-partner-detail="' + id + '"]');
      if (!detail) return;
      detail.querySelectorAll('.detail-tab').forEach(btn => btn.classList.toggle('active', btn.dataset.tab === tab));
      detail.querySelectorAll('.detail-panel').forEach(panel => panel.classList.toggle('active', panel.dataset.panel === tab));
    }
    async function savePartnerInline(event,id){
      event.stopPropagation();
      const detail = document.querySelector('[data-partner-detail="' + id + '"]');
      const payload = {};
      detail.querySelectorAll('[data-field]').forEach(input => { payload[input.dataset.field] = input.value; });
      const res = await fetch('/don-hang/doi-tac-giao-hang/' + id + '/update',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
      const data = await res.json();
      if(!data.success)return alert(data.message||'Không lưu được đối tác giao hàng');
      location.reload();
    }
    async function savePartner(){
      const res = await fetch('/don-hang/doi-tac-giao-hang/add',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ma_doi_tac:maDoiTac.value,ten_doi_tac:tenDoiTac.value,sdt:sdt.value,email:email.value,dia_chi:diaChi.value,ghi_chu:ghiChu.value})});
      const data = await res.json(); if(!data.success)return alert(data.message||'Không lưu được'); location.reload();
    }
  </script>
</body>
</html>
