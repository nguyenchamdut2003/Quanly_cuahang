<%
  const safeInvoices = Array.isArray(locals.invoices) ? locals.invoices : [];
  const safePartners = Array.isArray(locals.partners) ? locals.partners : [];
  const safeUsers = Array.isArray(locals.users) ? locals.users : [];
  const safePriceBooks = Array.isArray(locals.priceBooks) ? locals.priceBooks : [];
  const safeFilters = locals.filters || {};
  const selectedStatuses = Array.isArray(safeFilters.trang_thai) ? safeFilters.trang_thai : (safeFilters.trang_thai ? [safeFilters.trang_thai] : []);
  const selectedTypes = Array.isArray(safeFilters.loai_hoa_don) ? safeFilters.loai_hoa_don : (safeFilters.loai_hoa_don ? [safeFilters.loai_hoa_don] : []);
  const exportParams = new URLSearchParams();
  Object.keys(safeFilters).forEach(key => {
    const value = safeFilters[key];
    if (Array.isArray(value)) {
      value.forEach(item => exportParams.append(key, item));
    } else if (value !== undefined && value !== null && value !== '') {
      exportParams.append(key, value);
    }
  });
  const exportQuery = exportParams.toString();
  const fmt = value => Number(value || 0).toLocaleString('vi-VN');
  const statusText = value => ({
    processing: 'Đang xử lý',
    completed: 'Hoàn thành',
    failed: 'Không giao được',
    cancelled: 'Đã hủy',
    paid: 'Đã thanh toán',
    partial: 'Thanh toán một phần',
    unpaid: 'Chưa thanh toán',
    draft: 'Đang xử lý',
    shipping: 'Đang xử lý',
    done: 'Hoàn thành'
  }[value] || 'Đang xử lý');
  const statusClass = value => {
    if (['completed', 'paid', 'done'].includes(value)) return 'completed';
    if (value === 'partial') return 'partial';
    if (value === 'unpaid') return 'unpaid';
    if (value === 'failed') return 'failed';
    if (value === 'cancelled') return 'cancelled';
    return 'processing';
  };
  const shipStatusText = value => ({ draft: 'Phiếu tạm', shipping: 'Đang giao', completed: 'Hoàn thành', cancelled: 'Đã hủy' }[value] || value || '');
  const invoiceStatus = item => item.trang_thai_chuan || item.trang_thai || 'processing';
  const totalRow = safeInvoices.reduce((sum, item) => {
    sum.goods += Number(item.tong_tien || 0);
    sum.discount += Number(item.giam_gia || 0);
    sum.paid += Number(item.khach_da_tra || 0);
    return sum;
  }, { goods: 0, discount: 0, paid: 0 });
%>
<!DOCTYPE html>
