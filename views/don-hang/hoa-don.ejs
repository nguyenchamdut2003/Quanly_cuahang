<body>
  <%- include('../partials/header') %>
  <form class="page" method="GET" action="/don-hang/hoa-don">
    <div class="shell">
      <aside class="sidebar">
        <h1 class="title">Hóa đơn</h1>
        <div class="filter">
          <div class="filter-title">Thời gian</div>
          <label class="radio"><input type="radio" name="time_type" value="this_month" <%= safeFilters.time_type === 'this_month' ? 'checked' : '' %> onchange="this.form.submit()"><span class="pill">Tháng này <i class="fa-solid fa-chevron-right"></i></span></label>
          <label class="radio"><input type="radio" name="time_type" value="custom" <%= safeFilters.time_type === 'custom' ? 'checked' : '' %>><span class="pill">Tùy chỉnh <i class="fa-regular fa-calendar-days"></i></span></label>
          <input class="control" type="date" name="date_from" value="<%= safeFilters.date_from || '' %>" onchange="this.form.submit()">
          <input class="control" type="date" name="date_to" value="<%= safeFilters.date_to || '' %>" onchange="this.form.submit()">
        </div>
        <div class="filter"><div class="filter-title">Loại hóa đơn</div><label class="check"><input name="loai_hoa_don" value="khong_giao_hang" type="checkbox" <%= !selectedTypes.length || selectedTypes.includes('khong_giao_hang') ? 'checked' : '' %> onchange="this.form.submit()"> Không giao hàng</label><label class="check"><input name="loai_hoa_don" value="giao_hang" type="checkbox" <%= !selectedTypes.length || selectedTypes.includes('giao_hang') ? 'checked' : '' %> onchange="this.form.submit()"> Giao hàng</label></div>
        <div class="filter"><div class="filter-title">Trạng thái hóa đơn</div><label class="check"><input name="trang_thai" value="processing" type="checkbox" <%= !selectedStatuses.length || selectedStatuses.includes('processing') ? 'checked' : '' %> onchange="this.form.submit()"> Đang xử lý</label><label class="check"><input name="trang_thai" value="completed" type="checkbox" <%= !selectedStatuses.length || selectedStatuses.includes('completed') ? 'checked' : '' %> onchange="this.form.submit()"> Hoàn thành</label><label class="check"><input name="trang_thai" value="failed" type="checkbox" <%= selectedStatuses.includes('failed') ? 'checked' : '' %> onchange="this.form.submit()"> Không giao được</label><label class="check"><input name="trang_thai" value="cancelled" type="checkbox" <%= selectedStatuses.includes('cancelled') ? 'checked' : '' %> onchange="this.form.submit()"> Đã hủy</label></div>
        <div class="filter"><div class="filter-title">Trạng thái giao hàng</div><select class="control" name="trang_thai_giao_hang" onchange="this.form.submit()"><option value="all">Chọn trạng thái</option><option value="draft" <%= safeFilters.trang_thai_giao_hang === 'draft' ? 'selected' : '' %>>Phiếu tạm</option><option value="shipping" <%= safeFilters.trang_thai_giao_hang === 'shipping' ? 'selected' : '' %>>Đang giao</option><option value="completed" <%= safeFilters.trang_thai_giao_hang === 'completed' ? 'selected' : '' %>>Hoàn thành</option><option value="cancelled" <%= safeFilters.trang_thai_giao_hang === 'cancelled' ? 'selected' : '' %>>Đã hủy</option></select></div>
        <div class="filter"><div class="filter-title">Đối tác giao hàng</div><select class="control" name="doi_tac" onchange="this.form.submit()"><option value="all">Chọn đối tác giao hàng</option><% safePartners.forEach(p => { %><option value="<%= p._id %>" <%= String(safeFilters.doi_tac || '') === String(p._id) ? 'selected' : '' %>><%= p.ten_doi_tac %></option><% }) %></select></div>
        <div class="filter"><div class="filter-title">Thời gian giao hàng</div><label class="radio"><input type="radio" name="delivery_time_type" value="all" <%= safeFilters.delivery_time_type !== 'custom' ? 'checked' : '' %>><span class="pill">Toàn thời gian <i class="fa-solid fa-chevron-right"></i></span></label><label class="radio"><input type="radio" name="delivery_time_type" value="custom" <%= safeFilters.delivery_time_type === 'custom' ? 'checked' : '' %>><span class="pill">Tùy chỉnh <i class="fa-regular fa-calendar-days"></i></span></label><input class="control" type="date" name="delivery_from" value="<%= safeFilters.delivery_from || '' %>" onchange="this.form.submit()"><input class="control" type="date" name="delivery_to" value="<%= safeFilters.delivery_to || '' %>" onchange="this.form.submit()"></div>
        <div class="filter"><div class="filter-title">Khu vực giao hàng</div><input class="control" name="khu_vuc" value="<%= safeFilters.khu_vuc || '' %>" placeholder="Chọn Tỉnh/TP - Quận/Huyện"></div>
        <div class="filter"><div class="filter-title">Phương thức thanh toán</div><select class="control" name="phuong_thuc_tt" onchange="this.form.submit()"><option value="">Chọn phương thức thanh toán...</option><option value="Tiền mặt" <%= safeFilters.phuong_thuc_tt === 'Tiền mặt' ? 'selected' : '' %>>Tiền mặt</option><option value="COD" <%= safeFilters.phuong_thuc_tt === 'COD' ? 'selected' : '' %>>COD</option><option value="chuyen_khoan" <%= safeFilters.phuong_thuc_tt === 'chuyen_khoan' ? 'selected' : '' %>>Chuyển khoản</option></select></div>
        <div class="filter"><div class="filter-title">Người tạo</div><input class="control" name="nguoi_tao" value="<%= safeFilters.nguoi_tao || '' %>" list="userList" placeholder="Chọn người tạo"></div>
        <div class="filter"><div class="filter-title">Người bán</div><input class="control" name="nguoi_ban" value="<%= safeFilters.nguoi_ban || '' %>" list="userList" placeholder="Chọn người bán"></div>
        <div class="filter"><div class="filter-title">Bảng giá</div><select class="control" name="bang_gia"><option value="">Chọn bảng giá</option><% safePriceBooks.forEach(p => { %><option value="<%= p._id %>" <%= String(safeFilters.bang_gia || '') === String(p._id) ? 'selected' : '' %>><%= p.ten_bang_gia %></option><% }) %></select></div>
        <div class="filter"><div class="filter-title">Kênh bán <a href="#" class="small-link">Tạo mới</a></div><select class="control" name="kenh_ban"><option value="">Chọn kênh bán</option><option value="ban_truc_tiep" <%= safeFilters.kenh_ban === 'ban_truc_tiep' ? 'selected' : '' %>>Bán trực tiếp</option><option value="online" <%= safeFilters.kenh_ban === 'online' ? 'selected' : '' %>>Online</option></select></div>
        <datalist id="userList"><% safeUsers.forEach(u => { %><option value="<%= u.ho_ten || u.username || u.email %>"></option><% }) %></datalist>
      </aside>
      <main class="main">
        <div class="toolbar">
          <div class="search"><i class="fa-solid fa-magnifying-glass"></i><input name="q" value="<%= safeFilters.q || '' %>" placeholder="Theo mã hóa đơn"><button type="submit"><i class="fa-solid fa-sliders"></i></button></div>
          <div class="actions">
            <div class="dropdown" id="createDropdown"><button class="btn primary" type="button" onclick="toggleCreateMenu(event)"><i class="fa-solid fa-plus"></i> Tạo mới <i class="fa-solid fa-chevron-down"></i></button><div class="dropdown-menu"><span class="dropdown-item disabled">Vận đơn KShip</span><a class="dropdown-item" href="/don-hang/hoa-don/create">Hóa đơn</a></div></div>
            <a href="/don-hang/hoa-don/export.xlsx<%= exportQuery ? '?' + exportQuery : '' %>" class="btn"><i class="fa-solid fa-file-export"></i> Xuất file <i class="fa-solid fa-chevron-down"></i></a>
          </div>
        </div>
        <div class="table-wrap">
          <table class="table">
            <thead><tr><th class="check-col"><input type="checkbox"></th><th class="star-col"><i class="fa-regular fa-star"></i></th><th>Mã hóa đơn</th><th>Thời gian</th><th>Mã trả hàng</th><th>Mã KH</th><th>Khách hàng</th><th>Tổng tiền hàng</th><th>Giảm giá</th><th>Khách đã trả</th><th>Trạng thái</th></tr></thead>
            <tbody>
              <tr><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td><strong><%= fmt(totalRow.goods) %></strong></td><td><strong><%= fmt(totalRow.discount) %></strong></td><td><strong><%= fmt(totalRow.paid) %></strong></td><td></td></tr>
              <% if (safeInvoices.length) { %>
                <% safeInvoices.forEach(i => { const st = invoiceStatus(i); %>
                  <tr class="invoice-row" data-invoice-row="<%= i._id %>" onclick="toggleInvoiceDetail('<%= i._id %>')"><td class="check-col"><input type="checkbox" onclick="event.stopPropagation()"></td><td class="star-col"><i class="fa-regular fa-star"></i></td><td><%- refLink('invoice', i, i.ma_hoa_don || '', 'onclick="event.stopPropagation()"') %></td><td><%= i.ngay_ban ? new Date(i.ngay_ban).toLocaleString('vi-VN') : '' %></td><td><%= i.phieu_tra_hang?.ma_phieu_tra || '' %></td><td><%- i.khach_hang_id ? refLink('customer', i.khach_hang_id, i.khach_hang_id.ma_khach_hang || '', 'onclick="event.stopPropagation()"') : '' %></td><td><%= i.khach_hang_id ? i.khach_hang_id.ten_khach_hang : 'Khách lẻ' %></td><td><%= fmt(i.tong_tien) %></td><td><%= fmt(i.giam_gia) %></td><td><%= fmt(i.khach_da_tra) %></td><td><span class="status <%= statusClass(st) %>"><%= statusText(st) %></span></td></tr>
                  <tr class="detail-row" data-invoice-detail="<%= i._id %>"><td class="detail-cell" colspan="11"><div class="invoice-detail"><div class="loading-detail">Đang tải thông tin hóa đơn...</div></div></td></tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="11" class="empty">Chưa có hóa đơn</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
        <div class="pager"><span>Hiển thị</span><select><option>15 dòng</option><option>30 dòng</option><option>50 dòng</option></select></div>
      </main>
    </div>
  </form>
  <script>
    const money = value => Number(value || 0).toLocaleString('vi-VN');
    const escapeHtml = value => String(value ?? '').replace(/[&<>"']/g, char => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[char]));
    const refAnchor = (href, text) => href ? `<a class="ref-link" href="${escapeHtml(href)}" onclick="event.stopPropagation()">${escapeHtml(text || '--')}</a>` : escapeHtml(text || '--');
    const invoiceStatusText = value => ({
      processing: 'Đang xử lý',
      completed: 'Hoàn thành',
      failed: 'Không giao được',
      cancelled: 'Đã hủy',
      paid: 'Đã thanh toán',
      partial: 'Thanh toán một phần',
      unpaid: 'Chưa thanh toán',
      draft: 'Đang xử lý',
      shipping: 'Đang xử lý',
      done: 'Hoàn thành'
    }[value] || 'Đang xử lý');
    const invoiceStatusClass = value => {
      if (['completed', 'paid', 'done'].includes(value)) return 'completed';
      if (value === 'partial') return 'partial';
      if (value === 'unpaid') return 'unpaid';
      if (value === 'failed') return 'failed';
      if (value === 'cancelled') return 'cancelled';
      return 'processing';
    };
    const shipmentStatusText = value => ({ draft:'Phiếu tạm', shipping:'Đang giao', completed:'Hoàn thành', cancelled:'Đã hủy' }[value] || value || '');

    function toggleCreateMenu(event) {
      event.stopPropagation();
      document.getElementById('createDropdown').classList.toggle('open');
    }
    document.addEventListener('click', () => document.getElementById('createDropdown')?.classList.remove('open'));

    async function toggleInvoiceDetail(id) {
      const row = document.querySelector('[data-invoice-row="' + id + '"]');
      const detailRow = document.querySelector('[data-invoice-detail="' + id + '"]');
      if (!detailRow) return;
      const shouldOpen = !detailRow.classList.contains('open');
      document.querySelectorAll('.detail-row').forEach(item => item.classList.remove('open'));
      document.querySelectorAll('.invoice-row').forEach(item => item.classList.remove('active'));
      if (!shouldOpen) return;
      detailRow.classList.add('open');
      row?.classList.add('active');
      if (detailRow.dataset.loaded === 'true') return;
      const res = await fetch('/don-hang/hoa-don/' + id + '/detail');
      const data = await res.json();
      if (!data.success) return alert(data.message || 'Không tải được hóa đơn');
      detailRow.querySelector('.invoice-detail').innerHTML = renderInvoiceDetail(data.data);
      detailRow.dataset.loaded = 'true';
    }

    function showInvoiceTab(event, id, tab) {
      event.stopPropagation();
      const detail = document.querySelector('[data-invoice-detail="' + id + '"]');
      detail.querySelectorAll('.tab').forEach(btn => btn.classList.toggle('active', btn.dataset.tab === tab));
      detail.querySelectorAll('.panel').forEach(panel => panel.classList.toggle('active', panel.dataset.panel === tab));
    }

    function renderInvoiceDetail(data) {
      const invoice = data.invoice || {};
      const customer = invoice.khach_hang_id || {};
      const shipment = data.shipment || {};
      const items = data.items || [];
      const histories = [...(data.debtHistory || []), ...(data.receipts || [])];
      const paid = Number(data.paid || 0);
      const payable = Number(invoice.thanh_toan || 0);
      const debt = Number(data.debt || Math.max(payable - paid, 0));
      const status = invoice.trang_thai_chuan || invoice.trang_thai || 'processing';
      const itemRows = items.map(item => {
        const product = item.hang_hoa_id || {};
        return `<tr><td>${refAnchor(product._id ? '/hang-hoa/' + product._id : '', product.ma_hang || '')}</td><td>${escapeHtml(product.ten_hang || '')}</td><td>${money(item.so_luong)}</td><td>${money(item.don_gia)}</td><td>${money(item.chiet_khau)}</td><td><strong>${money(item.thanh_tien)}</strong></td></tr>`;
      }).join('') || '<tr><td colspan="6" class="loading-detail">Hóa đơn chưa có hàng hóa</td></tr>';
      const historyRows = histories.map(item => {
        const receipt = item.phieu_thu_chi_id || item;
        const code = receipt.ma_phieu || 'Công nợ';
        const receiptHref = receipt._id ? '/so-quy/phieu-thu-chi/' + receipt._id : '';
        const date = new Date(item.ngay || receipt.ngay_lap || receipt.created_at || invoice.ngay_ban).toLocaleString('vi-VN');
        const amount = Math.abs(Number(item.so_tien || receipt.gia_tri || 0));
        const type = receipt.loai_phieu ? (receipt.loai_phieu === 'chi' ? 'Chi' : 'Thu') : (item.loai || '');
        return `<tr><td>${refAnchor(receiptHref, code)}</td><td>${escapeHtml(date)}</td><td>${escapeHtml(receipt.nguoi_tao_id?.ho_ten || '')}</td><td>${money(amount)}</td><td>${escapeHtml(receipt.loai_thu_chi || receipt.phuong_thuc_tt || receipt.phuong_thuc_thanh_toan || '')}</td><td><span class="status completed">${escapeHtml(type)}</span></td><td>${money(amount)}</td></tr>`;
      }).join('') || '<tr><td colspan="7" class="loading-detail">Chưa có lịch sử thanh toán hoặc công nợ</td></tr>';
      const shipmentPanel = shipment._id ? `
        <div class="panel" data-panel="shipping">
          <div class="ship-grid">
            <div class="mini-field"><label>Đối tác giao hàng</label><span>${escapeHtml(shipment.doi_tac_giao_hang_id?.ten_doi_tac || 'Tự giao hàng')}</span></div>
            <div class="mini-field"><label>Phí giao hàng</label><span>${money(shipment.phi_giao_hang)}</span></div>
            <div class="mini-field"><label>Trạng thái giao hàng</label><span>${escapeHtml(shipmentStatusText(shipment.trang_thai))}</span></div>
            <div class="mini-field"><label>Ngày giao</label><span>${shipment.updated_at ? escapeHtml(new Date(shipment.updated_at).toLocaleString('vi-VN')) : ''}</span></div>
          </div>
        </div>` : '<div class="panel" data-panel="shipping"><div class="loading-detail">Hóa đơn không có vận đơn</div></div>';

      return `
        <div class="tabs">
          <button type="button" class="tab active" data-tab="info" onclick="showInvoiceTab(event,'${invoice._id}','info')">Thông tin</button>
          <button type="button" class="tab" data-tab="payment" onclick="showInvoiceTab(event,'${invoice._id}','payment')">Thanh toán</button>
          <button type="button" class="tab" data-tab="shipping" onclick="showInvoiceTab(event,'${invoice._id}','shipping')">Giao hàng</button>
        </div>
        <div class="panel active" data-panel="info">
          <div class="detail-head">
            <div>
              <div><span class="detail-title">${escapeHtml(customer.ten_khach_hang || 'Khách lẻ')}</span> <span>${refAnchor(invoice._id ? '/hoa-don/' + invoice._id : '', invoice.ma_hoa_don || '')}</span> <span class="status ${escapeHtml(invoiceStatusClass(status))}">${escapeHtml(invoiceStatusText(status))}</span></div>
              <div class="detail-meta">
                <div class="mini-field"><label>Người tạo</label><span>${escapeHtml(invoice.nguoi_ban_id?.ho_ten || invoice.nguoi_ban_id?.username || '')}</span></div>
                <div class="mini-field"><label>Người bán</label><span>${escapeHtml(invoice.nguoi_ban_id?.ho_ten || invoice.nguoi_ban_id?.username || '')}</span></div>
                <div class="mini-field"><label>Ngày bán</label><span>${escapeHtml(new Date(invoice.ngay_ban || invoice.created_at).toLocaleString('vi-VN'))}</span></div>
                <div class="mini-field"><label>Kho</label><span>${escapeHtml(invoice.kho_id?.ten_kho || invoice.kho_id?.ma_kho || '')}</span></div>
                <div class="mini-field"><label>Đơn hàng</label><span>${refAnchor(invoice.don_hang_id?._id ? '/don-hang/' + invoice.don_hang_id._id : '', invoice.don_hang_id?.ma_don_hang || '')}</span></div>
                <div class="mini-field"><label>Kênh bán</label><span>Bán trực tiếp</span></div>
              </div>
            </div>
            <div>${escapeHtml(invoice.cua_hang_id?.ten_cua_hang || 'Chi nhánh trung tâm')}</div>
          </div>
          <table class="items-table"><thead><tr><th>Mã hàng</th><th>Tên hàng</th><th>Số lượng</th><th>Đơn giá</th><th>Giảm giá</th><th>Thành tiền</th></tr></thead><tbody>${itemRows}</tbody></table>
          <div class="detail-bottom">
            <div class="note">${escapeHtml(invoice.ghi_chu || 'Ghi chú')}</div>
            <div>
              <div class="total-line"><span>Tổng tiền hàng (${items.length})</span><strong>${money(invoice.tong_tien)}</strong></div>
              <div class="total-line"><span>Giảm giá hóa đơn</span><span>${money(invoice.giam_gia)}</span></div>
              <div class="total-line"><span>Khách cần trả</span><strong>${money(payable)}</strong></div>
              <div class="total-line"><span>Khách đã trả</span><strong>${money(paid)}</strong></div>
              <div class="total-line"><span>Còn nợ</span><strong>${money(debt)}</strong></div>
            </div>
          </div>
          <div class="page-actions page-actions--split page-actions--bordered detail-actions">
            <div class="page-actions__left detail-action-group"><button type="button" class="btn" onclick="cancelInvoice('${invoice._id}')"><i class="fa-regular fa-trash-can"></i> Hủy</button><a class="btn" href="/don-hang/hoa-don/create?copy_from=${invoice._id}"><i class="fa-regular fa-copy"></i> Sao chép</a><a class="btn" href="/don-hang/hoa-don/${invoice._id}/export.xlsx"><i class="fa-solid fa-file-export"></i> Xuất file</a></div>
            <div class="page-actions__right detail-action-group"><a class="btn" href="/don-hang/tra-hang/create?hoa_don_id=${invoice._id}"><i class="fa-solid fa-right-left"></i> Trả hàng</a>${invoice.don_hang_id ? `<a class="btn" href="/chung-tu-kho/ban-hang/${invoice.don_hang_id._id || invoice.don_hang_id}" target="_blank"><i class="fa-solid fa-print"></i> In</a>` : `<a class="btn" href="/chung-tu-kho/hoa-don-ban/${invoice._id}" target="_blank"><i class="fa-solid fa-print"></i> In</a>`}</div>
          </div>
        </div>
        <div class="panel" data-panel="payment"><table class="items-table"><thead><tr><th>Mã phiếu</th><th>Thời gian</th><th>Người tạo</th><th>Giá trị</th><th>Phương thức</th><th>Loại</th><th>Tiền thu/chi</th></tr></thead><tbody>${historyRows}</tbody></table></div>
        ${shipmentPanel}`;
    }

    async function cancelInvoice(id) {
      if (!confirm('Hủy hóa đơn này? Hệ thống sẽ hoàn kho, hủy phiếu thu, đảo công nợ và hủy vận đơn liên quan.')) return;
      const res = await fetch('/don-hang/hoa-don/' + id + '/cancel', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
      const data = await res.json();
      if (!data.success) return alert(data.message || 'Không hủy được hóa đơn');
      location.reload();
    }

    document.addEventListener('DOMContentLoaded', () => {
      const invoiceId = new URLSearchParams(window.location.search).get('invoice');
      if (!invoiceId) return;
      const row = document.querySelector('[data-invoice-row="' + invoiceId + '"]');
      if (!row) return;
      toggleInvoiceDetail(invoiceId);
      row.scrollIntoView({ block: 'center' });
    });
  </script>
</body>
</html>
