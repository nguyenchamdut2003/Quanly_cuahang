      async function saveOrder() {
        if (existingInvoice) return alert('Đơn hàng này đã có hóa đơn ' + (existingInvoice.ma_hoa_don || ''));
        if (!cart.length) return alert('Hóa đơn chưa có sản phẩm');
        if (!document.getElementById('khoId').value) return alert('Vui lòng chọn kho.');
        if (!customerId.value) return alert('Vui lòng chọn khách hàng.');
        const wantsShipping = codEnabled || Boolean(partnerId.value) || num(shippingFee.value) > 0;
        if (wantsShipping && !partnerId.value) return alert('Vui lòng chọn đối tác giao hàng');
        if (wantsShipping && !getRecipientAddressId()) return alert('Vui lòng chọn địa chỉ nhận hàng của khách.');
        if (num(shippingFee.value) < 0) return alert('Phí giao hàng không được âm.');
        if (!sourceOrder && cart.some(item => Number(item.so_luong || 0) > stockFor(item.hang_hoa_id))) alert('Hóa đơn này đang vượt tồn hiện có. Hóa đơn không trừ kho trong flow này.');
        const recipientCustomer = customers.find(x => x._id === recipientCustomerId.value);
        const noteInput = document.getElementById('deliveryNote');
        const payable = lastTotals.khachCanTra;
        const shippingAddress = getShippingEndPoint();
        const data = {
          khach_hang_id: customerId.value,
          cua_hang_id: pickupStoreId.value,
          kho_id: document.getElementById('khoId').value,
          bang_gia_id: selectedPriceBookId(),
          don_hang_id: sourceOrder ? sourceOrder._id : undefined,
          items: cart.map(item => ({
            hang_hoa_id: item.hang_hoa_id,
            so_luong: item.so_luong,
            don_gia_ban: item.don_gia_ban,
            chiet_khau: item.chiet_khau || 0,
            kieu_chiet_khau: item.kieu_chiet_khau || 'vnd'
          })),
          chiet_khau: num(discount.value),
          kieu_giam_gia: orderDiscountType.value,
          phi_van_chuyen: num(shippingFee.value),
          diem_di: getShippingStartPoint(),
          diem_den: shippingAddress,
          khoang_cach_km: num(shippingDistance.value),
          ghi_chu: '',
          doi_tac_giao_hang_id: partnerId.value,
          dia_chi_khach_hang_id: getRecipientAddressId(),
          nguoi_tra_phi_giao_hang: shippingFeePayer.value,
          ten_nguoi_nhan: recipientCustomer ? recipientCustomer.ten_khach_hang : '',
          sdt_nguoi_nhan: recipientPhone.value,
          dia_chi_nhan: shippingAddress,
          ghi_chu_giao_hang: noteInput ? noteInput.value : '',
          thu_ho_cod: codEnabled,
          cod_enabled: codEnabled,
          cod_amount: codEnabled ? payable : 0,
          khach_can_tra: lastTotals.khachCanTra,
          khach_thanh_toan: lastTotals.khachThanhToan,
          tien_thua_tra_khach: lastTotals.tienThuaTraKhach
        };
        try {
          const res = await fetch('/don-hang/hoa-don/create', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
          const result = await res.json();
          if (!result.success) return alert(result.message || 'Không tạo được hóa đơn');
          window.location.href = '/don-hang/hoa-don';
        } catch (err) {
          alert(err.message || 'Lỗi khi tạo hóa đơn');
        }
      }
      document.addEventListener('DOMContentLoaded', () => {
        if (copyFromError) alert(copyFromError);
        renderPickupStore();
        loadKhoByStore().then(async () => {
          await prefillFromSourceOrder();
          await prefillFromCopyInvoice();
        });
        renderCod();
        document.getElementById('khoId').addEventListener('change', handleWarehouseChange);
      });
      document.addEventListener('click', e => { if (!partnerPicker.contains(e.target)) partnerPicker.classList.remove('open'); });
    </script>
</body>

</html>
