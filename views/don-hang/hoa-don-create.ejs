<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  <title>
    <%= title %>
  </title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <style>
    body {
      overflow: hidden;
      background: #e9edf2;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    .order-create,
    .order-create input,
    .order-create select,
    .order-create button,
    .order-create table {
      font-family: inherit;
    }

    .order-create {
      height: calc(100vh - 98px);
      display: grid;
      grid-template-columns: minmax(0, 45fr) minmax(360px, 30fr) minmax(320px, 25fr);
      gap: 10px;
      padding: 12px 10px 0
    }

    .left,
    .middle,
    .right {
      background: #fff;
      border-radius: 8px;
      display: flex;
      flex-direction: column;
      overflow: hidden
    }

    .left {
      background: #e9edf2
    }

    .top-search {
      height: 38px;
      position: relative;
      margin-bottom: 10px
    }

    .top-search i {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      color: #667085
    }

    .top-search input {
      width: 460px;
      max-width: 100%;
      height: 38px;
      border: 1px solid #d0d7de;
      border-radius: 6px;
      padding: 0 12px 0 36px;
      font-size: 14px
    }

    .search-results {
      display: none;
      position: absolute;
      top: 42px;
      left: 0;
      width: 460px;
      background: #fff;
      border: 1px solid #cfd8e3;
      border-radius: 6px;
      box-shadow: 0 8px 22px rgba(0, 0, 0, .14);
      z-index: 50;
      max-height: 300px;
      overflow: auto
    }

    .search-item {
      height: 42px;
      padding: 0 12px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 13px;
      cursor: pointer
    }

    .search-item:hover {
      background: #f0f7ff
    }

    .search-item.product-search-item {
      height: auto;
      min-height: 52px;
      padding: 7px 12px;
      gap: 12px
    }

    .search-item-info {
      min-width: 0
    }

    .search-item-main {
      display: block;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis
    }

    .search-item-meta {
      display: block;
      margin-top: 3px;
      color: #667085;
      font-size: 12px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis
    }

    .search-item-price {
      flex: 0 0 auto
    }

    .cart-area {
      flex: 1;
      background: #e9edf2
    }

    .summary-card {
      min-height: 168px;
      background: #fff;
      border-radius: 8px;
      padding: 18px 26px;
      display: grid;
      grid-template-columns: 1fr 430px;
      gap: 20px;
      align-items: start
    }

    .note-line {
      color: #667085;
      font-size: 14px
    }

    .totals {
      font-size: 16px
    }

    .total-line {
      display: flex;
      justify-content: space-between;
      margin-bottom: 14px
    }

    .total-line strong {
      font-weight: 800
    }

    .payable {
      color: #006dff;
      font-size: 22px
    }

    .cart-table {
      width: 100%;
      border-collapse: collapse;
      background: #fff;
      border-radius: 8px;
      overflow: hidden
    }

    .cart-table th {
      height: 36px;
      background: #e8f3ff;
      text-align: left;
      padding: 0 10px;
      border-bottom: 1px solid #bcd9ff
    }

    .cart-table td {
      height: 40px;
      border-bottom: 1px solid #e5e9ee;
      padding: 0 10px
    }

    .num {
      text-align: right
    }

    .small {
      width: 74px;
      height: 28px;
      border: 1px solid #cfd8e3;
      border-radius: 5px;
      text-align: right;
      padding: 0 6px
    }

    .discount-pair {
      display: inline-flex;
      gap: 6px;
      align-items: center;
      justify-content: flex-end;
    }

    .discount-pair select {
      width: 70px;
      height: 28px;
      border: 1px solid #cfd8e3;
      border-radius: 5px;
      background: #fff;
    }

    .stock-text {
      display: block;
      margin-top: 3px;
      color: #667085;
      font-size: 12px;
    }

    .middle {
      padding: 14px 24px
    }

    .mid-head {
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 8px
    }

    .customer-search {
      position: relative;
      margin-bottom: 16px
    }

    .customer-search input {
      width: 100%;
      height: 38px;
      border: 0;
      background: #f0f2f5;
      border-radius: 5px;
      padding: 0 42px 0 32px;
      font-size: 16px
    }

    .customer-search i {
      position: absolute;
      left: 10px;
      top: 50%;
      transform: translateY(-50%);
      color: #667085
    }

    .customer-search button {
      position: absolute;
      right: 8px;
      top: 5px;
      border: 0;
      background: transparent;
      font-size: 24px;
      cursor: pointer
    }

    .section-line {
      display: grid;
      grid-template-columns: 22px 1fr;
      gap: 10px;
      margin-bottom: 14px
    }

    .marker {
      display: flex;
      justify-content: center;
      color: #0070f4;
      font-size: 20px
    }

    .marker.green {
      color: #00a651
    }

    .line-input {
      height: 38px;
      border: 0;
      border-bottom: 1px solid #c2cad3;
      padding: 0;
      font-size: 16px;
      outline: none
    }

    .two {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px
    }

    .muted-red {
      color: red;
      font-size: 12px;
      margin-top: -8px
    }

    .package {
      border-top: 1px solid #edf0f3;
      padding-top: 12px;
      margin-top: 12px
    }

    .package-title {
      font-size: 16px;
      margin-bottom: 10px
    }

    .pkg-grid {
      display: grid;
      grid-template-columns: 70px 84px 1fr;
      gap: 12px;
      align-items: center
    }

    .pkg-input {
      height: 30px;
      border: 0;
      border-bottom: 1px solid #c2cad3;
      text-align: center
    }

    .cod {
      margin-top: auto;
      border-top: 1px solid #edf0f3;
      padding-top: 14px
    }

    .cod-row {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      margin-top: 12px;
      color: #667085;
    }

    .cod-row strong {
      color: #111827;
    }

    .toggle {
      display: inline-block;
      width: 42px;
      height: 20px;
      background: #9aa4b2;
      border-radius: 999px;
      vertical-align: middle;
      margin-left: 10px;
      position: relative;
      cursor: pointer;
      transition: .2s
    }

    .toggle:before {
      content: '';
      position: absolute;
      width: 18px;
      height: 18px;
      left: 1px;
      top: 1px;
      background: #fff;
      border-radius: 50%;
      box-shadow: 0 1px 4px rgba(0, 0, 0, .25);
      transition: .2s
    }

    .toggle.on {
      background: #0070f4
    }

    .toggle.on:before {
      transform: translateX(22px)
    }

    .right {
      padding: 0
    }

    .tabs {
      height: 38px;
      display: grid;
      grid-template-columns: 1fr;
      border-bottom: 1px solid #d7dde5
    }

    .tab {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-weight: 700;
      color: #0070f4;
      border-bottom: 2px solid #0070f4
    }

    .right-body {
      padding: 22px 20px
    }

    .delivery-row {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-bottom: 18px
    }

    .delivery-row label {
      font-size: 13px;
      font-weight: 800;
      color: #344054
    }

    .delivery-input {
      width: 100%;
      height: 38px;
      border: 1px solid #cfd8e3;
      border-radius: 6px;
      padding: 0 12px;
      font-size: 14px;
      background: #fff;
    }

    .delivery-help {
      min-height: 18px;
      color: #667085;
      font-size: 12px;
    }

    .partner-picker {
      position: relative
    }

    .partner-trigger {
      width: 100%;
      min-height: 38px;
      border: 1px solid #cfd8e3;
      border-radius: 7px;
      background: #fff;
      color: #344054;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      padding: 0 11px;
      font-size: 14px;
      cursor: pointer
    }

    .partner-trigger.empty {
      color: #667085
    }

    .partner-menu {
      display: none;
      position: absolute;
      top: calc(100% + 4px);
      left: 0;
      right: 0;
      max-height: 230px;
      overflow: auto;
      background: #fff;
      border: 1px solid #cfd8e3;
      border-radius: 8px;
      box-shadow: 0 12px 26px rgba(0, 0, 0, .16);
      z-index: 80;
      padding: 6px
    }

    .partner-picker.open .partner-menu {
      display: block
    }

    .partner-option {
      min-height: 34px;
      display: flex;
      align-items: center;
      padding: 0 9px;
      border-radius: 6px;
      font-size: 13px;
      color: #344054;
      cursor: pointer
    }

    .partner-option:hover,
    .partner-option.active {
      background: #eef6ff;
      color: #006dff;
      font-weight: 800
    }

    .place-order {
      margin-top: auto;
      padding: 12px
    }

    .place-order button {
      width: 100%;
      height: 58px;
      border: 0;
      border-radius: 9px;
      background: #0070f4;
      color: #fff;
      font-size: 20px;
      font-weight: 800;
      cursor: pointer
    }
  </style>
</head>

<body>
  <%- include('../partials/header') %>
    <main class="order-create">
      <section class="left">
        <div class="top-search"><i class="fa-solid fa-magnifying-glass"></i><input id="productSearch"
            placeholder="Tìm hàng hóa (F3)">
          <div id="productResults" class="search-results"></div>
        </div>
        <div class="cart-area">
          <table class="cart-table">
            <thead>
              <tr>
                <th>STT</th>
                <th>Mã hàng</th>
                <th>Tên hàng</th>
                <th class="num">SL</th>
                <th class="num">Tồn</th>
                <th class="num">Đơn giá</th>
                <th class="num">Giảm giá</th>
                <th class="num">Thành tiền</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="cartBody"></tbody>
          </table>
        </div>
        <div class="summary-card">
          <div class="note-line"><i class="fa-solid fa-pen"></i> Ghi chú hóa đơn</div>
          <div class="totals">
            <div class="total-line"><span>Tổng tiền hàng</span><span id="subtotal">0</span></div>
            <div class="total-line"><span>Giảm giá</span>
              <span class="discount-pair"><input id="discount" class="small" value="0" oninput="renderCart()"><select
                  id="orderDiscountType" onchange="renderCart()">
                  <option value="vnd">VND</option>
                  <option value="phan_tram">%</option>
                </select></span>
            </div>
            <div class="total-line"><strong>Khách cần trả</strong><strong class="payable" id="grandTotal">0</strong>
            </div>
          </div>
        </div>
      </section>
      <section class="middle">
        <div class="mid-head"><strong id="storeName">Cửa hàng</strong><span>
            <%= new Date().toLocaleString('vi-VN', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit',
              minute:'2-digit' }) %>
          </span></div>
        <input type="hidden" id="customerId">
        <div class="section-line">
          <div class="marker"><i class="fa-solid fa-circle-dot"></i></div>
          <div><select id="pickupStoreId" class="line-input" onchange="handlePickupStoreChange()" style="width:100%">
              <% stores.forEach(s=> { %><option value="<%= s._id %>">
                  <%= s.ten_cua_hang %> - <%= s.sdt || 'Chưa có SĐT' %>
                </option>
                <% }) %>
            </select>
            <div class="muted-red" id="pickupInfo"></div>
            <select id="khoId" class="line-input" style="width:100%;margin-top:12px" disabled>
              <option value="">Vui lòng chọn cửa hàng trước</option>
            </select>
            <select id="priceBookId" class="line-input" onchange="handlePriceBookChange()" style="width:100%;margin-top:12px">
              <option value="">Bảng giá chung</option>
              <% priceBooks.forEach(bg => { %>
                <option value="<%= bg._id %>"><%= bg.ten_bang_gia %></option>
              <% }) %>
            </select>
          </div>
        </div>
        <div class="section-line">
          <div class="marker green"><i class="fa-solid fa-location-dot"></i></div>
          <div>
            <div class="two"><select id="recipientCustomerId" class="line-input" onchange="selectRecipientCustomer(this.value)">
                <option value="">Chọn khách hàng nhận</option>
                <% customers.forEach(c=> {
                  const defaultAddress = (c.dia_chi_list || []).find(a => a.mac_dinh) || (c.dia_chi_list || [])[0] || {};
                  const optionPhone = c.sdt || c.sdt2 || '';
                  const optionAddress = defaultAddress.dia_chi || defaultAddress.dia_chi_day_du || c.dia_chi_nhan || '';
                  const optionAddressId = defaultAddress._id || '';
                  const optionArea = defaultAddress.quan_huyen || defaultAddress.tinh_thanh || c.quan_huyen || c.tinh_thanh || '';
                  const optionWard = defaultAddress.phuong_xa || c.phuong_xa || '';
                %><option value="<%= c._id %>" data-name="<%= c.ten_khach_hang || '' %>" data-phone="<%= optionPhone %>" data-address="<%= optionAddress %>" data-address-id="<%= optionAddressId %>" data-area="<%= optionArea %>" data-ward="<%= optionWard %>">
                    <%= c.ten_khach_hang %>
                  </option>
                  <% }) %>
              </select><input id="recipientPhone" class="line-input" placeholder="Số điện thoại"></div><select
              id="recipientAddressSelect" class="line-input" onchange="selectRecipientAddress()"
              style="width:100%;margin-top:12px">
              <option value="">Địa chỉ chi tiết (Số nhà, ngõ, đường)</option>
            </select><input id="recipientAddress" class="line-input" style="width:100%;margin-top:12px"
              placeholder="Địa chỉ nhận hàng"><input id="recipientArea" class="line-input"
              style="width:100%;margin-top:12px" placeholder="Khu vực"><input id="recipientWard" class="line-input"
              style="width:100%;margin-top:12px" placeholder="Phường/Xã">
          </div>
        </div>
        <div class="cod"><strong>Thu hộ tiền (COD)</strong><span id="codToggle" class="toggle"
            onclick="toggleCod()"></span><strong style="float:right" id="codTotal">0</strong>
          <div class="cod-row"><span>Khách thanh toán</span><input id="customerPaidInput" class="small" value="0" oninput="handleCustomerPaidInput()"></div>
          <div class="cod-row"><span>Tiền thừa trả khách</span><strong id="customerChange">0</strong></div>
        </div>
      </section>
      <section class="right">
        <div class="tabs">
          <div class="tab"><i class="fa-solid fa-user-gear"></i> Tự giao hàng</div>
        </div>
        <div class="right-body">
          <div class="delivery-row">
            <label>Đối tác giao hàng</label>
            <input type="hidden" id="partnerId">
            <div class="partner-picker" id="partnerPicker">
              <button class="partner-trigger empty" type="button" onclick="togglePartnerMenu()">
                <span id="partnerLabel">Chọn đối tác</span>
                <i class="fa-solid fa-chevron-down"></i>
              </button>
              <div class="partner-menu">
                <% partners.forEach(p=> { %>
                  <div class="partner-option" data-partner-id="<%= p._id %>" onclick="selectPartner('<%= p._id %>', '<%= String(p.ten_doi_tac || '').replace(/'/g, '&#39;') %>')">
                    <%= p.ten_doi_tac %>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>
          <div class="delivery-row" style="margin-top:16px">
            <label>Khoảng cách (km)</label>
            <input id="shippingDistance" class="delivery-input" value="0" inputmode="decimal" oninput="scheduleShippingFee()">
          </div>
          <div class="delivery-row" style="margin-top:16px">
            <label>Người trả phí giao hàng</label>
            <select id="shippingFeePayer" class="delivery-input" onchange="renderCart()">
              <option value="khach">Khách trả</option>
              <option value="cua_hang">Cửa hàng trả</option>
            </select>
          </div>
          <div class="delivery-row" style="margin-top:16px">
            <label>Phí giao hàng</label>
            <input id="shippingFee" class="delivery-input" value="0" inputmode="numeric" oninput="handleManualShippingFee()">
            <div class="delivery-help" id="shippingFeeHelp">Có thể nhập tay nếu chưa có bảng giá.</div>
          </div>
        </div>
        <div class="place-order"><button onclick="saveOrder()" type="button">THANH TOÁN</button></div>
      </section>
    </main>
    <script>
      let cart = [];
      let codEnabled = false;
      let lastTotals = { khachCanTra: 0, khachThanhToan: 0, codAmount: 0, tienThuaTraKhach: 0 };
      let availableProducts = [];
      let previousKhoId = '';
      const sourceOrder = <%- JSON.stringify(sourceOrder || null) %>;
      const sourceOrderItems = <%- JSON.stringify((sourceOrderItems || []).map(row => ({ hang_hoa_id: String(row.hang_hoa_id?._id || row.hang_hoa_id || ''), ma_hang: row.hang_hoa_id?.ma_hang || '', ten_hang: row.hang_hoa_id?.ten_hang || '', so_luong: Number(row.so_luong_dat || row.so_luong || 0), ton_kho: 0, don_gia_ban: Number(row.don_gia_ban || 0), chiet_khau: Number(row.chiet_khau || 0), kieu_chiet_khau: row.kieu_chiet_khau || 'vnd', lo_hang_id: row.lo_hang_id ? String(row.lo_hang_id) : '' }))) %>;
      const sourceShipment = <%- JSON.stringify(sourceShipment || null) %>;
      const existingInvoice = <%- JSON.stringify(existingInvoice || null) %>;
      const sourceInvoice = <%- JSON.stringify(sourceInvoice || null) %>;
      const sourceInvoiceItems = <%- JSON.stringify((sourceInvoiceItems || []).map(row => ({ hang_hoa_id: String(row.hang_hoa_id?._id || row.hang_hoa_id || ''), ma_hang: row.hang_hoa_id?.ma_hang || '', ten_hang: row.hang_hoa_id?.ten_hang || '', so_luong: Number(row.so_luong || 0), ton_kho: 0, don_gia_ban: Number(row.don_gia || 0), chiet_khau: Number(row.chiet_khau || 0), kieu_chiet_khau: 'vnd', lo_hang_id: row.lo_hang_id ? String(row.lo_hang_id._id || row.lo_hang_id) : '' }))) %>;
      const sourceInvoiceShipment = <%- JSON.stringify(sourceInvoiceShipment || null) %>;
      const copyFromError = <%- JSON.stringify(copyFromError || '') %>;
      let shippingFeeManuallyEdited = false;
      let customerPaidTouched = false;
      let shippingFeeTimer = null;
      const products = <%- JSON.stringify(products.map(p => ({ _id: String(p._id), ma_hang: p.ma_hang || '', ten_hang: p.ten_hang || '', gia_co_dinh: p.gia_co_dinh || 0, nha_cung_cap_id: p.nha_cung_cap_id ? String(p.nha_cung_cap_id._id || p.nha_cung_cap_id) : '', ten_ncc: p.nha_cung_cap_id ? (p.nha_cung_cap_id.ten_ncc || p.nha_cung_cap_id.ten_cong_ty || '') : '', ma_ncc: p.nha_cung_cap_id ? (p.nha_cung_cap_id.ma_ncc || '') : '' }))) %>;
      const priceRows = <%- JSON.stringify((priceRows || []).map(r => ({ bang_gia_id: String(r.bang_gia_id || ''), hang_hoa_id: String(r.hang_hoa_id || ''), gia_ban: Number(r.gia_ban || 0) }))) %>;
      const customers = <%- JSON.stringify(customers.map(c => ({ _id: String(c._id), ma_khach_hang: c.ma_khach_hang || '', ten_khach_hang: c.ten_khach_hang || '', sdt: c.sdt || c.sdt2 || '', sdt2: c.sdt2 || '', email: c.email || '', dia_chi_nhan: c.dia_chi_nhan || '', tinh_thanh: c.tinh_thanh || '', quan_huyen: c.quan_huyen || '', phuong_xa: c.phuong_xa || '', dia_chi_list: (c.dia_chi_list || []).map(a => ({ _id: String(a._id || ''), dia_chi: a.dia_chi || a.dia_chi_day_du || '', tinh_thanh: a.tinh_thanh || '', quan_huyen: a.quan_huyen || '', phuong_xa: a.phuong_xa || '', mac_dinh: !!a.mac_dinh })) }))) %>;
      const stores = <%- JSON.stringify(stores.map(s => ({ _id: String(s._id), ten_cua_hang: s.ten_cua_hang || '', sdt: s.sdt || '', dia_chi: s.dia_chi || '', dia_chi_gui_hang: s.dia_chi_gui_hang || '', tinh_thanh: s.tinh_thanh || '', quan_huyen: s.quan_huyen || '', phuong_xa: s.phuong_xa || '' }))) %>;
      const fmt = n => Number(n || 0).toLocaleString('vi-VN');
      const num = v => Number(String(v || '').replace(/\./g, '').replace(/,/g, '')) || 0;
      const stockByProduct = new Map();
      const productSearch = document.getElementById('productSearch'), productResults = document.getElementById('productResults');
      const selectedPriceBookId = () => document.getElementById('priceBookId')?.value || '';
      function escapeHtml(value) {
        return String(value ?? '').replace(/[&<>"']/g, char => ({
          '&': '&amp;',
          '<': '&lt;',
          '>': '&gt;',
          '"': '&quot;',
          "'": '&#39;'
        }[char]));
      }
      function supplierName(product) {
        return product?.ten_ncc || 'Chưa có';
      }
      function priceFor(productId) {
        const row = priceRows.find(r => r.bang_gia_id === selectedPriceBookId() && r.hang_hoa_id === productId);
        if (row && Number(row.gia_ban || 0) > 0) return Number(row.gia_ban || 0);
