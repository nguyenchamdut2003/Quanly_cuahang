      async function calculateShippingFee() {
        if (!partnerId.value || !pickupStoreId.value) return;
        const endPoint = getShippingEndPoint();
        const addressId = getRecipientAddressId();
        if (!customerId.value || !addressId || !endPoint) return;
        try {
          const res = await fetch('/api/giao-hang/tinh-phi', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              cua_hang_id: pickupStoreId.value,
              khach_hang_id: customerId.value,
              dia_chi_khach_hang_id: addressId,
              doi_tac_giao_hang_id: partnerId.value,
              diem_di: getShippingStartPoint(),
              diem_den: endPoint,
              khoang_cach_km: num(shippingDistance.value)
            })
          });
          const text = await res.text();
          let result = {};
          try {
            result = text ? JSON.parse(text) : {};
          } catch (_) {
            throw new Error(text || 'Backend trả về phản hồi không hợp lệ');
          }
          if (!result.success) throw new Error(result.message || 'Không tính được phí giao hàng');
          if (!shippingFeeManuallyEdited) shippingFee.value = fmt(result.phi_giao_hang || 0);
          shippingFeeHelp.textContent = result.nguon_phi
            ? 'Đã lấy phí giao hàng từ lịch sử/bảng phí. Có thể sửa tay.'
            : 'Chưa có bảng giá phù hợp, có thể nhập tay.';
          renderCart();
