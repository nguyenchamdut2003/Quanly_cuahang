        <div class="filter-block"><div class="filter-title">Khu vá»±c giao hÃ ng</div><input name="khu_vuc" value="<%= safeFilters.khu_vuc || '' %>" class="filter-control" placeholder="Chá»n Tá»‰nh/TP - Quáº­n/Huyá»‡n"></div>
        <div class="filter-block"><div class="filter-title">PhÆ°Æ¡ng thá»©c thanh toÃ¡n</div><select name="phuong_thuc_tt" class="filter-control" onchange="this.form.submit()"><option value="">Chá»n phÆ°Æ¡ng thá»©c thanh toÃ¡n...</option><option value="COD" <%= safeFilters.phuong_thuc_tt === 'COD' ? 'selected' : '' %>>COD</option></select></div>
        <div class="filter-block"><div class="filter-title">NgÆ°á»i táº¡o</div><input name="nguoi_tao" value="<%= safeFilters.nguoi_tao || '' %>" list="userList" class="filter-control" placeholder="Chá»n ngÆ°á»i táº¡o"></div>
        <div class="filter-block"><div class="filter-title">NgÆ°á»i nháº­n Ä‘áº·t</div><input name="nguoi_nhan" value="<%= safeFilters.nguoi_nhan || '' %>" class="filter-control" placeholder="Chá»n ngÆ°á»i nháº­n Ä‘áº·t"></div>
