  <script>
    const money = value => Number(value || 0).toLocaleString('vi-VN');
    const statusLabels = { draft: 'Phiáº¿u táº¡m', shipping: 'Äang giao hÃ ng', completed: 'HoÃ n thÃ nh', cancelled: 'ÄÃ£ há»§y' };
    const deliveryStatusLabels = { chua_giao: 'Chưa giao', giao_mot_phan: 'Giao một phần', giao_thieu: 'Giao thiếu', giao_du: 'Giao đủ' };
    const deliveryStatusText = status => deliveryStatusLabels[status] || 'Chưa giao';
    const escapeHtml = value => String(value ?? '').replace(/[&<>"']/g, char => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[char]));
    const orderDetailCache = {};

    async function toggleOrderDetail(id) {
      const row = document.querySelector('[data-order-row="' + id + '"]');
      const detailRow = document.querySelector('[data-order-detail="' + id + '"]');
      if (!detailRow) return;
      const shouldOpen = !detailRow.classList.contains('open');
      document.querySelectorAll('.detail-row').forEach(item => item.classList.remove('open'));
      document.querySelectorAll('.order-row').forEach(item => item.classList.remove('active'));
      if (!shouldOpen) return;
      detailRow.classList.add('open');
      row?.classList.add('active');
      if (detailRow.dataset.loaded === 'true') return;
      await loadOrderDetail(id, detailRow);
    }

    async function loadOrderDetail(id, detailRow) {
      const res = await fetch('/don-hang/' + id + '/detail');
      const data = await res.json();
      if (!data.success) return alert(data.message || 'KhÃ´ng táº£i Ä‘Æ°á»£c Ä‘Æ¡n hÃ ng');
      const order = data.data.order;
      const shipment = data.data.shipment;
      const items = data.data.items || [];
      orderDetailCache[id] = data.data;
      const totalGoods = items.reduce((sum, item) => sum + Number(item.thanh_tien || 0), 0);
      const discount = Math.max(totalGoods - Number(order.tong_thanh_toan || order.tong_tien || 0), 0);
      detailRow.querySelector('.order-detail').innerHTML = renderOrderDetail(order, shipment, items, totalGoods, discount);
      detailRow.dataset.loaded = 'true';
    }

    function renderOrderDetail(order, shipment, items, totalGoods, discount) {
      const customer = order.khach_hang_id || {};
      const receiver = shipment?.ten_nguoi_nhan || customer.ten_khach_hang || '';
      const phone = shipment?.sdt_nguoi_nhan || customer.sdt || '';
      const address = shipment?.dia_chi_nhan || customer.dia_chi || '';
      const itemRows = items.map(item => {
        const product = item.hang_hoa_id || {};
        const deliveryStatus = deliveryStatusLabels[item.trang_thai_giao] || deliveryStatusLabels.chua_giao;
        return `<tr>
          <td><a href="#" class="detail-link">${escapeHtml(product.ma_hang || '')}</a></td>
          <td>${escapeHtml(product.ten_hang || '')}</td>
          <td class="num">${money(item.so_luong_dat || item.so_luong || 0)}</td>
          <td class="num">${money(item.so_luong_xac_nhan || 0)}</td>
          <td class="num">${money(item.so_luong_da_giao || 0)}</td>
          <td class="num">${money(item.so_luong_con_thieu || 0)}</td>
          <td>${escapeHtml(deliveryStatus)}</td>
          <td class="num">${money(item.don_gia_ban)}</td>
          <td class="num">${money(item.chiet_khau)}</td>
          <td class="num">${money(item.don_gia_ban)}</td>
          <td class="num"><strong>${money(item.thanh_tien)}</strong></td>
        </tr>`;
      }).join('') || '<tr><td colspan="11" class="loading-detail">ÄÆ¡n chÆ°a cÃ³ hÃ ng hÃ³a</td></tr>';

      return `
        <div class="detail-tabs"><button type="button" class="detail-tab">ThÃ´ng tin</button></div>
        <div class="detail-head">
          <div>
            <div><span class="detail-title">${escapeHtml(customer.ten_khach_hang || 'KhÃ¡ch láº»')}</span> <span>${escapeHtml(order.ma_don_hang || '')}</span></div>
            <div class="detail-meta">
              <div class="mini-field"><label>NgÆ°á»i táº¡o</label><span>${escapeHtml(order.nguoi_tao_id?.ho_ten || order.nguoi_tao_id?.username || '')}</span></div>
              <div class="mini-field"><label>NgÆ°á»i nháº­n Ä‘áº·t</label><input class="mini-input" value="${escapeHtml(order.nguoi_tao_id?.ho_ten || order.nguoi_tao_id?.username || '')}"></div>
              <div class="mini-field"><label>NgÃ y Ä‘áº·t</label><input class="mini-input" value="${escapeHtml(new Date(order.ngay_dat || order.created_at).toLocaleString('vi-VN'))}"></div>
              <div class="mini-field"><label>KÃªnh bÃ¡n</label><input class="mini-input" value="BÃ¡n trá»±c tiáº¿p"></div>
              <div class="mini-field"><label>Báº£ng giÃ¡</label><input class="mini-input" value="Báº£ng giÃ¡ chung"></div>
              <div class="mini-field"><label>Tráº¡ng thÃ¡i</label><select class="mini-select" onchange="updateOrderStatus('${order._id}',this.value)">${['draft','shipping','completed','cancelled'].map(status => `<option value="${status}" ${order.trang_thai === status ? 'selected' : ''}>${statusLabels[status]}</option>`).join('')}</select></div>
            </div>
          </div>
          <div>${escapeHtml(order.cua_hang_id?.ten_cua_hang || 'Chi nhÃ¡nh trung tÃ¢m')}</div>
        </div>
        <div class="delivery-box">
          <div class="delivery-title"><span><i class="fa-regular fa-hand-point-right"></i> Tá»± giao Ä‘áº¿n: <strong>${escapeHtml(address || 'ChÆ°a cÃ³ Ä‘á»‹a chá»‰ giao hÃ ng')}</strong></span><i class="fa-solid fa-chevron-up"></i></div>
          <div class="delivery-grid">
            <div class="mini-field"><label>NgÆ°á»i nháº­n</label><input class="mini-input" value="${escapeHtml(receiver)}"></div>
            <div class="mini-field"><label>MÃ£ váº­n Ä‘Æ¡n</label><input class="mini-input" value="${escapeHtml(shipment?.ma_van_don || '')}"></div>
            <div class="mini-field"><label>NgÆ°á»i giao</label><input class="mini-input" value="${escapeHtml(shipment?.doi_tac_giao_hang_id?.ten_doi_tac || 'Tá»± giao hÃ ng')}"></div>
            <div class="mini-field"><label>Äiá»‡n thoáº¡i</label><input class="mini-input" value="${escapeHtml(phone)}"></div>
            <div class="mini-field"><label>Trá»ng lÆ°á»£ng</label><input class="mini-input" value="500 g"></div>
            <div class="mini-field"><label>Thu há»™ tiá»n</label><input type="checkbox" checked></div>
            <div class="mini-field"><label>Äá»‹a chá»‰</label><input class="mini-input" value="${escapeHtml(address)}"></div>
            <div class="mini-field"><label>Dá»‹ch vá»¥</label><input class="mini-input" value="Giao thÆ°á»ng"></div>
            <div class="mini-field"><label>PhÃ­ tráº£ ÄTGH</label><input class="mini-input" value="${money(shipment?.phi_giao_hang || 0)}"></div>
          </div>
          <textarea class="note" placeholder="Ghi chÃº giao...">${escapeHtml(shipment?.ghi_chu || '')}</textarea>
        </div>
        <table class="items-table"><thead><tr><th>MÃ£ hÃ ng</th><th>TÃªn hÃ ng</th><th class="num">SL đặt</th><th class="num">SL xác nhận</th><th class="num">SL đã giao</th><th class="num">SL còn thiếu</th><th>Trạng thái giao</th><th class="num">ÄÆ¡n giÃ¡</th><th class="num">Giáº£m giÃ¡</th><th class="num">GiÃ¡ bÃ¡n</th><th class="num">ThÃ nh tiá»n</th></tr></thead><tbody>${itemRows}</tbody></table>
        <div class="detail-bottom">
          <textarea class="note" placeholder="Ghi chÃº...">${escapeHtml(order.ghi_chu || '')}</textarea>
          <div class="totals">
            <div class="total-line"><span>Tá»•ng tiá»n hÃ ng (${items.length})</span><strong>${money(totalGoods)}</strong></div>
            <div class="total-line"><span>Giáº£m giÃ¡ phiáº¿u Ä‘áº·t</span><span>${money(discount)}</span></div>
            <div class="total-line"><span>Tá»•ng cá»™ng</span><strong>${money(order.tong_thanh_toan || order.tong_tien)}</strong></div>
            <div class="total-line"><span>KhÃ¡ch Ä‘Ã£ tráº£</span><span>0</span></div>
          </div>
        </div>
        <div class="detail-actions">
          <div class="detail-action-group"><button type="button" class="btn" onclick="deleteOrder('${order._id}')"><i class="fa-regular fa-trash-can"></i> Há»§y</button><button type="button" class="btn"><i class="fa-regular fa-copy"></i> Sao chÃ©p</button><a class="btn" href="/don-hang/export.csv"><i class="fa-solid fa-file-export"></i> Xuáº¥t file</a></div>
          <div class="detail-action-group"><button type="button" class="btn solid" onclick="updateOrderStatus('${order._id}','shipping')"><i class="fa-solid fa-truck-fast"></i> Xá»­ lÃ½ Ä‘Æ¡n hÃ ng</button><button type="button" class="btn solid" onclick="confirmDelivery('${order._id}')"><i class="fa-solid fa-box-open"></i> Xác nhận giao</button><button type="button" class="btn"><i class="fa-regular fa-floppy-disk"></i> LÆ°u</button><button type="button" class="btn" onclick="finishOrder('${order._id}', '${order.trang_thai_giao_hang || 'chua_giao'}')"><i class="fa-regular fa-circle-check"></i> Káº¿t thÃºc</button><button type="button" class="btn"><i class="fa-solid fa-print"></i> In</button></div>
        </div>`;
    }

    async function updateOrderStatus(id, status, forceCompleteShort = false) {
      const res = await fetch('/don-hang/' + id + '/status', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ trang_thai: status, force_complete_short: forceCompleteShort }) });
      const data = await res.json();
      if (!data.success) return alert(data.message || 'KhÃ´ng cáº­p nháº­t Ä‘Æ°á»£c tráº¡ng thÃ¡i');
      location.reload();
    }

    async function finishOrder(id, deliveryStatus) {
      if (deliveryStatus !== 'giao_du' && !confirm('Đơn chưa giao đủ. Xác nhận kết thúc thiếu?')) return;
      await updateOrderStatus(id, 'completed', deliveryStatus !== 'giao_du');
    }

    async function confirmDelivery(id) {
      const detail = orderDetailCache[id];
      if (!detail) return alert('Vui lòng mở lại chi tiết đơn trước khi xác nhận giao.');
      const order = detail.order || {};
      const items = detail.items || [];
      const khoId = order.kho_id?._id || order.kho_id;
      if (!khoId) return alert('Đơn chưa có kho giao hàng.');
      const deliveryItems = [];
      for (const item of items) {
        const missing = Number(item.so_luong_con_thieu || item.so_luong_dat || item.so_luong || 0);
        if (missing <= 0) continue;
        const product = item.hang_hoa_id || {};
        const raw = prompt(`Số lượng giao cho ${product.ma_hang || product.ten_hang || 'hàng hóa'} (còn thiếu ${missing})`, String(missing));
        if (raw === null) continue;
        const quantity = Number(String(raw).replace(',', '.'));
        if (!Number.isFinite(quantity) || quantity <= 0) continue;
        deliveryItems.push({
          ct_don_hang_id: item._id,
          hang_hoa_id: product._id || item.hang_hoa_id,
          lo_hang_id: item.lo_hang_id || '',
          so_luong_giao: quantity
        });
      }
      if (!deliveryItems.length) return alert('Chưa có số lượng giao.');
      const res = await fetch('/don-hang/' + id + '/xac-nhan-giao', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ kho_id: khoId, items: deliveryItems })
      });
      const data = await res.json();
      if (!data.success) return alert(data.message || 'Không xác nhận giao được.');
      location.reload();
    }

    async function deleteOrder(id) {
      if (!confirm('Há»§y Ä‘Æ¡n Ä‘áº·t hÃ ng nÃ y?')) return;
      await updateOrderStatus(id, 'cancelled');
    }
  </script>
