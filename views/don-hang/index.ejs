<%
  const safeOrders = Array.isArray(locals.orders) ? locals.orders : [];
  const safeFilters = locals.filters || {};
  const safeUsers = Array.isArray(locals.users) ? locals.users : [];
  const selectedStatuses = Array.isArray(safeFilters.trang_thai) ? safeFilters.trang_thai : (safeFilters.trang_thai ? [safeFilters.trang_thai] : ['draft', 'shipping', 'completed']);
  const fmt = value => Number(value || 0).toLocaleString('vi-VN');
  const statusText = status => ({
    draft: 'Phiếu tạm',
    shipping: 'Đang giao hàng',
    completed: 'Hoàn thành',
    cancelled: 'Đã hủy'
  })[status] || 'Phiếu tạm';
  const deliveryStatusText = status => ({
    chua_giao: 'Chưa giao',
    giao_mot_phan: 'Giao một phần',
    giao_thieu: 'Giao thiếu',
    giao_du: 'Giao đủ'
  })[status] || 'Chưa giao';
  const exportParams = new URLSearchParams();
  Object.keys(safeFilters).forEach(function(key) {
    const value = safeFilters[key];
    if (Array.isArray(value)) {
      value.forEach(function(item) { exportParams.append(key, item); });
    } else if (value !== undefined && value !== null && value !== '') {
      exportParams.append(key, value);
    }
  });
  const exportQuery = exportParams.toString();
%>
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <style>
    .order-page{height:calc(100vh - 98px);background:#f3f6f9;display:flex;flex-direction:column}
    .order-shell{flex:1;min-height:0;display:grid;grid-template-columns:236px minmax(0,1fr);gap:12px;padding:14px clamp(12px,5vw,80px) 0}
    .sidebar{background:#fff;border-radius:6px;padding:14px 12px;overflow:auto}
    .title{font-size:20px;font-weight:700;color:#111827;margin:0 0 16px}
    .filter-block{margin-bottom:22px}.filter-title{font-size:13px;font-weight:700;color:#111827;margin-bottom:10px}
    .radio-line{display:flex;align-items:center;gap:9px;margin-top:9px}.radio-line input{accent-color:#0070f4}
    .radio-pill{flex:1;height:30px;border:1px solid #cfd8e3;border-radius:6px;background:#fff;display:flex;align-items:center;justify-content:space-between;padding:0 10px;font-size:13px;color:#111827}
    .tag-box{border:1px solid #cfd8e3;border-radius:6px;min-height:82px;padding:4px;background:#fff;display:flex;align-content:flex-start;gap:5px;flex-wrap:wrap}
    .tag{height:25px;background:#0070f4;color:#fff;border-radius:4px;padding:0 7px;display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:700}
    .filter-control{width:100%;height:31px;border:1px solid #cfd8e3;border-radius:6px;background:#fff;color:#8b95a1;padding:0 10px;font-size:13px;outline:none}
    .main{min-width:0;display:flex;flex-direction:column;gap:10px}.toolbar{display:flex;align-items:center;justify-content:space-between;gap:12px}
    .search{position:relative;flex:1;max-width:470px}.search i{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#7a8794}
    .search input{width:100%;height:31px;border:1px solid #cfd8e3;border-radius:7px;padding:0 38px 0 34px;font-size:13px;outline:none}
    .search button{position:absolute;right:4px;top:4px;width:24px;height:23px;border:0;background:#fff;color:#374151;cursor:pointer}
    .actions{display:flex;align-items:center;gap:8px}.btn{height:31px;border:1px solid #cfd8e3;background:#fff;border-radius:6px;padding:0 12px;color:#111827;font-size:13px;font-weight:700;display:inline-flex;align-items:center;gap:7px;cursor:pointer;text-decoration:none}.btn.primary{border-color:#0070f4;color:#0070f4}.icon{width:31px;height:31px;border:1px solid #cfd8e3;background:#fff;border-radius:7px;display:inline-flex;align-items:center;justify-content:center}
    .table-wrap{flex:1;min-height:0;background:#fff;border-radius:6px;overflow:auto}.table{width:100%;min-width:1080px;border-collapse:collapse}.table th{height:37px;background:#e8f3ff;color:#111827;font-size:12px;font-weight:700;text-align:left;border-bottom:1px solid #bcd9ff;padding:0 10px}.table td{height:43px;border-bottom:1px solid #e5e9ee;padding:0 10px;font-size:13px;color:#111827}.table tbody tr{cursor:pointer}.table tbody tr:hover{background:#f7fbff}.order-row.active td{background:#f1f8ff;border-top:2px solid #0070f4}.num{text-align:right}.check-col,.star-col{width:36px;text-align:center}.row-check{width:15px;height:15px;accent-color:#0070f4}.star-col{color:#8b95a1}.empty{height:100%;min-height:520px;text-align:center;color:#111827}.empty-wrap{height:520px;display:flex;align-items:center;justify-content:center;flex-direction:column}.empty-icon{width:94px;height:94px;border-radius:50%;background:#eef6ff;display:flex;align-items:center;justify-content:center;color:#0070f4;font-size:34px;margin-bottom:18px}.empty h3{font-size:16px;margin:0 0 12px}.empty p{font-size:14px;line-height:1.4;margin:0}.empty a{color:#0070f4;text-decoration:none}
    .status-badge{height:22px;border-radius:4px;background:#e8f3ff;color:#006dff;padding:0 7px;display:inline-flex;align-items:center;font-size:12px;font-weight:700}.status-badge.completed{background:#dff7e9;color:#008a3d}.status-badge.cancelled{background:#fee4e2;color:#b42318}.status-badge.shipping{background:#fff4d6;color:#9a6700}
    .date-range{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:8px}.date-range input{height:30px;border:1px solid #cfd8e3;border-radius:6px;padding:0 8px;font-size:12px}
    .detail-link{color:#006dff;text-decoration:none;font-weight:700}
    .status-check{display:none}
    .detail-row{display:none;cursor:default}.detail-row.open{display:table-row}.detail-cell{padding:0!important;border:2px solid #0070f4!important;border-top:0!important;background:#fff}.order-detail{padding:0 18px 14px}.detail-tabs{height:40px;display:flex;align-items:flex-end;border-bottom:1px solid #e5e9ee}.detail-tab{height:40px;border:0;background:#fff;color:#0070f4;border-bottom:2px solid #0070f4;font-weight:700;padding:0 0 8px;font-size:14px}.detail-head{display:flex;justify-content:space-between;gap:16px;padding:14px 0}.detail-title{font-size:16px;font-weight:800}.detail-meta{display:grid;grid-template-columns:repeat(3,1fr);gap:12px 22px;margin-top:12px}.mini-field label{display:block;font-size:12px;margin-bottom:5px}.mini-input,.mini-select{width:100%;height:31px;border:1px solid #cfd8e3;border-radius:6px;background:#fff;padding:0 9px;font-size:12px}.delivery-box{border:1px solid #cfd8e3;border-radius:6px;background:#fafbfc;padding:12px;margin:6px 0 14px}.delivery-title{display:flex;align-items:center;justify-content:space-between;font-size:12px;margin-bottom:10px}.delivery-grid{display:grid;grid-template-columns:1.2fr 1fr 1fr;gap:10px 22px}.note{width:100%;height:70px;border:1px solid #cfd8e3;border-radius:6px;padding:8px;font-size:12px;resize:vertical}.items-table{width:100%;border-collapse:collapse}.items-table th{height:32px;background:#f3f4f6;border-bottom:1px solid #cfd8e3;font-size:12px;text-align:left;padding:0 8px}.items-table td{height:42px;border-bottom:1px solid #e5e9ee;font-size:12px;padding:0 8px}.detail-bottom{display:grid;grid-template-columns:minmax(0,1fr) 260px;gap:18px;margin-top:14px}.totals{font-size:12px}.total-line{display:flex;justify-content:space-between;margin-bottom:10px}.detail-actions{height:42px;border-top:1px solid #e5e9ee;display:flex;align-items:center;justify-content:space-between;margin-top:10px}.detail-action-group{display:flex;gap:8px}.btn.solid{background:#0070f4;color:#fff;border-color:#0070f4}.loading-detail{height:160px;display:flex;align-items:center;justify-content:center;color:#667085}
    @media(max-width:1100px){.order-shell{padding:12px;grid-template-columns:220px minmax(0,1fr)}}
  </style>
</head>
<body>
  <%- include('../partials/header') %>
  <form id="filterForm" class="order-page" method="GET" action="/don-hang">
    <div class="order-shell">
      <aside class="sidebar">
        <h1 class="title">Đặt hàng</h1>
        <div class="filter-block">
          <div class="filter-title">Thời gian</div>
          <label class="radio-line"><input type="radio" name="time_type" value="this_month" <%= safeFilters.time_type !== 'custom' ? 'checked' : '' %> onchange="this.form.submit()"><span class="radio-pill">Tháng này <i class="fa-solid fa-chevron-right"></i></span></label>
          <label class="radio-line"><input type="radio" name="time_type" value="custom" <%= safeFilters.time_type === 'custom' ? 'checked' : '' %>><span class="radio-pill">Tùy chỉnh <i class="fa-regular fa-calendar-days"></i></span></label>
          <div class="date-range"><input type="date" name="date_from" value="<%= safeFilters.date_from || '' %>"><input type="date" name="date_to" value="<%= safeFilters.date_to || '' %>"></div>
        </div>
        <div class="filter-block">
          <div class="filter-title">Trạng thái</div>
          <div class="tag-box">
            <% [['draft','Phiếu tạm'],['shipping','Đang giao hàng'],['completed','Hoàn thành'],['cancelled','Đã hủy']].forEach(([value,label]) => { %>
              <label class="tag" style="<%= selectedStatuses.includes(value) ? '' : 'background:#e8f3ff;color:#006dff' %>"><input class="status-check" type="checkbox" name="trang_thai" value="<%= value %>" <%= selectedStatuses.includes(value) ? 'checked' : '' %> onchange="this.form.submit()"> <%= label %> <i class="fa-solid fa-xmark"></i></label>
            <% }) %>
          </div>
        </div>
        <div class="filter-block"><div class="filter-title">Đối tác giao hàng</div><select name="doi_tac" class="filter-control" onchange="this.form.submit()"><option value="">Chọn đối tác giao hàng</option><% (locals.partners || []).forEach(p => { %><option value="<%= p._id %>" <%= String(safeFilters.doi_tac || '') === String(p._id) ? 'selected' : '' %>><%= p.ten_doi_tac %></option><% }) %></select></div>
        <div class="filter-block"><div class="filter-title">Thời gian giao hàng</div><label class="radio-line"><input type="radio" name="delivery_time_type" value="all" <%= safeFilters.delivery_time_type !== 'custom' ? 'checked' : '' %>><span class="radio-pill">Toàn thời gian <i class="fa-solid fa-chevron-right"></i></span></label><label class="radio-line"><input type="radio" name="delivery_time_type" value="custom" <%= safeFilters.delivery_time_type === 'custom' ? 'checked' : '' %>><span class="radio-pill">Tùy chỉnh <i class="fa-regular fa-calendar-days"></i></span></label><div class="date-range"><input type="date" name="delivery_from" value="<%= safeFilters.delivery_from || '' %>"><input type="date" name="delivery_to" value="<%= safeFilters.delivery_to || '' %>"></div></div>
        <div class="filter-block"><div class="filter-title">Khu vực giao hàng</div><input name="khu_vuc" value="<%= safeFilters.khu_vuc || '' %>" class="filter-control" placeholder="Chọn Tỉnh/Thành phố"></div>
        <div class="filter-block"><div class="filter-title">Phương thức thanh toán</div><select name="phuong_thuc_tt" class="filter-control" onchange="this.form.submit()"><option value="">Chọn phương thức thanh toán...</option><option value="COD" <%= safeFilters.phuong_thuc_tt === 'COD' ? 'selected' : '' %>>COD</option></select></div>
        <div class="filter-block"><div class="filter-title">Người tạo</div><input name="nguoi_tao" value="<%= safeFilters.nguoi_tao || '' %>" list="userList" class="filter-control" placeholder="Chọn người tạo"></div>
        <div class="filter-block"><div class="filter-title">Người nhận đặt</div><input name="nguoi_nhan" value="<%= safeFilters.nguoi_nhan || '' %>" class="filter-control" placeholder="Chọn người nhận đặt"></div>
        <datalist id="userList"><% safeUsers.forEach(u => { %><option value="<%= u.ho_ten || u.username %>"></option><% }) %></datalist>
        <button type="submit" class="btn primary" style="width:100%;justify-content:center">Lọc</button>
      </aside>
      <main class="main">
        <div class="toolbar">
          <div class="search"><i class="fa-solid fa-magnifying-glass"></i><input name="q" value="<%= safeFilters.q || '' %>" placeholder="Theo mã phiếu đặt"><button type="submit"><i class="fa-solid fa-sliders"></i></button></div>
          <div class="actions">
            <a class="btn primary" href="/don-hang/create"><i class="fa-solid fa-plus"></i> Đặt hàng</a>
            <button type="button" class="btn" onclick="alert('Chọn các đơn cần gộp trước khi dùng chức năng này.')"><i class="fa-regular fa-copy"></i> Gộp đơn</button>
            <a class="btn" href="/don-hang/export.xlsx<%= exportQuery ? '?' + exportQuery : '' %>"><i class="fa-solid fa-file-export"></i> Xuất file <i class="fa-solid fa-chevron-down"></i></a>
          </div>
        </div>
        <div class="table-wrap">
          <table class="table">
            <thead><tr><th class="check-col"><input class="row-check" type="checkbox"></th><th class="star-col"><i class="fa-regular fa-star"></i></th><th>Mã đặt hàng</th><th>Thời gian</th><th>Mã KH</th><th>Khách hàng</th><th class="num">Khách cần trả</th><th class="num">Khách đã trả</th><th>Trạng thái</th><th>Giao hàng</th></tr></thead>
            <tbody>
              <% if (safeOrders.length) { %>
                <% safeOrders.forEach(o => { %>
                  <tr class="order-row" data-order-row="<%= o._id %>" onclick="toggleOrderDetail('<%= o._id %>')"><td class="check-col"><input class="row-check" type="checkbox" onclick="event.stopPropagation()"></td><td class="star-col"><i class="fa-regular fa-star"></i></td><td><%- refLink('order', o, o.ma_don_hang, 'onclick="event.stopPropagation()"') %></td><td><%= new Date(o.ngay_dat || o.created_at).toLocaleString('vi-VN') %></td><td><%- o.khach_hang_id ? refLink('customer', o.khach_hang_id, o.khach_hang_id.ma_khach_hang, 'onclick="event.stopPropagation()"') : '' %></td><td><%= o.khach_hang_id ? o.khach_hang_id.ten_khach_hang : 'Khách lẻ' %></td><td class="num"><%= fmt(o.tong_thanh_toan || o.tong_tien) %></td><td class="num"><%= fmt(o.khach_thanh_toan || 0) %></td><td><span class="status-badge <%= o.trang_thai %>"><%= statusText(o.trang_thai) %></span></td><td><span class="status-badge <%= o.trang_thai_giao_hang %>"><%= deliveryStatusText(o.trang_thai_giao_hang) %></span></td></tr>
                  <tr class="detail-row" data-order-detail="<%= o._id %>"><td class="detail-cell" colspan="10"><div class="order-detail"><div class="loading-detail">Đang tải thông tin đơn...</div></div></td></tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="10" class="empty"><div class="empty-wrap"><div class="empty-icon"><i class="fa-regular fa-inbox"></i></div><h3>Không tìm thấy kết quả</h3><p>Không tìm thấy giao dịch nào phù hợp trong tháng này.<br>Nhấn vào <a href="/don-hang">đây</a> để tiếp tục tìm kiếm.</p></div></td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </main>
    </div>
  </form>
  <script>
    const money = value => Number(value || 0).toLocaleString('vi-VN');
    const statusLabels = { draft: 'Phiếu tạm', shipping: 'Đang giao hàng', completed: 'Hoàn thành', cancelled: 'Đã hủy' };
    const deliveryStatusLabels = { chua_giao: 'Chưa giao', giao_mot_phan: 'Giao một phần', giao_thieu: 'Giao thiếu', giao_du: 'Giao đủ' };
    const deliveryStatusText = status => deliveryStatusLabels[status] || 'Chưa giao';
    const escapeHtml = value => String(value ?? '').replace(/[&<>"']/g, char => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[char]));
    const refAnchor = (href, text) => href ? `<a class="ref-link" href="${escapeHtml(href)}" onclick="event.stopPropagation()">${escapeHtml(text || '--')}</a>` : escapeHtml(text || '--');
    const orderDetailCache = {};

    async function toggleOrderDetail(id) {
      const row = document.querySelector('[data-order-row="' + id + '"]');
      const detailRow = document.querySelector('[data-order-detail="' + id + '"]');
      if (!detailRow) return;
      const shouldOpen = !detailRow.classList.contains('open');
      document.querySelectorAll('.detail-row').forEach(item => item.classList.remove('open'));
      document.querySelectorAll('.order-row').forEach(item => item.classList.remove('active'));
      if (!shouldOpen) return;
      detailRow.classList.add('open');
      row?.classList.add('active');
      if (detailRow.dataset.loaded === 'true') return;
      await loadOrderDetail(id, detailRow);
    }

    document.addEventListener('DOMContentLoaded', function() {
      const id = new URLSearchParams(window.location.search).get('order');
      if (id) {
        const row = document.querySelector('[data-order-row="' + id + '"]');
        if (row) {
          toggleOrderDetail(id);
          row.scrollIntoView({ block: 'center' });
        }
      }
    });

    async function loadOrderDetail(id, detailRow) {
      const res = await fetch('/don-hang/' + id + '/detail');
      const data = await res.json();
      if (!data.success) return alert(data.message || 'Không tải được đơn hàng');
      const order = data.data.order;
      const shipment = data.data.shipment;
      const invoice = data.data.invoice;
      const items = data.data.items || [];
      orderDetailCache[id] = data.data;
      const totalGoods = items.reduce((sum, item) => sum + Number(item.thanh_tien || 0), 0);
      const discount = Math.max(totalGoods - Number(order.tong_thanh_toan || order.tong_tien || 0), 0);
      detailRow.querySelector('.order-detail').innerHTML = renderOrderDetail(order, shipment, invoice, items, totalGoods, discount);
      detailRow.dataset.loaded = 'true';
    }

    function renderOrderDetail(order, shipment, invoice, items, totalGoods, discount) {
      const customer = order.khach_hang_id || {};
      const receiver = shipment?.ten_nguoi_nhan || customer.ten_khach_hang || '';
      const phone = shipment?.sdt_nguoi_nhan || customer.sdt || '';
      const address = shipment?.dia_chi_nhan || customer.dia_chi_day_du || '';
      const itemRows = items.map(item => {
        const product = item.hang_hoa_id || {};
        const deliveryStatus = deliveryStatusLabels[item.trang_thai_giao] || deliveryStatusLabels.chua_giao;
        return `<tr>
          <td>${refAnchor(product._id ? '/hang-hoa/' + product._id : '', product.ma_hang || '')}</td>
          <td>${escapeHtml(product.ten_hang || '')}</td>
          <td class="num">${money(item.so_luong_dat || item.so_luong || 0)}</td>
          <td class="num">${money(item.so_luong_xac_nhan || 0)}</td>
          <td class="num">${money(item.so_luong_da_giao || 0)}</td>
          <td class="num">${money(item.so_luong_con_thieu || 0)}</td>
          <td>${escapeHtml(deliveryStatus)}</td>
          <td class="num">${money(item.don_gia_ban)}</td>
          <td class="num">${money(item.chiet_khau)}</td>
          <td class="num">${money(item.don_gia_ban)}</td>
          <td class="num"><strong>${money(item.thanh_tien)}</strong></td>
        </tr>`;
      }).join('') || '<tr><td colspan="11" class="loading-detail">Đơn chưa có hàng hóa</td></tr>';
      const invoiceAction = invoice
        ? `<a class="btn solid" href="/don-hang/tra-hang/create?invoice_id=${invoice._id}"><i class="fa-solid fa-rotate-left"></i> Trả hàng</a>`
        : `<a class="btn solid" href="/don-hang/hoa-don/create?don_hang_id=${order._id}"><i class="fa-solid fa-file-invoice-dollar"></i> Tạo hóa đơn</a>`;

      return `
        <div class="detail-tabs"><button type="button" class="detail-tab">Thông tin</button></div>
        <div class="detail-head">
          <div>
            <div><span class="detail-title">${escapeHtml(customer.ten_khach_hang || 'Khách lẻ')}</span> <span>${refAnchor(order._id ? '/don-hang/' + order._id : '', order.ma_don_hang || '')}</span></div>
            <div class="detail-meta">
              <div class="mini-field"><label>Người tạo</label><span>${escapeHtml(order.nguoi_tao_id?.ho_ten || order.nguoi_tao_id?.username || '')}</span></div>
              <div class="mini-field"><label>Người nhận đặt</label><input class="mini-input" value="${escapeHtml(order.nguoi_tao_id?.ho_ten || order.nguoi_tao_id?.username || '')}"></div>
              <div class="mini-field"><label>Ngày đặt</label><input class="mini-input" value="${escapeHtml(new Date(order.ngay_dat || order.created_at).toLocaleString('vi-VN'))}"></div>
              <div class="mini-field"><label>Kênh bán</label><input class="mini-input" value="Bán trực tiếp"></div>
              <div class="mini-field"><label>Bảng giá</label><input class="mini-input" value="Bảng giá chung"></div>
              <div class="mini-field"><label>Trạng thái</label><select class="mini-select" onchange="updateOrderStatus('${order._id}',this.value)">${['draft','shipping','completed','cancelled'].map(status => `<option value="${status}" ${order.trang_thai === status ? 'selected' : ''}>${statusLabels[status]}</option>`).join('')}</select></div>
            </div>
          </div>
          <div>${escapeHtml(order.cua_hang_id?.ten_cua_hang || 'Chi nhánh trung tâm')}</div>
        </div>
        <div class="delivery-box">
          <div class="delivery-title"><span><i class="fa-regular fa-hand-point-right"></i> Tự giao đến: <strong>${escapeHtml(address || 'Chưa có địa chỉ giao hàng')}</strong></span><i class="fa-solid fa-chevron-up"></i></div>
          <div class="delivery-grid">
            <div class="mini-field"><label>Người nhận</label><input class="mini-input" value="${escapeHtml(receiver)}"></div>
            <div class="mini-field"><label>Mã vận đơn</label><span>${refAnchor(shipment?._id ? '/don-hang/van-don/' + shipment._id : '', shipment?.ma_van_don || '')}</span></div>
            <div class="mini-field"><label>Người giao</label><input class="mini-input" value="${escapeHtml(shipment?.doi_tac_giao_hang_id?.ten_doi_tac || 'Tự giao hàng')}"></div>
            <div class="mini-field"><label>Điện thoại</label><input class="mini-input" value="${escapeHtml(phone)}"></div>
            <div class="mini-field"><label>Trọng lượng</label><input class="mini-input" value="500 g"></div>
            <div class="mini-field"><label>Thu hộ tiền</label><input type="checkbox" checked></div>
            <div class="mini-field"><label>Địa chỉ</label><input class="mini-input" value="${escapeHtml(address)}"></div>
            <div class="mini-field"><label>Dịch vụ</label><input class="mini-input" value="Giao thường"></div>
            <div class="mini-field"><label>Phí trả ĐTGH</label><input class="mini-input" value="${money(shipment?.phi_giao_hang || 0)}"></div>
          </div>
          <textarea class="note js-shipment-note" data-order-id="${order._id}" placeholder="Ghi chú giao...">${escapeHtml(shipment?.ghi_chu || '')}</textarea>
        </div>
        <table class="items-table"><thead><tr><th>Mã hàng</th><th>Tên hàng</th><th class="num">SL đặt</th><th class="num">SL xác nhận</th><th class="num">SL đã giao</th><th class="num">SL còn thiếu</th><th>Trạng thái giao</th><th class="num">Đơn giá</th><th class="num">Giảm giá</th><th class="num">Giá bán</th><th class="num">Thành tiền</th></tr></thead><tbody>${itemRows}</tbody></table>
        <div class="detail-bottom">
          <textarea class="note js-order-note" data-order-id="${order._id}" placeholder="Ghi chú...">${escapeHtml(order.ghi_chu || '')}</textarea>
          <div class="totals">
            <div class="total-line"><span>Tổng tiền hàng (${items.length})</span><strong>${money(totalGoods)}</strong></div>
            <div class="total-line"><span>Giảm giá phiếu đặt</span><span>${money(discount)}</span></div>
            <div class="total-line"><span>Tổng cộng</span><strong>${money(order.tong_thanh_toan || order.tong_tien)}</strong></div>
            <div class="total-line"><span>Khách đã trả</span><span>0</span></div>
          </div>
        </div>
        <div class="page-actions page-actions--split page-actions--bordered detail-actions">
          <div class="page-actions__left detail-action-group"><button type="button" class="btn" onclick="deleteOrder('${order._id}')"><i class="fa-regular fa-trash-can"></i> Hủy</button><a class="btn" href="/don-hang/create?copy_from=${order._id}"><i class="fa-regular fa-copy"></i> Sao chép</a><a class="btn" href="/don-hang/${order._id}/export.xlsx"><i class="fa-solid fa-file-export"></i> Xuất file</a></div>
          <div class="page-actions__right detail-action-group"><button type="button" class="btn solid" onclick="updateOrderStatus('${order._id}','shipping')"><i class="fa-solid fa-truck-fast"></i> Xử lý đơn hàng</button><button type="button" class="btn solid" onclick="confirmDelivery('${order._id}')"><i class="fa-solid fa-box-open"></i> Xác nhận giao</button>${invoiceAction}<button type="button" class="btn" onclick="saveOrderDetail('${order._id}')"><i class="fa-regular fa-floppy-disk"></i> Lưu</button><button type="button" class="btn" onclick="finishOrder('${order._id}', '${order.trang_thai_giao_hang || 'chua_giao'}')"><i class="fa-regular fa-circle-check"></i> Kết thúc</button><a class="btn" href="/chung-tu-kho/ban-hang/${order._id}" target="_blank"><i class="fa-solid fa-print"></i> Mở riêng</a></div>
        </div>`;
    }

    async function updateOrderStatus(id, status, forceCompleteShort = false) {
      const res = await fetch('/don-hang/' + id + '/status', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ trang_thai: status, force_complete_short: forceCompleteShort }) });
      const data = await res.json();
      if (!data.success) return alert(data.message || 'Không cập nhật được trạng thái');
      location.reload();
    }

    async function finishOrder(id, deliveryStatus) {
      if (deliveryStatus !== 'giao_du' && !confirm('Đơn chưa giao đủ. Xác nhận kết thúc thiếu?')) return;
      await updateOrderStatus(id, 'completed', deliveryStatus !== 'giao_du');
    }

    async function confirmDelivery(id) {
      const detail = orderDetailCache[id];
      if (!detail) return alert('Vui lòng mở lại chi tiết đơn trước khi xác nhận giao.');
      const order = detail.order || {};
      const items = detail.items || [];
      const khoId = order.kho_id?._id || order.kho_id;
      if (!khoId) return alert('Đơn chưa có kho giao hàng.');
      const deliveryItems = [];
      for (const item of items) {
        const missing = Number(item.so_luong_con_thieu || item.so_luong_dat || item.so_luong || 0);
        if (missing <= 0) continue;
        const product = item.hang_hoa_id || {};
        const raw = prompt(`Số lượng giao cho ${product.ma_hang || product.ten_hang || 'hàng hóa'} (còn thiếu ${missing})`, String(missing));
        if (raw === null) continue;
        const quantity = Number(String(raw).replace(',', '.'));
        if (!Number.isFinite(quantity) || quantity <= 0) continue;
        deliveryItems.push({
          ct_don_hang_id: item._id,
          hang_hoa_id: product._id || item.hang_hoa_id,
          lo_hang_id: item.lo_hang_id || '',
          so_luong_giao: quantity
        });
      }
      if (!deliveryItems.length) return alert('Chưa có số lượng giao.');
      const res = await fetch('/don-hang/' + id + '/xac-nhan-giao', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ kho_id: khoId, items: deliveryItems })
      });
      const data = await res.json();
      if (!data.success) return alert(data.message || 'Không xác nhận giao được.');
      location.reload();
    }

    async function deleteOrder(id) {
      if (!confirm('Hủy đơn đặt hàng này?')) return;
      await updateOrderStatus(id, 'cancelled');
    }

    async function saveOrderDetail(id) {
      const detailRow = document.querySelector('[data-order-detail="' + id + '"]');
      const panel = detailRow?.querySelector('.order-detail');
      if (!panel) return alert('Vui lòng mở chi tiết đơn trước khi lưu.');
      const deliveryInputs = panel.querySelectorAll('.delivery-grid .mini-input');
      const payload = {
        ghi_chu: panel.querySelector('.js-order-note')?.value || '',
        shipment: {
          ten_nguoi_nhan: deliveryInputs[0]?.value || '',
          sdt_nguoi_nhan: deliveryInputs[3]?.value || '',
          dia_chi_nhan: deliveryInputs[6]?.value || '',
          ghi_chu: panel.querySelector('.js-shipment-note')?.value || ''
        }
      };
      const res = await fetch('/don-hang/' + id + '/detail', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const data = await res.json();
      if (!data.success) return alert(data.message || 'Không lưu được đơn hàng');
      alert(data.message || 'Đã lưu thông tin đơn hàng');
    }
  </script>
</body>
</html>
