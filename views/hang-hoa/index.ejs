<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body class="admin-body">
  <%- include('../partials/header', { activeMenu: activeMenu, user: user }) %>

  <main class="admin-shell customer-page">
    <%- include('../partials/flash-message', { flash: flash }) %>
    <div id="addProductModalOverlay" class="modal-overlay" data-auto-open="<%= formMode === 'create' ? '1' : '0' %>">
      <div class="modal-content product-create-modal">
        <div class="modal-header">
          <h3 id="productModalTitle">Tạo hàng hóa</h3>
          <button type="button" class="modal-close" id="addProductModalClose">×</button>
        </div>
        <form class="modal-body product-form-body" method="post" action="/hang-hoa/add" id="productCreateForm">
          <div class="product-form-grid">
            <section class="product-form-section">
              <h4>Thông tin</h4>
              <div class="store-fields product-fields">
                <div>
                  <span>Mã hàng</span>
                  <input name="ma_hang" placeholder="Tự động">
                </div>
                <div>
                  <span>Tên hàng *</span>
                  <input name="ten_hang" placeholder="Bắt buộc" required>
                </div>
                <div>
                  <span>Nhóm hàng</span>
                  <div class="group-manage-wrapper" id="productFormGroupWrapper">
                    <div class="group-manage-header">
                      <button class="group-manage-trigger" type="button" id="productFormGroupTrigger">
                        <span id="productFormGroupLabel">Chọn nhóm hàng</span>
                        <span>▾</span>
                      </button>
                      <button class="btn btn-primary btn-sm" type="button" id="productGroupModalAddBtn" title="Thêm nhóm hàng">Thêm</button>
                    </div>
                    <input type="hidden" name="nhom_hang_id" id="productFormGroupValue" value="">
                    <div class="group-manage-dropdown" id="productFormGroupDropdown"></div>
                  </div>
                </div>
                <div>
                  <span>Đơn vị tính</span>
                  <div class="group-manage-wrapper" id="productFormUnitWrapper">
                    <div class="group-manage-header">
                      <button class="group-manage-trigger" type="button" id="productFormUnitTrigger">
                        <span id="productFormUnitLabel">Chọn đơn vị tính</span>
                        <span>▾</span>
                      </button>
                      <button class="btn btn-primary btn-sm" type="button" id="unitTypeAddBtn" title="Thêm đơn vị tính">Thêm</button>
                    </div>
                    <input type="hidden" name="don_vi_tinh_id" id="productFormUnitValue" value="">
                    <div class="group-manage-dropdown" id="productFormUnitDropdown"></div>
                  </div>
                </div>
                <div>
                  <span>Nhà cung cấp</span>
                  <select name="nha_cung_cap_id">
                    <option value="">Chọn nhà cung cấp</option>
                    <% (suppliers || []).forEach(function(supplier) { %>
                      <option value="<%= supplier._id %>"><%= supplier.ten_ncc || '---' %></option>
                    <% }) %>
                  </select>
                </div>
              </div>
              <h4>Giá vốn, giá bán</h4>
              <div class="store-fields product-fields">
                <div>
                  <span>Giá vốn</span>
                  <input type="number" min="0" name="gia_von" value="0">
                </div>
                <div>
                  <span>Loại giá</span>
                  <select name="loai_gia" id="productPriceType">
                    <option value="thi_truong">Thị trường</option>
                    <option value="co_dinh">Cố định</option>
                  </select>
                </div>
                <div id="fixedPriceWrap">
                  <span>Giá bán</span>
                  <input type="number" min="0" name="gia_co_dinh" value="0">
                </div>
              </div>
            </section>

            <section class="product-form-section">
              <h4>Tồn kho</h4>
              <div class="store-fields product-fields">
                <div>
                  <span>Tồn ban đầu</span>
                  <input type="number" min="0" name="ton_ban_dau" value="0">
                </div>
                <div>
                  <span>Định mức tối thiểu</span>
                  <input type="number" min="0" name="dinh_muc_toi_thieu" value="0">
                </div>
              </div>
            </section>

            <section class="product-form-section">
              <h4>Thiết lập khác</h4>
              <div class="product-toggle-row">
                <label><input type="checkbox" name="ban_truc_tiep" value="true" checked> Bán trực tiếp</label>
                <label><input type="checkbox" name="quan_ly_theo_lo" value="true" id="productManageLotCheckbox"> Quản lý theo lô</label>
              </div>
              <div class="store-fields product-fields" id="initialLotFields" style="display:none;">
                <div>
                  <span>Hạn sử dụng mặc định (ngày)</span>
                  <input type="number" min="0" step="1" name="han_su_dung_mac_dinh_so_ngay" id="hsdMacDinhInput" value="5">
                </div>
                <div class="span-2">
                  <p id="hsdMacDinhPreview" class="product-hsd-preview muted-small">HSD dự kiến: --</p>
                </div>
                <div>
                  <span>Mã lô ban đầu</span>
                  <input name="initial_lot_ma" placeholder="Tự động">
                </div>
                <div>
                  <span>Tên lô ban đầu</span>
                  <input name="initial_lot_ten" placeholder="Lô mặc định">
                </div>
                <div>
                  <span>Hạn sử dụng</span>
                  <input type="date" name="initial_lot_han_su_dung">
                </div>
              </div>
              <div class="store-fields product-fields">
                <div class="span-2">
                  <span>Mô tả</span>
                  <input name="mo_ta" placeholder="Nhập mô tả ngắn">
                </div>
                <div>
                  <span>Trạng thái</span>
                  <select name="trang_thai">
                    <option value="active" selected>Đang kinh doanh</option>
                    <option value="inactive">Ngừng kinh doanh</option>
                  </select>
                </div>
              </div>
            </section>
          </div>
        </form>
        <div class="page-actions modal-footer">
          <button class="btn btn-light" type="button" id="addProductModalCancel">Bỏ qua</button>
          <button class="btn btn-primary" type="submit" form="productCreateForm" id="productModalSubmitBtn">Lưu</button>
        </div>
      </div>
    </div>

    <div class="customer-shell">
      <aside class="customer-filter">
        <h2>Hàng hóa</h2>
        <form method="get" action="/hang-hoa" id="hangHoaFilterForm">
          <section class="customer-filter-section">
            <div class="customer-filter-title-row">
              <h4>Nhóm hàng</h4>
              <button class="filter-link-btn" type="button" id="productGroupAddBtn">Tạo mới</button>
            </div>
            <% var selectedProductGroup = (groups || []).find(function(group) { return filter.groupId === String(group._id); }); %>
            <div class="group-manage-wrapper" id="productGroupManageSidebar">
              <div class="group-manage-header">
                <button class="group-manage-trigger" type="button" id="productGroupFilterTrigger">
                  <span id="productGroupFilterLabel"><%= selectedProductGroup ? selectedProductGroup.ten_nhom_hang : 'Chọn nhóm hàng' %></span>
                  <span>▾</span>
                </button>
              </div>
              <input type="hidden" name="groupId" id="productGroupFilterValue" value="<%= filter.groupId || 'all' %>">
              <div class="group-manage-dropdown" id="productGroupFilterDropdown">
                <div class="group-manage-item <%= (!filter.groupId || filter.groupId === 'all') ? 'is-active' : '' %>" data-id="" data-value="all" data-name="Chọn nhóm hàng" data-desc="">
                  <button class="group-manage-option" type="button">Chọn nhóm hàng</button>
                </div>
                <% (groups || []).forEach(function(group) { %>
                  <div class="group-manage-item <%= filter.groupId === String(group._id) ? 'is-active' : '' %>" data-id="<%= group._id %>" data-value="<%= group._id %>" data-name="<%= group.ten_nhom_hang || '---' %>" data-desc="<%= group.mo_ta || '' %>">
                    <button class="group-manage-option" type="button"><%= group.ten_nhom_hang || '---' %></button>
                    <div class="group-manage-actions">
                      <button class="group-manage-action-edit" type="button">Sửa</button>
                      <button class="group-manage-action-delete" type="button">Xóa</button>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>
          </section>
 
           <section class="customer-filter-section">
             <h4>Bảng giá</h4>
            <div class="filter-check-list">
              <% (bangGiaList || []).forEach(function(bg) { %>
                <% var isChecked = (filter.bangGiaIds || []).indexOf(String(bg._id)) >= 0; %>
                <label class="filter-check-item <%= isChecked ? 'is-checked' : '' %>">
                  <input type="checkbox" name="bangGia" value="<%= bg._id %>" <%= isChecked ? 'checked' : '' %> onchange="this.parentElement.classList.toggle('is-checked', this.checked)">
                  <span class="filter-check-label"><%= bg.ten_bang_gia %></span>
                </label>
              <% }) %>
              <% if (!bangGiaList || bangGiaList.length === 0) { %>
                <span style="font-size:12px;color:#64748b;padding:4px 12px">Không có bảng giá hoạt động.</span>
              <% } %>
            </div>
           </section>

          <section class="customer-filter-section">
            <h4>Tồn kho</h4>
            <div class="range-stack">
              <div class="range-row"><span>Từ</span><input type="number" min="0" name="stockFrom" value="<%= filter.stockFrom || '' %>" placeholder="Nhập giá trị"></div>
              <div class="range-row"><span>Tới</span><input type="number" min="0" name="stockTo" value="<%= filter.stockTo || '' %>" placeholder="Nhập giá trị"></div>
            </div>
          </section>

          <section class="customer-filter-section">
            <h4>Thời gian tạo</h4>
            <label class="filter-radio-row">
              <input type="radio" name="created" value="all" <%= filter.created !== 'custom' ? 'checked' : '' %>>
              <span>Toàn thời gian</span>
            </label>
            <label class="filter-radio-row">
              <input type="radio" name="created" value="custom" <%= filter.created === 'custom' ? 'checked' : '' %>>
              <span>Tùy chỉnh</span>
            </label>
            <div class="custom-date-range <%= filter.created === 'custom' ? 'is-visible' : '' %>" id="customDateRange">
              <label><span>Từ ngày</span><input type="date" name="createdFrom" value="<%= filter.createdFrom || '' %>"></label>
              <label><span>Đến ngày</span><input type="date" name="createdTo" value="<%= filter.createdTo || '' %>"></label>
            </div>
          </section>

          <section class="customer-filter-section">
            <h4>Nhà cung cấp</h4>
            <select name="supplierId">
              <option value="all">Chọn nhà cung cấp</option>
              <% (suppliers || []).forEach(function(supplier) { %>
                <option value="<%= supplier._id %>" <%= filter.supplierId === String(supplier._id) ? 'selected' : '' %>><%= supplier.ten_ncc || '---' %></option>
              <% }) %>
            </select>
          </section>

          <section class="customer-filter-section">
            <h4>Liên kết bán</h4>
            <div class="pill-row">
              <button class="pill-btn <%= filter.salesLink === 'all' ? 'is-active' : '' %>" type="button" data-target-input="salesLinkInput" data-value="all">Tất cả</button>
              <button class="pill-btn <%= filter.salesLink === 'yes' ? 'is-active' : '' %>" type="button" data-target-input="salesLinkInput" data-value="yes">Có</button>
              <button class="pill-btn <%= filter.salesLink === 'no' ? 'is-active' : '' %>" type="button" data-target-input="salesLinkInput" data-value="no">Không</button>
            </div>
            <input type="hidden" id="salesLinkInput" name="salesLink" value="<%= filter.salesLink || 'all' %>">
          </section>

          <section class="customer-filter-section">
            <h4>Trạng thái hàng hóa</h4>
            <div class="pill-row">
              <button class="pill-btn <%= filter.status === 'all' ? 'is-active' : '' %>" type="button" data-target-input="productStatusInput" data-value="all">Tất cả</button>
              <button class="pill-btn <%= filter.status === 'inactive' ? 'is-active' : '' %>" type="button" data-target-input="productStatusInput" data-value="inactive">Ngừng kinh doanh</button>
            </div>
            <input type="hidden" id="productStatusInput" name="status" value="<%= filter.status || 'all' %>">
            <div class="customer-filter-actions">
              <button class="btn btn-primary" type="submit">Áp dụng lọc</button>
              <a class="btn btn-light" href="/hang-hoa">Xóa lọc</a>
            </div>
          </section>
        </form>
      </aside>

      <section class="customer-content">
        <div class="customer-toolbar">
          <div class="customer-search">
            <span>⌕</span>
            <input type="search" name="keyword" form="hangHoaFilterForm" value="<%= filter.keyword || '' %>" placeholder="Theo mã, tên hàng">
          </div>
          <div class="customer-toolbar-actions">
            <button class="btn btn-primary" type="button" id="openAddProductModal">+ Tạo mới</button>
            <button class="btn btn-danger" type="submit" form="bulkDeleteProductsForm" onclick="return confirm('Xóa các hàng hóa đã chọn?')">Xóa đã chọn</button>
            <button class="btn btn-light" type="button" id="openExportColsModal">Xuất file</button>
          </div>
        </div>

        <div class="customer-table-wrap">
          <form id="bulkDeleteProductsForm" method="post" action="/hang-hoa/delete-selected">
          <table class="admin-table customer-table" data-kv-master="hang-hoa">
            <thead>
              <tr>
                <th class="check-cell"><input id="selectAllProducts" type="checkbox" aria-label="Chọn tất cả"></th>
                <th>Mã hàng</th>
                <th>Tên hàng</th>
                <th>Giá bán</th>
                <th>Giá vốn</th>
                <th>Tồn kho</th>
                <th>Nhóm hàng</th>
                <th>Nhà cung cấp</th>
                <th>Thời gian tạo</th>
              </tr>
            </thead>
            <tbody>
              <% if (!products || products.length === 0) { %>
                <tr>
                  <td colspan="9" class="empty-cell">Không có hàng hóa phù hợp với bộ lọc.</td>
                </tr>
              <% } %>
              <% (products || []).forEach(function(item) { %>
                <% var listBase = '/hang-hoa' + (filterQueryString ? ('?' + filterQueryString) : ''); %>
                <tr class="product-list-row" data-kv-detail-id="<%= item._id %>">
                  <td class="check-cell" onclick="event.stopPropagation()"><input class="product-checkbox" type="checkbox" name="ids" value="<%= item._id %>" aria-label="Chọn hàng hóa"></td>
                  <td><a class="table-code-link kv-detail-code-link" href="<%= listBase %>"><%= item.ma_hang || '---' %></a></td>
                  <td><strong><%= item.ten_hang || '---' %></strong></td>
                  <td><%= Number(item.gia_ban_hien_thi || 0).toLocaleString('vi-VN') %></td>
                  <td><%= Number(item.gia_von || 0).toLocaleString('vi-VN') %></td>
                  <td><%= Number(item.ton_kho || 0).toLocaleString('vi-VN') %></td>
                  <td><%= item.nhom_hang_ten || '---' %></td>
                  <td><%= item.nha_cung_cap_ten || '---' %></td>
                  <td><%= formatDate(item.created_at) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          </form>
          <% (products || []).forEach(function(item) { %>
            <form id="deleteProductForm_<%= item._id %>" method="post" action="/hang-hoa/<%= item._id %>/delete"></form>
          <% }) %>
        </div>
      </section>
    </div>
  </main>

  <!-- ── Export Columns Picker Modal ────────────────────────── -->
  <div id="exportColsModalOverlay" style="display:none;position:fixed;inset:0;background:rgba(15,23,42,.45);z-index:1200;align-items:center;justify-content:center">
    <div style="background:#fff;border-radius:10px;padding:24px 28px;width:min(520px,calc(100vw - 32px));max-height:calc(100vh - 80px);overflow-y:auto;box-shadow:0 18px 44px rgba(15,23,42,.28)">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
        <h3 style="margin:0;font-size:17px">Tùy chọn cột xuất file</h3>
        <button id="exportColsModalClose" type="button" style="border:0;background:none;font-size:22px;cursor:pointer;line-height:1">×</button>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px 24px;margin-bottom:18px" id="exportColsGrid">
        <label style="display:flex;align-items:center;gap:7px;font-size:13px"><input type="checkbox" class="export-col-cb" value="loai_hang" checked> Loại hàng</label>
        <label style="display:flex;align-items:center;gap:7px;font-size:13px"><input type="checkbox" class="export-col-cb" value="ma_hang" checked> Mã hàng</label>
        <label style="display:flex;align-items:center;gap:7px;font-size:13px"><input type="checkbox" class="export-col-cb" value="ten_hang" checked> Tên hàng</label>
        <label style="display:flex;align-items:center;gap:7px;font-size:13px"><input type="checkbox" class="export-col-cb" value="thuong_hieu"> Thương hiệu</label>
        <label style="display:flex;align-items:center;gap:7px;font-size:13px"><input type="checkbox" class="export-col-cb" value="nhom_hang" checked> Nhóm hàng</label>
        <label style="display:flex;align-items:center;gap:7px;font-size:13px"><input type="checkbox" class="export-col-cb" value="hinh_anh"> Hình ảnh</label>
        <label style="display:flex;align-items:center;gap:7px;font-size:13px"><input type="checkbox" class="export-col-cb" value="dang_kinh_doanh" checked> Đang kinh doanh</label>
        <label style="display:flex;align-items:center;gap:7px;font-size:13px"><input type="checkbox" class="export-col-cb" value="ban_truc_tiep"> Được bán trực tiếp</label>
        <label style="display:flex;align-items:center;gap:7px;font-size:13px"><input type="checkbox" class="export-col-cb" value="gia_ban" checked> Giá bán</label>
        <label style="display:flex;align-items:center;gap:7px;font-size:13px"><input type="checkbox" class="export-col-cb" value="gia_von" checked> Giá vốn</label>
        <label style="display:flex;align-items:center;gap:7px;font-size:13px"><input type="checkbox" class="export-col-cb" value="ton_kho" checked> Tồn kho</label>
        <label style="display:flex;align-items:center;gap:7px;font-size:13px"><input type="checkbox" class="export-col-cb" value="kh_dat"> KH đặt</label>
        <label style="display:flex;align-items:center;gap:7px;font-size:13px"><input type="checkbox" class="export-col-cb" value="du_kien_het"> Dự kiến hết hàng</label>
        <label style="display:flex;align-items:center;gap:7px;font-size:13px"><input type="checkbox" class="export-col-cb" value="ton_nho_nhat"> Tồn nhỏ nhất</label>
        <label style="display:flex;align-items:center;gap:7px;font-size:13px"><input type="checkbox" class="export-col-cb" value="ton_lon_nhat"> Tồn lớn nhất</label>
        <label style="display:flex;align-items:center;gap:7px;font-size:13px"><input type="checkbox" class="export-col-cb" value="dvt"> ĐVT</label>
        <label style="display:flex;align-items:center;gap:7px;font-size:13px"><input type="checkbox" class="export-col-cb" value="ma_dvt_co_ban"> Mã ĐVT cơ bản</label>
        <label style="display:flex;align-items:center;gap:7px;font-size:13px"><input type="checkbox" class="export-col-cb" value="quy_doi"> Quy đổi</label>
      </div>
      
      <div style="margin-bottom:16px">
        <h4 style="margin:0 0 10px 0;font-size:14px;color:#475569">Bảng giá muốn xuất kèm</h4>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px 24px" id="exportBangGiaGrid">
          <% (bangGiaList || []).forEach(function(bg) { %>
            <label style="display:flex;align-items:center;gap:7px;font-size:13px"><input type="checkbox" class="export-bang-gia-cb" value="<%= bg._id %>"> <%= bg.ten_bang_gia %></label>
          <% }) %>
          <% if (!bangGiaList || bangGiaList.length === 0) { %>
            <span style="grid-column: span 2; font-size:12px;color:#94a3b8">Không có bảng giá khả dụng.</span>
          <% } %>
        </div>
      </div>
      <div id="exportColsError" style="color:#d92d20;font-size:13px;margin-bottom:10px;display:none">Vui lòng chọn ít nhất 1 cột.</div>
      <div style="display:flex;align-items:center;justify-content:space-between;gap:10px">
        <button id="exportColsDeselectAll" type="button" class="btn btn-light btn-sm">Bỏ chọn tất cả</button>
        <div style="display:flex;gap:8px">
          <button id="exportColsCancel" type="button" class="btn btn-light btn-sm">Hủy</button>
          <button id="exportColsSubmit" type="button" class="btn btn-primary btn-sm">Xuất file</button>
        </div>
      </div>
    </div>
  </div>
  <!-- hidden form to POST export request -->
  <form id="exportColsForm" method="POST" action="/hang-hoa/export-excel" style="display:none">
    <div id="exportColsFormInputs"></div>
    <!-- pass current filter values so backend applies same filter -->
    <input type="hidden" name="groupId" value="<%= filter.groupId || 'all' %>">
    <input type="hidden" name="supplierId" value="<%= filter.supplierId || 'all' %>">
    <input type="hidden" name="stockFrom" value="<%= filter.stockFrom || '' %>">
    <input type="hidden" name="stockTo" value="<%= filter.stockTo || '' %>">
    <input type="hidden" name="created" value="<%= filter.created || 'all' %>">
    <input type="hidden" name="createdFrom" value="<%= filter.createdFrom || '' %>">
    <input type="hidden" name="createdTo" value="<%= filter.createdTo || '' %>">
    <input type="hidden" name="salesLink" value="<%= filter.salesLink || 'all' %>">
    <input type="hidden" name="status" value="<%= filter.status || 'all' %>">
    <input type="hidden" name="keyword" value="<%= filter.keyword || '' %>">
  </form>
  <div id="productGroupModalOverlay" class="group-modal-overlay">
    <div class="group-modal">
      <div class="group-modal-header">
        <h3 id="productGroupModalTitle">Sửa nhóm hàng</h3>
        <button type="button" class="group-modal-close" id="productGroupModalClose">×</button>
      </div>
      <div class="group-modal-body">
        <label>
          <span>Tên nhóm</span>
          <input id="productGroupNameInput" type="text" placeholder="Nhập tên nhóm">
        </label>
        <label>
          <span>Mô tả</span>
          <input id="productGroupDescInput" type="text" placeholder="Nhập mô tả (không bắt buộc)">
        </label>
      </div>
      <div class="page-actions group-modal-footer">
        <button class="btn btn-light btn-sm" type="button" id="productGroupModalCancel">Bỏ qua</button>
        <button class="btn btn-primary btn-sm" type="button" id="productGroupModalSubmit">Lưu</button>
      </div>
    </div>
  </div>
  <div id="unitTypeModalOverlay" class="group-modal-overlay">
    <div class="group-modal">
      <div class="group-modal-header">
        <h3 id="unitTypeModalTitle">Thêm đơn vị tính</h3>
        <button type="button" class="group-modal-close" id="unitTypeModalClose">×</button>
      </div>
      <div class="group-modal-body">
        <label>
          <span>Tên đơn vị tính</span>
          <input id="unitTypeNameInput" type="text" placeholder="Nhập tên đơn vị tính">
        </label>
        <label>
          <span>Mã đơn vị (không bắt buộc)</span>
          <input id="unitTypeCodeInput" type="text" placeholder="Ví dụ: DVT001">
        </label>
      </div>
      <div class="page-actions group-modal-footer">
        <button class="btn btn-light btn-sm" type="button" id="unitTypeModalCancel">Bỏ qua</button>
        <button class="btn btn-primary btn-sm" type="button" id="unitTypeModalSubmit">Lưu</button>
      </div>
    </div>
  </div>
  <script id="productGroupsSeed" type="application/json"><%- JSON.stringify(groups || []) %></script>
  <script id="unitTypesSeed" type="application/json"><%- JSON.stringify(units || []) %></script>
  <script src="/js/kv-inline-detail.js"></script>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var masterTable = document.querySelector('table[data-kv-master="hang-hoa"]');
      if (masterTable && typeof KvInlineDetail !== 'undefined') {
        var kvHangHoa = new KvInlineDetail({
          table: masterTable,
          colspan: 9,
          buildUrl: function(id) {
            return '/hang-hoa/api/' + encodeURIComponent(id) + '/detail';
          }
        });
        if (/^#p-/.test(location.hash)) {
          var pid = decodeURIComponent(location.hash.slice(3));
          if (pid) {
            kvHangHoa.openById(pid);
            var clean = location.pathname + (location.search || '');
            history.replaceState(null, '', clean);
          }
        }
      }

      var createdRadios = Array.prototype.slice.call(document.querySelectorAll('input[name="created"]'));
      var customDateRange = document.getElementById('customDateRange');
      function toggleCustomDateRange() {
        if (!customDateRange) return;
        var selected = createdRadios.find(function(radio) { return radio.checked; });
        customDateRange.classList.toggle('is-visible', selected && selected.value === 'custom');
      }
      createdRadios.forEach(function(radio) {
        radio.addEventListener('change', toggleCustomDateRange);
      });
      toggleCustomDateRange();

      var pillButtons = Array.prototype.slice.call(document.querySelectorAll('.pill-btn'));
      pillButtons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var targetInputId = btn.getAttribute('data-target-input');
          var value = btn.getAttribute('data-value');
          var input = document.getElementById(targetInputId);
          if (!input) return;
          input.value = value;
          var siblings = Array.prototype.slice.call(btn.parentElement.querySelectorAll('.pill-btn'));
          siblings.forEach(function(item) { item.classList.remove('is-active'); });
          btn.classList.add('is-active');
        });
      });

      var openAddProductModalBtn = document.getElementById('openAddProductModal');
      var addProductModalOverlay = document.getElementById('addProductModalOverlay');
      var addProductModalClose = document.getElementById('addProductModalClose');
      var addProductModalCancel = document.getElementById('addProductModalCancel');
      var productModalTitle = document.getElementById('productModalTitle');
      var productModalSubmitBtn = document.getElementById('productModalSubmitBtn');
      var productCreateForm = document.getElementById('productCreateForm');
      var productPriceType = document.getElementById('productPriceType');
      var fixedPriceWrap = document.getElementById('fixedPriceWrap');
      var productManageLotCheckbox = document.getElementById('productManageLotCheckbox');
      var initialLotFields = document.getElementById('initialLotFields');
      var hsdMacDinhInput = document.getElementById('hsdMacDinhInput');
      var hsdMacDinhPreview = document.getElementById('hsdMacDinhPreview');
      var selectAllProducts = document.getElementById('selectAllProducts');
      var productCheckboxes = Array.prototype.slice.call(document.querySelectorAll('.product-checkbox'));
      var customerTableWrap = document.querySelector('.customer-table-wrap');
      function toggleFixedPrice() {
        if (!fixedPriceWrap || !productPriceType) return;
        fixedPriceWrap.style.display = productPriceType.value === 'co_dinh' ? '' : 'none';
      }

      function toggleInitialLotFields() {
        if (!initialLotFields || !productManageLotCheckbox) return;
        initialLotFields.style.display = productManageLotCheckbox.checked ? '' : 'none';
        if (productManageLotCheckbox.checked) updateHsdPreview();
      }

      function updateHsdPreview() {
        if (!hsdMacDinhPreview) return;
        var days = Number(hsdMacDinhInput && hsdMacDinhInput.value);
        if (!Number.isFinite(days) || days < 0) days = 0;
        var date = new Date();
        date.setHours(0, 0, 0, 0);
        date.setDate(date.getDate() + days);
        var dd = String(date.getDate()).padStart(2, '0');
        var mm = String(date.getMonth() + 1).padStart(2, '0');
        var yyyy = date.getFullYear();
        hsdMacDinhPreview.textContent = 'HSD dự kiến: ' + dd + '/' + mm + '/' + yyyy;
      }

      function setProductFormValue(name, value) {
        if (!productCreateForm) return;
        var input = productCreateForm.querySelector('[name="' + name + '"]');
        if (!input) return;
        input.value = value == null ? '' : String(value);
      }

      function setProductCheckbox(name, value) {
        if (!productCreateForm) return;
        var input = productCreateForm.querySelector('input[name="' + name + '"]');
        if (!input) return;
        input.checked = !!value;
      }

      function openAddProductModal() {
        if (!addProductModalOverlay) return;
        if (productModalTitle) productModalTitle.textContent = 'Tạo hàng hóa';
        if (productModalSubmitBtn) productModalSubmitBtn.textContent = 'Lưu';
        if (productCreateForm) {
          productCreateForm.setAttribute('action', '/hang-hoa/add');
          productCreateForm.reset();
        }
        setProductFormValue('han_su_dung_mac_dinh_so_ngay', 5);
        if (typeof refreshProductFormGroup === 'function') refreshProductFormGroup('');
        if (typeof refreshProductFormUnit === 'function') refreshProductFormUnit('');
        addProductModalOverlay.classList.add('is-visible');
        toggleFixedPrice();
        toggleInitialLotFields();
        updateHsdPreview();
      }

      function openEditProductModal(product) {
        if (!addProductModalOverlay || !product || !product._id) return;
        if (productModalTitle) productModalTitle.textContent = 'Sửa hàng hóa';
        if (productModalSubmitBtn) productModalSubmitBtn.textContent = 'Cập nhật';
        if (productCreateForm) {
          productCreateForm.setAttribute('action', '/hang-hoa/' + product._id + '/update');
        }

        setProductFormValue('ma_hang', product.ma_hang || '');
        setProductFormValue('ten_hang', product.ten_hang || '');
        setProductFormValue('nha_cung_cap_id', product.nha_cung_cap_id || '');
        setProductFormValue('gia_von', Number(product.gia_von || 0));
        setProductFormValue('loai_gia', product.loai_gia || 'thi_truong');
        setProductFormValue('gia_co_dinh', Number(product.gia_co_dinh || 0));
        setProductFormValue('ton_ban_dau', Number(product.ton_ban_dau || 0));
        setProductFormValue('dinh_muc_toi_thieu', Number(product.dinh_muc_toi_thieu || 0));
        setProductFormValue('mo_ta', product.mo_ta || '');
        setProductFormValue('trang_thai', product.trang_thai || 'active');
        setProductCheckbox('ban_truc_tiep', !!product.ban_truc_tiep);
        setProductCheckbox('quan_ly_theo_lo', !!product.quan_ly_theo_lo);
        setProductFormValue(
          'han_su_dung_mac_dinh_so_ngay',
          product.han_su_dung_mac_dinh_so_ngay != null ? product.han_su_dung_mac_dinh_so_ngay : 5
        );

        if (typeof refreshProductFormGroup === 'function') {
          refreshProductFormGroup(product.nhom_hang_id || '');
        }
        if (typeof refreshProductFormUnit === 'function') {
          refreshProductFormUnit(product.don_vi_tinh_id || '');
        }

        addProductModalOverlay.classList.add('is-visible');
        toggleFixedPrice();
        toggleInitialLotFields();
        updateHsdPreview();
      }

      function closeAddProductModal() {
        if (!addProductModalOverlay) return;
        addProductModalOverlay.classList.remove('is-visible');
      }

      if (productPriceType) productPriceType.addEventListener('change', toggleFixedPrice);
      if (productManageLotCheckbox) productManageLotCheckbox.addEventListener('change', toggleInitialLotFields);
      if (hsdMacDinhInput) hsdMacDinhInput.addEventListener('input', updateHsdPreview);
      if (openAddProductModalBtn) openAddProductModalBtn.addEventListener('click', openAddProductModal);
      if (addProductModalClose) addProductModalClose.addEventListener('click', closeAddProductModal);
      if (addProductModalCancel) addProductModalCancel.addEventListener('click', closeAddProductModal);
      if (addProductModalOverlay && addProductModalOverlay.getAttribute('data-auto-open') === '1') openAddProductModal();
      toggleFixedPrice();
      toggleInitialLotFields();

      function openCopyProductModal(product) {
        if (!product) return;
        openAddProductModal();
        if (productModalTitle) productModalTitle.textContent = 'Sao chép hàng hóa';
        if (productModalSubmitBtn) productModalSubmitBtn.textContent = 'Lưu';
        setProductFormValue('ma_hang', '');
        setProductFormValue('ten_hang', (product.ten_hang || '') + ' (bản sao)');
        setProductFormValue('nha_cung_cap_id', product.nha_cung_cap_id || '');
        setProductFormValue('gia_von', Number(product.gia_von || 0));
        setProductFormValue('loai_gia', product.loai_gia || 'thi_truong');
        setProductFormValue('gia_co_dinh', Number(product.gia_co_dinh || 0));
        setProductFormValue('ton_ban_dau', 0);
        setProductFormValue('dinh_muc_toi_thieu', Number(product.dinh_muc_toi_thieu || 0));
        setProductFormValue('mo_ta', product.mo_ta || '');
        setProductFormValue('trang_thai', 'active');
        setProductCheckbox('ban_truc_tiep', !!product.ban_truc_tiep);
        setProductCheckbox('quan_ly_theo_lo', !!product.quan_ly_theo_lo);
        setProductFormValue(
          'han_su_dung_mac_dinh_so_ngay',
          product.han_su_dung_mac_dinh_so_ngay != null ? product.han_su_dung_mac_dinh_so_ngay : 5
        );
        if (typeof refreshProductFormGroup === 'function') {
          refreshProductFormGroup(product.nhom_hang_id || '');
        }
        if (typeof refreshProductFormUnit === 'function') {
          refreshProductFormUnit(product.don_vi_tinh_id || '');
        }
        toggleInitialLotFields();
        updateHsdPreview();
      }

      function printProductLabel(product) {
        if (!product) return;
        const win = window.open('', '_blank');
        if (!win) return alert('Trình duyệt chặn cửa sổ in.');
        const price = Number(product.gia_co_dinh || product.gia_ban || 0).toLocaleString('vi-VN');
        const labelHtml = '<html><head><title>In tem ' + (product.ma_hang || '') + '</title><style>body{font-family:Arial;padding:16px}.label{width:220px;border:1px solid #ccc;padding:12px;margin:8px;display:inline-block}.code{font-size:18px;font-weight:700}</style></head><body><div class="label"><div class="code">' + (product.ma_hang || '') + '</div><div>' + (product.ten_hang || '') + '</div><div>Gi\u00e1: ' + price + '</div></div></body></html>';
        win.document.write(labelHtml);
        win.document.close();
        win.focus();
        win.print();
      }

      if (customerTableWrap) {
        customerTableWrap.addEventListener('click', function(event) {
          var button = event.target.closest('.btn-edit-product, .btn-copy-product, .btn-print-label');
          if (!button || !customerTableWrap.contains(button)) return;
          event.preventDefault();
          event.stopPropagation();
          var payload = button.getAttribute('data-product') || '{}';
          try {
            var product = JSON.parse(payload);
            if (button.classList.contains('btn-edit-product')) openEditProductModal(product);
            else if (button.classList.contains('btn-copy-product')) openCopyProductModal(product);
            else if (button.classList.contains('btn-print-label')) printProductLabel(product);
          } catch (_error) {
            alert('Không đọc được dữ liệu hàng hóa.');
          }
        });
      }

      if (selectAllProducts && productCheckboxes.length > 0) {
        selectAllProducts.addEventListener('change', function() {
          productCheckboxes.forEach(function(item) { item.checked = selectAllProducts.checked; });
        });
        productCheckboxes.forEach(function(item) {
          item.addEventListener('change', function() {
            var allChecked = productCheckboxes.every(function(node) { return node.checked; });
            selectAllProducts.checked = allChecked;
          });
        });
      }

      var productFormUnitTrigger = document.getElementById('productFormUnitTrigger');
      var productFormUnitLabel = document.getElementById('productFormUnitLabel');
      var productFormUnitValue = document.getElementById('productFormUnitValue');
      var productFormUnitDropdown = document.getElementById('productFormUnitDropdown');
      var unitTypeAddBtn = document.getElementById('unitTypeAddBtn');
      var unitTypeModalOverlay = document.getElementById('unitTypeModalOverlay');
      var unitTypeModalTitle = document.getElementById('unitTypeModalTitle');
      var unitTypeModalClose = document.getElementById('unitTypeModalClose');
      var unitTypeModalCancel = document.getElementById('unitTypeModalCancel');
      var unitTypeModalSubmit = document.getElementById('unitTypeModalSubmit');
      var unitTypeNameInput = document.getElementById('unitTypeNameInput');
      var unitTypeCodeInput = document.getElementById('unitTypeCodeInput');
      var unitTypeModalMode = 'add';
      var activeUnitTypeItem = null;

      var productFormGroupTrigger = document.getElementById('productFormGroupTrigger');
      var productFormGroupLabel = document.getElementById('productFormGroupLabel');
      var productFormGroupValue = document.getElementById('productFormGroupValue');
      var productFormGroupDropdown = document.getElementById('productFormGroupDropdown');
      var productGroupFilterTrigger = document.getElementById('productGroupFilterTrigger');
      var productGroupFilterLabel = document.getElementById('productGroupFilterLabel');
      var productGroupFilterValue = document.getElementById('productGroupFilterValue');
      var productGroupFilterDropdown = document.getElementById('productGroupFilterDropdown');
      var productGroupAddBtn = document.getElementById('productGroupAddBtn');
      var productGroupModalOverlay = document.getElementById('productGroupModalOverlay');
      var productGroupModalTitle = document.getElementById('productGroupModalTitle');
      var productGroupModalClose = document.getElementById('productGroupModalClose');
      var productGroupModalCancel = document.getElementById('productGroupModalCancel');
      var productGroupModalSubmit = document.getElementById('productGroupModalSubmit');
      var productGroupNameInput = document.getElementById('productGroupNameInput');
      var productGroupDescInput = document.getElementById('productGroupDescInput');
      var productGroupModalMode = 'add';
      var activeProductGroupItem = null;

      function escapeManageAttr(value) {
        return String(value || '').replace(/"/g, '&quot;');
      }

      function updateManageWidget(context) {
        if (!context || !context.dropdown) return;
        var activeItem = context.dropdown.querySelector('.group-manage-item.is-active');
        var fallback = context.emptyLabel || 'Chọn';
        if (context.labelEl) {
          context.labelEl.textContent = activeItem
            ? (activeItem.getAttribute('data-name') || fallback)
            : fallback;
        }
        if (context.valueEl) {
          context.valueEl.value = activeItem
            ? (activeItem.getAttribute('data-value') || context.emptyValue || '')
            : (context.emptyValue || '');
        }
      }

      function bindManageDropdown(context, handlers) {
        if (!context || !context.dropdown) return;
        var items = Array.prototype.slice.call(context.dropdown.querySelectorAll('.group-manage-item'));
        items.forEach(function(item) {
          var optionBtn = item.querySelector('.group-manage-option');
          var editBtn = item.querySelector('.group-manage-action-edit');
          var deleteBtn = item.querySelector('.group-manage-action-delete');

          if (optionBtn) {
            optionBtn.addEventListener('click', function() {
              items.forEach(function(node) { node.classList.remove('is-active'); });
              item.classList.add('is-active');
              updateManageWidget(context);
              context.dropdown.classList.remove('is-open');
            });
          }

          if (editBtn && handlers && handlers.onEdit) {
            editBtn.addEventListener('click', function(event) {
              event.stopPropagation();
              handlers.onEdit(item);
            });
          }

          if (deleteBtn && handlers && handlers.onDelete) {
            deleteBtn.addEventListener('click', function(event) {
              event.stopPropagation();
              handlers.onDelete(item);
            });
          }
        });
      }

      var productFormGroupContext = {
        dropdown: productFormGroupDropdown,
        trigger: productFormGroupTrigger,
        labelEl: productFormGroupLabel,
        valueEl: productFormGroupValue,
        emptyValue: '',
        emptyLabel: 'Chọn nhóm hàng'
      };

      var productGroupFilterContext = {
        dropdown: productGroupFilterDropdown,
        trigger: productGroupFilterTrigger,
        labelEl: productGroupFilterLabel,
        valueEl: productGroupFilterValue,
        emptyValue: 'all',
        emptyLabel: 'Chọn nhóm hàng'
      };

      var productFormUnitContext = {
        dropdown: productFormUnitDropdown,
        trigger: productFormUnitTrigger,
        labelEl: productFormUnitLabel,
        valueEl: productFormUnitValue,
        emptyValue: '',
        emptyLabel: 'Chọn đơn vị tính'
      };

      function renderProductGroupDropdown(context, selectedValue) {
        if (!context || !context.dropdown) return;
        var groups = window.__productGroups || [];
        var emptyValue = context.emptyValue;
        var emptyLabel = context.emptyLabel;
        var selected = selectedValue == null ? (context.valueEl ? context.valueEl.value : emptyValue) : selectedValue;
        var rows = [];
        var isEmptyActive = String(selected || '') === String(emptyValue || '');
        rows.push(
          '<div class="group-manage-item ' + (isEmptyActive ? 'is-active' : '') + '" data-id="" data-value="' + escapeManageAttr(emptyValue) + '" data-name="' + escapeManageAttr(emptyLabel) + '" data-desc="">' +
            '<button class="group-manage-option" type="button">' + emptyLabel + '</button>' +
          '</div>'
        );
        groups.forEach(function(group) {
          var id = String(group._id || '');
          var isActive = id === String(selected || '');
          rows.push(
            '<div class="group-manage-item ' + (isActive ? 'is-active' : '') + '" data-id="' + id + '" data-value="' + id + '" data-name="' + escapeManageAttr(group.ten_nhom_hang) + '" data-desc="' + escapeManageAttr(group.mo_ta) + '">' +
              '<button class="group-manage-option" type="button">' + (group.ten_nhom_hang || '') + '</button>' +
              '<div class="group-manage-actions">' +
                '<button class="group-manage-action-edit" type="button">Sửa</button>' +
                '<button class="group-manage-action-delete" type="button">Xóa</button>' +
              '</div>' +
            '</div>'
          );
        });
        context.dropdown.innerHTML = rows.join('');
        bindManageDropdown(context, {
          onEdit: function(item) {
            activeProductGroupItem = item;
            openProductGroupModal('edit');
          },
          onDelete: function(item) {
            var groupId = item.getAttribute('data-id') || '';
            if (!groupId) {
              alert('Vui lòng chọn nhóm cần xóa.');
              return;
            }
            if (!confirm('Bạn có chắc muốn xóa nhóm hàng này không?')) return;
            var resetFilter = productGroupFilterValue && String(productGroupFilterValue.value) === groupId;
            var resetForm = productFormGroupValue && String(productFormGroupValue.value) === groupId;
            requestProductGroups('/hang-hoa/groups/' + groupId + '/delete', {}, {
              filter: resetFilter ? 'all' : undefined,
              form: resetForm ? '' : undefined
            });
          }
        });
        updateManageWidget(context);
      }

      function refreshProductFormGroup(selectedId) {
        renderProductGroupDropdown(productFormGroupContext, selectedId == null ? '' : selectedId);
      }

      function refreshProductGroupWidget(selectedId) {
        var selected = selectedId == null
          ? ((productGroupFilterValue && productGroupFilterValue.value) || 'all')
          : selectedId;
        renderProductGroupDropdown(productGroupFilterContext, selected);
      }

      function refreshAllProductGroups(selected) {
        var filterId = selected && selected.filter != null ? selected.filter : undefined;
        var formId = selected && selected.form != null ? selected.form : undefined;
        if (filterId !== undefined) refreshProductGroupWidget(filterId);
        else refreshProductGroupWidget();
        if (formId !== undefined) refreshProductFormGroup(formId);
        else refreshProductFormGroup(productFormGroupValue ? productFormGroupValue.value : '');
      }

      function requestProductGroups(url, payload, selected) {
        var formBody = Object.keys(payload).map(function(key) {
          return encodeURIComponent(key) + '=' + encodeURIComponent(payload[key]);
        }).join('&');

        fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
          },
          body: formBody
        })
          .then(function(response) {
            return response.json().catch(function() {
              return { success: false, message: 'Server không trả về JSON hợp lệ.' };
            });
          })
          .then(function(data) {
            if (!data || !data.success) {
              alert((data && data.message) || 'Không thể xử lý nhóm hàng.');
              return;
            }
            if (Array.isArray(data.groups)) {
              window.__productGroups = data.groups;
            } else if (data.data && data.data._id) {
              window.__productGroups = (window.__productGroups || []).filter(function(group) {
                return String(group._id) !== String(data.data._id);
              });
              window.__productGroups.push(data.data);
            }
            var activeGroupId = data.selectedId || (data.data && data.data._id) || '';
            var nextSelected = selected && typeof selected === 'object' ? selected : {};
            if (activeGroupId) {
              if (nextSelected.filter == null && productGroupFilterValue && String(productGroupFilterValue.value) === 'all') {
                nextSelected.filter = activeGroupId;
              }
              if (nextSelected.form == null) {
                nextSelected.form = activeGroupId;
              }
            }
            refreshAllProductGroups(nextSelected);
            closeProductGroupModal();
          })
          .catch(function(error) {
            alert((error && error.message) || 'Có lỗi khi xử lý nhóm hàng.');
          });
      }

      function openProductGroupModal(mode) {
        productGroupModalMode = mode;
        if (!productGroupModalOverlay || !productGroupModalTitle) return;
        if (mode === 'add') {
          activeProductGroupItem = null;
          productGroupModalTitle.textContent = 'Thêm nhóm hàng';
          if (productGroupNameInput) productGroupNameInput.value = '';
          if (productGroupDescInput) productGroupDescInput.value = '';
        } else {
          productGroupModalTitle.textContent = 'Sửa nhóm hàng';
          if (productGroupNameInput) productGroupNameInput.value = activeProductGroupItem ? (activeProductGroupItem.getAttribute('data-name') || '') : '';
          if (productGroupDescInput) productGroupDescInput.value = activeProductGroupItem ? (activeProductGroupItem.getAttribute('data-desc') || '') : '';
        }
        productGroupModalOverlay.classList.add('is-open');
      }

      function closeProductGroupModal() {
        if (!productGroupModalOverlay) return;
        productGroupModalOverlay.classList.remove('is-open');
      }

      function renderProductUnitDropdown(context, selectedValue) {
        if (!context || !context.dropdown) return;
        var emptyValue = context.emptyValue;
        var emptyLabel = context.emptyLabel;
        var selected = selectedValue == null ? (context.valueEl ? context.valueEl.value : emptyValue) : selectedValue;
        var rows = [];
        var isEmptyActive = String(selected || '') === String(emptyValue || '');
        rows.push(
          '<div class="group-manage-item ' + (isEmptyActive ? 'is-active' : '') + '" data-id="" data-value="' + escapeManageAttr(emptyValue) + '" data-name="' + escapeManageAttr(emptyLabel) + '" data-code="">' +
            '<button class="group-manage-option" type="button">' + emptyLabel + '</button>' +
          '</div>'
        );
        (unitTypes || []).forEach(function(unit) {
          var id = String(unit._id || '');
          var isActive = id === String(selected || '');
          rows.push(
            '<div class="group-manage-item ' + (isActive ? 'is-active' : '') + '" data-id="' + id + '" data-value="' + id + '" data-name="' + escapeManageAttr(unit.ten_don_vi) + '" data-code="' + escapeManageAttr(unit.ma_don_vi) + '">' +
              '<button class="group-manage-option" type="button">' + (unit.ten_don_vi || '---') + '</button>' +
              '<div class="group-manage-actions">' +
                '<button class="group-manage-action-edit" type="button">Sửa</button>' +
                '<button class="group-manage-action-delete" type="button">Xóa</button>' +
              '</div>' +
            '</div>'
          );
        });
        context.dropdown.innerHTML = rows.join('');
        bindManageDropdown(context, {
          onEdit: function(item) {
            activeUnitTypeItem = item;
            openUnitTypeModal('edit');
          },
          onDelete: function(item) {
            var unitId = item.getAttribute('data-id') || '';
            if (!unitId) {
              alert('Vui lòng chọn đơn vị tính cần xóa.');
              return;
            }
            if (!confirm('Bạn có chắc muốn xóa đơn vị tính này không?')) return;
            var resetForm = productFormUnitValue && String(productFormUnitValue.value) === unitId;
            requestUnitTypes('/hang-hoa/units/' + unitId + '/delete', {}, resetForm ? '' : undefined);
          }
        });
        updateManageWidget(context);
      }

      function refreshProductFormUnit(selectedId) {
        renderProductUnitDropdown(productFormUnitContext, selectedId == null ? '' : selectedId);
      }

      function requestUnitTypes(url, payload, selectedId, callback) {
        var formBody = Object.keys(payload).map(function(key) {
          return encodeURIComponent(key) + '=' + encodeURIComponent(payload[key]);
        }).join('&');

        fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
          },
          body: formBody
        })
          .then(function(response) {
            return response.json().catch(function() {
              return { success: false, message: 'Server không trả về JSON hợp lệ.' };
            });
          })
          .then(function(data) {
            if (!data || !data.success) {
              alert((data && data.message) || 'Không thể xử lý đơn vị tính.');
              return;
            }
            var nextUnits = Array.isArray(data.units) ? data.units : unitTypes;
            if ((!Array.isArray(data.units) || data.units.length === 0) && data.data && data.data._id) {
              nextUnits = (nextUnits || []).filter(function(unit) {
                return String(unit._id) !== String(data.data._id);
              });
              nextUnits.push(data.data);
            }
            unitTypes = nextUnits || [];
            var nextSelected = selectedId != null
              ? selectedId
              : (data.selectedId || (data.data && data.data._id) || (productFormUnitValue ? productFormUnitValue.value : ''));
            refreshProductFormUnit(nextSelected);
            if (typeof callback === 'function') callback();
          })
          .catch(function(error) {
            alert((error && error.message) || 'Có lỗi khi xử lý đơn vị tính.');
          });
      }

      function openUnitTypeModal(mode) {
        unitTypeModalMode = mode;
        if (!unitTypeModalOverlay || !unitTypeModalTitle) return;
        if (mode === 'add') {
          activeUnitTypeItem = null;
          unitTypeModalTitle.textContent = 'Thêm đơn vị tính';
          if (unitTypeNameInput) unitTypeNameInput.value = '';
          if (unitTypeCodeInput) unitTypeCodeInput.value = '';
          if (unitTypeCodeInput) unitTypeCodeInput.removeAttribute('disabled');
        } else {
          unitTypeModalTitle.textContent = 'Sửa đơn vị tính';
          if (unitTypeNameInput) unitTypeNameInput.value = activeUnitTypeItem ? (activeUnitTypeItem.getAttribute('data-name') || '') : '';
          if (unitTypeCodeInput) unitTypeCodeInput.value = activeUnitTypeItem ? (activeUnitTypeItem.getAttribute('data-code') || '') : '';
          if (unitTypeCodeInput) unitTypeCodeInput.setAttribute('disabled', 'disabled');
        }
        unitTypeModalOverlay.classList.add('is-open');
      }

      function closeUnitTypeModal() {
        if (!unitTypeModalOverlay) return;
        unitTypeModalOverlay.classList.remove('is-open');
      }

      if (productFormUnitTrigger && productFormUnitDropdown) {
        productFormUnitTrigger.addEventListener('click', function() {
          productFormUnitDropdown.classList.toggle('is-open');
        });
      }
      if (unitTypeAddBtn) {
        unitTypeAddBtn.addEventListener('click', function() {
          openUnitTypeModal('add');
        });
      }
      if (unitTypeModalOverlay) {
        unitTypeModalOverlay.addEventListener('click', function(event) {
          if (event.target === unitTypeModalOverlay) closeUnitTypeModal();
        });
      }
      if (unitTypeModalClose) unitTypeModalClose.addEventListener('click', closeUnitTypeModal);
      if (unitTypeModalCancel) unitTypeModalCancel.addEventListener('click', closeUnitTypeModal);

      if (unitTypeModalSubmit) {
        unitTypeModalSubmit.addEventListener('click', function() {
          if (!unitTypeNameInput || !unitTypeNameInput.value.trim()) {
            alert('Vui lòng nhập tên đơn vị tính.');
            return;
          }
          if (unitTypeModalMode === 'add') {
            requestUnitTypes('/hang-hoa/units/add', {
              ten_don_vi: unitTypeNameInput.value.trim(),
              ma_don_vi: unitTypeCodeInput && unitTypeCodeInput.value ? unitTypeCodeInput.value.trim() : ''
            }, null, function() {
              closeUnitTypeModal();
            });
            return;
          }
          var unitId = activeUnitTypeItem ? (activeUnitTypeItem.getAttribute('data-id') || '') : '';
          if (!unitId) {
            alert('Vui lòng chọn đơn vị tính cần sửa.');
            return;
          }
          requestUnitTypes('/hang-hoa/units/' + unitId + '/update', {
            ten_don_vi: unitTypeNameInput.value.trim()
          }, unitId, function() {
            closeUnitTypeModal();
          });
        });
      }

      if (productFormGroupTrigger && productFormGroupDropdown) {
        productFormGroupTrigger.addEventListener('click', function() {
          productFormGroupDropdown.classList.toggle('is-open');
        });
      }
      if (productGroupFilterTrigger && productGroupFilterDropdown) {
        productGroupFilterTrigger.addEventListener('click', function() {
          productGroupFilterDropdown.classList.toggle('is-open');
        });
      }
      if (productGroupAddBtn) {
        productGroupAddBtn.addEventListener('click', function() {
          openProductGroupModal('add');
        });
      }
      var productGroupModalAddBtn = document.getElementById('productGroupModalAddBtn');
      if (productGroupModalAddBtn) {
        productGroupModalAddBtn.addEventListener('click', function(event) {
          event.preventDefault();
          openProductGroupModal('add');
        });
      }
      if (productGroupModalOverlay) {
        productGroupModalOverlay.addEventListener('click', function(event) {
          if (event.target === productGroupModalOverlay) closeProductGroupModal();
        });
      }
      if (productGroupModalClose) productGroupModalClose.addEventListener('click', closeProductGroupModal);
      if (productGroupModalCancel) productGroupModalCancel.addEventListener('click', closeProductGroupModal);

      if (productGroupModalSubmit) {
        productGroupModalSubmit.addEventListener('click', function() {
          if (!productGroupNameInput || !productGroupNameInput.value.trim()) {
            alert('Vui lòng nhập tên nhóm hàng.');
            return;
          }
          if (productGroupModalMode === 'add') {
            requestProductGroups('/hang-hoa/groups/add', {
              ten_nhom_hang: productGroupNameInput.value.trim(),
              mo_ta: productGroupDescInput ? productGroupDescInput.value.trim() : ''
            }, {});
            return;
          }
          var groupId = activeProductGroupItem ? (activeProductGroupItem.getAttribute('data-id') || '') : '';
          if (!groupId) {
            alert('Vui lòng chọn nhóm cần sửa.');
            return;
          }
          requestProductGroups('/hang-hoa/groups/' + groupId + '/update', {
            ten_nhom_hang: productGroupNameInput.value.trim(),
            mo_ta: productGroupDescInput ? productGroupDescInput.value.trim() : ''
          }, { form: groupId, filter: groupId });
        });
      }

      var unitTypesSeed = document.getElementById('unitTypesSeed');
      var unitTypes = unitTypesSeed ? JSON.parse(unitTypesSeed.textContent || '[]') : [];
      refreshProductFormUnit('');

      var productGroupsSeed = document.getElementById('productGroupsSeed');
      window.__productGroups = productGroupsSeed ? JSON.parse(productGroupsSeed.textContent || '[]') : [];
      refreshProductFormGroup('');
      refreshProductGroupWidget((productGroupFilterValue && productGroupFilterValue.value) || 'all');

      window.refreshProductFormGroup = refreshProductFormGroup;
      window.refreshProductFormUnit = refreshProductFormUnit;

      function closeManageDropdownOnOutsideClick(event, context) {
        if (!context || !context.dropdown || !context.trigger) return;
        if (!context.dropdown.contains(event.target) && !context.trigger.contains(event.target)) {
          context.dropdown.classList.remove('is-open');
        }
      }

      document.addEventListener('click', function(event) {
        closeManageDropdownOnOutsideClick(event, productGroupFilterContext);
        closeManageDropdownOnOutsideClick(event, productFormGroupContext);
        closeManageDropdownOnOutsideClick(event, productFormUnitContext);
      });
    });
  </script>

  <script>
    // --- Export Columns Popup ----------------------------------------
    (function() {
      var overlay   = document.getElementById('exportColsModalOverlay');
      var openBtn   = document.getElementById('openExportColsModal');
      var closeBtn  = document.getElementById('exportColsModalClose');
      var cancelBtn = document.getElementById('exportColsCancel');
      var deselectBtn = document.getElementById('exportColsDeselectAll');
      var submitBtn = document.getElementById('exportColsSubmit');
      var errorDiv  = document.getElementById('exportColsError');
      var form      = document.getElementById('exportColsForm');
      var formInputs = document.getElementById('exportColsFormInputs');

      function openModal() {
        if (overlay) overlay.style.display = 'flex';
        if (errorDiv) errorDiv.style.display = 'none';
      }
      function closeModal() {
        if (overlay) overlay.style.display = 'none';
      }

      if (openBtn)   openBtn.addEventListener('click', openModal);
      if (closeBtn)  closeBtn.addEventListener('click', closeModal);
      if (cancelBtn) cancelBtn.addEventListener('click', closeModal);

      // Close on backdrop click
      if (overlay) {
        overlay.addEventListener('click', function(e) {
          if (e.target === overlay) closeModal();
        });
      }

      // Deselect all
      if (deselectBtn) {
        deselectBtn.addEventListener('click', function() {
          var cbs = Array.prototype.slice.call(document.querySelectorAll('.export-col-cb'));
          cbs.forEach(function(cb) { cb.checked = false; });
        });
      }

      // Submit
      if (submitBtn) {
        submitBtn.addEventListener('click', function() {
          var cbs = Array.prototype.slice.call(document.querySelectorAll('.export-col-cb'));
          var selected = cbs.filter(function(cb) { return cb.checked; });

          if (selected.length === 0) {
            if (errorDiv) errorDiv.style.display = 'block';
            return;
          }
          if (errorDiv) errorDiv.style.display = 'none';

          // Build column hidden inputs
          if (formInputs) {
            formInputs.innerHTML = '';
            selected.forEach(function(cb) {
              var input = document.createElement('input');
              input.type = 'hidden';
              input.name = 'columns';
              input.value = cb.value;
              formInputs.appendChild(input);
            });

            // Collect selected price books to export
            var bgCbs = Array.prototype.slice.call(document.querySelectorAll('.export-bang-gia-cb'));
            bgCbs.filter(function(cb) { return cb.checked; }).forEach(function(cb) {
              var input = document.createElement('input');
              input.type = 'hidden';
              input.name = 'bangGia';
              input.value = cb.value;
              formInputs.appendChild(input);
            });
          }

          if (form) form.submit();
        });
      }
    })();
  </script>
</body>
</html>
