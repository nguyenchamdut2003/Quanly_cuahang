<!doctype html>
<html lang="vi">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body class="admin-body">
  <%- include('../partials/header', { activeMenu: activeMenu, user: user }) %>

  <main class="admin-shell customer-page">
    <%- include('../partials/flash-message', { flash: flash }) %>
    <div id="addProductModalOverlay" class="modal-overlay" data-auto-open="<%= formMode === 'create' ? '1' : '0' %>">
      <div class="modal-content product-create-modal">
        <div class="modal-header">
          <h3 id="productModalTitle">Tạo hàng hóa</h3>
          <button type="button" class="modal-close" id="addProductModalClose">×</button>
        </div>
        <form class="modal-body product-form-body" method="post" action="/hang-hoa/add" id="productCreateForm">
          <div class="product-form-grid">
            <section class="product-form-section">
              <h4>Thông tin</h4>
              <div class="store-fields product-fields">
                <div>
                  <span>Mã hàng</span>
                  <input name="ma_hang" placeholder="Tự động">
                </div>
                <div>
                  <span>Tên hàng *</span>
                  <input name="ten_hang" placeholder="Bắt buộc" required>
                </div>
                <div>
                  <span>Nhóm hàng</span>
                  <select name="nhom_hang_id">
                    <option value="">Chọn nhóm hàng</option>
                    <% (groups || []).forEach(function(group) { %>
                      <option value="<%= group._id %>"><%= group.ten_nhom_hang || '---' %></option>
                    <% }) %>
                  </select>
                </div>
                <div>
                  <span>Đơn vị tính</span>
                  <% var initialUnit = (units && units[0]) ? units[0] : null; %>
                  <div class="address-type-wrapper">
                    <div class="address-type-header">
                      <button class="address-type-trigger" type="button" id="unitTypeTrigger">
                        <span id="unitTypeSelectedLabel"><%= initialUnit ? initialUnit.ten_don_vi : 'Chọn đơn vị tính' %></span>
                        <span>▾</span>
                      </button>
                      <button class="btn btn-primary btn-sm" type="button" id="unitTypeAddBtn">Thêm</button>
                    </div>
                    <input type="hidden" name="don_vi_tinh_id" id="unitTypeValue" value="<%= initialUnit ? initialUnit._id : '' %>">
                    <div class="address-type-dropdown" id="unitTypeDropdown">
                      <% (units || []).forEach(function(unit) { %>
                        <div
                          class="address-type-item <%= initialUnit && String(initialUnit._id) === String(unit._id) ? 'is-active' : '' %>"
                          data-id="<%= unit._id %>"
                          data-value="<%= unit._id %>"
                          data-name="<%= unit.ten_don_vi || '---' %>"
                          data-code="<%= unit.ma_don_vi || '' %>"
                        >
                          <button class="address-type-option" type="button"><%= unit.ten_don_vi || '---' %></button>
                          <div class="address-type-actions">
                            <button class="address-type-action-edit" type="button">Sửa</button>
                            <button class="address-type-action-delete" type="button">Xóa</button>
                          </div>
                        </div>
                      <% }) %>
                    </div>
                  </div>
                </div>
                <div>
                  <span>Nhà cung cấp</span>
                  <select name="nha_cung_cap_id">
                    <option value="">Chọn nhà cung cấp</option>
                    <% (suppliers || []).forEach(function(supplier) { %>
                      <option value="<%= supplier._id %>"><%= supplier.ten_ncc || '---' %></option>
                    <% }) %>
                  </select>
                </div>
              </div>
              <h4>Giá vốn, giá bán</h4>
              <div class="store-fields product-fields">
                <div>
                  <span>Giá vốn</span>
                  <input type="number" min="0" name="gia_von" value="0">
                </div>
                <div>
                  <span>Loại giá</span>
                  <select name="loai_gia" id="productPriceType">
                    <option value="thi_truong">Thị trường</option>
                    <option value="co_dinh">Cố định</option>
                  </select>
                </div>
                <div id="fixedPriceWrap">
                  <span>Giá bán</span>
                  <input type="number" min="0" name="gia_co_dinh" value="0">
                </div>
              </div>
            </section>

            <section class="product-form-section">
              <h4>Tồn kho</h4>
              <div class="store-fields product-fields">
                <div>
                  <span>Tồn ban đầu</span>
                  <input type="number" min="0" name="ton_ban_dau" value="0">
                </div>
                <div>
                  <span>Định mức tối thiểu</span>
                  <input type="number" min="0" name="dinh_muc_toi_thieu" value="0">
                </div>
              </div>
            </section>

            <section class="product-form-section">
              <h4>Thiết lập khác</h4>
              <div class="product-toggle-row">
                <label><input type="checkbox" name="ban_truc_tiep" value="true" checked> Bán trực tiếp</label>
                <label><input type="checkbox" name="quan_ly_theo_lo" value="true" id="productManageLotCheckbox"> Quản lý theo lô</label>
              </div>
              <div class="store-fields product-fields" id="initialLotFields" style="display:none;">
                <div>
                  <span>Mã lô ban đầu</span>
                  <input name="initial_lot_ma" placeholder="Tự động">
                </div>
                <div>
                  <span>Tên lô ban đầu</span>
                  <input name="initial_lot_ten" placeholder="Lô mặc định">
                </div>
                <div>
                  <span>Hạn sử dụng</span>
                  <input type="date" name="initial_lot_han_su_dung">
                </div>
              </div>
              <div class="store-fields product-fields">
                <div class="span-2">
                  <span>Mô tả</span>
                  <input name="mo_ta" placeholder="Nhập mô tả ngắn">
                </div>
                <div>
                  <span>Trạng thái</span>
                  <select name="trang_thai">
                    <option value="active" selected>Đang kinh doanh</option>
                    <option value="inactive">Ngừng kinh doanh</option>
                  </select>
                </div>
              </div>
            </section>
          </div>
        </form>
        <div class="modal-footer">
          <button class="btn btn-light" type="button" id="addProductModalCancel">Bỏ qua</button>
          <button class="btn btn-primary" type="submit" form="productCreateForm" id="productModalSubmitBtn">Lưu</button>
        </div>
      </div>
    </div>

    <div class="customer-shell">
      <aside class="customer-filter">
        <h2>Hàng hóa</h2>
        <form method="get" action="/hang-hoa" id="hangHoaFilterForm">
          <section class="customer-filter-section">
            <div class="customer-filter-title-row">
              <h4>Nhóm hàng</h4>
              <button class="filter-link-btn" type="button" id="productGroupAddBtn">Tạo mới</button>
            </div>
            <% var selectedProductGroup = (groups || []).find(function(group) { return filter.groupId === String(group._id); }); %>
            <div class="group-manage-wrapper" id="productGroupManageSidebar">
              <div class="group-manage-header">
                <button class="group-manage-trigger" type="button" id="productGroupFilterTrigger">
                  <span id="productGroupFilterLabel"><%= selectedProductGroup ? selectedProductGroup.ten_nhom_hang : 'Chọn nhóm hàng' %></span>
                  <span>▾</span>
                </button>
              </div>
              <input type="hidden" name="groupId" id="productGroupFilterValue" value="<%= filter.groupId || 'all' %>">
              <div class="group-manage-dropdown" id="productGroupFilterDropdown">
                <div class="group-manage-item <%= (!filter.groupId || filter.groupId === 'all') ? 'is-active' : '' %>" data-id="" data-value="all" data-name="Chọn nhóm hàng" data-desc="">
                  <button class="group-manage-option" type="button">Chọn nhóm hàng</button>
                </div>
                <% (groups || []).forEach(function(group) { %>
                  <div class="group-manage-item <%= filter.groupId === String(group._id) ? 'is-active' : '' %>" data-id="<%= group._id %>" data-value="<%= group._id %>" data-name="<%= group.ten_nhom_hang || '---' %>" data-desc="<%= group.mo_ta || '' %>">
                    <button class="group-manage-option" type="button"><%= group.ten_nhom_hang || '---' %></button>
                    <div class="group-manage-actions">
                      <button class="group-manage-action-edit" type="button">Sửa</button>
                      <button class="group-manage-action-delete" type="button">Xóa</button>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>
          </section>

          <section class="customer-filter-section">
            <h4>Tồn kho</h4>
            <div class="range-stack">
              <div class="range-row"><span>Từ</span><input type="number" min="0" name="stockFrom" value="<%= filter.stockFrom || '' %>" placeholder="Nhập giá trị"></div>
              <div class="range-row"><span>Tới</span><input type="number" min="0" name="stockTo" value="<%= filter.stockTo || '' %>" placeholder="Nhập giá trị"></div>
            </div>
          </section>

          <section class="customer-filter-section">
            <h4>Thời gian tạo</h4>
            <label class="filter-radio-row">
              <input type="radio" name="created" value="all" <%= filter.created !== 'custom' ? 'checked' : '' %>>
              <span>Toàn thời gian</span>
            </label>
            <label class="filter-radio-row">
              <input type="radio" name="created" value="custom" <%= filter.created === 'custom' ? 'checked' : '' %>>
              <span>Tùy chỉnh</span>
            </label>
            <div class="custom-date-range <%= filter.created === 'custom' ? 'is-visible' : '' %>" id="customDateRange">
              <label><span>Từ ngày</span><input type="date" name="createdFrom" value="<%= filter.createdFrom || '' %>"></label>
              <label><span>Đến ngày</span><input type="date" name="createdTo" value="<%= filter.createdTo || '' %>"></label>
            </div>
          </section>

          <section class="customer-filter-section">
            <h4>Nhà cung cấp</h4>
            <select name="supplierId">
              <option value="all">Chọn nhà cung cấp</option>
              <% (suppliers || []).forEach(function(supplier) { %>
                <option value="<%= supplier._id %>" <%= filter.supplierId === String(supplier._id) ? 'selected' : '' %>><%= supplier.ten_ncc || '---' %></option>
              <% }) %>
            </select>
          </section>

          <section class="customer-filter-section">
            <h4>Liên kết bán</h4>
            <div class="pill-row">
              <button class="pill-btn <%= filter.salesLink === 'all' ? 'is-active' : '' %>" type="button" data-target-input="salesLinkInput" data-value="all">Tất cả</button>
              <button class="pill-btn <%= filter.salesLink === 'yes' ? 'is-active' : '' %>" type="button" data-target-input="salesLinkInput" data-value="yes">Có</button>
              <button class="pill-btn <%= filter.salesLink === 'no' ? 'is-active' : '' %>" type="button" data-target-input="salesLinkInput" data-value="no">Không</button>
            </div>
            <input type="hidden" id="salesLinkInput" name="salesLink" value="<%= filter.salesLink || 'all' %>">
          </section>

          <section class="customer-filter-section">
            <h4>Trạng thái hàng hóa</h4>
            <div class="pill-row">
              <button class="pill-btn <%= filter.status === 'all' ? 'is-active' : '' %>" type="button" data-target-input="productStatusInput" data-value="all">Tất cả</button>
              <button class="pill-btn <%= filter.status === 'inactive' ? 'is-active' : '' %>" type="button" data-target-input="productStatusInput" data-value="inactive">Ngừng kinh doanh</button>
            </div>
            <input type="hidden" id="productStatusInput" name="status" value="<%= filter.status || 'all' %>">
            <div class="customer-filter-actions">
              <button class="btn btn-primary" type="submit">Áp dụng lọc</button>
              <a class="btn btn-light" href="/hang-hoa">Xóa lọc</a>
            </div>
          </section>
        </form>
      </aside>

      <section class="customer-content">
        <div class="customer-toolbar">
          <div class="customer-search">
            <span>⌕</span>
            <input type="search" name="keyword" form="hangHoaFilterForm" value="<%= filter.keyword || '' %>" placeholder="Theo mã, tên hàng">
          </div>
          <div class="customer-toolbar-actions">
            <button class="btn btn-primary" type="button" id="openAddProductModal">+ Tạo mới</button>
            <button class="btn btn-danger" type="submit" form="bulkDeleteProductsForm" onclick="return confirm('Xóa các hàng hóa đã chọn?')">Xóa đã chọn</button>
            <button class="btn btn-light" type="button">Import file</button>
            <button class="btn btn-light" type="button">Xuất file</button>
          </div>
        </div>

        <div class="customer-table-wrap">
          <form id="bulkDeleteProductsForm" method="post" action="/hang-hoa/delete-selected">
          <table class="admin-table customer-table">
            <thead>
              <tr>
                <th class="check-cell"><input id="selectAllProducts" type="checkbox" aria-label="Chọn tất cả"></th>
                <th>Mã hàng</th>
                <th>Tên hàng</th>
                <th>Giá bán</th>
                <th>Giá vốn</th>
                <th>Tồn kho</th>
                <th>Nhóm hàng</th>
                <th>Nhà cung cấp</th>
                <th>Thời gian tạo</th>
                <th class="text-right">Thao tác</th>
              </tr>
            </thead>
            <tbody>
              <% if (!products || products.length === 0) { %>
                <tr>
                  <td colspan="10" class="empty-cell">Không có hàng hóa phù hợp với bộ lọc.</td>
                </tr>
              <% } %>
              <% (products || []).forEach(function(item) { %>
                <% var isSelectedProduct = selectedProduct && String(selectedProduct._id) === String(item._id); %>
                <% var productBaseQuery = filterQueryString ? ('?' + filterQueryString) : '?'; %>
                <% var productRowHref = isSelectedProduct ? ('/hang-hoa' + (filterQueryString ? ('?' + filterQueryString) : '')) : ('/hang-hoa' + productBaseQuery + (filterQueryString ? '&' : '') + 'product=' + item._id); %>
                <tr class="product-list-row <%= isSelectedProduct ? 'is-selected' : '' %>" data-row-href="<%= productRowHref %>">
                  <td class="check-cell" onclick="event.stopPropagation()"><input class="product-checkbox" type="checkbox" name="ids" value="<%= item._id %>" aria-label="Chọn hàng hóa"></td>
                  <td><a class="table-code-link" href="<%= productRowHref %>"><%= item.ma_hang || '---' %></a></td>
                  <td><strong><%= item.ten_hang || '---' %></strong></td>
                  <td><%= Number(item.gia_ban_hien_thi || 0).toLocaleString('vi-VN') %></td>
                  <td><%= Number(item.gia_von || 0).toLocaleString('vi-VN') %></td>
                  <td><%= Number(item.ton_kho || 0).toLocaleString('vi-VN') %></td>
                  <td><%= item.nhom_hang_ten || '---' %></td>
                  <td><%= item.nha_cung_cap_ten || '---' %></td>
                  <td><%= formatDate(item.created_at) %></td>
                  <td class="text-right" onclick="event.stopPropagation()">
                    <div class="warehouse-action-buttons">
                      <button class="btn btn-light btn-sm btn-edit-product" type="button" data-product='<%= JSON.stringify(item) %>'>Sửa</button>
                      <button class="btn btn-danger btn-sm" type="submit" form="deleteProductForm_<%= item._id %>" onclick="return confirm('Bạn có chắc muốn xóa hàng hóa này không?')">Xóa</button>
                    </div>
                  </td>
                </tr>
                <% if (isSelectedProduct) { %>
                  <tr class="product-detail-row">
                    <td colspan="10">
                      <div class="product-detail">
                        <div class="detail-tabs">
                          <div class="detail-tab-list">
                            <button class="detail-tab is-active" type="button" data-tab-target="product-info">Thông tin</button>
                            <button class="detail-tab" type="button" data-tab-target="product-note">Mô tả, ghi chú</button>
                            <button class="detail-tab" type="button" data-tab-target="product-card">Thẻ kho</button>
                            <button class="detail-tab" type="button" data-tab-target="product-stock">Tồn kho</button>
                            <% if (item.quan_ly_theo_lo) { %>
                              <button class="detail-tab" type="button" data-tab-target="product-lots">Lô hàng</button>
                            <% } %>
                          </div>
                        </div>

                        <div class="product-detail-body">
                          <section class="detail-pane is-active" data-tab-panel="product-info">
                            <div class="product-info-head">
                              <div class="product-thumb">▰</div>
                              <div>
                                <h2><%= item.ten_hang || 'Hàng hóa' %></h2>
                                <p>Nhóm hàng: <%= item.nhom_hang_ten || '---' %></p>
                                <div class="tag-row">
                                  <span class="tag">Hàng hóa thường</span>
                                  <span class="tag tag-green"><%= item.ban_truc_tiep ? 'Bán trực tiếp' : 'Không bán trực tiếp' %></span>
                                  <span class="tag"><%= item.quan_ly_theo_lo ? 'Quản lý theo lô' : 'Không quản lý theo lô' %></span>
                                </div>
                              </div>
                            </div>

                            <div class="product-info-grid">
                              <div><span>Mã hàng</span><strong><%= item.ma_hang || '---' %></strong></div>
                              <div><span>Tồn kho</span><strong><%= Number(item.ton_kho || 0).toLocaleString('vi-VN') %></strong></div>
                              <div><span>Định mức tồn</span><strong><%= Number(item.dinh_muc_toi_thieu || 0).toLocaleString('vi-VN') %> - 0</strong></div>
                              <div><span>Giá vốn</span><strong><%= Number(item.gia_von || 0).toLocaleString('vi-VN') %></strong></div>
                              <div><span>Giá bán</span><strong><%= Number(item.gia_ban_hien_thi || 0).toLocaleString('vi-VN') %></strong></div>
                              <div><span>Đơn vị tính</span><strong><%= item.don_vi_tinh_ten || '---' %></strong></div>
                              <div><span>Nhà cung cấp</span><strong><%= item.nha_cung_cap_ten || '---' %></strong></div>
                              <div><span>Trạng thái</span><strong><%= item.trang_thai === 'inactive' ? 'Ngừng kinh doanh' : 'Đang kinh doanh' %></strong></div>
                            </div>
                          </section>

                          <section class="detail-pane" data-tab-panel="product-note">
                            <div class="product-note-box">
                              <span>Mô tả, ghi chú</span>
                              <p><%= item.mo_ta || 'Chưa có mô tả hoặc ghi chú cho hàng hóa này.' %></p>
                            </div>
                          </section>

                          <section class="detail-pane" data-tab-panel="product-card">
                            <table class="admin-table product-inner-table">
                              <thead>
                                <tr>
                                  <th>Thời gian</th>
                                  <th>Kho</th>
                                  <th>Loại chứng từ</th>
                                  <th class="text-right">Số lượng</th>
                                </tr>
                              </thead>
                              <tbody>
                                <% if (!selectedProductHistories || selectedProductHistories.length === 0) { %>
                                  <tr><td colspan="4" class="empty-cell">Chưa có phát sinh thẻ kho.</td></tr>
                                <% } %>
                                <% (selectedProductHistories || []).forEach(function(row) { %>
                                  <tr>
                                    <td><%= formatDate(row.ngay || row.created_at) %></td>
                                    <td><%= row.kho_ten || '---' %></td>
                                    <td><%= row.loai_phieu || '---' %><% if (row.lo_hang_id) { %> - <%= row.lo_hang_id.ma_lo || row.lo_hang_id.ten_lo || 'Lô' %><% } %></td>
                                    <td class="text-right"><%= Number(row.so_luong_thay_doi || 0).toLocaleString('vi-VN') %></td>
                                  </tr>
                                <% }) %>
                              </tbody>
                            </table>
                          </section>

                          <section class="detail-pane" data-tab-panel="product-stock">
                            <table class="admin-table product-inner-table">
                              <thead>
                                <tr>
                                  <th>Kho</th>
                                  <th class="text-right">Tồn kho</th>
                                  <th>Cập nhật</th>
                                </tr>
                              </thead>
                              <tbody>
                                <% if (!selectedProductInventory || selectedProductInventory.length === 0) { %>
                                  <tr><td colspan="3" class="empty-cell">Chưa có tồn kho theo kho.</td></tr>
                                <% } %>
                                <% (selectedProductInventory || []).forEach(function(row) { %>
                                  <tr>
                                    <td><%= row.kho_ten || '---' %></td>
                                    <td class="text-right"><%= Number(row.so_luong || 0).toLocaleString('vi-VN') %></td>
                                    <td><%= formatDate(row.updated_at || row.created_at) %></td>
                                  </tr>
                                <% }) %>
                              </tbody>
                            </table>
                          </section>

                          <% if (item.quan_ly_theo_lo) { %>
                            <section class="detail-pane" data-tab-panel="product-lots">
                              <table class="admin-table product-inner-table">
                                <thead>
                                  <tr>
                                    <th>Mã lô</th>
                                    <th>Tên lô</th>
                                    <th>Kho</th>
                                    <th>Hạn sử dụng</th>
                                    <th class="text-right">Tồn lô</th>
                                    <th>Trạng thái</th>
                                  </tr>
                                </thead>
                                <tbody>
                                  <% if (!selectedProductLots || selectedProductLots.length === 0) { %>
                                    <tr><td colspan="6" class="empty-cell">Chưa có tồn theo lô.</td></tr>
                                  <% } %>
                                  <% (selectedProductLots || []).forEach(function(row) { %>
                                    <tr>
                                      <td><%= row.lo_hang_id?.ma_lo || '---' %></td>
                                      <td><%= row.lo_hang_id?.ten_lo || '---' %></td>
                                      <td><%= row.kho_ten || '---' %></td>
                                      <td><%= formatDate(row.lo_hang_id?.han_su_dung) %></td>
                                      <td class="text-right"><%= Number(row.so_luong || 0).toLocaleString('vi-VN') %></td>
                                      <td><%= row.lo_hang_id?.trang_thai || '---' %></td>
                                    </tr>
                                  <% }) %>
                                </tbody>
                              </table>
                            </section>
                          <% } %>
                        </div>

                        <div class="product-detail-footer">
                          <button class="btn btn-light btn-sm" type="button">Xóa</button>
                          <button class="btn btn-light btn-sm" type="button">Sao chép</button>
                          <button class="btn btn-primary btn-sm" type="button">Chỉnh sửa</button>
                          <button class="btn btn-light btn-sm" type="button">In tem mã</button>
                        </div>
                      </div>
                    </td>
                  </tr>
                <% } %>
              <% }) %>
            </tbody>
          </table>
          </form>
          <% (products || []).forEach(function(item) { %>
            <form id="deleteProductForm_<%= item._id %>" method="post" action="/hang-hoa/<%= item._id %>/delete"></form>
          <% }) %>
        </div>
      </section>
    </div>
  </main>
  <div id="productGroupModalOverlay" class="group-modal-overlay">
    <div class="group-modal">
      <div class="group-modal-header">
        <h3 id="productGroupModalTitle">Sửa nhóm hàng</h3>
        <button type="button" class="group-modal-close" id="productGroupModalClose">×</button>
      </div>
      <div class="group-modal-body">
        <label>
          <span>Tên nhóm</span>
          <input id="productGroupNameInput" type="text" placeholder="Nhập tên nhóm">
        </label>
        <label>
          <span>Ghi chú</span>
          <input id="productGroupDescInput" type="text" placeholder="Nhập ghi chú">
        </label>
      </div>
      <div class="group-modal-footer">
        <button class="btn btn-light btn-sm" type="button" id="productGroupModalCancel">Bỏ qua</button>
        <button class="btn btn-primary btn-sm" type="button" id="productGroupModalSubmit">Lưu</button>
      </div>
    </div>
  </div>
  <div id="unitTypeModalOverlay" class="group-modal-overlay">
    <div class="group-modal">
      <div class="group-modal-header">
        <h3 id="unitTypeModalTitle">Thêm đơn vị tính</h3>
        <button type="button" class="group-modal-close" id="unitTypeModalClose">×</button>
      </div>
      <div class="group-modal-body">
        <label>
          <span>Tên đơn vị tính</span>
          <input id="unitTypeNameInput" type="text" placeholder="Nhập tên đơn vị tính">
        </label>
        <label>
          <span>Mã đơn vị (không bắt buộc)</span>
          <input id="unitTypeCodeInput" type="text" placeholder="Ví dụ: DVT001">
        </label>
      </div>
      <div class="group-modal-footer">
        <button class="btn btn-light btn-sm" type="button" id="unitTypeModalCancel">Bỏ qua</button>
        <button class="btn btn-primary btn-sm" type="button" id="unitTypeModalSubmit">Lưu</button>
      </div>
    </div>
  </div>
  <script id="productGroupsSeed" type="application/json"><%- JSON.stringify(groups || []) %></script>
  <script id="unitTypesSeed" type="application/json"><%- JSON.stringify(units || []) %></script>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var productDetail = document.querySelector('.product-detail');
      if (productDetail) {
        var productTabs = Array.prototype.slice.call(productDetail.querySelectorAll('.detail-tab'));
        var productPanels = Array.prototype.slice.call(productDetail.querySelectorAll('.detail-pane'));
        productTabs.forEach(function(tab) {
          tab.addEventListener('click', function() {
            var target = tab.getAttribute('data-tab-target');
            productTabs.forEach(function(item) { item.classList.remove('is-active'); });
            productPanels.forEach(function(panel) {
              panel.classList.toggle('is-active', panel.getAttribute('data-tab-panel') === target);
            });
            tab.classList.add('is-active');
          });
        });
      }

      var productRows = Array.prototype.slice.call(document.querySelectorAll('.product-list-row'));
      productRows.forEach(function(row) {
        row.addEventListener('click', function(event) {
          if (event.target.closest('a, button, input, select, textarea, label')) return;
          var href = row.getAttribute('data-row-href');
          if (href) window.location.href = href;
        });
      });

      var createdRadios = Array.prototype.slice.call(document.querySelectorAll('input[name="created"]'));
      var customDateRange = document.getElementById('customDateRange');
      function toggleCustomDateRange() {
        if (!customDateRange) return;
        var selected = createdRadios.find(function(radio) { return radio.checked; });
        customDateRange.classList.toggle('is-visible', selected && selected.value === 'custom');
      }
      createdRadios.forEach(function(radio) {
        radio.addEventListener('change', toggleCustomDateRange);
      });
      toggleCustomDateRange();

      var pillButtons = Array.prototype.slice.call(document.querySelectorAll('.pill-btn'));
      pillButtons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var targetInputId = btn.getAttribute('data-target-input');
          var value = btn.getAttribute('data-value');
          var input = document.getElementById(targetInputId);
          if (!input) return;
          input.value = value;
          var siblings = Array.prototype.slice.call(btn.parentElement.querySelectorAll('.pill-btn'));
          siblings.forEach(function(item) { item.classList.remove('is-active'); });
          btn.classList.add('is-active');
        });
      });

      var openAddProductModalBtn = document.getElementById('openAddProductModal');
      var addProductModalOverlay = document.getElementById('addProductModalOverlay');
      var addProductModalClose = document.getElementById('addProductModalClose');
      var addProductModalCancel = document.getElementById('addProductModalCancel');
      var productModalTitle = document.getElementById('productModalTitle');
      var productModalSubmitBtn = document.getElementById('productModalSubmitBtn');
      var productCreateForm = document.getElementById('productCreateForm');
      var productPriceType = document.getElementById('productPriceType');
      var fixedPriceWrap = document.getElementById('fixedPriceWrap');
      var productManageLotCheckbox = document.getElementById('productManageLotCheckbox');
      var initialLotFields = document.getElementById('initialLotFields');
      var selectAllProducts = document.getElementById('selectAllProducts');
      var productCheckboxes = Array.prototype.slice.call(document.querySelectorAll('.product-checkbox'));
      var editProductButtons = Array.prototype.slice.call(document.querySelectorAll('.btn-edit-product'));

      function toggleFixedPrice() {
        if (!fixedPriceWrap || !productPriceType) return;
        fixedPriceWrap.style.display = productPriceType.value === 'co_dinh' ? '' : 'none';
      }

      function toggleInitialLotFields() {
        if (!initialLotFields || !productManageLotCheckbox) return;
        initialLotFields.style.display = productManageLotCheckbox.checked ? '' : 'none';
      }

      function setProductFormValue(name, value) {
        if (!productCreateForm) return;
        var input = productCreateForm.querySelector('[name="' + name + '"]');
        if (!input) return;
        input.value = value == null ? '' : String(value);
      }

      function setProductCheckbox(name, value) {
        if (!productCreateForm) return;
        var input = productCreateForm.querySelector('input[name="' + name + '"]');
        if (!input) return;
        input.checked = !!value;
      }

      function openAddProductModal() {
        if (!addProductModalOverlay) return;
        if (productModalTitle) productModalTitle.textContent = 'Tạo hàng hóa';
        if (productModalSubmitBtn) productModalSubmitBtn.textContent = 'Lưu';
        if (productCreateForm) {
          productCreateForm.setAttribute('action', '/hang-hoa/add');
          productCreateForm.reset();
        }
        if (unitTypeSelectedLabel) unitTypeSelectedLabel.textContent = 'Chọn đơn vị tính';
        if (unitTypeValue) unitTypeValue.value = '';
        if (unitTypeDropdown) {
          var unitItems = Array.prototype.slice.call(unitTypeDropdown.querySelectorAll('.address-type-item'));
          unitItems.forEach(function(item) { item.classList.remove('is-active'); });
        }
        addProductModalOverlay.classList.add('is-visible');
        toggleFixedPrice();
        toggleInitialLotFields();
      }

      function openEditProductModal(product) {
        if (!addProductModalOverlay || !product || !product._id) return;
        if (productModalTitle) productModalTitle.textContent = 'Sửa hàng hóa';
        if (productModalSubmitBtn) productModalSubmitBtn.textContent = 'Cập nhật';
        if (productCreateForm) {
          productCreateForm.setAttribute('action', '/hang-hoa/' + product._id + '/update');
        }

        setProductFormValue('ma_hang', product.ma_hang || '');
        setProductFormValue('ten_hang', product.ten_hang || '');
        setProductFormValue('nhom_hang_id', product.nhom_hang_id || '');
        setProductFormValue('nha_cung_cap_id', product.nha_cung_cap_id || '');
        setProductFormValue('gia_von', Number(product.gia_von || 0));
        setProductFormValue('loai_gia', product.loai_gia || 'thi_truong');
        setProductFormValue('gia_co_dinh', Number(product.gia_co_dinh || 0));
        setProductFormValue('ton_ban_dau', Number(product.ton_ban_dau || 0));
        setProductFormValue('dinh_muc_toi_thieu', Number(product.dinh_muc_toi_thieu || 0));
        setProductFormValue('mo_ta', product.mo_ta || '');
        setProductFormValue('trang_thai', product.trang_thai || 'active');
        setProductCheckbox('ban_truc_tiep', !!product.ban_truc_tiep);
        setProductCheckbox('quan_ly_theo_lo', !!product.quan_ly_theo_lo);

        var selectedUnitId = String(product.don_vi_tinh_id || '');
        if (unitTypeValue) unitTypeValue.value = selectedUnitId;
        if (unitTypeDropdown) {
          var allItems = Array.prototype.slice.call(unitTypeDropdown.querySelectorAll('.address-type-item'));
          var activeItem = null;
          allItems.forEach(function(item) {
            var isActive = String(item.getAttribute('data-id') || '') === selectedUnitId;
            item.classList.toggle('is-active', isActive);
            if (isActive) activeItem = item;
          });
          if (unitTypeSelectedLabel) {
            unitTypeSelectedLabel.textContent = activeItem
              ? (activeItem.getAttribute('data-name') || 'Chọn đơn vị tính')
              : 'Chọn đơn vị tính';
          }
        }

        addProductModalOverlay.classList.add('is-visible');
        toggleFixedPrice();
        toggleInitialLotFields();
      }

      function closeAddProductModal() {
        if (!addProductModalOverlay) return;
        addProductModalOverlay.classList.remove('is-visible');
      }

      if (productPriceType) productPriceType.addEventListener('change', toggleFixedPrice);
      if (productManageLotCheckbox) productManageLotCheckbox.addEventListener('change', toggleInitialLotFields);
      if (openAddProductModalBtn) openAddProductModalBtn.addEventListener('click', openAddProductModal);
      if (addProductModalClose) addProductModalClose.addEventListener('click', closeAddProductModal);
      if (addProductModalCancel) addProductModalCancel.addEventListener('click', closeAddProductModal);
      if (addProductModalOverlay && addProductModalOverlay.getAttribute('data-auto-open') === '1') openAddProductModal();
      toggleFixedPrice();
      toggleInitialLotFields();

      editProductButtons.forEach(function(button) {
        button.addEventListener('click', function(event) {
          event.preventDefault();
          event.stopPropagation();
          var payload = button.getAttribute('data-product') || '{}';
          try {
            var product = JSON.parse(payload);
            openEditProductModal(product);
          } catch (_error) {
            alert('Không đọc được dữ liệu hàng hóa để sửa.');
          }
        });
      });

      if (selectAllProducts && productCheckboxes.length > 0) {
        selectAllProducts.addEventListener('change', function() {
          productCheckboxes.forEach(function(item) { item.checked = selectAllProducts.checked; });
        });
        productCheckboxes.forEach(function(item) {
          item.addEventListener('change', function() {
            var allChecked = productCheckboxes.every(function(node) { return node.checked; });
            selectAllProducts.checked = allChecked;
          });
        });
      }

      var unitTypeTrigger = document.getElementById('unitTypeTrigger');
      var unitTypeSelectedLabel = document.getElementById('unitTypeSelectedLabel');
      var unitTypeValue = document.getElementById('unitTypeValue');
      var unitTypeDropdown = document.getElementById('unitTypeDropdown');
      var unitTypeAddBtn = document.getElementById('unitTypeAddBtn');
      var unitTypeModalOverlay = document.getElementById('unitTypeModalOverlay');
      var unitTypeModalTitle = document.getElementById('unitTypeModalTitle');
      var unitTypeModalClose = document.getElementById('unitTypeModalClose');
      var unitTypeModalCancel = document.getElementById('unitTypeModalCancel');
      var unitTypeModalSubmit = document.getElementById('unitTypeModalSubmit');
      var unitTypeNameInput = document.getElementById('unitTypeNameInput');
      var unitTypeCodeInput = document.getElementById('unitTypeCodeInput');
      var unitTypeModalMode = 'add';
      var activeUnitTypeItem = null;

      function bindUnitTypeItems() {
        var unitItems = Array.prototype.slice.call(document.querySelectorAll('#unitTypeDropdown .address-type-item'));
        unitItems.forEach(function(item) {
          var optionBtn = item.querySelector('.address-type-option');
          var editBtn = item.querySelector('.address-type-action-edit');
          var deleteBtn = item.querySelector('.address-type-action-delete');

          if (optionBtn) {
            optionBtn.addEventListener('click', function() {
              unitItems.forEach(function(node) { node.classList.remove('is-active'); });
              item.classList.add('is-active');
              if (unitTypeSelectedLabel) unitTypeSelectedLabel.textContent = item.getAttribute('data-name') || '';
              if (unitTypeValue) unitTypeValue.value = item.getAttribute('data-value') || '';
              if (unitTypeDropdown) unitTypeDropdown.classList.remove('is-open');
            });
          }

          if (editBtn) {
            editBtn.addEventListener('click', function(event) {
              event.stopPropagation();
              activeUnitTypeItem = item;
              openUnitTypeModal('edit');
            });
          }

          if (deleteBtn) {
            deleteBtn.addEventListener('click', function(event) {
              event.stopPropagation();
              var unitId = item.getAttribute('data-id') || '';
              if (!unitId) {
                alert('Vui lòng chọn đơn vị tính cần xóa.');
                return;
              }
              if (!confirm('Bạn có chắc muốn xóa đơn vị tính này không?')) return;
              requestUnitTypes('/hang-hoa/units/' + unitId + '/delete', {});
            });
          }
        });
      }

      function renderUnitTypeList(unitTypes, selectedId) {
        if (!unitTypeDropdown || !unitTypeValue || !unitTypeSelectedLabel) return;
        var selectedType = null;
        if (selectedId) {
          selectedType = unitTypes.find(function(item) { return String(item._id) === String(selectedId); }) || null;
        }
        if (!selectedType && unitTypes.length > 0) selectedType = unitTypes[0];

        unitTypeDropdown.innerHTML = unitTypes.map(function(unit) {
          var isActive = selectedType && String(selectedType._id) === String(unit._id);
          return (
            '<div class="address-type-item ' + (isActive ? 'is-active' : '') + '" data-id="' + String(unit._id || '') + '" data-value="' + String(unit._id || '') + '" data-name="' + String(unit.ten_don_vi || '').replace(/"/g, '&quot;') + '" data-code="' + String(unit.ma_don_vi || '').replace(/"/g, '&quot;') + '">' +
              '<button class="address-type-option" type="button">' + (unit.ten_don_vi || '---') + '</button>' +
              '<div class="address-type-actions">' +
                '<button class="address-type-action-edit" type="button">Sửa</button>' +
                '<button class="address-type-action-delete" type="button">Xóa</button>' +
              '</div>' +
            '</div>'
          );
        }).join('');

        if (selectedType) {
          unitTypeValue.value = selectedType._id || '';
          unitTypeSelectedLabel.textContent = selectedType.ten_don_vi || 'Chọn đơn vị tính';
        } else {
          unitTypeValue.value = '';
          unitTypeSelectedLabel.textContent = 'Chọn đơn vị tính';
        }

        activeUnitTypeItem = null;
        bindUnitTypeItems();
      }

      function requestUnitTypes(url, payload, callback) {
        var formBody = Object.keys(payload).map(function(key) {
          return encodeURIComponent(key) + '=' + encodeURIComponent(payload[key]);
        }).join('&');

        fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
          },
          body: formBody
        })
          .then(function(response) {
            return response.json().catch(function() {
              return { success: false, message: 'Server không trả về JSON hợp lệ.' };
            });
          })
          .then(function(data) {
            if (!data || !data.success) {
              alert((data && data.message) || 'Không thể xử lý đơn vị tính.');
              return;
            }
            var nextUnits = Array.isArray(data.units) ? data.units : unitTypes;
            if ((!Array.isArray(data.units) || data.units.length === 0) && data.data && data.data._id) {
              nextUnits = (nextUnits || []).filter(function(unit) {
                return String(unit._id) !== String(data.data._id);
              });
              nextUnits.push(data.data);
            }
            unitTypes = nextUnits || [];
            renderUnitTypeList(unitTypes, data.selectedId || (data.data && data.data._id) || '');
            if (typeof callback === 'function') callback();
          })
          .catch(function(error) {
            alert((error && error.message) || 'Có lỗi khi xử lý đơn vị tính.');
          });
      }

      function openUnitTypeModal(mode) {
        unitTypeModalMode = mode;
        if (!unitTypeModalOverlay || !unitTypeModalTitle) return;
        if (mode === 'add') {
          unitTypeModalTitle.textContent = 'Thêm đơn vị tính';
          if (unitTypeNameInput) unitTypeNameInput.value = '';
          if (unitTypeCodeInput) unitTypeCodeInput.value = '';
          if (unitTypeCodeInput) unitTypeCodeInput.removeAttribute('disabled');
        } else {
          unitTypeModalTitle.textContent = 'Sửa đơn vị tính';
          if (unitTypeNameInput) unitTypeNameInput.value = activeUnitTypeItem ? (activeUnitTypeItem.getAttribute('data-name') || '') : '';
          if (unitTypeCodeInput) unitTypeCodeInput.value = activeUnitTypeItem ? (activeUnitTypeItem.getAttribute('data-code') || '') : '';
          if (unitTypeCodeInput) unitTypeCodeInput.setAttribute('disabled', 'disabled');
        }
        unitTypeModalOverlay.classList.add('is-open');
      }

      function closeUnitTypeModal() {
        if (!unitTypeModalOverlay) return;
        unitTypeModalOverlay.classList.remove('is-open');
      }

      if (unitTypeAddBtn) {
        unitTypeAddBtn.addEventListener('click', function() {
          openUnitTypeModal('add');
        });
      }
      if (unitTypeTrigger && unitTypeDropdown) {
        unitTypeTrigger.addEventListener('click', function() {
          unitTypeDropdown.classList.toggle('is-open');
        });
      }
      if (unitTypeModalClose) unitTypeModalClose.addEventListener('click', closeUnitTypeModal);
      if (unitTypeModalCancel) unitTypeModalCancel.addEventListener('click', closeUnitTypeModal);

      if (unitTypeModalSubmit) {
        unitTypeModalSubmit.addEventListener('click', function() {
          if (!unitTypeNameInput || !unitTypeNameInput.value.trim()) {
            alert('Vui lòng nhập tên đơn vị tính.');
            return;
          }
          if (unitTypeModalMode === 'add') {
            requestUnitTypes('/hang-hoa/units/add', {
              ten_don_vi: unitTypeNameInput.value.trim(),
              ma_don_vi: unitTypeCodeInput && unitTypeCodeInput.value ? unitTypeCodeInput.value.trim() : ''
            }, function() {
              closeUnitTypeModal();
            });
            return;
          }

          var unitId = activeUnitTypeItem ? (activeUnitTypeItem.getAttribute('data-id') || '') : '';
          if (!unitId) {
            alert('Vui lòng chọn đơn vị tính cần sửa.');
            return;
          }
          requestUnitTypes('/hang-hoa/units/' + unitId + '/update', {
            ten_don_vi: unitTypeNameInput.value.trim()
          }, function() {
            closeUnitTypeModal();
          });
        });
      }

      var unitTypesSeed = document.getElementById('unitTypesSeed');
      var unitTypes = unitTypesSeed ? JSON.parse(unitTypesSeed.textContent || '[]') : [];
      renderUnitTypeList(unitTypes, (unitTypeValue && unitTypeValue.value) || '');

      var productGroupFilterTrigger = document.getElementById('productGroupFilterTrigger');
      var productGroupFilterLabel = document.getElementById('productGroupFilterLabel');
      var productGroupFilterValue = document.getElementById('productGroupFilterValue');
      var productGroupFilterDropdown = document.getElementById('productGroupFilterDropdown');
      var productGroupAddBtn = document.getElementById('productGroupAddBtn');
      var productGroupModalOverlay = document.getElementById('productGroupModalOverlay');
      var productGroupModalTitle = document.getElementById('productGroupModalTitle');
      var productGroupModalClose = document.getElementById('productGroupModalClose');
      var productGroupModalCancel = document.getElementById('productGroupModalCancel');
      var productGroupModalSubmit = document.getElementById('productGroupModalSubmit');
      var productGroupNameInput = document.getElementById('productGroupNameInput');
      var productGroupDescInput = document.getElementById('productGroupDescInput');
      var productGroupModalMode = 'add';
      var activeProductGroupItem = null;

      function bindProductGroupItems() {
        var groupItems = Array.prototype.slice.call(document.querySelectorAll('#productGroupFilterDropdown .group-manage-item'));
        groupItems.forEach(function(item) {
          var optionBtn = item.querySelector('.group-manage-option');
          var editBtn = item.querySelector('.group-manage-action-edit');
          var deleteBtn = item.querySelector('.group-manage-action-delete');

          if (optionBtn) {
            optionBtn.addEventListener('click', function() {
              groupItems.forEach(function(node) { node.classList.remove('is-active'); });
              item.classList.add('is-active');
              if (productGroupFilterValue) productGroupFilterValue.value = item.getAttribute('data-value') || 'all';
              if (productGroupFilterLabel) productGroupFilterLabel.textContent = item.getAttribute('data-name') || 'Chọn nhóm hàng';
              if (productGroupFilterDropdown) productGroupFilterDropdown.classList.remove('is-open');
            });
          }

          if (editBtn) {
            editBtn.addEventListener('click', function(event) {
              event.stopPropagation();
              activeProductGroupItem = item;
              openProductGroupModal('edit');
            });
          }

          if (deleteBtn) {
            deleteBtn.addEventListener('click', function(event) {
              event.stopPropagation();
              var groupId = item.getAttribute('data-id') || '';
              if (!groupId) {
                alert('Vui lòng chọn nhóm cần xóa.');
                return;
              }
              if (!confirm('Bạn có chắc muốn xóa nhóm hàng này không?')) return;
              requestProductGroups('/hang-hoa/groups/' + groupId + '/delete', {}, '');
            });
          }
        });
      }

      function renderProductGroupList(selectedValue) {
        if (!productGroupFilterDropdown) return;
        var groups = window.__productGroups || [];
        var rows = [];
        rows.push(
          '<div class="group-manage-item ' + ((selectedValue === 'all' || !selectedValue) ? 'is-active' : '') + '" data-id="" data-value="all" data-name="Chọn nhóm hàng" data-desc="">' +
            '<button class="group-manage-option" type="button">Chọn nhóm hàng</button>' +
          '</div>'
        );
        groups.forEach(function(group) {
          var id = String(group._id || '');
          var isActive = id === String(selectedValue || '');
          rows.push(
            '<div class="group-manage-item ' + (isActive ? 'is-active' : '') + '" data-id="' + id + '" data-value="' + id + '" data-name="' + (group.ten_nhom_hang || '').replace(/"/g, '&quot;') + '" data-desc="' + (group.mo_ta || '').replace(/"/g, '&quot;') + '">' +
              '<button class="group-manage-option" type="button">' + (group.ten_nhom_hang || '') + '</button>' +
              '<div class="group-manage-actions">' +
                '<button class="group-manage-action-edit" type="button">Sửa</button>' +
                '<button class="group-manage-action-delete" type="button">Xóa</button>' +
              '</div>' +
            '</div>'
          );
        });
        productGroupFilterDropdown.innerHTML = rows.join('');
        bindProductGroupItems();
      }

      function refreshProductGroupSelect(groups, selectedId) {
        var groupSelect = document.querySelector('select[name="nhom_hang_id"]');
        if (!groupSelect) return;
        var selected = selectedId || groupSelect.value || '';
        var options = ['<option value="">Chọn nhóm hàng</option>'];
        (groups || []).forEach(function(group) {
          var id = String(group._id || '');
          var name = String(group.ten_nhom_hang || '---').replace(/</g, '&lt;').replace(/>/g, '&gt;');
          options.push('<option value="' + id + '"' + (id === String(selected) ? ' selected' : '') + '>' + name + '</option>');
        });
        groupSelect.innerHTML = options.join('');
      }

      function refreshProductGroupWidget(selectedId) {
        var selected = selectedId || (productGroupFilterValue ? productGroupFilterValue.value : 'all') || 'all';
        renderProductGroupList(selected);
        if (productGroupFilterDropdown && productGroupFilterLabel) {
          var activeItem = productGroupFilterDropdown.querySelector('.group-manage-item.is-active');
          productGroupFilterLabel.textContent = activeItem ? (activeItem.getAttribute('data-name') || 'Chọn nhóm hàng') : 'Chọn nhóm hàng';
          if (productGroupFilterValue) productGroupFilterValue.value = activeItem ? (activeItem.getAttribute('data-value') || 'all') : 'all';
        }
      }

      function requestProductGroups(url, payload, selectedId) {
        var formBody = Object.keys(payload).map(function(key) {
          return encodeURIComponent(key) + '=' + encodeURIComponent(payload[key]);
        }).join('&');

        fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
          },
          body: formBody
        })
          .then(function(response) {
            return response.json().catch(function() {
              return { success: false, message: 'Server không trả về JSON hợp lệ.' };
            });
          })
          .then(function(data) {
            if (!data || !data.success) {
              alert((data && data.message) || 'Không thể xử lý nhóm hàng.');
              return;
            }
            if (Array.isArray(data.groups)) {
              window.__productGroups = data.groups;
            } else if (data.data && data.data._id) {
              window.__productGroups = (window.__productGroups || []).filter(function(group) {
                return String(group._id) !== String(data.data._id);
              });
              window.__productGroups.push(data.data);
            }
            var activeGroupId = data.selectedId || (data.data && data.data._id) || selectedId || '';
            refreshProductGroupWidget(activeGroupId);
            refreshProductGroupSelect(window.__productGroups || [], activeGroupId);
            closeProductGroupModal();
          })
          .catch(function(error) {
            alert((error && error.message) || 'Có lỗi khi xử lý nhóm hàng.');
          });
      }

      function openProductGroupModal(mode) {
        productGroupModalMode = mode;
        if (!productGroupModalOverlay || !productGroupModalTitle) return;
        if (mode === 'add') {
          productGroupModalTitle.textContent = 'Thêm nhóm hàng';
          if (productGroupNameInput) productGroupNameInput.value = '';
          if (productGroupDescInput) productGroupDescInput.value = '';
        } else {
          productGroupModalTitle.textContent = 'Sửa nhóm hàng';
          if (productGroupNameInput) productGroupNameInput.value = activeProductGroupItem ? (activeProductGroupItem.getAttribute('data-name') || '') : '';
          if (productGroupDescInput) productGroupDescInput.value = activeProductGroupItem ? (activeProductGroupItem.getAttribute('data-desc') || '') : '';
        }
        productGroupModalOverlay.classList.add('is-open');
      }

      function closeProductGroupModal() {
        if (!productGroupModalOverlay) return;
        productGroupModalOverlay.classList.remove('is-open');
      }

      if (productGroupFilterTrigger && productGroupFilterDropdown) {
        productGroupFilterTrigger.addEventListener('click', function() {
          productGroupFilterDropdown.classList.toggle('is-open');
        });
      }
      if (productGroupAddBtn) {
        productGroupAddBtn.addEventListener('click', function() {
          openProductGroupModal('add');
        });
      }
      if (productGroupModalClose) productGroupModalClose.addEventListener('click', closeProductGroupModal);
      if (productGroupModalCancel) productGroupModalCancel.addEventListener('click', closeProductGroupModal);

      if (productGroupModalSubmit) {
        productGroupModalSubmit.addEventListener('click', function() {
          if (!productGroupNameInput || !productGroupNameInput.value.trim()) {
            alert('Vui lòng nhập tên nhóm hàng.');
            return;
          }
          if (productGroupModalMode === 'add') {
            requestProductGroups('/hang-hoa/groups/add', {
              ten_nhom_hang: productGroupNameInput.value.trim(),
              mo_ta: productGroupDescInput ? productGroupDescInput.value.trim() : ''
            }, '');
            return;
          }
          var groupId = activeProductGroupItem ? (activeProductGroupItem.getAttribute('data-id') || '') : '';
          if (!groupId) {
            alert('Vui lòng chọn nhóm cần sửa.');
            return;
          }
          requestProductGroups('/hang-hoa/groups/' + groupId + '/update', {
            ten_nhom_hang: productGroupNameInput.value.trim(),
            mo_ta: productGroupDescInput ? productGroupDescInput.value.trim() : ''
          }, groupId);
        });
      }

      var productGroupsSeed = document.getElementById('productGroupsSeed');
      window.__productGroups = productGroupsSeed ? JSON.parse(productGroupsSeed.textContent || '[]') : [];
      refreshProductGroupWidget((productGroupFilterValue && productGroupFilterValue.value) || 'all');

      document.addEventListener('click', function(event) {
        if (productGroupFilterDropdown && productGroupFilterTrigger) {
          if (!productGroupFilterDropdown.contains(event.target) && !productGroupFilterTrigger.contains(event.target)) {
            productGroupFilterDropdown.classList.remove('is-open');
          }
        }

        if (unitTypeDropdown && unitTypeTrigger) {
          if (!unitTypeDropdown.contains(event.target) && !unitTypeTrigger.contains(event.target)) {
            unitTypeDropdown.classList.remove('is-open');
          }
        }
      });
    });
  </script>
</body>
</html>
