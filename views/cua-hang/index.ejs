<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body class="admin-body">
  <%- include('../partials/header', { activeMenu: activeMenu, user: user }) %>

  <main class="admin-shell store-page">
    <%- include('../partials/flash-message', { flash: flash }) %>

    <div id="addStoreModalOverlay" class="modal-overlay" data-auto-open="<%= formMode === 'create' ? '1' : '0' %>">
      <div class="modal-content store-create-modal">
        <div class="modal-header">
          <h3>Tạo cửa hàng</h3>
          <button type="button" class="modal-close" id="addStoreModalClose">×</button>
        </div>
        <form class="modal-body store-form-grid" method="post" action="/cua-hang/add" id="storeCreateForm">
          <label>
            <span>Mã cửa hàng</span>
            <input name="ma_cua_hang" placeholder="Tự động nếu bỏ trống">
          </label>
          <label>
            <span>Tên cửa hàng *</span>
            <input name="ten_cua_hang" required>
          </label>
          <label>
            <span>Điện thoại</span>
            <input name="sdt">
          </label>
          <label>
            <span>Email</span>
            <input name="email" type="email">
          </label>
          <label class="span-2">
            <span>Địa chỉ chi tiết</span>
            <input name="dia_chi_chi_tiet">
          </label>
          <label class="span-2">
            <span>Địa chỉ gửi hàng chi tiết</span>
            <input name="dia_chi_gui_hang_chi_tiet">
          </label>
          <label>
            <span>Phường/xã</span>
            <input name="phuong_xa">
          </label>
          <label>
            <span>Tỉnh/thành</span>
            <input name="tinh_thanh">
          </label>
          <label>
            <span>Phường/xã gửi hàng</span>
            <input name="phuong_xa_gui_hang">
          </label>
          <label>
            <span>Tỉnh/thành gửi hàng</span>
            <input name="tinh_thanh_gui_hang">
          </label>
          <label>
            <span>Trạng thái</span>
            <select name="trang_thai">
              <option value="active" selected>Đang hoạt động</option>
              <option value="inactive">Ngừng hoạt động</option>
            </select>
          </label>
        </form>
        <div class="page-actions modal-footer">
          <button class="btn btn-light" type="button" id="addStoreModalCancel">Bỏ qua</button>
          <button class="btn btn-primary" type="submit" form="storeCreateForm">Tạo cửa hàng</button>
        </div>
      </div>
    </div>

    <div class="store-toolbar">
      <h1>Cửa hàng</h1>
      <div class="store-search">
        <span>⌕</span>
        <input type="search" placeholder="Theo mã, tên cửa hàng">
      </div>
      <div class="page-actions">
        <button class="btn btn-primary" type="button" id="openAddStoreModal">+ Tạo mới</button>
        <button class="btn btn-danger" type="submit" form="bulkDeleteForm" onclick="return confirm('Xóa các cửa hàng đã chọn?')">Xóa đã chọn</button>
        <a class="btn btn-light" href="/cua-hang/export.xlsx">Xuất file</a>
      </div>
    </div>

    <% if (formMode === 'edit') { %>
      <section class="store-form-panel">
        <div class="store-form-heading">
          <div>
            <h2><%= formMode === 'edit' ? 'Cập nhật cửa hàng' : 'Tạo cửa hàng' %></h2>
            <p>Nhập thông tin cơ bản của cửa hàng.</p>
          </div>
          <a class="link-button" href="/cua-hang">Hủy</a>
        </div>

        <% var formStore = editingStore || {}; %>
        <form class="store-form-grid" method="post" action="<%= formMode === 'edit' ? '/cua-hang/' + editingStore._id + '/update' : '/cua-hang/add' %>">
          <label>
            <span>Mã cửa hàng</span>
            <input name="ma_cua_hang" value="<%= formStore.ma_cua_hang || '' %>" placeholder="Tự động nếu bỏ trống">
          </label>
          <label>
            <span>Tên cửa hàng *</span>
            <input name="ten_cua_hang" value="<%= formStore.ten_cua_hang || '' %>" required>
          </label>
          <label>
            <span>Điện thoại</span>
            <input name="sdt" value="<%= formStore.sdt || '' %>">
          </label>
          <label>
            <span>Email</span>
            <input name="email" value="<%= formStore.email || '' %>" type="email">
          </label>
          <label class="span-2">
            <span>Địa chỉ</span>
            <input name="dia_chi_chi_tiet" value="<%= formStore.dia_chi_chi_tiet || '' %>">
          </label>
          <label class="span-2">
            <span>Địa chỉ gửi hàng</span>
            <input name="dia_chi_gui_hang_chi_tiet" value="<%= formStore.dia_chi_gui_hang_chi_tiet || '' %>">
          </label>
          <label>
            <span>Phường/xã</span>
            <input name="phuong_xa" value="<%= formStore.phuong_xa || '' %>">
          </label>
          <label>
            <span>Tỉnh/thành</span>
            <input name="tinh_thanh" value="<%= formStore.tinh_thanh || '' %>">
          </label>
          <label>
            <span>Phường/xã gửi hàng</span>
            <input name="phuong_xa_gui_hang" value="<%= formStore.phuong_xa_gui_hang || '' %>">
          </label>
          <label>
            <span>Tỉnh/thành gửi hàng</span>
            <input name="tinh_thanh_gui_hang" value="<%= formStore.tinh_thanh_gui_hang || '' %>">
          </label>
          <label>
            <span>Trạng thái</span>
            <select name="trang_thai">
              <option value="active" <%= formStore.trang_thai !== 'inactive' ? 'selected' : '' %>>Đang hoạt động</option>
              <option value="inactive" <%= formStore.trang_thai === 'inactive' ? 'selected' : '' %>>Ngừng hoạt động</option>
            </select>
          </label>
          <div class="store-form-actions">
            <button class="btn btn-primary" type="submit"><%= formMode === 'edit' ? 'Lưu thay đổi' : 'Tạo cửa hàng' %></button>
            <a class="btn btn-light" href="/cua-hang">Hủy</a>
          </div>
        </form>
      </section>
    <% } %>

    <% var filterQueryPrefix = filterQueryString ? filterQueryString + '&' : ''; %>
    <div class="store-layout">
      <aside class="store-filter-panel">
        <form method="get" action="/cua-hang" class="store-filter-form">
          <div class="filter-heading">
            <h3>Bộ lọc</h3>
            <div class="filter-heading-actions">
              <button class="btn btn-primary btn-sm" type="submit">Áp dụng</button>
              <a class="filter-reset" href="/cua-hang">Xóa lọc</a>
            </div>
          </div>

          <section class="filter-group">
            <h4>Trạng thái</h4>
            <select name="status">
              <option value="all" <%= filter.status === 'all' ? 'selected' : '' %>>Tất cả</option>
              <option value="active" <%= filter.status === 'active' ? 'selected' : '' %>>Đang hoạt động</option>
              <option value="inactive" <%= filter.status === 'inactive' ? 'selected' : '' %>>Ngưng hoạt động</option>
            </select>
          </section>

          <section class="filter-group">
            <h4>Tỉnh/thành</h4>
            <% var selectedCityLabel = filter.city && filter.city !== 'all' ? filter.city : 'Tất cả tỉnh/thành'; %>
            <div class="group-manage-wrapper">
              <div class="group-manage-header">
                <button class="group-manage-trigger" type="button" id="storeCityFilterTrigger">
                  <span id="storeCityFilterLabel"><%= selectedCityLabel %></span>
                  <span>▾</span>
                </button>
              </div>
              <input type="hidden" name="city" id="storeCityFilterValue" value="<%= filter.city || 'all' %>">
              <div class="group-manage-dropdown" id="storeCityFilterDropdown">
                <div class="group-manage-item <%= (!filter.city || filter.city === 'all') ? 'is-active' : '' %>" data-value="all" data-name="Tất cả tỉnh/thành">
                  <button class="group-manage-option" type="button">Tất cả tỉnh/thành</button>
                </div>
                <% provinceOptions.forEach(function(city) { %>
                  <div class="group-manage-item <%= filter.city === city ? 'is-active' : '' %>" data-value="<%= city %>" data-name="<%= city %>">
                    <button class="group-manage-option" type="button"><%= city %></button>
                  </div>
                <% }) %>
              </div>
            </div>
          </section>

          <section class="filter-group">
            <h4>Số lượng kho</h4>
            <select name="warehouse">
              <option value="all" <%= filter.warehouse === 'all' ? 'selected' : '' %>>Tất cả</option>
              <option value="none" <%= filter.warehouse === 'none' ? 'selected' : '' %>>Chưa có kho</option>
              <option value="has" <%= filter.warehouse === 'has' ? 'selected' : '' %>>Có kho</option>
              <option value="gte1" <%= filter.warehouse === 'gte1' ? 'selected' : '' %>>Từ 1 kho trở lên</option>
              <option value="gte2" <%= filter.warehouse === 'gte2' ? 'selected' : '' %>>Từ 2 kho trở lên</option>
            </select>
          </section>

          <section class="filter-group">
            <h4>Thời gian tạo</h4>
            <select name="created" id="createdFilterSelect">
              <option value="all" <%= filter.created === 'all' ? 'selected' : '' %>>Toàn thời gian</option>
              <option value="today" <%= filter.created === 'today' ? 'selected' : '' %>>Hôm nay</option>
              <option value="7days" <%= filter.created === '7days' ? 'selected' : '' %>>7 ngày qua</option>
              <option value="30days" <%= filter.created === '30days' ? 'selected' : '' %>>30 ngày qua</option>
              <option value="custom" <%= filter.created === 'custom' ? 'selected' : '' %>>Tùy chỉnh</option>
            </select>
            <div class="custom-date-range <%= filter.created === 'custom' ? 'is-visible' : '' %>" id="customDateRange">
              <label>
                <span>Từ ngày</span>
                <input type="date" name="createdFrom" value="<%= filter.createdFrom || '' %>">
              </label>
              <label>
                <span>Đến ngày</span>
                <input type="date" name="createdTo" value="<%= filter.createdTo || '' %>">
              </label>
            </div>
          </section>

        </form>
      </aside>

      <section class="store-table-panel">
        <div class="table-wrap">
          <form id="bulkDeleteForm" method="post" action="/cua-hang/delete-selected">
          <table class="admin-table store-table">
            <thead>
              <tr>
                <th class="check-cell"><input id="selectAllStores" type="checkbox" aria-label="Chọn tất cả"></th>
                <th>Mã cửa hàng</th>
                <th>Tên cửa hàng</th>
                <th>Điện thoại</th>
                <th>Email</th>
                <th>Kho</th>
                <th>Trạng thái</th>
                <th>Thời gian tạo</th>
              </tr>
            </thead>
            <tbody>
              <% if (stores.length === 0) { %>
                <tr>
                  <td colspan="8" class="empty-cell">Không có cửa hàng phù hợp với bộ lọc.</td>
                </tr>
              <% } %>
              <% stores.forEach(function(store) { %>
                <% var isSelected = selectedStore && String(selectedStore._id) === String(store._id); %>
                <% var rowHref = isSelected ? ('/cua-hang' + (filterQueryString ? '?' + filterQueryString : '')) : ('/cua-hang?' + filterQueryPrefix + 'store=' + store._id); %>
                <tr class="<%= isSelected ? 'is-selected' : '' %>" onclick="window.location.href='<%= rowHref %>'">
                  <td class="check-cell" onclick="event.stopPropagation()"><input class="store-checkbox" type="checkbox" name="ids" value="<%= store._id %>" aria-label="Chọn cửa hàng"></td>
                  <td><a class="table-code-link" href="<%= rowHref %>"><%= store.ma_cua_hang || '---' %></a></td>
                  <td><strong><%= store.ten_cua_hang || '---' %></strong><div class="muted-line"><%= store.dia_chi_day_du || store.dia_chi_gui_hang_day_du || 'Chưa có địa chỉ' %></div></td>
                  <td><%= store.sdt || '---' %></td>
                  <td><%= store.email || '---' %></td>
                  <td><%= warehouseCountMap[String(store._id)] || 0 %></td>
                  <td>
                    <span class="status-pill <%= store.trang_thai === 'active' ? 'is-active' : '' %>">
                      <%= store.trang_thai === 'active' ? 'Đang hoạt động' : 'Ngừng hoạt động' %>
                    </span>
                  </td>
                  <td><%= formatDate(store.created_at) %></td>
                </tr>

                <% if (isSelected) { %>
                  <tr class="store-detail-row">
                    <td colspan="8">
                      <div class="store-detail">
                        <div class="detail-tabs">
                          <div class="detail-tab-list">
                            <button class="detail-tab is-active" type="button" data-tab-target="store-info">Thông tin</button>
                            <button class="detail-tab" type="button" data-tab-target="store-warehouses">Danh sách kho</button>
                            <button class="detail-tab" type="button" data-tab-target="store-notes">Ghi chú</button>
                          </div>
                          <button class="detail-collapse-btn" type="button" aria-expanded="true">Thu gọn</button>
                        </div>

                        <div class="store-detail-body">
                          <div class="store-detail-pane is-active" data-tab-pane="store-info">
                          <div class="store-info-block">
                            <div class="store-image-placeholder">CH</div>
                            <div>
                              <h2><%= selectedStore.ten_cua_hang || 'Cửa hàng' %></h2>
                              <p><%= selectedStore.ma_cua_hang || '---' %> - <%= selectedStore.tinh_thanh || 'Chưa có tỉnh thành' %></p>
                              <div class="tag-row">
                                <span class="tag">Cửa hàng</span>
                                <span class="tag tag-green"><%= selectedStore.trang_thai === 'active' ? 'Đang hoạt động' : 'Ngừng hoạt động' %></span>
                              </div>
                            </div>
                          </div>

                          <div class="store-fields">
                            <div>
                              <span>Mã cửa hàng</span>
                              <input name="ma_cua_hang" value="<%= selectedStore.ma_cua_hang || '' %>">
                            </div>
                            <div>
                              <span>Tên cửa hàng *</span>
                              <input name="ten_cua_hang" value="<%= selectedStore.ten_cua_hang || '' %>" required>
                            </div>
                            <div>
                              <span>Điện thoại</span>
                              <input name="sdt" value="<%= selectedStore.sdt || '' %>">
                            </div>
                            <div>
                              <span>Email</span>
                              <input name="email" type="email" value="<%= selectedStore.email || '' %>">
                            </div>
                            <div>
                              <span>Địa chỉ</span>
                              <input name="dia_chi_chi_tiet" value="<%= selectedStore.dia_chi_chi_tiet || '' %>">
                            </div>
                            <div>
                              <span>Địa chỉ gửi hàng</span>
                              <input name="dia_chi_gui_hang_chi_tiet" value="<%= selectedStore.dia_chi_gui_hang_chi_tiet || '' %>">
                            </div>
                            <div>
                              <span>Phường/xã</span>
                              <input name="phuong_xa" value="<%= selectedStore.phuong_xa || '' %>">
                            </div>
                            <div>
                              <span>Tỉnh/thành</span>
                              <input name="tinh_thanh" value="<%= selectedStore.tinh_thanh || '' %>">
                            </div>
                            <div>
                              <span>Phường/xã gửi hàng</span>
                              <input name="phuong_xa_gui_hang" value="<%= selectedStore.phuong_xa_gui_hang || '' %>">
                            </div>
                            <div>
                              <span>Tỉnh/thành gửi hàng</span>
                              <input name="tinh_thanh_gui_hang" value="<%= selectedStore.tinh_thanh_gui_hang || '' %>">
                            </div>
                            <div>
                              <span>Trạng thái</span>
                              <select name="trang_thai">
                                <option value="active" <%= selectedStore.trang_thai !== 'inactive' ? 'selected' : '' %>>Đang hoạt động</option>
                                <option value="inactive" <%= selectedStore.trang_thai === 'inactive' ? 'selected' : '' %>>Ngừng hoạt động</option>
                              </select>
                            </div>
                            <div>
                              <span>Kho trực thuộc</span>
                              <strong><%= warehouses.length %></strong>
                            </div>
                          </div>
                          </div>

                          <div class="store-detail-pane" data-tab-pane="store-warehouses">
                          <div class="warehouse-section">
                            <div class="warehouse-heading">
                              <h3>Danh sách kho</h3>
                              <div class="detail-actions">
                                <button class="btn btn-light" type="button">➕ Thêm kho</button>

                              </div>
                            </div>

                            <table class="admin-table warehouse-table">
                              <thead>
                                <tr>
                                  <th>Mã kho</th>
                                  <th>Tên kho</th>
                                  <th>Địa chỉ</th>
                                  <th>Trạng thái</th>
                                  <th>Thời gian tạo</th>
                                </tr>
                              </thead>
                              <tbody>
                                <% if (warehouses.length === 0) { %>
                                  <tr>
                                    <td colspan="5" class="empty-cell">Chưa có kho cho cửa hàng này.</td>
                                  </tr>
                                <% } %>
                                <tr class="warehouse-edit-row warehouse-add-row">
                                  <td><input form="warehouseAddForm" name="ma_kho" value="" placeholder="Mã kho (tự động)"></td>
                                  <td><input form="warehouseAddForm" name="ten_kho" value="" placeholder="Tên kho mới"></td>
                                  <td><input form="warehouseAddForm" name="dia_chi_chi_tiet" value="" placeholder="Địa chỉ chi tiết"></td>
                                  <td>
                                    <select form="warehouseAddForm" name="trang_thai">
                                      <option value="active" selected>Đang hoạt động</option>
                                      <option value="inactive">Ngừng hoạt động</option>
                                    </select>
                                  </td>
                                  <td class="warehouse-action-cell">
                                    <button
                                      form="warehouseAddForm"
                                      class="btn btn-primary btn-sm"
                                      type="submit"
                                      onclick="return confirm('Bạn có muốn thêm kho mới không?')"
                                    >✨ Thêm</button>

                                  </td>
                                </tr>
                                <% warehouses.forEach(function(warehouse) { %>
                                  <% var warehouseFormId = 'warehouseForm_' + String(warehouse._id); %>
                                  <tr class="warehouse-edit-row">
                                    <td><input form="<%= warehouseFormId %>" name="ma_kho" value="<%= warehouse.ma_kho || '' %>"></td>
                                    <td><input form="<%= warehouseFormId %>" name="ten_kho" value="<%= warehouse.ten_kho || '' %>" required></td>
                                    <td><input form="<%= warehouseFormId %>" name="dia_chi_chi_tiet" value="<%= warehouse.dia_chi_chi_tiet || warehouse.dia_chi_day_du || warehouse.dia_chi || '' %>"></td>
                                    <td>
                                      <select form="<%= warehouseFormId %>" name="trang_thai">
                                        <option value="active" <%= warehouse.trang_thai !== 'inactive' ? 'selected' : '' %>>Đang hoạt động</option>
                                        <option value="inactive" <%= warehouse.trang_thai === 'inactive' ? 'selected' : '' %>>Ngừng hoạt động</option>
                                      </select>
                                    </td>
                                    <td class="warehouse-action-cell">
                                      <div class="warehouse-action-meta"><%= formatDate(warehouse.created_at) %></div>
                                      <div class="warehouse-action-buttons">
                                        <button
                                          form="<%= warehouseFormId %>"
                                          class="btn btn-light btn-sm"
                                          type="submit"
                                          onclick="return confirm('Bạn có muốn lưu chỉnh sửa kho này không?')"
                                        >💾 Lưu</button>
                                        <button
                                          form="warehouseDeleteForm_<%= warehouse._id %>"
                                          class="btn btn-danger btn-sm"
                                          type="submit"
                                          onclick="return confirm('Bạn có chắc muốn xóa kho này không?')"
                                        >🗑️ Xóa</button>

                                      </div>
                                    </td>
                                  </tr>
                                <% }) %>
                              </tbody>
                            </table>
                          </div>
                          </div>

                          <div class="store-detail-pane" data-tab-pane="store-notes">
                            <div class="warehouse-section">
                              <h3>Ghi chú</h3>
                              <p class="muted-line">Chưa có ghi chú cho cửa hàng này.</p>
                            </div>
                          </div>
                        </div>
                        <div class="page-actions detail-panel-footer page-actions--sm">
                          <button
                            class="btn btn-danger btn-sm"
                            type="submit"
                            formaction="/cua-hang/<%= selectedStore._id %>/delete"
                            formmethod="post"
                            onclick="return confirm('Bạn có chắc muốn xóa cửa hàng này và các kho trực thuộc không?')"
                          >Xóa</button>
                          <button
                            class="btn btn-success btn-sm"
                            type="submit"
                            formaction="/cua-hang/<%= selectedStore._id %>/update"
                            formmethod="post"
                            onclick="return confirm('Bạn có muốn lưu thay đổi cửa hàng này không?')"
                          >Chỉnh sửa</button>
                          <a
                            class="btn btn-success btn-sm"
                            href="/cua-hang/<%= selectedStore._id %>/export/info.xlsx"
                            data-store-export-action
                            data-store-info-url="/cua-hang/<%= selectedStore._id %>/export/info.xlsx"
                            data-store-info-label="Xuất thông tin"
                            data-store-info-disabled="0"
                            data-store-warehouses-url="/cua-hang/<%= selectedStore._id %>/export/warehouses.xlsx"
                            data-store-warehouses-label="Xuất kho"
                            data-store-warehouses-disabled="<%= warehouses.length ? '0' : '1' %>"
                            data-store-notes-url="/cua-hang/<%= selectedStore._id %>/export/notes.xlsx"
                            data-store-notes-label="Xuất ghi chú"
                            data-store-notes-disabled="1"
                          >Xuất thông tin</a>
                        </div>
                      </div>
                    </td>
                  </tr>
                <% } %>
              <% }) %>
            </tbody>
          </table>
          </form>
          <% if (selectedStore) { %>
            <form id="warehouseAddForm" method="post" action="/cua-hang/<%= selectedStore._id %>/warehouse/add"></form>
            <% warehouses.forEach(function(warehouse) { %>
              <form id="warehouseForm_<%= warehouse._id %>" method="post" action="/cua-hang/<%= selectedStore._id %>/warehouse/<%= warehouse._id %>/update"></form>
              <form id="warehouseDeleteForm_<%= warehouse._id %>" method="post" action="/cua-hang/<%= selectedStore._id %>/warehouse/<%= warehouse._id %>/delete"></form>
            <% }) %>
          <% } %>
        </div>
      </section>
    </div>
  </main>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var addStoreModalOverlay = document.getElementById('addStoreModalOverlay');
      var openAddStoreModalBtn = document.getElementById('openAddStoreModal');
      var addStoreModalClose = document.getElementById('addStoreModalClose');
      var addStoreModalCancel = document.getElementById('addStoreModalCancel');
      var storeCreateForm = document.getElementById('storeCreateForm');

      function openAddStoreModal() {
        if (!addStoreModalOverlay) return;
        if (storeCreateForm) storeCreateForm.reset();
        addStoreModalOverlay.classList.add('is-visible');
        var nameInput = storeCreateForm ? storeCreateForm.querySelector('[name="ten_cua_hang"]') : null;
        if (nameInput) setTimeout(function() { nameInput.focus(); }, 50);
      }

      function closeAddStoreModal() {
        if (!addStoreModalOverlay) return;
        addStoreModalOverlay.classList.remove('is-visible');
      }

      if (openAddStoreModalBtn) openAddStoreModalBtn.addEventListener('click', openAddStoreModal);
      if (addStoreModalClose) addStoreModalClose.addEventListener('click', closeAddStoreModal);
      if (addStoreModalCancel) addStoreModalCancel.addEventListener('click', closeAddStoreModal);
      if (addStoreModalOverlay) {
        addStoreModalOverlay.addEventListener('click', function(event) {
          if (event.target === addStoreModalOverlay) closeAddStoreModal();
        });
        if (addStoreModalOverlay.getAttribute('data-auto-open') === '1') openAddStoreModal();
      }

      var selectAll = document.getElementById('selectAllStores');
      var checkboxes = Array.prototype.slice.call(document.querySelectorAll('.store-checkbox'));

      if (selectAll) {
        selectAll.addEventListener('change', function () {
          checkboxes.forEach(function (checkbox) {
            checkbox.checked = selectAll.checked;
          });
        });
      }

      checkboxes.forEach(function (checkbox) {
        checkbox.addEventListener('change', function () {
          if (!selectAll) return;
          selectAll.checked = checkboxes.length > 0 && checkboxes.every(function (item) {
            return item.checked;
          });
        });
      });

      var createdFilterSelect = document.getElementById('createdFilterSelect');
      var customDateRange = document.getElementById('customDateRange');
      var storeCityFilterTrigger = document.getElementById('storeCityFilterTrigger');
      var storeCityFilterLabel = document.getElementById('storeCityFilterLabel');
      var storeCityFilterValue = document.getElementById('storeCityFilterValue');
      var storeCityFilterDropdown = document.getElementById('storeCityFilterDropdown');

      function toggleCustomDateRange() {
        if (!customDateRange) return;
        var isCustom = createdFilterSelect && createdFilterSelect.value === 'custom';
        customDateRange.classList.toggle('is-visible', isCustom);
      }

      if (createdFilterSelect) createdFilterSelect.addEventListener('change', toggleCustomDateRange);

      toggleCustomDateRange();

      if (storeCityFilterTrigger && storeCityFilterDropdown) {
        storeCityFilterTrigger.addEventListener('click', function () {
          storeCityFilterDropdown.classList.toggle('is-open');
        });

        Array.prototype.slice.call(storeCityFilterDropdown.querySelectorAll('.group-manage-item')).forEach(function (item) {
          var optionBtn = item.querySelector('.group-manage-option');
          if (!optionBtn) return;
          optionBtn.addEventListener('click', function () {
            Array.prototype.slice.call(storeCityFilterDropdown.querySelectorAll('.group-manage-item')).forEach(function (node) {
              node.classList.remove('is-active');
            });
            item.classList.add('is-active');
            if (storeCityFilterValue) storeCityFilterValue.value = item.getAttribute('data-value') || 'all';
            if (storeCityFilterLabel) storeCityFilterLabel.textContent = item.getAttribute('data-name') || 'Tất cả tỉnh/thành';
            storeCityFilterDropdown.classList.remove('is-open');
          });
        });
      }

      var detailBlocks = Array.prototype.slice.call(document.querySelectorAll('.store-detail'));
      detailBlocks.forEach(function (detailBlock) {
        var collapseBtn = detailBlock.querySelector('.detail-collapse-btn');
        var detailBody = detailBlock.querySelector('.store-detail-body');
        var tabs = Array.prototype.slice.call(detailBlock.querySelectorAll('.detail-tab'));
        var panes = Array.prototype.slice.call(detailBlock.querySelectorAll('.store-detail-pane'));
        var exportAction = detailBlock.querySelector('[data-store-export-action]');
        if (!collapseBtn || !detailBody) return;

        function syncStoreExportAction(target) {
          if (!exportAction || !target) return;
          var key = String(target || '').replace(/^store-/, '');
          var url = exportAction.getAttribute('data-store-' + key + '-url') || '#';
          var label = exportAction.getAttribute('data-store-' + key + '-label') || 'Xuất thông tin';
          var disabled = exportAction.getAttribute('data-store-' + key + '-disabled') === '1';
          exportAction.textContent = label;
          exportAction.href = disabled ? '#' : url;
          exportAction.classList.toggle('is-disabled', disabled);
          exportAction.setAttribute('aria-disabled', disabled ? 'true' : 'false');
        }

        syncStoreExportAction('store-info');

        tabs.forEach(function(tab) {
          tab.addEventListener('click', function(event) {
            event.stopPropagation();
            var target = tab.getAttribute('data-tab-target');
            tabs.forEach(function(node) {
              node.classList.toggle('is-active', node === tab);
            });
            panes.forEach(function(pane) {
              pane.classList.toggle('is-active', pane.getAttribute('data-tab-pane') === target);
            });
            syncStoreExportAction(target);
          });
        });

        if (exportAction) {
          exportAction.addEventListener('click', function(event) {
            if (exportAction.getAttribute('aria-disabled') === 'true') {
              event.preventDefault();
              alert('Không có dữ liệu để xuất');
            }
          });
        }

        collapseBtn.addEventListener('click', function () {
          var isCollapsed = detailBlock.classList.toggle('is-collapsed');
          collapseBtn.textContent = isCollapsed ? 'Mở rộng' : 'Thu gọn';
          collapseBtn.setAttribute('aria-expanded', isCollapsed ? 'false' : 'true');
        });
      });

      document.addEventListener('click', function (event) {
        if (!storeCityFilterDropdown || !storeCityFilterTrigger) return;
        if (storeCityFilterDropdown.contains(event.target)) return;
        if (storeCityFilterTrigger.contains(event.target)) return;
        storeCityFilterDropdown.classList.remove('is-open');
      });
    });
  </script>
</body>
</html>
