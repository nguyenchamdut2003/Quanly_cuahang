<%
  const safeReport = locals.report || {};
  const rows = Array.isArray(safeReport.rows) ? safeReport.rows : [];
  const topCustomers = Array.isArray(safeReport.topCustomers) ? safeReport.topCustomers : [];
  const totals = safeReport.totals || {};
  const range = safeReport.range || {};
  const filters = safeReport.filters || {};
  const viewMode = safeReport.viewMode || 'chart';
  const focus = safeReport.focus || 'ban-hang';
  const fmt = value => Number(value || 0).toLocaleString('vi-VN');
  const generatedAt = safeReport.generatedAt ? new Date(safeReport.generatedAt).toLocaleString('vi-VN') : new Date().toLocaleString('vi-VN');
  const baseParams = `from=${range.from || ''}&to=${range.to || ''}&customer=${encodeURIComponent(filters.customer || '')}&focus=${encodeURIComponent(focus)}`;
  const reportUrl = `/bao-cao/khach-hang?view=report&${baseParams}`;
  const chartUrl = `/bao-cao/khach-hang?view=chart&${baseParams}`;
  const exportUrl = `/bao-cao/khach-hang/export.csv?${baseParams}`;
%>
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    body{background:#f3f6f9;color:#20242a}.page{height:calc(100vh - 112px);padding:22px 60px 0;display:grid;grid-template-columns:282px minmax(0,1fr);gap:14px;overflow:hidden}.title{grid-column:1 / -1;font-size:25px;font-weight:800;margin:0 0 6px}.filters{background:#fff;border-radius:8px;padding:14px;overflow:visible}.filter-scroll{height:100%;overflow:auto}.filter-block{margin-bottom:24px}.filter-title{font-size:17px;font-weight:800;margin-bottom:12px}.mode-row{display:flex;gap:8px}.mode-btn{height:36px;border:1px solid #cfd8e3;border-radius:20px;background:#fff;padding:0 16px;font-size:16px;text-decoration:none;color:#1f2937;display:inline-flex;align-items:center;font-weight:600}.mode-btn.active{background:#0070f4;border-color:#0070f4;color:#fff;font-weight:800}.line{height:1px;background:#e5e9ee;margin:20px 0}.select,.input{height:36px;width:100%;border:1px solid #cfd8e3;border-radius:8px;background:#fff;padding:0 12px;font-size:15px;color:#1f2937}.input::placeholder{color:#8b95a1}.focus-wrap{position:relative}.focus-menu{position:absolute;left:0;right:0;top:40px;background:#fff;border-radius:0 0 8px 8px;box-shadow:0 14px 30px rgba(0,0,0,.18);z-index:5;display:none;overflow:hidden}.focus-wrap.open .focus-menu{display:block}.focus-menu a{height:46px;display:flex;align-items:center;justify-content:space-between;padding:0 16px;text-decoration:none;color:#111827}.focus-menu a.active{background:#eef6ff;color:#006dff;font-weight:800}.radio-row{display:flex;align-items:center;gap:9px;margin:9px 0}.radio-row input[type=radio]{width:18px;height:18px;accent-color:#0070f4}.date-box{height:36px;border:1px solid #cfd8e3;border-radius:8px;display:flex;align-items:center;justify-content:space-between;padding:0 12px;flex:1;background:#fff;cursor:pointer}.date-pair{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-left:26px;margin-top:8px}.time-pop{position:absolute;left:306px;top:318px;width:820px;background:#fff;border-radius:8px;box-shadow:0 14px 34px rgba(0,0,0,.24);padding:24px 18px;z-index:4;display:none;grid-template-columns:repeat(5,1fr);gap:28px}.time-pop.open{display:grid}.time-col h4{margin:0 0 12px;font-size:16px}.time-col button{height:36px;border:1px solid #cfd8e3;background:#fff;border-radius:20px;padding:0 14px;margin:0 0 9px;font-size:15px;cursor:pointer}.time-col button.active{background:#0070f4;color:#fff;border-color:#0070f4;font-weight:800}.btn{height:36px;border:1px solid #cfd8e3;border-radius:8px;background:#fff;padding:0 14px;font-weight:800;cursor:pointer;text-decoration:none;color:#111827;display:inline-flex;align-items:center;gap:8px}.btn.primary{background:#0070f4;border-color:#0070f4;color:#fff}.filter-actions{display:flex;gap:8px}.content{min-width:0;overflow:hidden}.chart-card{height:calc(100vh - 176px);min-height:584px;background:#fff;position:relative;padding:16px 12px 0}.chart-title{text-align:center;font-size:18px;color:#344054;margin-bottom:12px}.chart-wrap{height:520px}.report-shell{background:#8c98a6;height:calc(100vh - 176px);overflow:auto;position:relative}.viewer-bar{height:40px;display:flex;align-items:center;justify-content:center;gap:20px;color:#fff;position:sticky;top:0;background:#8c98a6;z-index:2}.viewer-bar button,.viewer-bar a{border:0;background:transparent;color:#fff;font-size:16px;text-decoration:none;cursor:pointer}.viewer-page{width:970px;min-height:690px;background:#fff;margin:0 auto 26px;padding:18px 16px 40px;box-shadow:0 1px 2px rgba(0,0,0,.12)}.doc-meta{font-size:14px;color:#444;margin-bottom:4px}.doc-title{text-align:center;font-size:29px;font-weight:800;margin:4px 0 12px}.doc-sub{text-align:center;color:#444;line-height:1.9}.report-table{margin-top:44px;width:100%;border-collapse:collapse;font-size:15px}.report-table th{height:52px;background:#b9e9fb;color:#27313f;font-weight:800;text-align:left;border:1px solid #c9d8df;padding:0 12px}.report-table th.num,.report-table td.num{text-align:right}.report-table td{height:50px;border-bottom:1px solid #d4d8dd;padding:0 12px;text-align:left}.total-row td{background:#f6f1d8;font-weight:800}.code{color:#006dff;font-weight:800}.chat{position:fixed;right:14px;bottom:10px;background:#0070f4;color:#fff;border-radius:8px;height:36px;display:flex;align-items:center;gap:6px;padding:0 12px;font-weight:800}@media print{body{background:#fff}.topbar,.nav-bar,.filters,.viewer-bar,.chat{display:none!important}.page{display:block;height:auto;padding:0}.title{display:none}.report-shell{background:#fff;overflow:visible;height:auto}.viewer-page{box-shadow:none;margin:0;width:auto;min-height:auto}}
  </style>
</head>
<body>
  <%- include('../partials/header') %>

  <form class="page" method="GET" action="/bao-cao/khach-hang">
    <input type="hidden" name="view" value="<%= viewMode %>">
    <h1 class="title">Báo cáo khách hàng</h1>

    <aside class="filters">
      <div class="filter-scroll">
        <% if (viewMode === 'report') { %>
          <div class="filter-block"><a class="btn" href="<%= exportUrl %>"><i class="fa-solid fa-file-export"></i> Xuất tất cả</a></div>
        <% } %>

        <div class="filter-block">
          <div class="filter-title">Kiểu hiển thị<%= viewMode === 'report' ? ' <span style="color:#0070f4">•</span>' : '' %></div>
          <div class="mode-row"><a class="mode-btn <%= viewMode === 'chart' ? 'active' : '' %>" href="<%= chartUrl %>">Biểu đồ</a><a class="mode-btn <%= viewMode === 'report' ? 'active' : '' %>" href="<%= reportUrl %>">Báo cáo</a></div>
          <div class="line"></div>
          <% if (viewMode === 'report') { %><select class="select"><option>Hiển thị dọc</option><option>Hiển thị ngang</option></select><% } %>
        </div>

        <div class="filter-block">
          <div class="filter-title">Mối quan tâm</div>
          <div class="focus-wrap" id="focusWrap">
            <input type="hidden" name="focus" value="<%= focus %>">
            <button class="select" type="button" onclick="focusWrap.classList.toggle('open')" style="text-align:left;display:flex;align-items:center;justify-content:space-between">
              <span><%= focus === 'loi-nhuan' ? 'Lợi nhuận' : focus === 'cong-no' ? 'Công nợ' : focus === 'hang-ban-theo-khach' ? 'Hàng bán theo khách' : 'Bán hàng' %></span>
              <i class="fa-solid fa-chevron-down"></i>
            </button>
            <div class="focus-menu">
              <a class="<%= focus === 'ban-hang' ? 'active' : '' %>" href="/bao-cao/khach-hang?view=<%= viewMode %>&focus=ban-hang&from=<%= range.from || '' %>&to=<%= range.to || '' %>">Bán hàng <%= focus === 'ban-hang' ? '<i class="fa-solid fa-check"></i>' : '' %></a>
              <a class="<%= focus === 'loi-nhuan' ? 'active' : '' %>" href="/bao-cao/khach-hang?view=<%= viewMode %>&focus=loi-nhuan&from=<%= range.from || '' %>&to=<%= range.to || '' %>">Lợi nhuận</a>
              <a class="<%= focus === 'cong-no' ? 'active' : '' %>" href="/bao-cao/khach-hang?view=<%= viewMode %>&focus=cong-no&from=<%= range.from || '' %>&to=<%= range.to || '' %>">Công nợ</a>
              <a class="<%= focus === 'hang-ban-theo-khach' ? 'active' : '' %>" href="/bao-cao/khach-hang?view=<%= viewMode %>&focus=hang-ban-theo-khach&from=<%= range.from || '' %>&to=<%= range.to || '' %>">Hàng bán theo khách</a>
            </div>
          </div>
        </div>

        <div class="filter-block">
          <div class="filter-title">Thời gian</div>
          <label class="radio-row"><input type="radio" checked><span class="date-box" onclick="document.getElementById('timePop').classList.toggle('open')">Tuần này <i class="fa-solid fa-chevron-right"></i></span></label>
          <div class="date-pair"><input class="input" type="date" name="from" value="<%= range.from || '' %>"><input class="input" type="date" name="to" value="<%= range.to || '' %>"></div>
          <label class="radio-row"><input type="radio"><span class="date-box">Tùy chỉnh <i class="fa-regular fa-calendar-days"></i></span></label>
        </div>

        <div class="filter-block"><div class="filter-title">Khách hàng</div><input class="input" name="customer" value="<%= filters.customer || '' %>" placeholder="Theo mã, tên, số điện thoại"></div>
        <div class="filter-actions"><button class="btn primary" type="submit">Lọc</button><a class="btn" href="/bao-cao/khach-hang?view=<%= viewMode %>">Bỏ lọc</a></div>
      </div>
    </aside>

    <div class="time-pop" id="timePop">
      <div class="time-col"><h4>Theo ngày</h4><button>Hôm nay</button><button>Hôm qua</button></div>
      <div class="time-col"><h4>Theo tuần</h4><button class="active">Tuần này</button><button>Tuần trước</button><button>7 ngày qua</button></div>
      <div class="time-col"><h4>Theo tháng</h4><button>Tháng này</button><button>Tháng trước</button><button>Tháng này (âm lịch)</button><button>Tháng trước (âm lịch)</button><button>30 ngày qua</button></div>
      <div class="time-col"><h4>Theo quý</h4><button>Quý này</button><button>Quý trước</button></div>
      <div class="time-col"><h4>Theo năm</h4><button>Năm nay</button><button>Năm trước</button><button>Năm này (âm lịch)</button><button>Năm trước (âm lịch)</button></div>
    </div>

    <main class="content">
      <% if (viewMode === 'chart') { %>
        <section class="chart-card"><div class="chart-title">Top 10 khách hàng mua nhiều nhất (đã trừ trả hàng)</div><div class="chart-wrap"><canvas id="customerChart"></canvas></div></section>
      <% } else { %>
        <section class="report-shell">
          <div class="viewer-bar"><button type="button"><i class="fa-solid fa-rotate-left"></i></button><button type="button"><i class="fa-solid fa-rotate-right"></i></button><button type="button"><i class="fa-solid fa-arrows-rotate"></i></button><button type="button"><i class="fa-solid fa-backward-fast"></i></button><button type="button"><i class="fa-solid fa-backward-step"></i></button><span style="background:#fff;color:#111;padding:4px 14px">1</span><strong>/ 1</strong><button type="button"><i class="fa-solid fa-forward-step"></i></button><button type="button"><i class="fa-solid fa-forward-fast"></i></button><a href="<%= exportUrl %>"><i class="fa-solid fa-file-lines"></i></a><a href="<%= exportUrl %>"><i class="fa-solid fa-cloud-arrow-down"></i></a><button type="button" onclick="window.print()"><i class="fa-solid fa-print"></i></button><button type="button"><i class="fa-solid fa-magnifying-glass-plus"></i></button><button type="button"><i class="fa-solid fa-magnifying-glass-minus"></i></button><button type="button"><i class="fa-solid fa-magnifying-glass"></i></button><button type="button"><i class="fa-solid fa-expand"></i></button></div>
          <div class="viewer-page">
            <div class="doc-meta">Ngày lập: <%= generatedAt %></div>
            <div class="doc-title">Báo cáo bán hàng theo khách hàng</div>
            <div class="doc-sub"><div>Từ ngày <%= range.from ? new Date(range.from + 'T00:00:00').toLocaleDateString('vi-VN') : '' %> đến ngày <%= range.to ? new Date(range.to + 'T00:00:00').toLocaleDateString('vi-VN') : '' %></div><div>Chi nhánh: <%= safeReport.branchName || 'Chi nhánh trung tâm' %></div></div>
            <table class="report-table">
              <thead><tr><th>Mã KH</th><th>Khách hàng</th><th class="num">Doanh thu</th><th class="num">Giá trị trả</th><th class="num">Doanh thu thuần</th></tr></thead>
              <tbody>
                <tr class="total-row"><td colspan="2">SL khách hàng: <%= fmt(totals.customerCount) %></td><td class="num"><%= fmt(totals.revenue) %></td><td class="num"><%= fmt(totals.returned) %></td><td class="num" style="color:#006dff"><%= fmt(totals.netRevenue) %></td></tr>
                <% rows.forEach(item => { %><tr><td class="code"><%= item.code || '---' %></td><td><%= item.name %></td><td class="num"><%= fmt(item.revenue) %></td><td class="num"><%= fmt(item.returned) %></td><td class="num"><%= fmt(item.netRevenue) %></td></tr><% }) %>
              </tbody>
            </table>
          </div>
        </section>
      <% } %>
    </main>
  </form>

  <div class="chat"><i class="fa-regular fa-comment-dots"></i> 1900 6522</div>
  <script>
    const topCustomers = <%- JSON.stringify(topCustomers) %>;
    if (document.getElementById('customerChart')) {
      new Chart(document.getElementById('customerChart').getContext('2d'), {
        type: 'bar',
        data: { labels: topCustomers.map(x => x.name), datasets: [{ data: topCustomers.map(x => x.netRevenue), backgroundColor: '#0070f4', borderRadius: 5, barThickness: 26 }] },
        options: { indexAxis: 'y', maintainAspectRatio: false, plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => Number(ctx.raw || 0).toLocaleString('vi-VN') } } }, scales: { x: { beginAtZero: true, grid: { color: '#e5e9ee' }, ticks: { callback: v => Number(v).toLocaleString('vi-VN') } }, y: { grid: { display: false }, ticks: { color: '#344054' } } } }
      });
    }
  </script>
</body>
</html>
