<%
  const safeReport = locals.report || {};
  const safeSummary = safeReport.summary || {};
  const safeInvoices = Array.isArray(safeReport.invoices) ? safeReport.invoices : [];
  const safeReturns = Array.isArray(safeReport.returns) ? safeReport.returns : [];
  const safeReceipts = Array.isArray(safeReport.receipts) ? safeReport.receipts : [];
  const qtyByInvoice = safeReport.qtyByInvoice || new Map();
  const filters = safeReport.filters || {};
  const fmt = value => Number(value || 0).toLocaleString('vi-VN');
  const dateValue = safeReport.date || new Date().toISOString().slice(0, 10);
  const displayDate = value => value ? new Date(value).toLocaleDateString('vi-VN') : '';
  const displayDateTime = value => value ? new Date(value).toLocaleString('vi-VN') : '';
%>
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <style>
    body{background:#f3f6f9;color:#20242a}.page{height:calc(100vh - 112px);padding:22px 60px 0;display:grid;grid-template-columns:282px minmax(0,1fr);gap:14px;overflow:hidden}.title{grid-column:1 / -1;font-size:25px;font-weight:800;margin:0 0 6px}.filters{background:#fff;border-radius:8px;padding:14px;overflow:auto}.filter-block{margin-bottom:24px}.filter-title{font-size:17px;font-weight:800;margin-bottom:12px}.select,.input{height:36px;width:100%;border:1px solid #cfd8e3;border-radius:8px;background:#fff;padding:0 12px;font-size:15px;color:#1f2937}.input::placeholder{color:#8b95a1}.view-chip{display:inline-flex;align-items:center;height:36px;padding:0 16px;border-radius:20px;background:#0070f4;color:#fff;font-weight:800}.line{height:1px;background:#e5e9ee;margin:20px 0}.radio-row{display:flex;align-items:center;gap:9px;margin:9px 0}.radio-row input{width:18px;height:18px;accent-color:#0070f4}.date-box{height:36px;border:1px solid #cfd8e3;border-radius:8px;display:flex;align-items:center;justify-content:space-between;padding:0 12px;flex:1;background:#fff}.date-pair{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-left:26px;margin-top:8px}.report-shell{background:#8c98a6;min-width:0;overflow:auto;position:relative}.viewer-bar{height:40px;display:flex;align-items:center;justify-content:center;gap:20px;color:#fff;position:sticky;top:0;background:#8c98a6;z-index:2}.viewer-bar button,.viewer-bar a{border:0;background:transparent;color:#fff;font-size:16px;text-decoration:none;cursor:pointer}.viewer-page{width:970px;min-height:690px;background:#fff;margin:0 auto 26px;padding:18px 16px 40px;box-shadow:0 1px 2px rgba(0,0,0,.12)}.doc-meta{font-size:14px;color:#444;margin-bottom:4px}.doc-title{text-align:center;font-size:29px;font-weight:800;margin:4px 0 12px}.doc-sub{text-align:center;color:#444;line-height:1.9}.report-table{margin-top:66px;width:100%;border-collapse:collapse;font-size:15px}.report-table th{height:42px;background:#b9e9fb;color:#27313f;font-weight:800;text-align:center;border:1px solid #c9d8df}.report-table td{height:42px;border:1px solid #e2e5e9;padding:0 10px;text-align:right}.report-table td.left{text-align:left}.group-row td{background:#f6f1d8;font-weight:800}.detail-row td{background:#fff}.toggle{width:16px;height:16px;border:1px solid #333;display:inline-flex;align-items:center;justify-content:center;margin-right:8px;cursor:pointer;font-size:12px;line-height:1}.negative{color:#d11111}.summary-strip{margin-top:26px;display:grid;grid-template-columns:repeat(4,1fr);gap:12px}.summary-card{border:1px solid #e1e7ef;border-radius:6px;padding:12px;background:#fbfdff}.summary-card label{display:block;color:#64748b;margin-bottom:8px}.summary-card strong{font-size:20px}.chat{position:fixed;right:14px;bottom:10px;background:#0070f4;color:#fff;border-radius:8px;height:36px;display:flex;align-items:center;gap:6px;padding:0 12px;font-weight:800}.filter-actions{display:flex;gap:8px}.btn{height:36px;border:1px solid #cfd8e3;border-radius:8px;background:#fff;padding:0 14px;font-weight:800;cursor:pointer;text-decoration:none;color:#111827;display:inline-flex;align-items:center;gap:8px}.btn.primary{background:#0070f4;border-color:#0070f4;color:#fff}@media print{body{background:#fff}.topbar,.nav-bar,.filters,.viewer-bar,.chat{display:none!important}.page{display:block;height:auto;padding:0}.title{display:none}.report-shell{background:#fff;overflow:visible}.viewer-page{box-shadow:none;margin:0;width:auto;min-height:auto}}
  </style>
</head>
<body>
  <%- include('../partials/header') %>

  <form class="page" method="GET" action="/bao-cao/cuoi-ngay">
    <h1 class="title">Báo cáo cuối ngày</h1>

    <aside class="filters">
      <div class="filter-block">
        <div class="filter-title">Kiểu hiển thị</div>
        <span class="view-chip">Báo cáo</span>
        <div class="line"></div>
        <select class="select" name="layout">
          <option>Hiển thị dọc</option>
          <option>Hiển thị ngang</option>
        </select>
      </div>

      <div class="filter-block">
        <div class="filter-title">Mối quan tâm</div>
        <select class="select" name="focus">
          <option value="ban-hang" <%= filters.focus === 'ban-hang' ? 'selected' : '' %>>Bán hàng</option>
          <option value="thu-chi" <%= filters.focus === 'thu-chi' ? 'selected' : '' %>>Thu chi</option>
          <option value="tra-hang" <%= filters.focus === 'tra-hang' ? 'selected' : '' %>>Trả hàng</option>
        </select>
      </div>

      <div class="filter-block">
        <div class="filter-title">Thời gian</div>
        <label class="radio-row">
          <input type="radio" checked>
          <input class="date-box" type="date" name="date" value="<%= dateValue %>" onchange="this.form.submit()">
        </label>
        <div class="date-pair">
          <input class="input" placeholder="Từ">
          <input class="input" placeholder="Đến">
        </div>
        <label class="radio-row">
          <input type="radio">
          <span class="date-box">Tùy chỉnh <i class="fa-regular fa-calendar-days"></i></span>
        </label>
      </div>

      <div class="filter-block">
        <div class="filter-title">Khách hàng</div>
        <input class="input" name="customer" value="<%= filters.customer || '' %>" placeholder="Theo mã, tên, số điện thoại">
      </div>

      <div class="filter-block">
        <div class="filter-title">Người bán</div>
        <input class="input" name="seller" value="<%= filters.seller || '' %>" placeholder="Chọn người bán">
      </div>

      <div class="filter-block">
        <div class="filter-title">Người tạo</div>
        <input class="input" name="creator" value="<%= filters.creator || '' %>" placeholder="Chọn người tạo">
      </div>

      <div class="filter-block">
        <div class="filter-title">Phương thức thanh toán</div>
        <select class="select" name="payment">
          <option value="">Chọn phương thức thanh toán</option>
          <option value="COD" <%= filters.payment === 'COD' ? 'selected' : '' %>>COD</option>
          <option value="cash" <%= filters.payment === 'cash' ? 'selected' : '' %>>Tiền mặt</option>
          <option value="bank" <%= filters.payment === 'bank' ? 'selected' : '' %>>Chuyển khoản</option>
        </select>
      </div>

      <div class="filter-block">
        <div class="filter-title">Phương thức bán hàng</div>
        <select class="select" name="sale_method">
          <option>Chọn phương thức bán hàng</option>
          <option>Bán trực tiếp</option>
          <option>Bán giao hàng</option>
        </select>
      </div>

      <div class="filter-actions">
        <button class="btn primary" type="submit">Lọc</button>
        <a class="btn" href="/bao-cao/cuoi-ngay">Bỏ lọc</a>
      </div>
    </aside>

    <main class="report-shell">
      <div class="viewer-bar">
        <button type="button"><i class="fa-solid fa-rotate-left"></i></button>
        <button type="button"><i class="fa-solid fa-rotate-right"></i></button>
        <button type="button"><i class="fa-solid fa-arrows-rotate"></i></button>
        <button type="button"><i class="fa-solid fa-backward-fast"></i></button>
        <button type="button"><i class="fa-solid fa-backward-step"></i></button>
        <span style="background:#fff;color:#111;padding:4px 14px">1</span><strong>/ 1</strong>
        <button type="button"><i class="fa-solid fa-forward-step"></i></button>
        <button type="button"><i class="fa-solid fa-forward-fast"></i></button>
        <a href="/bao-cao/cuoi-ngay/export.csv?date=<%= dateValue %>&customer=<%= encodeURIComponent(filters.customer || '') %>"><i class="fa-solid fa-file-lines"></i></a>
        <a href="/bao-cao/cuoi-ngay/export.csv?date=<%= dateValue %>&customer=<%= encodeURIComponent(filters.customer || '') %>"><i class="fa-solid fa-cloud-arrow-down"></i></a>
        <button type="button" onclick="window.print()"><i class="fa-solid fa-print"></i></button>
        <button type="button"><i class="fa-solid fa-magnifying-glass-plus"></i></button>
        <button type="button"><i class="fa-solid fa-magnifying-glass-minus"></i></button>
        <button type="button"><i class="fa-solid fa-magnifying-glass"></i></button>
        <button type="button"><i class="fa-solid fa-expand"></i></button>
      </div>

      <section class="viewer-page">
        <div class="doc-meta">Ngày lập: <%= displayDateTime(safeReport.generatedAt) %></div>
        <div class="doc-title">Báo cáo cuối ngày về bán hàng</div>
        <div class="doc-sub">
          <div>Ngày bán: <%= displayDate(dateValue) %></div>
          <div>Ngày thanh toán: <%= displayDate(dateValue) %></div>
          <div>Chi nhánh: <%= safeReport.branchName || 'Chi nhánh trung tâm' %></div>
        </div>

        <table class="report-table">
          <thead>
            <tr>
              <th>Mã giao dịch</th>
              <th>Thời gian</th>
              <th>SL</th>
              <th>Doanh thu</th>
              <th>Thu khác</th>
              <th>VAT</th>
              <th>Làm tròn</th>
              <th>Phí trả hàng</th>
              <th>Thực thu</th>
            </tr>
          </thead>
          <tbody>
            <tr class="group-row" data-group="invoice">
              <td class="left"><span class="toggle" onclick="toggleGroup('invoice', this)">+</span>Hóa đơn: <%= safeSummary.invoiceCount || 0 %></td>
              <td></td>
              <td><%= fmt(safeSummary.totalQuantity) %></td>
              <td><%= fmt(safeSummary.invoiceRevenue) %></td>
              <td>0</td>
              <td>0</td>
              <td>0</td>
              <td>0</td>
              <td><%= fmt(safeSummary.invoicePaid) %></td>
            </tr>
            <% safeInvoices.forEach(item => { %>
              <tr class="detail-row invoice-detail" hidden>
                <td class="left"><%= item.ma_hoa_don %> - <%= item.khach_hang_id?.ten_khach_hang || 'Khách lẻ' %></td>
                <td><%= displayDateTime(item.ngay_ban) %></td>
                <td><%= fmt(qtyByInvoice.get(String(item._id)) || 0) %></td>
                <td><%= fmt(item.tong_tien) %></td>
                <td>0</td>
                <td>0</td>
                <td>0</td>
                <td>0</td>
                <td><%= fmt(item.thanh_toan) %></td>
              </tr>
            <% }) %>

            <tr class="group-row" data-group="return">
              <td class="left"><span class="toggle" onclick="toggleGroup('return', this)">+</span>Trả hàng: <%= safeSummary.returnCount || 0 %></td>
              <td></td>
              <td>0</td>
              <td class="negative">-<%= fmt(safeSummary.returnTotal) %></td>
              <td>0</td>
              <td>0</td>
              <td>0</td>
              <td>0</td>
              <td class="negative">-<%= fmt(safeSummary.returnTotal) %></td>
            </tr>
            <% safeReturns.forEach(item => { %>
              <tr class="detail-row return-detail" hidden>
                <td class="left"><%= item.ma_phieu_tra %> - <%= item.khach_hang_id?.ten_khach_hang || 'Khách lẻ' %></td>
                <td><%= displayDateTime(item.ngay_tra) %></td>
                <td>0</td>
                <td class="negative">-<%= fmt(item.tong_tien_tra) %></td>
                <td>0</td>
                <td>0</td>
                <td>0</td>
                <td>0</td>
                <td class="negative">-<%= fmt(item.tong_tien_tra) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>

        <div class="summary-strip">
          <div class="summary-card"><label>Giảm giá hóa đơn</label><strong><%= fmt(safeSummary.invoiceDiscount) %></strong></div>
          <div class="summary-card"><label>Thu khác</label><strong><%= fmt(safeSummary.otherReceiptTotal) %></strong></div>
          <div class="summary-card"><label>Chi khác</label><strong><%= fmt(safeSummary.otherPaymentTotal) %></strong></div>
          <div class="summary-card"><label>Doanh thu thuần</label><strong><%= fmt(safeSummary.netRevenue) %></strong></div>
        </div>
      </section>
    </main>
  </form>

  <div class="chat"><i class="fa-regular fa-comment-dots"></i> 1900 6522</div>

  <script>
    function toggleGroup(group, btn) {
      const rows = document.querySelectorAll(`.${group}-detail`);
      const willShow = Array.from(rows).some(row => row.hidden);
      rows.forEach(row => row.hidden = !willShow);
      btn.textContent = willShow ? '-' : '+';
    }
  </script>
</body>
</html>
