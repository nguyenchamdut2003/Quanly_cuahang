<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <style>
      .kiemkho-container {
        display: grid;
        grid-template-columns: 1fr 350px;
        gap: 20px;
        padding: 20px;
        background-color: #f0f2f5;
        min-height: calc(100vh - 100px);
      }
      .left-panel, .right-panel {
        background: #fff;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
      }
      .search-box {
        position: relative;
        margin-bottom: 20px;
      }
      .search-box input {
        width: 100%;
        padding: 12px 40px;
        border: 1px solid #ddd;
        border-radius: 6px;
      }
      .search-box i {
        position: absolute;
        left: 15px;
        top: 15px;
        color: #999;
      }
      .kk-table {
        width: 100%;
        border-collapse: collapse;
      }
      .kk-table th {
        background: #f8f9fa;
        padding: 10px;
        text-align: left;
        border-bottom: 2px solid #eee;
      }
      .kk-table td {
        padding: 12px 10px;
        border-bottom: 1px solid #eee;
      }
      .input-thuc-te {
        width: 80px;
        padding: 6px;
        border: 1px solid #ddd;
        border-radius: 4px;
        text-align: right;
        background: #fffbe6;
      }
      .lech-positive { color: #52c41a; font-weight: bold; }
      .lech-negative { color: #ff4d4f; font-weight: bold; }
      .search-results {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: #fff;
        border: 1px solid #ddd;
        z-index: 1000;
        max-height: 250px;
        overflow-y: auto;
        display: none;
      }
      .search-item {
        padding: 10px 15px;
        cursor: pointer;
        border-bottom: 1px solid #f0f0f0;
      }
      .search-item:hover { background: #e6f7ff; }
      .btn-finish {
        width: 100%;
        padding: 15px;
        background: #52c41a;
        color: #fff;
        border: none;
        border-radius: 6px;
        font-size: 16px;
        font-weight: bold;
        cursor: pointer;
        margin-top: 20px;
      }
    </style>
  </head>
  <body>
    <%- include('../partials/header') %>

    <div class="kiemkho-container">
      <div class="left-panel">
        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 20px;">
          <a href="/kiem-kho" style="color: #666;"><i class="fa-solid fa-arrow-left"></i></a>
          <h2 style="margin: 0;">Kiểm kho</h2>
        </div>

        <div class="search-box">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" id="kkSearch" placeholder="Tìm hàng hóa theo mã hoặc tên...">
          <div id="kkResults" class="search-results"></div>
        </div>

        <table class="kk-table">
          <thead>
            <tr>
              <th width="40">STT</th>
              <th width="120">Mã hàng</th>
              <th>Tên hàng</th>
              <th width="80">ĐVT</th>
              <th width="110">Mã lô</th>
              <th width="120">Hạn sử dụng</th>
              <th width="100" style="text-align: right;">Hệ thống</th>
              <th width="100" style="text-align: right;">Thực tế</th>
              <th width="100" style="text-align: right;">Lệch</th>
              <th width="220">Nguyên nhân lệch</th>
            </tr>
          </thead>
          <tbody id="kkBody">
            <!-- Items added here -->
          </tbody>
        </table>
      </div>

      <div class="right-panel">
        <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
          <span><strong>Người tạo:</strong> <%= user.ho_ten %></span>
          <span><%= new Date().toLocaleString('vi-VN') %></span>
        </div>

        <div class="form-group">
          <label>Cửa hàng kiểm</label>
          <select id="storeId" class="form-control" style="width: 100%; padding: 8px; margin-top: 5px;">
            <% stores.forEach(s => { %>
              <option value="<%= s._id %>"><%= s.ten_cua_hang %></option>
            <% }) %>
          </select>
        </div>

        <div class="form-group" style="margin-top: 15px;">
          <label>Kho kiểm</label>
          <select id="khoId" class="form-control" style="width: 100%; padding: 8px; margin-top: 5px;" disabled>
            <option value="">Vui lòng chọn cửa hàng trước</option>
          </select>
        </div>

        <div class="form-group" style="margin-top: 15px;">
          <label>Ghi chú</label>
          <textarea id="ghiChu" style="width: 100%; padding: 8px; margin-top: 5px; height: 80px;"></textarea>
        </div>

        <div style="margin-top: 30px; border-top: 1px dashed #ddd; padding-top: 20px;">
          <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
            <span>Tổng SL thực tế:</span>
            <span id="totalThucTe" style="font-weight: bold;">0</span>
          </div>
          <div style="display: flex; justify-content: space-between;">
            <span>Tổng lệch:</span>
            <span id="totalLech" style="font-weight: bold;">0</span>
          </div>
        </div>

        <button class="btn-finish" onclick="saveKiemKho()">
          <i class="fa-solid fa-check-double"></i> HOÀN THÀNH
        </button>
      </div>
    </div>

    <script>
      let kkItems = [];

      const searchInput = document.getElementById('kkSearch');
      const resultsDiv = document.getElementById('kkResults');
      const storeSelect = document.getElementById('storeId');
      const khoSelect = document.getElementById('khoId');

      function rowKey(item) {
        return String(item.hang_hoa_id || '') + '::' + String(item.lo_hang_id || '');
      }

      function formatDate(value) {
        if (!value) return '';
        var date = new Date(value);
        if (isNaN(date.getTime())) return '';
        return date.toLocaleDateString('vi-VN');
      }

      async function loadKhoByStore() {
        const storeId = storeSelect.value;
        khoSelect.innerHTML = '<option value="">Chọn kho</option>';
        khoSelect.disabled = true;
        kkItems = [];
        renderKK();

        if (!storeId) return;

        try {
          const res = await fetch('/api/cua-hang/' + encodeURIComponent(storeId) + '/kho');
          const result = await res.json();
          const warehouses = result.success ? (result.data || []) : [];
          khoSelect.innerHTML = '<option value="">Chọn kho</option>' + warehouses.map(k => `<option value="${k._id}">${k.ten_kho || k.ma_kho || ''}</option>`).join('');
          khoSelect.disabled = false;
        } catch (error) {
          khoSelect.innerHTML = '<option value="">Không tải được kho</option>';
        }
      }

      async function loadHangKiemKho() {
        kkItems = [];
        renderKK();

        if (!khoSelect.value) return;

        try {
          const res = await fetch('/api/kho/' + encodeURIComponent(khoSelect.value) + '/hang-kiem-kho');
          const result = await res.json();
          if (!result.success) {
            alert(result.message || 'Không tải được hàng kiểm kho.');
            return;
          }
          kkItems = (result.data || []).map(row => ({
            key: rowKey(row),
            hang_hoa_id: row.hang_hoa_id,
            lo_hang_id: row.lo_hang_id || null,
            ma_hang: row.ma_hang || '',
            ten_hang: row.ten_hang || '',
            don_vi_tinh: row.don_vi_tinh || '',
            ma_lo: row.ma_lo || '',
            han_su_dung: row.han_su_dung || '',
            ton_kho_he_thong: Number(row.ton_kho_he_thong || 0),
            so_luong_thuc_te: Number(row.ton_kho_he_thong || 0),
            nguyen_nhan_lech: ''
          }));
          renderKK();
        } catch (error) {
          alert('Không tải được hàng kiểm kho.');
        }
      }

      storeSelect.addEventListener('change', loadKhoByStore);
      khoSelect.addEventListener('change', loadHangKiemKho);
      document.addEventListener('DOMContentLoaded', loadKhoByStore);

      function renderSearchResults() {
        const query = searchInput.value.trim().toLowerCase();
        if (!query) {
          resultsDiv.style.display = 'none';
          return;
        }
        const filtered = kkItems.filter(item =>
          String(item.ten_hang || '').toLowerCase().includes(query) ||
          String(item.ma_hang || '').toLowerCase().includes(query) ||
          String(item.ma_lo || '').toLowerCase().includes(query)
        ).slice(0, 30);

        resultsDiv.innerHTML = filtered.map(item => `
          <div class="search-item" onclick="focusKKItem('${item.key}')">
            <span>${item.ten_hang} (${item.ma_hang})${item.ma_lo ? ' - Lô ' + item.ma_lo : ''}</span>
            <span style="float: right; color: #999;">Tồn: ${item.ton_kho_he_thong}</span>
          </div>
        `).join('') || '<div class="search-item"><span>Không có hàng phù hợp</span></div>';
        resultsDiv.style.display = 'block';
      }

      searchInput.addEventListener('focus', renderSearchResults);
      searchInput.addEventListener('click', renderSearchResults);
      searchInput.addEventListener('input', renderSearchResults);

      function focusKKItem(key) {
        const row = document.querySelector('[data-row-key="' + key + '"]');
        if (row) row.scrollIntoView({ block: 'center', behavior: 'smooth' });
        searchInput.value = '';
        resultsDiv.style.display = 'none';
      }

      function renderKK() {
        const body = document.getElementById('kkBody');
        let totalTT = 0;
        let totalL = 0;

        body.innerHTML = kkItems.map((item, index) => {
          const lech = Number(item.so_luong_thuc_te || 0) - Number(item.ton_kho_he_thong || 0);
          totalTT += Number(item.so_luong_thuc_te || 0);
          totalL += lech;

          return `
            <tr data-row-key="${item.key}">
              <td>${index + 1}</td>
              <td>${item.ma_hang}</td>
              <td>${item.ten_hang}</td>
              <td>${item.don_vi_tinh || ''}</td>
              <td>${item.ma_lo || ''}</td>
              <td>${formatDate(item.han_su_dung)}</td>
              <td style="text-align: right;">${item.ton_kho_he_thong}</td>
              <td style="text-align: right;">
                <input type="number" min="0" class="input-thuc-te" value="${item.so_luong_thuc_te}" onchange="updateTT('${item.key}', this.value)">
              </td>
              <td style="text-align: right;" class="${lech > 0 ? 'lech-positive' : (lech < 0 ? 'lech-negative' : '')}">
                ${lech > 0 ? '+' + lech : lech}
              </td>
              <td>
                <input class="input-thuc-te" style="width: 100%; text-align: left;" value="${item.nguyen_nhan_lech || ''}" placeholder="${lech !== 0 ? 'Bắt buộc khi lệch' : ''}" onchange="updateReason('${item.key}', this.value)">
              </td>
            </tr>
          `;
        }).join('') || '<tr><td colspan="10" style="text-align:center;color:#777;padding:40px;">Chọn kho để tải hàng hóa đang có tồn.</td></tr>';

        document.getElementById('totalThucTe').innerText = totalTT;
        document.getElementById('totalLech').innerText = totalL;
      }

      function updateTT(key, val) {
        const item = kkItems.find(i => i.key === key);
        const nextValue = Number(val);
        if (item) item.so_luong_thuc_te = Number.isFinite(nextValue) && nextValue >= 0 ? nextValue : 0;
        renderKK();
      }

      function updateReason(key, val) {
        const item = kkItems.find(i => i.key === key);
        if (item) item.nguyen_nhan_lech = val || '';
      }

      async function saveKiemKho() {
        if (!document.getElementById('khoId').value) return alert('Vui lòng chọn kho.');
        if (kkItems.length === 0) return alert('Kho không có hàng hóa còn tồn để kiểm.');
        const missingReason = kkItems.find(item => {
          const lech = Number(item.so_luong_thuc_te || 0) - Number(item.ton_kho_he_thong || 0);
          return lech !== 0 && !String(item.nguyen_nhan_lech || '').trim();
        });
        if (missingReason) return alert('Vui lòng nhập nguyên nhân lệch cho hàng hóa có chênh lệch.');

        const data = {
          cua_hang_id: document.getElementById('storeId').value,
          kho_id: document.getElementById('khoId').value,
          ghi_chu: document.getElementById('ghiChu').value,
          items: kkItems.map(item => ({
            hang_hoa_id: item.hang_hoa_id,
            lo_hang_id: item.lo_hang_id || null,
            ton_kho_he_thong: item.ton_kho_he_thong,
            so_luong_thuc_te: item.so_luong_thuc_te,
            nguyen_nhan_lech: item.nguyen_nhan_lech || ''
          }))
        };

        try {
          const res = await fetch('/kiem-kho', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          const result = await res.json();
          if (result.success) {
            alert(result.message);
            window.location.href = '/kiem-kho';
          } else {
            alert(result.message || 'Không thể lưu phiếu kiểm kho.');
          }
        } catch (err) {
          alert('Lỗi khi lưu phiếu kiểm kho');
        }
      }
    </script>
  </body>
</html>
