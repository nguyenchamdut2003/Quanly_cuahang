<!DOCTYPE html>
<html>
  <head>
    <title>Đăng nhập - KiotViet ERP</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <style>
      body{background:linear-gradient(135deg,#0070f4 0%,#00c6ff 100%);height:100vh;display:flex;align-items:center;justify-content:center;margin:0;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif}
      .login-card{background:#fff;padding:40px;border-radius:12px;box-shadow:0 10px 25px rgba(0,0,0,.2);width:400px;text-align:center}
      .login-card h1{color:#0070f4;margin-bottom:10px;font-size:28px}
      .login-card p{color:#666;margin-bottom:30px}
      .btn-google{display:flex;align-items:center;justify-content:center;gap:10px;width:100%;padding:12px;background:#fff;border:1px solid #ddd;border-radius:6px;color:#444;font-size:16px;font-weight:600;cursor:pointer;text-decoration:none;transition:background .3s}
      .btn-google:hover{background:#f5f5f5;box-shadow:0 2px 5px rgba(0,0,0,.1)}
      .alert{margin:0 0 18px;padding:10px 12px;border-radius:6px;background:#fff1f0;color:#b42318;font-size:13px;text-align:left}
    </style>
  </head>
  <body>
    <div class="login-card">
      <h1>Hệ thống quản lý bán hàng & kho vận</h1>
      <% const loginError = locals.error || (locals.query && locals.query.error); %>
      <% if (loginError === 'admin_required') { %>
        <div class="alert">Tài khoản này chưa được cấp quyền admin hoặc chưa được kích hoạt.</div>
      <% } else if (loginError === 'unauthorized') { %>
        <div class="alert">Vui lòng đăng nhập bằng tài khoản admin.</div>
      <% } else if (loginError === 'login_failed') { %>
        <div class="alert">Đăng nhập thất bại. Vui lòng thử lại.</div>
      <% } %>
      <hr style="margin-bottom:30px;border:0;border-top:1px solid #eee">
      <a href="/auth/google" class="btn-google">
        <img src="https://upload.wikimedia.org/wikipedia/commons/5/53/Google_%22G%22_Logo.svg" width="20" alt="Google">
        Đăng nhập bằng Google
      </a>
    </div>
  </body>
</html>
